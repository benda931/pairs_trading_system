def calculate_historical_volatility(prices):
    log_returns = np.log(prices / prices.shift(1)).dropna()
    return log_returns.std() * np.sqrt(252)

def calculate_beta(prices, market=None):
    if market is None:
        market = prices
    log_ret = np.log(prices / prices.shift(1)).dropna()
    market_ret = np.log(market / market.shift(1)).dropna()
    beta = np.cov(log_ret, market_ret)[0, 1] / np.var(market_ret)
    return beta

def evaluate_pair_quality(z, corr, hl, volz):
    score = 0
    if abs(z) > 1: score += 1
    if corr > 0.7: score += 1
    if hl < 20: score += 1
    if abs(volz) < 1.5: score += 1
    if score == 4: return "⭐⭐⭐⭐ מצוין"
    elif score == 3: return "⭐⭐⭐ טוב"
    elif score == 2: return "⭐⭐ בינוני"
    else: return "⭐ חלש"

