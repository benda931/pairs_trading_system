    # ===== Helperים פנימיים (רק לטאב הזה) =====

    def _estimate_hurst(series: pd.Series) -> float:
        """אמדן Hurst פשוט על ה-spread (לא דורש ספריות נוספות)."""
        s = pd.to_numeric(series.dropna(), errors="coerce").dropna()
        if len(s) < 100:
            return float("nan")
        lags = np.arange(2, min(50, len(s) // 4))
        if len(lags) < 5:
            return float("nan")
        tau = []
        for lag in lags:
            diff = s.diff(lag).dropna()
            if diff.empty:
                continue
            tau.append(np.sqrt((diff ** 2).mean()))
        if len(tau) < 5:
            return float("nan")
        tau = np.array(tau)
        lags_f = np.array(lags[: len(tau)], dtype=float)
        try:
            poly = np.polyfit(np.log(lags_f), np.log(tau), 1)
            hurst = 2 * poly[0]
            return float(hurst)
        except Exception:
            return float("nan")

    def _ou_half_life(series: pd.Series) -> float:
        """אמדן Half-life בסגנון OU דרך AR(1) פשוט (ל-spread)."""
        s = pd.to_numeric(series.dropna(), errors="coerce").dropna()
        if len(s) < 50:
            return float("nan")
        x = s.shift(1).dropna()
        y = s.loc[x.index]
        x = x.values
        y = y.values
        try:
            # y = a + b x + e
            b, a = np.polyfit(x, y, 1)
            if b <= 0 or b >= 1:
                return float("nan")
            kappa = -np.log(b)
            hl = np.log(2) / kappa
            return float(hl)
        except Exception:
            return float("nan")

    def _quick_pnl_backtest(spread: pd.Series, entry_z: float = 2.0, exit_z: float = 0.5) -> Dict[str, float]:
        """
        Backtest מהיר מאוד על spread יחיד (ללא Backtester מלא):
        סימולציית MR בסיסית: כניסה כש-|Z|>entry, יציאה כש-|Z|<exit, סימן הפוך ל-Z.
        """
        s = pd.to_numeric(spread.dropna(), errors="coerce").dropna()
        if len(s) < 80:
            return {"Sharpe": np.nan, "Profit": np.nan, "Drawdown": np.nan}
        ret = s.diff().dropna()
        if ret.empty:
            return {"Sharpe": np.nan, "Profit": np.nan, "Drawdown": np.nan}

        # Rolling z
        z = (s - s.rolling(60, min_periods=20).mean()) / s.rolling(60, min_periods=20).std()
        z = z.dropna()
        pos = pd.Series(0.0, index=z.index)
        state = 0.0
        for t, zt in z.items():
            if state == 0:
                if zt > entry_z:
                    state = -1.0
                elif zt < -entry_z:
                    state = 1.0
            else:
                if abs(zt) < exit_z:
                    state = 0.0
            pos.loc[t] = state
        # התאמת ret ל-index של pos
        ret_aligned = ret.reindex(pos.index).fillna(0.0)
        pnl = (pos.shift(1).fillna(0.0) * ret_aligned).cumsum()
        pnl_series = pos.shift(1).fillna(0.0) * ret_aligned

        if pnl_series.std(ddof=1) == 0:
            sharpe = np.nan
        else:
            sharpe = float(np.sqrt(252) * pnl_series.mean() / pnl_series.std(ddof=1))
        profit = float(pnl.iloc[-1])
        # Max drawdown
        cum = pnl
        peak = cum.cummax()
        dd = (cum - peak)
        max_dd = float(dd.min()) if not dd.empty else np.nan
        return {"Sharpe": sharpe, "Profit": profit, "Drawdown": max_dd}

    def _detect_signal_events(spread: pd.Series, z_window: int, entry_z: float, exit_z: float) -> pd.DataFrame:
        """
        בונה סדרת Z ומתוכה "אירועים" של כניסה/יציאה (trade-like events table).
        """
        s = pd.to_numeric(spread.dropna(), errors="coerce").dropna()
        if len(s) < z_window + 5:
            return pd.DataFrame()
        rolling_mean = s.rolling(z_window, min_periods=z_window // 2).mean()
        rolling_std = s.rolling(z_window, min_periods=z_window // 2).std()
        z = (s - rolling_mean) / rolling_std
        z = z.dropna()

        rows = []
        state = 0  # 0=flat, +1=long spread, -1=short spread
        for dt, zv in z.items():
            if state == 0:
                if zv > entry_z:
                    state = -1
                    rows.append({"date": dt, "side": "Short", "z": float(zv)})
                elif zv < -entry_z:
                    state = 1
                    rows.append({"date": dt, "side": "Long", "z": float(zv)})
            else:
                if abs(zv) < exit_z:
                    rows.append({"date": dt, "side": "Flat", "z": float(zv)})
                    state = 0
        return pd.DataFrame(rows)

    def _compute_pair_health(sig: Optional[Dict[str, Any]], hurst: float, ou_hl: float) -> Dict[str, str]:
        """
        מחזיר חיווי מילולי: health, execution_profile, regime_comment.
        """
        if not sig:
            return {
                "health": "unknown",
                "execution": "unknown",
                "regime": "unknown",
            }
        corr = float(sig.get("corr") or 0.0)
        hl = float(sig.get("half_life") or np.nan)
        q = float(sig.get("quality_score") or np.nan)

        # Health
        if corr >= 0.7 and (not np.isnan(hl) and 3 <= hl <= 40) and (not np.isnan(q) and q >= 60):
            health = "Healthy Mean Reverter"
        elif corr < 0.3 or (not np.isnan(hl) and hl > 80):
            health = "Weak / Broken Pair"
        else:
            health = "Intermediate / Needs Monitoring"

        # Execution
        if not np.isnan(hl):
            if hl <= 8:
                exec_prof = "Short-Term MR"
            elif hl <= 30:
                exec_prof = "Swing MR"
            else:
                exec_prof = "Slow MR / Carry"
        else:
            exec_prof = "Unknown"

        # Regime comment (משולב קצת עם Hurst / OU)
        if not np.isnan(hurst) and hurst < 0.4:
            regime = "Strong Mean-Reversion footprint (Hurst<0.4)"
        elif not np.isnan(hurst) and hurst > 0.6:
            regime = "Trending / Regime-shift candidate (Hurst>0.6)"
        else:
            regime = "Neutral / Mixed regime"

        return {
            "health": health,
            "execution": exec_prof,
            "regime": regime,
        }

    def _render_pair_status_panel(
        pair_label: str,
        sig: Optional[Dict[str, Any]],
        hurst: float,
        ou_hl: float,
    ) -> None:
        """
        חלונית מצב לזוג:
        - Score כללי (0–100) + פירוק למרכיבים.
        - ציפייה לצעד הבא של הספרד (revert/expand, כיוון).
        - הערה על משטר מאקרו אם יש macro_meta.
        """
        with st.expander("📌 מצב הזוג — סקור, כיוון צפוי ותנאי שוק", expanded=True):
            if not sig:
                st.info("אין סיגנל מחושב לזוג — אי אפשר לבנות מצב מפורט.")
                return

            # ----- 1) מרכיבי סקור -----
            corr = float(sig.get("corr") or 0.0)
            hl = float(sig.get("half_life") or np.nan)
            q = float(sig.get("quality_score") or 0.0)
            z_val = float(sig.get("z") or 0.0)

            # Structure: corr ב-[0,1], נמשוך אותו קצת לסף 0.3→0.7
            struct_score = 0.0
            if corr > -1.0:
                struct_score = max(0.0, min((corr - 0.3) / 0.4, 1.0))  # corr≈0.3 → 0, corr≈0.7 → 1

            # Mean-Reversion Quality: 0–1
            mr_score = max(0.0, min(q / 100.0, 1.0))

            # Execution Friendliness: OU half-life קצר = טוב, ארוך = פחות
            if np.isnan(ou_hl) or ou_hl <= 0:
                exec_score = 0.5
            else:
                exec_score = float(1.0 - min(max(ou_hl / 120.0, 0.0), 1.0))

            overall_01 = 0.4 * struct_score + 0.4 * mr_score + 0.2 * exec_score
            overall_100 = float(max(0.0, min(overall_01 * 100.0, 100.0)))

            # תווית איכות
            if overall_100 >= 75:
                label = "💎 מועמד חזק (Core MR)"
            elif overall_100 >= 55:
                label = "⚖️ בינוני/סביר — דורש מעקב"
            else:
                label = "⚠️ חלש / גבולי לשימוש"

            c1, c2, c3, c4 = st.columns(4)
            with c1:
                st.metric("Pair Score (0–100)", f"{overall_100:.1f}")
            with c2:
                st.metric("Structure (Corr)", f"{struct_score*100:.0f}")
            with c3:
                st.metric("MR Quality", f"{mr_score*100:.0f}")
            with c4:
                st.metric("Execution", f"{exec_score*100:.0f}")
            st.caption(label)

            # ----- 2) כיוון צפוי של הספרד בצעד הבא -----
            # נשתמש בז + HL כדי לתת אינטואיציה:
            # |Z| קטן → קרוב לפייר ואליו; |Z| גדול → פוטנציאל MR חזק.
            z_abs = abs(z_val)
            text_move: list[str] = []

            if np.isnan(hl) or hl <= 0:
                hl_txt = "לא מוגדר (חסר דאטה מספיק ל-Half-life)."
            else:
                hl_txt = f"הערכה גסה לזמן חצי-החזרה: ~{hl:.1f} ימים מסחר."

            if z_abs < 0.8:
                text_move.append(
                    "🔹 הספרד קרוב לפייר-ואליו (|Z|<0.8) — לא צפוי מהלך גדול מיידי, "
                    "אלא אם יש שוק תנודתי מאוד."
                )
            elif z_abs < 2.0:
                text_move.append(
                    "🔹 הספרד בסטייה בינונית (0.8≤|Z|<2) — פוטנציאל Mean-Reversion קיים, "
                    "אבל פחות 'חזק' מאיתות קלאסי."
                )
            else:
                text_move.append(
                    "🔹 הספרד בסטייה חדה (|Z|≥2) — אם המבנה של הזוג יציב, "
                    "מצופה מהלך Mean-Reversion משמעותי."
                )

            # כיוון (על בסיס סימן ה-Z)
            if z_val > 0:
                text_move.append(
                    "👉 Z חיובי — הספרד מעל הפייר-ואליו. במונחי פוזיציה קלאסית: "
                    "**Short spread** → בדרך כלל Short על leg הראשון (X) ו-Long על השני (Y). "
                    "אם MR יצליח, מצופה שהספרד **יסתגר/ירד**."
                )
            elif z_val < 0:
                text_move.append(
                    "👉 Z שלילי — הספרד מתחת לפייר-ואליו. במונחי פוזיציה: "
                    "**Long spread** → Long על leg הראשון (X) ו-Short על השני (Y). "
                    "אם MR יצליח, מצופה שהספרד **יעלה לכיוון הממוצע**."
                )
            else:
                text_move.append("👉 Z≈0 — הספרד סביב הפייר-ואליו; אין העדפה ברורה לכיוון כרגע.")

            st.markdown("**כיוון צפוי (אם Mean-Reversion עובד):**")
            for line in text_move:
                st.markdown(line)
            st.caption(f"⏱ {hl_txt}")

            # ----- 3) תנאי שוק (מאקרו) שבהם הספרד נפתח/נסגר -----
            macro_meta = st.session_state.get("macro_meta", {}) or {}
            regime_label = str(macro_meta.get("regime_label", "") or "").lower()

            st.markdown("**הקשר מאקרו (אם קיים):**")
            if not macro_meta:
                st.caption(
                    "לא קיים כרגע snapshot מאקרו ב-session (טאב המאקרו אולי לא הורץ). "
                    "לניתוח תלוּי-משטר אמיתי (באיזה Regime הזוג עובד/נשבר) "
                    "כדאי להשתמש ב-Macro DNA / Pair Macro Tab."
                )
            else:
                if regime_label == "risk_on":
                    st.write(
                        "• משטר נוכחי: **Risk-On** — בדרך כלל ספרדי MR שנשענים על מניות "
                        "יכולים להיות יותר תנודתיים, אך סגירות קורות מהר יותר אחרי שוקים."
                    )
                elif regime_label == "risk_off":
                    st.write(
                        "• משטר נוכחי: **Risk-Off** — שווקים נוטים להבריח מסיכון; "
                        "ספרדים בעלי β גבוה יכולים להיפתח חזק. חשוב לבדוק שלא מדובר ב-Regime Shift ולא רק MR רגיל."
                    )
                elif regime_label in {"stagflation", "reflation", "slowdown"}:
                    st.write(
                        f"• משטר נוכחי: **{regime_label}** — סביבת מאקרו מורכבת; "
                        "מומלץ לבדוק בטאב מאקרו איך הזוג מגיב היסטורית לכל Regime לפני הפעלה חיה."
                    )
                else:
                    st.write(
                        "• משטר מאקרו נייטרלי/לא מוגדר — אין Bias חזק מהמאקרו כרגע "
                        "לכיוון פתיחה/סגירה של הספרד."
                    )

                st.caption(
                    "הערה: בלי ניתוח Macro-DNA ספציפי לזוג, קשה לומר *באילו משטרים בדיוק* "
                    "הספרד נפתח/נסגר — לצורך זה בנינו את טאב המאקרו (Macro DNA לזוג)."
                )

    # =====================================================
    # חלק 1 — בחירת זוג + טווח + Controls (שמאל)
    # =====================================================

    col_top_left, col_top_right = st.columns([1, 2])

    with col_top_left:
        start_date, end_date = date_range_picker("ניתוח זוג — טווח תאריכים", 365, "t2")

        ctrl_pair = controls_pair("t2")
        ctrl_pair_full = {
            **ctrl_pair,
            **st.session_state.get("risk_capital", {}),
        }
        ctx_pair = build_ctx(start_date, end_date, ctrl_pair_full, section="pair")

        # בחירת מקור הזוג: Universe / Watchlist / Recent
        pairs_all = get_pairs(False)
        if not pairs_all:
            st.info("אין זוגות available לניתוח. בדוק את ה-universe.")
            pairs_labels = []
        else:
            universe_labels = [make_pair_label(p) for p in pairs_all]

            pair_flags = st.session_state.get("pair_flags", {})
            pair_flags = dict(pair_flags) if isinstance(pair_flags, dict) else {}
            watchlist_pairs = pair_flags.get("important", []) or []
            watchlist_labels = list(dict.fromkeys(watchlist_pairs))  # unique, preserve order

            recent_pairs = st.session_state.get("pair_recent", [])
            recent_pairs = list(dict.fromkeys(recent_pairs))  # unique
            recent_labels = [make_pair_label(p) for p in recent_pairs]

            src_mode = st.radio(
                "מקור בחירה",
                ["Universe", "Watchlist", "Recently Viewed"],
                index=0,
                key=keygen("pair", "src_mode"),
            )

            if src_mode == "Watchlist" and watchlist_labels:
                pairs_labels = watchlist_labels
            elif src_mode == "Recently Viewed" and recent_labels:
                pairs_labels = recent_labels
            else:
                pairs_labels = universe_labels

        selected_label = None
        if not pairs_labels:
            st.info("אין זוגים נבחרים במקור הנוכחי (Watchlist/Recent ריקים?).")
        else:
            sel_default_idx = 0
            try:
                sel_name = st.session_state.get("selected_pair")
                if sel_name:
                    if sel_name in pairs_labels:
                        sel_default_idx = max(0, pairs_labels.index(sel_name))
            except Exception:
                pass

            selected_label = st.selectbox(
                "בחר זוג לניתוח עיקרי",
                options=pairs_labels,
                index=min(sel_default_idx, len(pairs_labels) - 1),
                key=keygen("pair", "main_sel"),
            )
            st.session_state["selected_pair"] = selected_label

            # עדכון רשימת "Recently Viewed"
            try:
                rv = st.session_state.get("pair_recent", [])
                rv = list(rv) if isinstance(rv, list) else []
                if selected_label not in rv:
                    rv.append(selected_label)
                st.session_state["pair_recent"] = rv[-30:]
            except Exception:
                pass

        # Controls מתקדמים לזוג: spread method + חלונות
        st.markdown("**Spread & Windows**")
        spread_method = st.selectbox(
            "שיטת Spread",
            ["log_spread", "diff", "ratio"],
            index=0,
            key=keygen("pair", "spread_method"),
        )
        beta_source = st.selectbox(
            "מקור β",
            ["dynamic (rolling)", "signal β", "1.0 (no hedge)"],
            index=0,
            key=keygen("pair", "beta_source"),
        )
        hedge_enabled = st.checkbox(
            "הפעל Hedge (השתמש ב־β לחישוב spread)",
            value=True,
            key=keygen("pair", "hedge_enabled"),
        )

        c_w1, c_w2 = st.columns(2)
        with c_w1:
            z_window_pair = int(
                st.number_input(
                    "Z-window (ניתוח זוג)",
                    min_value=5,
                    max_value=365,
                    value=int(ctrl_pair.get("ma_win", 20)),
                    step=1,
                    key=keygen("pair", "z_win"),
                )
            )
            corr_window = int(
                st.number_input(
                    "חלון Corr (ימים)",
                    min_value=20,
                    max_value=365,
                    value=int(ctrl_pair.get("corr_win", 60)),
                    step=5,
                    key=keygen("pair", "corr_win"),
                )
            )
        with c_w2:
            hl_window = int(
                st.number_input(
                    "חלון Half-Life estimation",
                    min_value=20,
                    max_value=365,
                    value=int(ctrl_pair.get("hl_win", 120)),
                    step=5,
                    key=keygen("pair", "hl_win"),
                )
            )
            beta_window = int(
                st.number_input(
                    "חלון β מתגלגל",
                    min_value=10,
                    max_value=365,
                    value=int(ctrl_pair.get("beta_win", 60)),
                    step=5,
                    key=keygen("pair", "beta_win"),
                )
            )

    # =====================================================
    # חלק 2 — KPIs + גרף מרכזי (ימין עליון)
    # =====================================================
    with col_top_right:
        if not selected_label:
            st.empty()
        else:
            # ניסיון להביא אות מחושב לזוג
            try:
                sig = compute_pair_signal(
                    selected_label,
                    start_date,
                    end_date,
                    z_window=int(z_window_pair),
                    multi_z_windows=[10, 30, 60],
                    beta_window=beta_window,
                    min_points=40,
                )
            except Exception as e:
                logger.warning("compute_pair_signal failed for %s: %s", selected_label, e)
                sig = None

            # --- KPIs בסיסיים ---
            k1, k2, k3, k4 = st.columns(4)
            if sig:
                z_val = sig.get("z")
                hl_val = sig.get("half_life")
                corr_val = sig.get("corr")
                beta_val = sig.get("beta")
                q_val = sig.get("quality_score")
                edge_val = sig.get("edge")

                k1.metric("Z-score", f"{z_val:.2f}" if z_val is not None else "N/A")
                k2.metric("Half-Life", f"{hl_val:.1f}" if hl_val is not None and not pd.isna(hl_val) else "N/A")
                k3.metric("Corr", f"{corr_val:.3f}" if corr_val is not None else "N/A")
                k4.metric("β (hedge)", f"{beta_val:.3f}" if beta_val is not None else "N/A")

                k5, k6 = st.columns(2)
                k5.metric("Quality Score", f"{q_val:.1f}" if q_val is not None and not pd.isna(q_val) else "N/A")
                k6.metric("Edge", f"{edge_val:.3f}" if edge_val is not None and not pd.isna(edge_val) else "N/A")
            else:
                for col, lbl in zip(
                    (k1, k2, k3, k4),
                    ("Z-score", "Half-Life", "Corr", "β (hedge)"),
                ):
                    col.metric(lbl, "N/A")

            # --- גרף: מחירים + Spread + Bands ---
            sym_x, sym_y = split_pair_label(selected_label) if selected_label else (None, None)

            spread = None
            s1 = s2 = None
            hurst_est = np.nan
            ou_hl_est = np.nan

            try:
                if sym_x and sym_y:
                    s1, s2, _ = load_pair_legs(selected_label, start_date, end_date)
                    if not s1.empty and not s2.empty:
                        if beta_source == "signal β" and sig and sig.get("beta") is not None:
                            beta_last = float(sig["beta"])
                        elif beta_source == "dynamic (rolling)":
                            # נשתמש ב־rolling β בהמשך; כאן נתחיל מבטא 1.0 ל־spread מהיר
                            beta_last = 1.0
                        else:
                            beta_last = 1.0

                        # חישוב spread לפי שיטה
                        if spread_method == "log_spread":
                            s1_log = np.log(s1.clip(lower=1e-9))
                            s2_log = np.log(s2.clip(lower=1e-9))
                            base_spread = s1_log - s2_log
                        elif spread_method == "ratio":
                            base_spread = (s1 / s2).replace([np.inf, -np.inf], np.nan)
                        else:
                            base_spread = s1 - s2

                        spread = base_spread
                        if hedge_enabled and beta_source == "signal β":
                            spread = s1 - beta_last * s2

                        spread = pd.to_numeric(spread, errors="coerce").dropna()

                        if not spread.empty:
                            # Hurst & OU Half-life
                            hurst_est = _estimate_hurst(spread)
                            ou_hl_est = _ou_half_life(spread)

                        # גרף מרכזי
                        import plotly.express as px  # type: ignore

                        df_plot = (
                            pd.DataFrame(
                                {
                                    "Date": s1.index,
                                    sym_x: s1.values,
                                    sym_y: s2.values,
                                }
                            )
                            .dropna()
                        )
                        if spread is not None and not spread.empty:
                            df_plot = df_plot.join(spread.rename("Spread"), how="left")

                        fig_main = px.line(
                            df_plot,
                            x="Date",
                            y=[c for c in df_plot.columns if c != "Date"],
                            title=f"Price & Spread — {selected_label}",
                        )

                        # Bands על spread אם קיים
                        if spread is not None and not spread.empty:
                            mean_sp = spread.rolling(z_window_pair, min_periods=z_window_pair // 2).mean()
                            std_sp = spread.rolling(z_window_pair, min_periods=z_window_pair // 2).std()
                            band_up = (mean_sp + 2 * std_sp).rename("Spread +2σ")
                            band_dn = (mean_sp - 2 * std_sp).rename("Spread -2σ")
                            df_bands = pd.concat([spread.rename("Spread"), band_up, band_dn], axis=1).dropna()
                            if not df_bands.empty:
                                fig_sp = px.line(
                                    df_bands.reset_index(),
                                    x="index",
                                    y=df_bands.columns,
                                    title=f"Spread & Bands — {selected_label}",
                                )
                                st.plotly_chart(fig_main, use_container_width=True)
                                st.plotly_chart(fig_sp, use_container_width=True)
                            else:
                                st.plotly_chart(fig_main, use_container_width=True)
                        else:
                            st.plotly_chart(fig_main, use_container_width=True)
                    else:
                        st.caption("אין מספיק דאטה לזוג הנבחר כדי להציג גרף.")
                else:
                    st.caption("לא ניתן לפרש את הזוג הנבחר ל-sym_x/sym_y.")
            except Exception as e:
                st.caption(f"Visualization skipped: {e}")

            # --- Health mini-cards (Health / Exec / Regime) ---
            health_info = _compute_pair_health(sig, hurst_est, ou_hl_est)
            h1, h2, h3 = st.columns(3)
            h1.metric("Pair Health", health_info["health"])
            h2.metric("Execution Profile", health_info["execution"])
            h3.metric("Regime", health_info["regime"])

            # --- חלונית מצב: סקור, כיוון צפוי ותנאי שוק ---
            if sig:
                with st.expander("📌 מצב הזוג — סקור, כיוון צפוי ותנאי שוק", expanded=False):
                    # מרכיבי סקור (0–100) – מבנה / איכות MR / ביצועיות
                    corr_val = float(sig.get("corr") or 0.0)
                    hl_val = float(sig.get("half_life") or np.nan)
                    q_val = float(sig.get("quality_score") or 0.0)
                    z_now = sig.get("z")

                    # 1) סקור מבנה (Corr/Coint)
                    struct_score = max(0.0, min((corr_val + 1.0) / 2.0, 1.0)) * 100.0

                    # 2) איכות MR (על בסיס Quality 0–100)
                    mr_score = max(0.0, min(q_val / 100.0, 1.0)) * 100.0

                    # 3) ביצועיות – ככל שה-HL קצר יותר, כך נוח יותר לביצוע
                    exec_score = 0.0
                    if not np.isnan(ou_hl_est):
                        exec_score = max(
                            0.0,
                            min(1.0 - min(ou_hl_est, 240.0) / 240.0, 1.0),
                        ) * 100.0

                    # 4) Deploy Readiness (אותה נוסחה כמו בחלק ה-Risk)
                    score_dr = 50.0
                    score_dr += 20.0 * max(0.0, min((corr_val - 0.3) / 0.4, 1.0))  # Corr
                    if not np.isnan(hl_val):
                        if 3 <= hl_val <= 40:
                            score_dr += 15.0
                        elif hl_val > 80:
                            score_dr -= 10.0
                    score_dr += (q_val - 50.0) * 0.3
                    score_dr = max(0.0, min(score_dr, 100.0))

                    # נשמור ב-session למי שרוצה להשתמש בחלקים אחרים
                    st.session_state["pair_deploy_readiness"] = score_dr

                    c_s1, c_s2, c_s3, c_s4 = st.columns(4)
                    c_s1.metric("Overall Pair Score", f"{score_dr:.1f}/100")
                    c_s2.metric("Structure", f"{struct_score:.1f}")
                    c_s3.metric("MR Quality", f"{mr_score:.1f}")
                    c_s4.metric("Execution", f"{exec_score:.1f}")

                    st.markdown("---")

                    # כיוון צפוי – האם הספרד צפוי להיסגר או להיפתח, ולאיזה צד
                    direction_txt = "אין איתות חזק כרגע."
                    bias_txt = ""
                    if z_now is not None and not pd.isna(z_now):
                        z_f = float(z_now)
                        if abs(z_f) < 0.8:
                            direction_txt = "הספרד קרוב לפייר-ואליו (Z≈0) – אין ציפייה חזקה לתנועה."
                        elif z_f > 0:
                            direction_txt = (
                                "הספרד **מעל** הפייר-ואליו (Z>0) – "
                                "בסיסית מצופה **היצרות** ספרד (Short spread / מכירה של leg ראשון)."
                            )
                            if abs(z_f) >= 2.5:
                                bias_txt = "הסטייה חדה (|Z|≥2.5) – סיכוי גבוה למהלך mean-reversion קצר טווח."
                        else:  # z_f < 0
                            direction_txt = (
                                "הספרד **מתחת** לפייר-ואליו (Z<0) – "
                                "בסיסית מצופה **היצרות** מלמטה (Long spread / קניה של leg ראשון)."
                            )
                            if abs(z_f) >= 2.5:
                                bias_txt = "הסטייה חדה (|Z|≥2.5) – סיכוי גבוה לריבאונד כלפי מעלה."

                    # אופק זמן משוער לפי OU Half-life
                    if not np.isnan(ou_hl_est):
                        t_h = float(ou_hl_est)
                        hor_txt = f"אופק חצי-החזרה משוער: **~{t_h:.1f} ימי מסחר** (OU Half-life)."
                    elif not np.isnan(hl_val):
                        hor_txt = f"אופק Mean-Reversion משוער: **~{hl_val:.1f} ימי Half-life (סטטיסטי)**."
                    else:
                        hor_txt = "לא ניתן להעריך אופק זמן חזרה (חסר HL יציב)."

                    st.markdown(f"**כיוון צפוי:** {direction_txt}")
                    if bias_txt:
                        st.markdown(f"**אינדיקציית חוזק:** {bias_txt}")
                    st.markdown(f"**אופק זמן:** {hor_txt}")

                    # הקשר מאקרו אם קיים מהטאב Macro
                    macro_meta = st.session_state.get("macro_meta", {})
                    regime_label = macro_meta.get("regime_label") if isinstance(macro_meta, dict) else None
                    if regime_label:
                        st.markdown("---")
                        st.markdown(
                            f"**משטר מאקרו נוכחי:** `{regime_label}`  \n"
                            "מומלץ לפרש את האות בהקשר המשטר: "
                            "למשל ב־Risk-Off יתכן שסטיות גדולות מחזיקות יותר זמן."
                        )
                    # ---- רמז מסודר לטאב האופטימיזציה (opt_pair_status) ----

                    # פרופיל אופטימיזציה מומלץ לפי Deploy Readiness
                    opt_hint_profile = "default"
                    if score_dr >= 70:
                        opt_hint_profile = "aggressive"
                    elif score_dr <= 40:
                        opt_hint_profile = "defensive"

                    # מטרת אופטימיזציה ראשית + פרופיל תרחיש
                    primary_obj = "Sharpe"
                    scenario_profile = "Neutral"
                    scenario_tail_weight = 0.2

                    if opt_hint_profile == "defensive":
                        primary_obj = "TailRisk"
                        scenario_profile = "Risk-Off"
                        scenario_tail_weight = 0.4
                    elif opt_hint_profile == "aggressive":
                        primary_obj = "Sharpe"
                        scenario_profile = "Risk-On"
                        scenario_tail_weight = 0.2

                    # התאמה לפי משטר מאקרו (אם יש)
                    if regime_label:
                        reg_lower = str(regime_label).lower()
                        if "risk_off" in reg_lower or "risk-off" in reg_lower:
                            scenario_profile = "Risk-Off"
                            scenario_tail_weight = max(scenario_tail_weight, 0.4)
                        elif "stagflation" in reg_lower or "crisis" in reg_lower:
                            scenario_profile = "Crisis"
                            scenario_tail_weight = max(scenario_tail_weight, 0.5)

                    # שמירת סטטוס מלא ל-session לטובת טאב האופטימיזציה
                    st.session_state["opt_pair_status"] = {
                        "pair": selected_label,
                        "scores": {
                            "overall": float(score_dr),
                            "structure": float(struct_score),
                            "mr_quality": float(mr_score),
                            "execution": float(exec_score),
                        },
                        "signal": {
                            "z": float(z_now) if z_now is not None and not pd.isna(z_now) else None,
                            "half_life": float(hl_val) if not np.isnan(hl_val) else None,
                            "hurst": float(hurst_est) if not np.isnan(hurst_est) else None,
                            "ou_half_life": float(ou_hl_est) if not np.isnan(ou_hl_est) else None,
                        },
                        "labels": health_info,  # כולל health/execution/regime
                        "opt_hint": {
                            "profile": opt_hint_profile,                # default / defensive / aggressive
                            "primary_objective": primary_obj,          # Sharpe / TailRisk
                            "scenario_profile": scenario_profile,      # Neutral / Risk-On / Risk-Off / Crisis
                            "scenario_tail_weight": scenario_tail_weight,
                            "wf_use": True if score_dr >= 60 else False,  # אם הזוג בריא → להפעיל WF
                        },
                        "ts": datetime.now().isoformat(timespec="seconds"),
                    }

    # =====================================================
    # חלק 3 — Core Analytics & Signals Timeline
    # =====================================================
    if selected_label and spread is not None and not spread.empty:
        st.markdown("### 📊 Core Analytics & Signal Timeline")

        ca1, ca2 = st.columns(2)
        with ca1:
            # Trade-like events & mini backtest
            entry_z_val = float(st.number_input(
                "Entry |Z| לסימולציה מהירה",
                min_value=0.5,
                max_value=5.0,
                value=2.0,
                step=0.1,
                key=keygen("pair", "sim_entry_z"),
            ))
            exit_z_val = float(st.number_input(
                "Exit |Z| לסימולציה מהירה",
                min_value=0.0,
                max_value=4.0,
                value=0.5,
                step=0.1,
                key=keygen("pair", "sim_exit_z"),
            ))

            events_df = _detect_signal_events(spread, z_window_pair, entry_z_val, exit_z_val)
            if not events_df.empty:
                st.caption(f"נמצאו {len(events_df)} אירועי Signal/Exit בתור סימולציה.")
                st.dataframe(events_df.tail(30), use_container_width=True)
            else:
                st.caption("לא נוצרו אירועים בתצורת Entry/Exit הנוכחית.")

            # Backtest מהיר על spread
            sim_res = _quick_pnl_backtest(spread, entry_z_val, exit_z_val)
            st.markdown("**Backtest מהיר (spread-only):**")
            st.write(
                {
                    "Sharpe_sim": sim_res["Sharpe"],
                    "Profit_sim": sim_res["Profit"],
                    "MaxDD_sim": sim_res["Drawdown"],
                }
            )

        with ca2:
            # Signal timeline — |Z| לאורך זמן + threshold
            try:
                import plotly.express as px  # type: ignore

                z_series = (spread - spread.rolling(z_window_pair, min_periods=z_window_pair // 2).mean()) / spread.rolling(
                    z_window_pair, min_periods=z_window_pair // 2
                ).std()
                z_series = z_series.dropna()
                df_z = pd.DataFrame({"Date": z_series.index, "Z": z_series.values})
                if not df_z.empty:
                    fig_z = px.line(df_z, x="Date", y="Z", title="Z-score Timeline")
                    fig_z.add_hline(y=entry_z_val, line_dash="dot")
                    fig_z.add_hline(y=-entry_z_val, line_dash="dot")
                    st.plotly_chart(fig_z, use_container_width=True)
            except Exception:
                pass

        # Scoring breakdown (Structure / MR / Execution)
        st.markdown("### 🧬 Pair Scoring Breakdown")
        struct_score = float(sig.get("corr", 0.0)) if sig else 0.0
        mr_score = float(sig.get("quality_score", 0.0)) / 100.0 if sig and sig.get("quality_score") is not None else 0.0
        exec_score = 0.0
        if not np.isnan(ou_hl_est):
            exec_score = float(1.0 - min(max(ou_hl_est / 120.0, 0.0), 1.0))

        df_scores = pd.DataFrame(
            [
                {"component": "Structure (Corr/Coint)", "score": struct_score},
                {"component": "Mean-Reversion Quality", "score": mr_score},
                {"component": "Execution Friendliness", "score": exec_score},
            ]
        )
        st.dataframe(df_scores, use_container_width=True)
        try:
            if px is not None:
                fig_sc = px.bar(df_scores, x="component", y="score", title="Pair Scoring Breakdown")
                st.plotly_chart(fig_sc, use_container_width=True)
        except Exception:
            pass

    # =====================================================
    # חלק 4 — Pair Tab Engine (pair_tab.py) + Advanced Diagnostics
    # =====================================================
    st.markdown("### 🔬 Pair Tab Engine (pair_tab.py)")
    with st.spinner("🧪 Analyzing pair (Pair Tab)…"):
        try:
            if pairs_all:
                try:
                    _render_pair_tab(
                        pairs_all,
                        config,
                        start_date,
                        end_date,
                        **ctrl_pair,
                        ctx=asdict(ctx_pair),
                    )
                except TypeError:
                    try:
                        _render_pair_tab(pairs_all, config, start_date, end_date, **ctrl_pair)
                    except TypeError:
                        _render_pair_tab(pairs_all, config, start_date, end_date)
        except Exception as e:
            logger.exception(e)
            _report_exception(e, "Tab Pair")
            st.error(f"❗ שגיאה בטאב ניתוח זוג: {e}")

    # Diagnostcs β & Spread (מורחב)
    with st.expander("🔍 Diagnostics — β, Spread, Hurst & OU", expanded=False):
        try:
            pairs_diag = pairs_all
            if not pairs_diag:
                st.info("אין זוגות זמינים לדיאגנוסטיקה.")
            else:
                labels_diag = [make_pair_label(p) for p in pairs_diag]
                sel_diag_default = 0
                try:
                    sel_name_diag = st.session_state.get("selected_pair")
                    if sel_name_diag and sel_name_diag in labels_diag:
                        sel_diag_default = max(0, labels_diag.index(sel_name_diag))
                except Exception:
                    pass

                diag_idx = st.selectbox(
                    "זוג לדיאגנוסטיקה",
                    options=list(range(len(labels_diag))),
                    index=min(sel_diag_default, len(labels_diag) - 1),
                    format_func=lambda i: labels_diag[i],
                    key=keygen("pair", "diag"),
                )
                pair_label_diag = labels_diag[diag_idx]
                sym_x_d, sym_y_d = split_pair_label(pair_label_diag)

                if not (sym_x_d and sym_y_d):
                    st.caption("לא ניתן לפרק את הסימבול לזוג (sym_x/sym_y). יוצג רק מחיר בודד.")
                    df_single = _load_pair_data(pair_label_diag, start_date, end_date).copy()
                    if not df_single.empty:
                        price_col = "Close" if "Close" in df_single.columns else df_single.columns[0]
                        st.line_chart(df_single[price_col].astype(float))
                    else:
                        st.caption("אין דאטה לזוג הנבחר.")
                else:
                    df_x = _load_pair_data(sym_x_d, start_date, end_date)
                    df_y = _load_pair_data(sym_y_d, start_date, end_date)
                    s1_d = _pick_price_series(df_x)
                    s2_d = _pick_price_series(df_y)
                    s1_d, s2_d = s1_d.align(s2_d, join="inner")

                    method = str(ctrl_pair.get("hr_method", "OLS"))
                    win = max(10, int(ctrl_pair.get("ma_win", 20)))

                    beta_series = None
                    if len(s1_d) >= win and len(s2_d) >= win:
                        try:
                            beta_series = _rolling_beta(s1_d, s2_d, win)
                            import plotly.express as px  # type: ignore

                            dfb = pd.DataFrame({"Date": beta_series.index, "beta": beta_series.values}).dropna()
                            fig_b = px.line(
                                dfb,
                                x="Date",
                                y="beta",
                                title=f"Dynamic β — {pair_label_diag} ({method})",
                            )
                            st.plotly_chart(fig_b, use_container_width=True)
                        except Exception as _e:
                            st.caption(f"Beta computation failed: {_e}")

                    try:
                        if beta_series is not None and not beta_series.dropna().empty:
                            beta_last = float(beta_series.dropna().iloc[-1])
                        else:
                            beta_last = 1.0
                    except Exception:
                        beta_last = 1.0

                    try:
                        spread_diag = s1_d - beta_last * s2_d
                        import plotly.express as px  # type: ignore

                        fig_h = px.histogram(
                            spread_diag.dropna(),
                            nbins=60,
                            title=f"Spread Histogram — {pair_label_diag}",
                        )
                        st.plotly_chart(fig_h, use_container_width=True)

                        # Hurst & OU HL
                        hurst_d = _estimate_hurst(spread_diag)
                        ou_hl_d = _ou_half_life(spread_diag)
                        st.write(
                            {
                                "Hurst_estimate": hurst_d,
                                "OU_half_life_est": ou_hl_d,
                            }
                        )
                    except Exception as _e:
                        st.caption(f"Spread histogram failed: {_e}")
        except Exception as e:
            st.caption(f"Diagnostics skipped: {e}")

    # =====================================================
    # חלק 5 — Risk, VaR/ES & Deploy Readiness
    # =====================================================
    if selected_label and spread is not None and not spread.empty:
        with st.expander("🛡 Risk Profile, VaR/ES & Deploy Readiness", expanded=False):
            try:
                # VaR & ES על תשואות spread
                ret_sp = spread.diff().dropna()
                if len(ret_sp) >= 100:
                    alpha = st.number_input(
                        "Alpha ל-VaR/ES",
                        min_value=0.01,
                        max_value=0.20,
                        value=0.05,
                        step=0.01,
                        key=keygen("pair", "risk_alpha"),
                    )
                    q = float(np.quantile(ret_sp, alpha))
                    es = float(ret_sp[ret_sp <= q].mean()) if (ret_sp <= q).any() else float("nan")
                    max_dd_sp = float((ret_sp.cumsum() - ret_sp.cumsum().cummax()).min())
                    st.write(
                        {
                            "VaR": q,
                            "ES": es,
                            "MaxDD_spread": max_dd_sp,
                        }
                    )
                else:
                    st.caption("מעט מדי תצפיות ל-VaR/ES (צריך לפחות ~100).")

                # Deploy readiness score (0–100)
                if sig:
                    corr = float(sig.get("corr") or 0.0)
                    hl = float(sig.get("half_life") or np.nan)
                    q = float(sig.get("quality_score") or 0.0)
                else:
                    corr = 0.0
                    hl = np.nan
                    q = 0.0

                score_dr = 50.0
                score_dr += 20.0 * max(0.0, min((corr - 0.3) / 0.4, 1.0))  # corr
                if not np.isnan(hl):
                    if 3 <= hl <= 40:
                        score_dr += 15.0
                    elif hl > 80:
                        score_dr -= 10.0
                score_dr += (q - 50.0) * 0.3
                if score_dr > 100.0:
                    score_dr = 100.0
                if score_dr < 0.0:
                    score_dr = 0.0

                st.metric("Live Deploy Readiness (0–100)", f"{score_dr:.1f}")

                # Red-flags list
                flags = []
                if corr < 0.3:
                    flags.append("קורלציה נמוכה (<0.3)")
                if not np.isnan(hl) and hl > 80:
                    flags.append("Half-life ארוך מאוד (>80) – MR חלש")
                if sig and sig.get("quality_score") is not None and float(sig["quality_score"]) < 40:
                    flags.append("Quality Score נמוך (<40)")
                if not np.isnan(hurst_est) and 0.4 <= hurst_est <= 0.6:
                    flags.append("Hurst≈0.5 → Random Walk / ללא מבנה ברור")
                if flags:
                    st.markdown("**Red Flags:**")
                    for f in flags:
                        st.markdown(f"- {f}")
                else:
                    st.markdown("**אין Red Flags משמעותיים לפי החוקים הפשוטים.**")
            except Exception as e:
                st.caption(f"Risk/Deploy section failed: {e}")

    # =====================================================
    # חלק 6א — Multi-Pair Micro View & Execution Heatmap
    # =====================================================
    with st.expander("🌐 Multi-Pair Micro View & Execution Heatmap", expanded=False):
        try:
            # מקור זוגות ל-grid: Universe / Watchlist בלבד
            pairs_src = get_pairs(False)
            if not pairs_src:
                st.caption("אין universe טעון כרגע — Multi-Pair View כבוי.")
            else:
                universe_labels = [make_pair_label(p) for p in pairs_src]

                pair_flags = st.session_state.get("pair_flags", {}) or {}
                watchlist_pairs = pair_flags.get("important", []) or []
                watchlist_labels = list(dict.fromkeys(watchlist_pairs))

                src_mode = st.radio(
                    "מקור זוגות ל-Micro View",
                    ["Universe", "Watchlist בלבד"],
                    index=0,
                    key=keygen("pair", "micro_src"),
                )

                if src_mode == "Watchlist בלבד" and watchlist_labels:
                    labels_grid = watchlist_labels
                else:
                    labels_grid = universe_labels

                if not labels_grid:
                    st.caption("אין זוגות במקור שנבחר (Watchlist ריק?).")
                else:
                    max_rows = int(
                        st.number_input(
                            "מספר זוגות מקס' לניתוח micro",
                            min_value=5,
                            max_value=80,
                            value=20,
                            step=5,
                            key=keygen("pair", "micro_max_rows"),
                        )
                    )

                    labels_grid = labels_grid[:max_rows]

                    # פרמטרי חלון שנשתמש בהם לסיגנל מהיר
                    z_win_micro = int(
                        st.number_input(
                            "Z-window ל-Micro View",
                            min_value=5,
                            max_value=365,
                            value=int(z_window_pair),
                            step=1,
                            key=keygen("pair", "micro_z_win"),
                        )
                    )
                    beta_win_micro = int(
                        st.number_input(
                            "חלון β ל-Micro View",
                            min_value=10,
                            max_value=365,
                            value=int(beta_window),
                            step=5,
                            key=keygen("pair", "micro_beta_win"),
                        )
                    )

                    # מחשבים טבלה קומפקטית לכל זוג
                    rows_micro: list[dict[str, Any]] = []
                    for lbl in labels_grid:
                        try:
                            sig_i = compute_pair_signal(
                                lbl,
                                start_date,
                                end_date,
                                z_window=z_win_micro,
                                multi_z_windows=[10, 30, 60],
                                beta_window=beta_win_micro,
                                min_points=40,
                            )
                        except Exception:
                            sig_i = None

                        sym_x_i, sym_y_i = split_pair_label(lbl)
                        hurst_i = np.nan
                        ou_hl_i = np.nan

                        try:
                            if sym_x_i and sym_y_i:
                                s1_i, s2_i, _ = load_pair_legs(lbl, start_date, end_date)
                                if not s1_i.empty and not s2_i.empty:
                                    # Spread ל-Hurst/OU — לוקחים log_spread בסיסי
                                    s1_log = np.log(s1_i.clip(lower=1e-9))
                                    s2_log = np.log(s2_i.clip(lower=1e-9))
                                    spread_i = (s1_log - s2_log).dropna()
                                    if not spread_i.empty:
                                        hurst_i = _estimate_hurst(spread_i)
                                        ou_hl_i = _ou_half_life(spread_i)
                        except Exception:
                            pass

                        if not sig_i:
                            rows_micro.append(
                                {
                                    "pair": lbl,
                                    "corr": np.nan,
                                    "half_life": np.nan,
                                    "quality": np.nan,
                                    "z_now": np.nan,
                                    "hurst": hurst_i,
                                    "ou_half_life": ou_hl_i,
                                    "scan_style": "unknown",
                                    "deploy_score": np.nan,
                                }
                            )
                            continue

                        corr_i = float(sig_i.get("corr") or 0.0)
                        hl_i = float(sig_i.get("half_life") or np.nan)
                        q_i = float(sig_i.get("quality_score") or 0.0)
                        z_i = float(sig_i.get("z") or 0.0)

                        # Health & execution מה-helper הקיים
                        health_i = _compute_pair_health(sig_i, hurst_i, ou_hl_i)

                        # deploy_score קטן לזוג (0–100) — כמו בחלק ה-Risk אבל מקוצר
                        score_deploy = 50.0
                        score_deploy += 20.0 * max(0.0, min((corr_i - 0.3) / 0.4, 1.0))
                        if not np.isnan(hl_i):
                            if 3 <= hl_i <= 40:
                                score_deploy += 15.0
                            elif hl_i > 80:
                                score_deploy -= 10.0
                        score_deploy += (q_i - 50.0) * 0.3
                        score_deploy = max(0.0, min(score_deploy, 100.0))

                        rows_micro.append(
                            {
                                "pair": lbl,
                                "corr": corr_i,
                                "half_life": hl_i,
                                "quality": q_i,
                                "z_now": z_i,
                                "hurst": hurst_i,
                                "ou_half_life": ou_hl_i,
                                "health": health_i["health"],
                                "execution": health_i["execution"],
                                "regime_view": health_i["regime"],
                                "deploy_score": score_deploy,
                            }
                        )

                    if not rows_micro:
                        st.caption("לא הצלחנו לחשב מדדים לשום זוג במקור שנבחר.")
                    else:
                        df_micro = pd.DataFrame(rows_micro).set_index("pair")
                        st.dataframe(
                            df_micro,
                            use_container_width=True,
                            height=260,
                        )

                        # Heatmap קטן על Corr / HL / Quality / Deploy
                        try:
                            import plotly.express as px  # type: ignore

                            cols_hm = ["corr", "half_life", "quality", "deploy_score"]
                            cols_hm = [c for c in cols_hm if c in df_micro.columns]
                            if cols_hm:
                                fig_hm = px.imshow(
                                    df_micro[cols_hm].T,
                                    aspect="auto",
                                    origin="lower",
                                    labels={"x": "pair", "y": "metric", "color": "value"},
                                    title="Execution Heatmap — Corr / HL / Quality / Deploy",
                                )
                                st.plotly_chart(fig_hm, use_container_width=True)
                        except Exception:
                            pass

                        # 5 הזוגות הכי דומים לזוג הנוכחי לפי Corr/HL/Quality/Hurst
                        if selected_label and selected_label in df_micro.index:
                            base_vec = df_micro.loc[selected_label, ["corr", "half_life", "quality", "hurst", "ou_half_life"]]
                            base_arr = base_vec.to_numpy(dtype=float)
                            if not np.all(np.isnan(base_arr)):
                                dists: list[tuple[str, float]] = []
                                for pair_i, row_i in df_micro.iterrows():
                                    if pair_i == selected_label:
                                        continue
                                    v = row_i[["corr", "half_life", "quality", "hurst", "ou_half_life"]].to_numpy(dtype=float)
                                    if np.any(np.isnan(v)) or np.any(np.isnan(base_arr)):
                                        continue
                                    # נורמליזציה גסה לממד
                                    scale = np.maximum(np.abs(base_arr), 1.0)
                                    d = float(np.linalg.norm((v - base_arr) / scale))
                                    dists.append((pair_i, d))
                                dists.sort(key=lambda x: x[1])
                                nn = dists[:5]
                                if nn:
                                    st.markdown("**5 הזוגות הכי דומים לזוג הנוכחי (Profile Similarity):**")
                                    st.dataframe(
                                        pd.DataFrame(nn, columns=["pair", "distance"]),
                                        use_container_width=True,
                                        height=180,
                                    )

        except Exception as e:
            st.caption(f"Multi-pair micro view failed: {e}")

    # =====================================================
    # חלק 6 — Macro & Factor Mini View + Integration
    # =====================================================
    with st.expander("🌐 Macro & Factor Mini View + Integration", expanded=False):
        try:
            # Micro macro-DNA: ננסה לקרוא מתוך session_state אם המקרו כבר עבד
            macro_meta = st.session_state.get("macro_meta", {})
            st.markdown("**Macro Meta (אם קיים):**")
            if macro_meta:
                st.json(macro_meta)
            else:
                st.caption("Macro meta לא קיים ב-session (טאב מאקרו אולי לא הורץ).")

            st.markdown("**Integration Hooks:**")
            col_i1, col_i2 = st.columns(2)
            with col_i1:
                if st.button("📨 שלח זוג לאופטימיזציה (Tab 8)", key=keygen("pair", "send_opt")) and selected_label:
                    ox, oy = split_pair_label(selected_label)
                    opt_params = st.session_state.get("opt_params", {}) or {}
                    if ox and oy:
                        opt_params["sym_x"] = ox
                        opt_params["sym_y"] = oy
                        st.session_state["opt_params"] = opt_params
                        st.success("הזוג נשלח לטאב אופטימיזציה — עבור ל-Tab 8.")
            with col_i2:
                if st.button("🔔 הוסף כ-Alert Candidate", key=keygen("pair", "add_alert")) and selected_label:
                    alerts = st.session_state.get("pair_alert_candidates", [])
                    alerts = list(alerts) if isinstance(alerts, list) else []
                    if selected_label not in alerts:
                        alerts.append(selected_label)
                    st.session_state["pair_alert_candidates"] = alerts[-100:]
                    st.success(f"{selected_label} נוסף לרשימת Alert Candidates.")

        except Exception as e:
            st.caption(f"Macro/Integration section failed: {e}")

    # =====================================================
    # חלק 7 — Pair History, Watchlist & Notebook Export
    # =====================================================
    with st.expander("📒 Pair History, Watchlist & Notebook Export", expanded=False):
        try:
            # היסטוריית ניתוחים
            hist = st.session_state.get("pair_analysis_history", [])
            hist = list(hist) if isinstance(hist, list) else []

            if selected_label and sig:
                hist_entry = {
                    "ts": datetime.now().isoformat(timespec="seconds"),
                    "pair": selected_label,
                    "z": sig.get("z"),
                    "corr": sig.get("corr"),
                    "half_life": sig.get("half_life"),
                    "quality": sig.get("quality_score"),
                }
                hist.append(hist_entry)
                st.session_state["pair_analysis_history"] = hist[-50:]

            if hist:
                st.caption("**Pair analysis history (last 50 rows):**")
                st.dataframe(pd.DataFrame(hist).tail(20), use_container_width=True)

            # Watchlist (already exists, רק תצוגה מהירה)
            pair_flags = st.session_state.get("pair_flags", {})
            imp = (pair_flags or {}).get("important", [])
            st.markdown("**Watchlist pairs:**")
            st.write(imp if imp else "—")

            # Notebook/Report Markdown export
            title = st.text_input(
                "כותרת דוח Markdown לזוג",
                value=f"Pair Analysis Report — {selected_label or 'N/A'}",
                key=keygen("pair", "md_title"),
            )
            notes_md = st.text_area(
                "הערות (Markdown)",
                value="",
                key=keygen("pair", "md_notes"),
                height=120,
            )
            if st.button("📥 יצוא דוח Pair Markdown", key=keygen("pair", "md_build")) and selected_label:
                kp = {
                    "z": sig.get("z") if sig else None,
                    "half_life": sig.get("half_life") if sig else None,
                    "corr": sig.get("corr") if sig else None,
                    "beta": sig.get("beta") if sig else None,
                    "quality": sig.get("quality_score") if sig else None,
                    "edge": sig.get("edge") if sig else None,
