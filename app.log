def render_session_debug_panel() -> None:
    """
    מציג פאנל Session Debug משודרג:

    • כמות המפתחות ב-session_state.
    • מפתחות חשובים (opt_*, risk_*, feature_flags, ctx, run_id).
    • אפשרות לסינון לפי prefix.
    • הצגת כל ה-session (אם רוצים) – עם JSON-safe.
    """
    with st.expander("🧭 Session Debug", expanded=False):
        try:
            keys = sorted(st.session_state.keys())
            st.caption(f"Total session keys: {len(keys)}")

            # Prefix filter קטן
            prefix = st.text_input(
                "Filter session keys by prefix (optional)",
                value="",
                key=keygen("sess", "prefix"),
            ).strip()
            if prefix:
                keys_filtered = [k for k in keys if k.startswith(prefix)]
            else:
                keys_filtered = keys

            st.caption(f"Filtered keys: {len(keys_filtered)}")
            important = {
                k: st.session_state.get(k)
                for k in keys_filtered
                if any(
                    k.startswith(pfx)
                    for pfx in ("opt_", "risk_", "feature_flags", "ctx", "run_id", "global_seed")
                )
            }
            st.subheader("Important keys (filtered)")
            st.json(make_json_safe(important))

            with st.expander("All filtered session keys (raw)", expanded=False):
                st.json(make_json_safe({k: st.session_state.get(k) for k in keys_filtered}))
        except Exception as e:
            st.caption(f"Session debug unavailable: {e}")


