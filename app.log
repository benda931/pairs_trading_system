        st.markdown("**Context Summary**")
        st.json(
            {
                "dates": f"{ctx_ov.start_date} → {ctx_ov.end_date}",
                "top_n_pairs": int(ctrl_ov.get("top_n", 10) or 10),
                "returns_window": int(ctrl_ov.get("ret_win", 20) or 20),
                "vol_window": int(ctrl_ov.get("vol_win", 30) or 30),
            }
        )

        pairs_all = get_pairs(False)
        st.caption(f"Universe size: {len(pairs_all)} זוגות")

        # בחירת field לקורלציה (מחירים / ספרד)
        corr_field = st.selectbox(
            "שדה לחישוב קורלציה",
            ["Close", "Adj Close", "Open"],
            index=0,
            key=keygen("ov", "corr_field"),
        )

        # אפשרות לבחור top_n מתוך universe (לא רק prefix)
        st.caption("טווח זוגות לחישוב מטריצת קורלציה")
        use_top = st.radio(
            "Subset",
            ["Top לפי סדר universe", "כל ה-universe (זהיר!)"],
            index=0,
            key=keygen("ov", "subset_mode"),
        )

    with col_right:
        st.markdown("**Correlation Matrix of Pairs**")
        try:
            pairs_full = get_pairs(False)
            if not pairs_full:
                st.info("אין זוגות להציג בסקירה.")
                corr = None
            else:
                if use_top.startswith("Top"):
                    pairs_top = pairs_full[: int(ctrl_ov.get("top_n", 10) or 10)]
                else:
                    pairs_top = pairs_full

                corr = compute_return_corr_matrix(
                    pairs_top,
                    start_date,
                    end_date,
                    field=corr_field,
                    window=int(ctrl_ov.get("ret_win", 20) or 20),
                )
            if corr is None or corr.empty:
                st.info("אין מספיק דאטה למטריצת קורלציה.")
            else:
                try:
                    import plotly.express as px  # type: ignore

                    fig_corr = px.imshow(
                        corr,
                        text_auto=True,
                        aspect="auto",
                        title=f"Correlation Heatmap ({corr_field} returns)",
                    )
                    st.plotly_chart(fig_corr, width="stretch")
                except Exception:
                    st.dataframe(corr)

                st.download_button(
                    "💾 הורד מטריצת קורלציה (CSV)",
                    corr.to_csv().encode("utf-8"),
                    file_name=f"correlation_matrix_{ctx_ov.run_id}.csv",
                    mime="text/csv",
                    key=keygen("dl", "corr"),
                )

                # סטטיסטיקות על המטריצה (בלי האלכסון)
                try:
                    m = corr.values
                    mask = ~np.eye(m.shape[0], dtype=bool)
                    vals = m[mask]
                    vals = vals[~np.isnan(vals)]
                    if vals.size > 0:
                        avg_corr = float(vals.mean())
                        max_corr = float(vals.max())
                        min_corr = float(vals.min())
                        st.caption(
                            f"Average off-diagonal corr: {avg_corr:.3f} • "
                            f"Max: {max_corr:.3f} • Min: {min_corr:.3f}"
                        )
                except Exception:
                    pass

                # Top correlated & Top diversifiers
                with st.expander("Top Correlated & Diversifying Pairs", expanded=False):
                    try:
                        corr_long = (
                            corr.stack()
                            .reset_index()
                            .rename(columns={"level_0": "A", "level_1": "B", 0: "corr"})
                        )
                        # הסרת האלכסון וזוגות כפולים (A,B) & (B,A)
                        corr_long = corr_long[corr_long["A"] < corr_long["B"]]
                        corr_long["abs_corr"] = corr_long["corr"].abs()

                        top_corr = corr_long.sort_values("abs_corr", ascending=False).head(15)
                        top_div = corr_long.sort_values("abs_corr", ascending=True).head(15)

                        c1, c2 = st.columns(2)
                        with c1:
                            st.markdown("**Top Correlated Pairs (|corr| גבוה)**")
                            st.dataframe(top_corr, width="stretch", height=260)
                        with c2:
                            st.markdown("**Top Diversifiers (|corr| נמוך)**")
                            st.dataframe(top_div, width="stretch", height=260)
                    except Exception as e:
                        st.caption(f"Top correlated/diversifiers unavailable: {e}")
        except Exception as e:
            st.error(f"Correlation computation failed: {e}")

    # ================== חלק 2 — Corr Regime Comparison ==================
    st.subheader("🔄 Stability Check — שינוי קורלציות בזמן")

    try:
        pairs_full = get_pairs(False)
        if not pairs_full:
            st.caption("אין universe לזיהוי שינויי קורלציה.")
        else:
            # נחלק את התקופה ל"חלק ישן" ו"חלק חדש" (למשל חצי-חצי)
            total_days = (end_date - start_date).days
            if total_days < 60:
                st.caption("הטווח קצר מדי להשוואת Regimes (דרושים לפחות ~60 ימים).")
            else:
                mid_date = start_date + timedelta(days=total_days // 2)

                pairs_top = pairs_full[: int(ctrl_ov.get("top_n", 10) or 10)]

                corr_old = compute_return_corr_matrix(
                    pairs_top,
                    start_date,
                    mid_date,
                    field=corr_field,
                    window=int(ctrl_ov.get("ret_win", 20) or 20),
                )
                corr_new = compute_return_corr_matrix(
                    pairs_top,
                    mid_date,
                    end_date,
                    field=corr_field,
                    window=int(ctrl_ov.get("ret_win", 20) or 20),
                )

                if corr_old.empty or corr_new.empty:
                    st.caption("אין מספיק דאטה להשוואת קורלציות בין חצאי התקופה.")
                else:
                    try:
                        # נבנה מטריצת Δcorr = corr_new - corr_old
                        common_idx = corr_old.index.intersection(corr_new.index)
                        common_cols = corr_old.columns.intersection(corr_new.columns)
                        c_old = corr_old.loc[common_idx, common_cols]
                        c_new = corr_new.loc[common_idx, common_cols]
                        delta = c_new - c_old

                        import plotly.express as px  # type: ignore

                        fig_delta = px.imshow(
                            delta,
                            text_auto=False,
                            aspect="auto",
                            title="ΔCorrelation (New - Old)",
                            color_continuous_midpoint=0.0,
                        )
                        st.plotly_chart(fig_delta, width="stretch")

                        with st.expander("Pairs with biggest Δcorr (abs)", expanded=False):
                            corr_long = (
                                delta.stack()
                                .reset_index()
                                .rename(columns={"level_0": "A", "level_1": "B", 0: "delta_corr"})
                            )
                            corr_long = corr_long[corr_long["A"] < corr_long["B"]]
                            corr_long["abs_delta"] = corr_long["delta_corr"].abs()
                            movers = corr_long.sort_values("abs_delta", ascending=False).head(20)
                            st.dataframe(movers, width="stretch", height=260)
                    except Exception as e:
                        st.caption(f"ΔCorrelation visualization unavailable: {e}")
    except Exception as e:
        st.caption(f"Regime comparison skipped: {e}")

    # ================== חלק 3 — Spread Viewer ==================
    st.subheader("🧮 Spread Viewer (Rolling MA)")

    try:
        pairs_all = get_pairs(False)
        if pairs_all:
            labels = [make_pair_label(p) for p in pairs_all]
            # ברירת מחדל: הזוג המסומן גלובלית אם אפשר
            sel_default = 0
            try:
                sel_global = st.session_state.get("selected_pair")
                if sel_global:
                    sel_label = make_pair_label(sel_global)
                    if sel_label in labels:
                        sel_default = max(0, labels.index(sel_label))
            except Exception:
                pass

            col_sp1, col_sp2 = st.columns([1, 3])
            with col_sp1:
                sample_idx = st.selectbox(
                    "בחר זוג לצפייה ב-Spread",
                    options=list(range(len(labels))),
                    index=min(sel_default, len(labels) - 1),
                    format_func=lambda i: labels[i],
                    key=keygen("ov", "spread_pair_sel"),
                )
                label = labels[sample_idx]
                vol_win = int(ctrl_ov.get("vol_win", 30) or 30)

            with col_sp2:
                df_s = _load_pair_data(label, start_date, end_date).copy()
                if df_s is None or df_s.empty:
                    st.caption("אין דאטה לזוג הנבחר כדי להציג Spread.")
                else:
                    close_col = "Close" if "Close" in df_s.columns else df_s.columns[0]
                    df_s["MA"] = df_s[close_col].rolling(vol_win).mean()
                    df_s["Spread"] = df_s[close_col] - df_s["MA"]
                    try:
                        import plotly.express as px  # type: ignore

                        df_plot = df_s.reset_index()
                        if df_plot.columns[0] != "Date":
                            df_plot = df_plot.rename(columns={df_plot.columns[0]: "Date"})
                        fig_spread = px.line(
                            df_plot,
                            x="Date",
                            y=["Spread", close_col, "MA"],
                            title=f"Price & Rolling Spread (MA={vol_win}) for {label}",
                        )
                        st.plotly_chart(fig_spread, width="stretch")
                    except Exception:
                        st.line_chart(df_s["Spread"])
        else:
            st.info("No pairs available for spread chart.")
    except Exception as e:
        st.error(f"Spread chart error: {e}")

