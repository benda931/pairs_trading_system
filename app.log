# ===================== Date Range Picker & Numeric Control Helpers =====================

TODAY = date.today()


def date_range_picker(
    label: str,
    default_days: int,
    key: str,
    help_text: str = "בחר טווח תאריכים",
) -> Tuple[date, date]:
    """
    Date-range picker בטוח ומודע ל-namespace (שימוש ב-keygen).

    • default_days: כמה ימים אחורה מ-TODAY להגדיר כדיפולט.
    • אם המשתמש בוחר רק תאריך אחד (באג/התנהגות) ⇒ מחזיר אותו כתאריך start=end.

    משמש בכל הטאבים:
    - Dashboard Home (מאוחר יותר)
    - Scan / Pair / Backtest / Matrix / Portfolio וכו'.
    """
    start_default = TODAY - timedelta(days=default_days)
    full_key = keygen("drp", key)
    result = st.date_input(
        label,
        (start_default, TODAY),
        key=full_key,
        help=help_text,
    )
    if isinstance(result, tuple) and len(result) == 2:
        return result
    # fallback – תאריך יחיד
    return result, result  # type: ignore[return-value]


def _num_slider(
    label: str,
    value: float,
    min_v: float,
    max_v: float,
    step: float,
    key: str,
    help: Optional[str] = None,
) -> float:
    """
    Wrapper סביב st.slider כדי לשמור על מראה אחיד ו-keygen.

    • מחזיר always float.
    • ניתן להשתמש לפרמטרים כמו: z_window, hl_min, slippage, fee וכו'.
    """
    return float(
        st.slider(
            label,
            min_value=min_v,
            max_value=max_v,
            value=value,
            step=step,
            key=key,
            help=help,
        )
    )

def _num_input(
    label: str,
    value: float,
    min_v: Optional[float],
    max_v: Optional[float],
    step: Optional[float],
    key: str,
    help: Optional[str] = None,
) -> float:
    """
    עטיפה סביב st.number_input במקום slider.

    • אם min_v/max_v None – אין הגבלה.
    • מחזיר תמיד float – בקוד הקורא אפשר לעשות int(...).
    """
    kwargs: Dict[str, Any] = {"key": key, "help": help}
    if min_v is not None:
        kwargs["min_value"] = min_v
    if max_v is not None:
        kwargs["max_value"] = max_v
    if step is not None:
        kwargs["step"] = step
    return float(
        st.number_input(
            label,
            value=value,
            **kwargs,
        )
    )

# ===================== Controls Builders per Tab =====================

def controls_scan(prefix: str) -> Dict[str, Any]:
    """
    Controls לטאב Smart Scan / Analysis (גרסה משודרגת):

    • אין סליידרים – הכל קלטים מספריים.
    • הוספת פרמטרים לסקור:
        - max_fair_value_zdist – מרחק מקסימלי מה-Fair Value ב-Z.
        - score_weights_* – משקלים לסקור מורכב.
    """
    st.subheader("⚙️ הגדרות סריקה (Smart Scan)")

    cols = st.columns(3)
    with cols[0]:
        universe_n = int(
            _num_input(
                "מספר זוגות לסריקה",
                value=50,
                min_v=1,
                max_v=1000,
                step=1,
                key=keygen(prefix, "universe"),
                help="כמה זוגות להכניס לסריקה (Top N מה-universe).",
            )
        )
        min_corr = _num_input(
            "מינ' מתאם",
            value=0.5,
            min_v=-1.0,
            max_v=1.0,
            step=0.01,
            key=keygen(prefix, "mincorr"),
            help="סינון זוגות עם קורלציה נמוכה יותר ב-window שנבחר.",
        )

    with cols[1]:
        z_window = int(
            _num_input(
                "חלון Z-Score (ימים)",
                value=30,
                min_v=5,
                max_v=365,
                step=1,
                key=keygen(prefix, "zwin"),
            )
        )
        hl_min = int(
            _num_input(
                "Half-life מינ' (ימים)",
                value=5,
                min_v=1,
                max_v=365,
                step=1,
                key=keygen(prefix, "hlmin"),
            )
        )

    with cols[2]:
        coint_p = _num_input(
            "סף p לקו-אינטגרציה",
            value=0.05,
            min_v=0.0001,
            max_v=0.5,
            step=0.001,
            key=keygen(prefix, "cointp"),
        )
        vol_cap = _num_input(
            "תקרת תנודתיות (סטיית תקן)",
            value=0.08,
            min_v=0.0,
            max_v=1.0,
            step=0.005,
            key=keygen(prefix, "volcap"),
        )

    st.caption("טיפ: סף p נמוך = בדיקה מחמירה יותר לקו-אינטגרציה. חלון Z גדול = יותר 'סבלנות' לסטיות.")

    # ---------- Advanced scan parameters / scoring ----------
    with st.expander("🧪 Advanced scan filters & scoring", expanded=False):
        col_a, col_b = st.columns(2)
        with col_a:
            max_fv_zdist = _num_input(
                "מרחק מקסימלי מה-Fair Value (|Spread Z|)",
                value=3.0,
                min_v=0.0,
                max_v=10.0,
                step=0.1,
                key=keygen(prefix, "max_fv_zdist"),
                help="זוגות עם |Z| גדול מזה ייחשבו כ'ממש רחוקים מה-Fair Value'.",
            )
            min_quality_score = _num_input(
                "Quality score מינימלי (0–100)",
                value=40.0,
                min_v=0.0,
                max_v=100.0,
                step=1.0,
                key=keygen(prefix, "min_quality"),
                help="סינון זוגות עם ציון איכות נמוך (evaluate_pair_quality).",
            )
        with col_b:
            max_half_life = _num_input(
                "Half-life מקסימלי (ימים)",
                value=60.0,
                min_v=1.0,
                max_v=365.0,
                step=1.0,
                key=keygen(prefix, "hlmax"),
                help="להימנע מזוגות איטיים מדי (HL גדול מאוד).",
            )
            max_z_abs = _num_input(
                "סף |Z| להצגת 'אזהרה'",
                value=2.5,
                min_v=0.0,
                max_v=10.0,
                step=0.1,
                key=keygen(prefix, "z_alert"),
            )

        st.markdown("**משקלים לסקור מורכב (Composite Scan Score):**")
        col_w1, col_w2, col_w3, col_w4 = st.columns(4)
        with col_w1:
            w_corr = _num_input(
                "משקל Corr",
                value=0.3,
                min_v=0.0,
                max_v=1.0,
                step=0.05,
                key=keygen(prefix, "w_corr"),
            )
        with col_w2:
            w_hl = _num_input(
                "משקל Half-life",
                value=0.2,
                min_v=0.0,
                max_v=1.0,
                step=0.05,
                key=keygen(prefix, "w_hl"),
            )
        with col_w3:
            w_z = _num_input(
                "משקל |Z|",
                value=0.3,
                min_v=0.0,
                max_v=1.0,
                step=0.05,
                key=keygen(prefix, "w_z"),
            )
        with col_w4:
            w_quality = _num_input(
                "משקל Quality",
                value=0.2,
                min_v=0.0,
                max_v=1.0,
                step=0.05,
                key=keygen(prefix, "w_quality"),
            )

    return {
        "universe_n": universe_n,
        "min_corr": min_corr,
        "z_window": z_window,
        "hl_min": hl_min,
        "coint_p": coint_p,
        "vol_cap": vol_cap,
        # Advanced:
        "max_fair_value_zdist": max_fv_zdist,
        "min_quality_score": min_quality_score,
        "max_half_life": max_half_life,
        "max_z_alert": max_z_abs,
        "score_weights": {
            "corr": w_corr,
            "half_life": w_hl,
            "z": w_z,
            "quality": w_quality,
        },
    }



def controls_pair(prefix: str) -> Dict[str, Any]:
    """
    Controls לטאב ניתוח זוג:

    • entry_z / exit_z / take_z
    • ma_win – חלון ממוצע נע לספרד/מחיר.
    • hr_method – שיטת יחס גידור (OLS / Kalman / Rolling OLS).
    • atr_mult – כפולה ל-ATR Stop.

    ניתן לחבר בהמשך:
    - sizing mode (fixed risk / vol-target / risk-parity).
    - max holding days.
    """
    st.subheader("⚙️ הגדרות ניתוח זוג")
    cols = st.columns(3)
    with cols[0]:
        entry_z = _num_slider(
            "כניסה (Z)",
            2.0,
            0.5,
            5.0,
            0.1,
            keygen(prefix, "entryz"),
        )
        exit_z = _num_slider(
            "יציאה (Z)",
            0.5,
            0.0,
            3.0,
            0.1,
            keygen(prefix, "exitz"),
        )
    with cols[1]:
        ma_win = int(
            _num_slider(
                "חלון ממוצע נע",
                20,
                3,
                120,
                1,
                keygen(prefix, "ma"),
            )
        )
        hr_method = st.selectbox(
            "שיטת יחס גידור",
            ["OLS", "Kalman", "Rolling OLS"],
            key=keygen(prefix, "hrm"),
        )
    with cols[2]:
        atr_mult = _num_slider(
            "ATR Stop x",
            2.0,
            0.5,
            10.0,
            0.1,
            keygen(prefix, "atr"),
        )
        take_z = _num_slider(
            "Take Profit (Z)",
            3.0,
            0.5,
            8.0,
            0.1,
            key=keygen(prefix, "tpz"),
        )
    return {
        "entry_z": entry_z,
        "exit_z": exit_z,
        "ma_win": ma_win,
        "hr_method": hr_method,
        "atr_mult": atr_mult,
        "take_z": take_z,
    }


