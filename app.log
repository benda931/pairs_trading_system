        # ================== חלק 2 — Return Correlation Matrix ==================
        corr_mx = None
        dist_mx = None

        with col_right:
            if show_corr:
                st.markdown("**Return Correlation Matrix**")
                st.caption("Heatmap של קורלציות בין זוגות על בסיס תשואות מתגלגלות.")
                try:
                    corr_mx = compute_return_corr_matrix(
                        pairs_all,
                        start_date,
                        end_date,
                        field=str(ctrl_mx.get("field", "Close")),
                        window=int(ctrl_mx.get("ret_win", 20) or 20),
                    )
                    if corr_mx is None or corr_mx.empty:
                        st.info("אין מספיק דאטה למטריצת קורלציה (Returns).")
                    else:
                        try:
                            import plotly.express as px  # type: ignore

                            fig_corr = px.imshow(
                                corr_mx,
                                text_auto=False,
                                aspect="auto",
                                color_continuous_scale=heatmap_color,
                                title=f"Return Correlation Heatmap ({ctrl_mx.get('field','Close')} returns)",
                            )
                            fig_corr.update_traces(
                                hovertemplate="Pair i=%{y}<br>Pair j=%{x}<br>corr=%{z:.3f}<extra></extra>"
                            )
                            st.plotly_chart(fig_corr, use_container_width=True)
                        except Exception:
                            st.dataframe(corr_mx)

                        # Matrix health mini-metrics
                        try:
                            m = corr_mx.values
                            mask = ~np.eye(m.shape[0], dtype=bool)
                            vals = m[mask]
                            vals = vals[~np.isnan(vals)]
                            if vals.size > 0:
                                avg_corr = float(vals.mean())
                                max_corr = float(vals.max())
                                min_corr = float(vals.min())
                                high_corr_ratio = float((vals > 0.8).mean())

                                kpi1, kpi2, kpi3, kpi4 = st.columns(4)
                                kpi1.metric("Avg off-diagonal corr", f"{avg_corr:.3f}")
                                kpi2.metric("Max corr", f"{max_corr:.3f}")
                                kpi3.metric("Min corr", f"{min_corr:.3f}")
                                kpi4.metric("High-corr ratio (>0.8)", f"{100*high_corr_ratio:.1f}%")
                        except Exception:
                            pass

                        # פרופיל קורלציה לכל זוג (row mean)
                        with st.expander("Average correlation per pair (row mean)", expanded=False):
                            try:
                                row_mean = corr_mx.mean(axis=1).sort_values(ascending=False)
                                st.dataframe(
                                    row_mean.to_frame("AvgCorr"),
                                    use_container_width=True,
                                    height=260,
                                )
                            except Exception as e:
                                st.caption(f"Row-wise avg corr unavailable: {e}")
                except Exception as e:
                    st.error(f"Correlation matrix computation failed: {e}")
                    corr_mx = None

        # ================== חלק 2.5 — Matrix Health Dashboard ==================
        if corr_mx is not None and not corr_mx.empty:
            st.markdown("#### 🩺 Matrix Health Dashboard")
            try:
                import numpy as np

                m = corr_mx.values
                mask = ~np.eye(m.shape[0], dtype=bool)
                vals = m[mask]
                vals = vals[~np.isnan(vals)]
                if vals.size > 0:
                    avg_corr = float(vals.mean())
                    std_corr = float(vals.std())
                    high_corr_ratio = float((vals > 0.8).mean())
                    neg_corr_ratio = float((vals < -0.2).mean())

                    c1, c2, c3, c4 = st.columns(4)
                    c1.metric("Mean corr", f"{avg_corr:.3f}")
                    c2.metric("Std(corr)", f"{std_corr:.3f}")
                    c3.metric("% corr > 0.8", f"{100*high_corr_ratio:.1f}%")
                    c4.metric("% corr < -0.2", f"{100*neg_corr_ratio:.1f}%")
            except Exception:
                st.caption("Matrix health metrics unavailable (error in computation).")

            # Drift monitor & simple regime classification
            with st.expander("📈 Matrix Drift Monitor & Regime Classifier", expanded=False):
                try:
                    import numpy as np

                    prev_corr = st.session_state.get("mx_prev_corr")
                    drift_label = "Unknown"
                    drift_score = None

                    if prev_corr is not None:
                        try:
                            prev_corr_df = prev_corr
                            if isinstance(prev_corr_df, pd.DataFrame) and prev_corr_df.shape == corr_mx.shape:
                                diff = corr_mx - prev_corr_df
                                diff_vals = diff.values
                                drift_score = float(np.linalg.norm(diff_vals) / np.sqrt(diff_vals.size))
                                if drift_score < 0.05:
                                    drift_label = "Stable"
                                elif drift_score < 0.15:
                                    drift_label = "Transition"
                                else:
                                    drift_label = "Drifting"

                                d1, d2 = st.columns(2)
                                d1.metric("Drift score", f"{drift_score:.3f}")
                                d2.metric("Regime label", drift_label)
                        except Exception:
                            st.caption("לא ניתן לחשב Drift על בסיס המטריצה הקודמת.")
                    else:
                        st.caption("אין snapshot קודם להשוואה – יישמר snapshot חדש אחרי הרצה זו.")

                    # שמירת drift ל-session_state לשימוש בטאבים אחרים
                    st.session_state["mx_drift_score"] = drift_score
                    st.session_state["mx_drift_label"] = drift_label
                    # שמירת snapshot עדכני
                    st.session_state["mx_prev_corr"] = corr_mx.copy()
                except Exception:
                    st.caption("Matrix drift monitor unavailable (internal error).")

        # ================== חלק 2.6 — Matrix Insights (תובנות טקסטואליות) ==================
        if corr_mx is not None and not corr_mx.empty:
            st.markdown("#### 🔎 Matrix Insights – תובנות אוטומטיות על ה-universe")
            try:
                import numpy as np

                m = corr_mx.values
                mask = ~np.eye(m.shape[0], dtype=bool)
                vals = m[mask]
                vals = vals[~np.isnan(vals)]
                if vals.size == 0:
                    st.caption("אין מספיק ערכי קורלציה כדי להפיק תובנות.")
                else:
                    mean_corr = float(vals.mean())
                    std_corr = float(vals.std())
                    high_corr_ratio = float((vals > 0.8).mean())
                    ultra_high_ratio = float((vals > 0.95).mean())
                    neg_ratio = float((vals < -0.2).mean())
                    n_pairs = corr_mx.shape[0]

                    bullets: list[str] = []

                    # צפיפות שוק / crowdedness
                    if mean_corr > 0.7 and high_corr_ratio > 0.5:
                        bullets.append(
                            "🔴 **שוק סופר-דחוס** – רוב הזוגות קשורים חזק (mean corr > 0.7, הרבה corr>0.8). "
                            "זה מצב שמגביה סיכון ל-deleveraging קולקטיבי ומקטין פיזור אמיתי."
                        )
                    elif mean_corr > 0.5:
                        bullets.append(
                            "🟠 **שוק יחסית דחוס** – קורלציה ממוצעת גבוהה, כדאי לשים לב לגודל פוזיציות ולרמת מינוף."
                        )
                    elif mean_corr < 0.3 and high_corr_ratio < 0.2:
                        bullets.append(
                            "🟢 **שוק מקוטע / מפוזר** – הרבה זוגות עם קורלציה נמוכה, יש פוטנציאל לפיזור ומיקרו-הזדמנויות."
                        )

                    # זנבות שליליים / חוסר גידור טבעי
                    if neg_ratio < 0.05 and mean_corr > 0.6:
                        bullets.append(
                            "⚠️ כמעט ואין קשרים שליליים (corr<-0.2) – ה-universe שלך מספק מעט גידור טבעי, "
                            "שווה לחשוב על הוספת נכסים/זוגות עם דינמיקה הפוכה."
                        )

                    # זיהוי "קירוב" מוחלט
                    if ultra_high_ratio > 0.2:
                        bullets.append(
                            "⚠️ אחוז לא קטן מהקורלציות מעל 0.95 – חלק מהזוגות כמעט זהים סטטיסטית, "
                            "יכול להעיד על Universe צפוף מדי או על צורך בסינון/דה-דופ."
                        )

                    bullets.append(
                        f"ℹ️ הטאב מחשב כרגע קורלציה עבור **{n_pairs}** זוגות. "
                        "כדאי להשתמש ב-Clustering, Tail-Dependence ו-Pair Focus כדי לזהות קלסטרים והזדמנויות ספציפיות."
                    )

                    if bullets:
                        for msg in bullets:
                            st.write(f"- {msg}")
                    else:
                        st.caption("לא זוהו תבניות חריגות – מבנה המטריצה נראה סביר יחסית כרגע.")
            except Exception as e:
                st.caption(f"Matrix Insights: חישוב תובנות נכשל (שגיאה פנימית): {e}")

        # ================== חלק 2.7 — Multi-Horizon & Alternative Correlation Views ==================
        if corr_mx is not None and not corr_mx.empty and not light_mode:
            st.markdown("#### 📊 Multi-Horizon & Alternative Correlation Views")

            with st.expander("📊 Multi-Horizon Correlation – השוואת אופקי זמן", expanded=False):
                try:
                    import numpy as np

                    candidate_horizons = [5, 10, 20, 60, 120]
                    default_horizons = [10, 20, 60]

                    horizons = st.multiselect(
                        "בחר אופקי זמן (חלון תשואה בימים)",
                        options=candidate_horizons,
                        default=[h for h in default_horizons if h in candidate_horizons],
                        key="mx_multi_horizons",
                    )

                    stats_rows: list[dict[str, float]] = []
                    for h in horizons:
                        try:
                            mx_h = compute_return_corr_matrix(
                                pairs_all,
                                start_date,
                                end_date,
                                field=str(ctrl_mx.get("field", "Close")),
                                window=h,
                            )
                        except Exception:
                            mx_h = None

                        if mx_h is None or mx_h.empty:
                            continue

                        m = mx_h.values
                        mask = ~np.eye(m.shape[0], dtype=bool)
                        vals = m[mask]
                        vals = vals[~np.isnan(vals)]
                        if vals.size == 0:
                            continue

                        avg_corr = float(vals.mean())
                        std_corr = float(vals.std())
                        high_corr_ratio = float((vals > 0.8).mean())
                        neg_corr_ratio = float((vals < -0.2).mean())
                        stats_rows.append(
                            {
                                "Horizon": h,
                                "MeanCorr": avg_corr,
                                "StdCorr": std_corr,
                                "HighCorrRatio(>0.8)": high_corr_ratio,
                                "NegCorrRatio(<-0.2)": neg_corr_ratio,
                            }
                        )

                    if stats_rows:
                        df_stats = pd.DataFrame(stats_rows).set_index("Horizon").sort_index()
                        st.dataframe(df_stats, use_container_width=True, height=220)
                    else:
                        st.caption("לא הצלחנו לחשב סטטיסטיקות עבור האופקים שנבחרו.")
                except Exception as e:
                    st.caption(f"Multi-horizon stats unavailable: {e}")

            with st.expander("🧮 Alternative Correlation Views (Rank / Vol-Adjusted Hooks)", expanded=False):
                st.caption(
                    "כאן ניתן להפעיל שיטות קורלציה אלטרנטיביות. "
                    "Spearman (Rank) יפעל אם compute_return_corr_matrix תומכת method='spearman'. "
                    "Vol-Adjusted תלוי באימפלמנטציה אצלך (mode='vol_adjusted')."
                )

                alt_method = st.selectbox(
                    "שיטת קורלציה אלטרנטיבית",
                    [
                        "None (Base Pearson)",
                        "Spearman (Rank Corr)",
                        "Vol-Adjusted (אם נתמך)",
                    ],
                    key="mx_alt_corr_method",
                )

                if alt_method != "None (Base Pearson)":
                    with st.spinner("מחשב מטריצת קורלציה אלטרנטיבית..."):
                        alt_mx = None
                        try:
                            if alt_method.startswith("Spearman"):
                                alt_mx = compute_return_corr_matrix(
                                    pairs_all,
                                    start_date,
                                    end_date,
                                    field=str(ctrl_mx.get("field", "Close")),
                                    window=int(ctrl_mx.get("ret_win", 20) or 20),
                                    method="spearman",  # type: ignore[arg-type]
                                )
                            elif alt_method.startswith("Vol-Adjusted"):
                                alt_mx = compute_return_corr_matrix(
                                    pairs_all,
                                    start_date,
                                    end_date,
                                    field=str(ctrl_mx.get("field", "Close")),
                                    window=int(ctrl_mx.get("ret_win", 20) or 20),
                                    mode="vol_adjusted",  # type: ignore[arg-type]
                                )
                        except TypeError:
                            alt_mx = None
                            st.warning(
                                "נראה ש-compute_return_corr_matrix אצלך לא תומכת בפרמטרים האלה "
                                "(method / mode). אפשר להרחיב אותה בהמשך כדי לאפשר את הפיצ'רים האלה."
                            )
                        except Exception as e:
                            alt_mx = None
                            st.warning(f"Alternative correlation computation failed: {e}")

                        if alt_mx is not None and not alt_mx.empty:
                            try:
                                import plotly.express as px  # type: ignore

                                fig_alt = px.imshow(
                                    alt_mx,
                                    text_auto=False,
                                    aspect="auto",
                                    color_continuous_scale=heatmap_color,
                                    title=f"Alternative Correlation Heatmap – {alt_method}",
                                )
                                fig_alt.update_traces(
                                    hovertemplate="Pair i=%{y}<br>Pair j=%{x}<br>corr_alt=%{z:.3f}<extra></extra>"
                                )
                                st.plotly_chart(fig_alt, use_container_width=True)
                            except Exception:
                                st.dataframe(alt_mx, use_container_width=True)
                        else:
                            st.caption("לא זמינה כרגע מטריצת קורלציה אלטרנטיבית (ראה אזהרה למעלה).")

        # ================== חלק 2.8 — ΔCorr Heatmap (שינוי קורלציה בין תקופות) ==================
        if corr_mx is not None and not corr_mx.empty and not light_mode:
            st.markdown("#### 📉 ΔCorr Heatmap – שינוי מבנה הקורלציה בין תקופות")

            with st.expander("📉 ΔCorr בין תחילת הטווח לסופו (Split by midpoint)", expanded=False):
                try:
                    import numpy as np
                    from datetime import timedelta

                    # נחשב נקודת אמצע אוטומטית
                    try:
                        delta_days = (end_date - start_date).days  # type: ignore[operator]
                        start_date_dt = start_date
                        end_date_dt = end_date
                    except Exception:
                        ds = pd.to_datetime(start_date)
                        de = pd.to_datetime(end_date)
                        delta_days = (de - ds).days
                        start_date_dt = ds
                        end_date_dt = de

                    if delta_days < 4:
                        st.caption("הטווח קצר מדי כדי לפצל לשתי תקופות משמעותיות.")
                    else:
                        mid_date = start_date_dt + timedelta(days=delta_days // 2)

                        st.caption(
                            f"Periods: Early = {start_date_dt} → {mid_date}, "
                            f"Late = {mid_date} → {end_date_dt}"
                        )

                        with st.spinner("מחשב מטריצות קורלציה לשתי התקופות..."):
                            mx_early = compute_return_corr_matrix(
                                pairs_all,
                                start_date_dt,
                                mid_date,
                                field=str(ctrl_mx.get("field", "Close")),
                                window=int(ctrl_mx.get("ret_win", 20) or 20),
                            )
                            mx_late = compute_return_corr_matrix(
                                pairs_all,
                                mid_date,
                                end_date_dt,
                                field=str(ctrl_mx.get("field", "Close")),
                                window=int(ctrl_mx.get("ret_win", 20) or 20),
                            )

                        if (
                            mx_early is None
                            or mx_late is None
                            or mx_early.empty
                            or mx_late.empty
                        ):
                            st.caption("לא הצלחנו לחשב מטריצות לשתי התקופות (חוסר דאטה?).")
                        else:
                            common_idx = mx_early.index.intersection(mx_late.index)
                            mx_early = mx_early.loc[common_idx, common_idx]
                            mx_late = mx_late.loc[common_idx, common_idx]

                            if mx_early.shape != mx_late.shape or mx_early.empty:
                                st.caption("אין חיתוך מספיק בין ה-universe בשתי התקופות.")
                            else:
                                delta_mx = mx_late - mx_early

                                try:
                                    import plotly.express as px  # type: ignore

                                    fig_delta = px.imshow(
                                        delta_mx,
                                        text_auto=False,
                                        aspect="auto",
                                        color_continuous_scale="RdBu",
                                        title="ΔCorr Heatmap (Late - Early)",
                                    )
                                    fig_delta.update_traces(
                                        hovertemplate=(
                                            "Pair i=%{y}<br>Pair j=%{x}"
                                            "<br>Δcorr=%{z:.3f}<extra></extra>"
                                        )
                                    )
                                    st.plotly_chart(fig_delta, use_container_width=True)
                                except Exception:
                                    st.dataframe(delta_mx, use_container_width=True)

                                # סטטיסטיקת שינוי
                                try:
                                    dv = delta_mx.values
                                    mask = ~np.eye(dv.shape[0], dtype=bool)
                                    vals = dv[mask]
                                    vals = vals[~np.isnan(vals)]
                                    if vals.size > 0:
                                        mean_delta = float(vals.mean())
                                        std_delta = float(vals.std())
                                        big_moves = float((np.abs(vals) > 0.2).mean())

                                        d1, d2, d3 = st.columns(3)
                                        d1.metric("Mean Δcorr", f"{mean_delta:.3f}")
                                        d2.metric("Std(Δcorr)", f"{std_delta:.3f}")
                                        d3.metric("% |Δcorr| > 0.2", f"{100*big_moves:.1f}%")
                                except Exception:
                                    st.caption("לא ניתן לחשב סטטיסטיקות Δcorr (שגיאה פנימית).")
                except Exception as e:
                    st.caption(f"ΔCorr section skipped (error): {e}")

        # ================== חלק 3 — Distance Matrix & Cluster Intuition ==================
        if show_dist:
            st.subheader("📐 Distance Matrix (1 - corr) – אינטואיציה לקלסטרים")
            try:
                if corr_mx is None or corr_mx.empty:
                    st.caption("אין מטריצת קורלציה זמינה כדי לבנות Distance Matrix.")
                else:
                    dist_mx = 1.0 - corr_mx
                    try:
                        import plotly.express as px  # type: ignore

                        fig_dist = px.imshow(
                            dist_mx,
                            text_auto=False,
                            aspect="auto",
                            color_continuous_scale=heatmap_color,
                            title="Distance Matrix (1 - corr)",
                        )
                        st.plotly_chart(fig_dist, use_container_width=True)
                    except Exception:
                        st.dataframe(dist_mx)
            except Exception as e:
                st.caption(f"Distance matrix unavailable: {e}")

        # ================== חלק 4 — Factor Map (PCA על המטריצה) ==================
        df_pca = None
        if show_pca:
            st.subheader("🧭 Factor Map — מיפוי זוגות במרחב 2D (PCA על Corr)")
            try:
                if corr_mx is None or corr_mx.empty:
                    st.caption("אין מטריצת קורלציה כדי ליצור Factor Map.")
                else:
                    try:
                        vals, vecs = np.linalg.eigh(corr_mx.values)
                        idx_sorted = np.argsort(vals)[::-1]
                        top2 = idx_sorted[:2]
                        pcs = vecs[:, top2]
                        df_pca = pd.DataFrame(
                            {
                                "Pair": corr_mx.index,
                                "PC1": pcs[:, 0],
                                "PC2": pcs[:, 1],
                            }
                        )

                        import plotly.express as px  # type: ignore

                        fig_pca = px.scatter(
                            df_pca,
                            x="PC1",
                            y="PC2",
                            text="Pair",
                            title="Factor Map (PCA on Corr Matrix)",
                        )
                        fig_pca.update_traces(textposition="top center")
                        st.plotly_chart(fig_pca, use_container_width=True)
                    except Exception as e:
                        st.caption(f"PCA factor map unavailable: {e}")
            except Exception as e:
                st.caption(f"Factor map skipped: {e}")

        # ================== חלק 5 — Clustering (אם זמין) ==================
        df_clusters = None
        if show_clusters:
            st.subheader("🧩 Clustering (אם ספריות זמינות)")
            try:
                enable_clustering = bool(ctrl_mx.get("enable_clustering", True))
                if not enable_clustering:
                    st.caption("Clustering כבוי (Feature Flag).")
                elif corr_mx is None or corr_mx.empty:
                    st.caption("אין מטריצת קורלציה זמינה לצורך clustering.")
                else:
                    try:
                        from sklearn.cluster import KMeans  # type: ignore

                        n_clusters = st.slider(
                            "מספר קלסטרים (K)",
                            min_value=2,
                            max_value=min(12, len(corr_mx)),
                            value=min(5, len(corr_mx)),
                            step=1,
                            key=keygen("mx", "k_clusters"),
                        )
                        if dist_mx is None:
                            dist_mx = 1.0 - corr_mx

                        km = KMeans(n_clusters=n_clusters, random_state=ctx_mx.seed)
                        labels_km = km.fit_predict(corr_mx.values)

                        df_clusters = pd.DataFrame(
                            {
                                "Pair": corr_mx.index,
                                "Cluster": labels_km,
                                "AvgCorr": corr_mx.mean(axis=1),
                            }
                        ).sort_values(["Cluster", "AvgCorr"], ascending=[True, False])

                        # חיפוש/סינון
                        filter_text = st.text_input(
                            "סינון לפי Pair / Cluster",
                            "",
                            key="mx_cluster_filter",
                        )
                        df_view = df_clusters
                        if filter_text:
                            ft = str(filter_text).lower()
                            df_view = df_view[
                                df_view["Pair"].astype(str).str.lower().str.contains(ft)
                                | df_view["Cluster"].astype(str).str.contains(ft)
                            ]

                        st.dataframe(df_view, use_container_width=True, height=260)

                        # מציגים Factor Map עם צביעת קלסטרים (אם df_pca קיים)
                        try:
                            if df_pca is not None:
                                df_pca_cl = df_pca.merge(df_clusters, on="Pair", how="left")
                                import plotly.express as px  # type: ignore

                                fig_pca_cl = px.scatter(
                                    df_pca_cl,
                                    x="PC1",
                                    y="PC2",
                                    color="Cluster",
                                    text="Pair",
                                    title="Factor Map עם Clusters (KMeans על Corr)",
                                )
                                fig_pca_cl.update_traces(textposition="top center")
                                st.plotly_chart(fig_pca_cl, use_container_width=True)
                        except Exception as e:
                            st.caption(f"Clustered factor map unavailable: {e}")
                    except ImportError:
                        st.caption("sklearn לא מותקן – Clustering באמצעות KMeans אינו זמין.")
                    except Exception as e:
                        st.caption(f"Clustering failed: {e}")
            except Exception as e:
                st.caption(f"Clustering section skipped: {e}")

        # ================== חלק 5.5 — Network / MST / Hierarchical (אופציונלי) ==================
        if show_clusters and corr_mx is not None and not corr_mx.empty:
            with st.expander("🌐 Network & MST View (אופציונלי)", expanded=False):
                try:
                    if dist_mx is None:
                        dist_mx = 1.0 - corr_mx

                    labels = list(corr_mx.index)
                    import networkx as nx  # type: ignore

                    G = nx.Graph()
                    for i, li in enumerate(labels):
                        for j in range(i + 1, len(labels)):
                            lj = labels[j]
                            w = float(dist_mx.iloc[i, j])
                            G.add_edge(li, lj, weight=w)

                    mst = nx.minimum_spanning_tree(G)
                    mst_edges = [
                        (u, v, d.get("weight", np.nan)) for u, v, d in mst.edges(data=True)
                    ]
                    df_mst = pd.DataFrame(mst_edges, columns=["Node1", "Node2", "Distance"])
                    st.dataframe(df_mst, use_container_width=True, height=240)
                    st.caption("Minimum Spanning Tree נותן מפת מבנה שוק קומפקטית.")
                except ImportError:
                    st.caption("networkx לא זמין – תצוגת MST לא זמינה.")
                except Exception as e:
                    st.caption(f"MST computation failed: {e}")

        # ================== חלק 5.7 — Cluster Stability Over Time ==================
        if show_clusters and corr_mx is not None and not corr_mx.empty and not light_mode:
            st.markdown("#### ⏳ Cluster Stability Over Time")

            with st.expander("⏳ יציבות קלסטרים לאורך מספר תקופות", expanded=False):
                try:
                    from sklearn.cluster import KMeans  # type: ignore
                    from datetime import timedelta

                    # ברירת מחדל ל-K: אם יש df_clusters נשתמש במספר הקלסטרים ממנו
                    default_k = 4
                    if df_clusters is not None and not df_clusters.empty:
                        try:
                            default_k = int(df_clusters["Cluster"].nunique())
                        except Exception:
                            pass

                    n_clusters_stab = st.slider(
                        "K לניתוח יציבות",
                        min_value=2,
                        max_value=min(12, len(corr_mx)),
                        value=min(default_k, len(corr_mx)),
                        step=1,
                        key="mx_stab_k",
                    )
                    n_slices = st.slider(
                        "מספר תקופות (Slices)",
                        min_value=2,
                        max_value=6,
                        value=3,
                        step=1,
                        key="mx_stab_slices",
                        help="כמה חלונות זמן לחתוך מהטווח הכולל לצורך בדיקת יציבות קלסטרים.",
                    )

                    # המרה ל-datetime שמיש
                    try:
                        total_days = (end_date - start_date).days  # type: ignore[operator]
                        start_dt = start_date
                        end_dt = end_date
                    except Exception:
                        start_dt = pd.to_datetime(start_date)
                        end_dt = pd.to_datetime(end_date)
                        total_days = (end_dt - start_dt).days

                    if total_days <= n_slices * 3:
                        st.caption("הטווח קצר מדי עבור מספר ה-slices שנבחר – הגדל טווח או הקטן slices.")
                    else:
                        slice_len = total_days // n_slices
                        boundaries = [start_dt + timedelta(days=slice_len * i) for i in range(n_slices)]
                        boundaries.append(end_dt)

                        labels_ref = None
                        assignments: list[np.ndarray] = []
                        slice_labels: list[str] = []

                        for i in range(n_slices):
                            s = boundaries[i]
                            e = boundaries[i + 1]
                            if (e - s).days < 3:
                                continue

                            try:
                                mx_slice = compute_return_corr_matrix(
                                    pairs_all,
                                    s,
                                    e,
                                    field=str(ctrl_mx.get("field", "Close")),
                                    window=int(ctrl_mx.get("ret_win", 20) or 20),
                                )
                            except Exception:
                                mx_slice = None

                            if mx_slice is None or mx_slice.empty:
                                continue

                            if labels_ref is None:
                                labels_ref = list(mx_slice.index)
                            else:
                                common_idx = mx_slice.index.intersection(labels_ref)
                                mx_slice = mx_slice.loc[common_idx, common_idx]
                                labels_ref = list(common_idx)

                            if not labels_ref:
                                continue

                            km = KMeans(
                                n_clusters=n_clusters_stab,
                                random_state=getattr(ctx_mx, "seed", 42),
                            )
                            labels_slice = km.fit_predict(mx_slice.values)
                            assignments.append(labels_slice)
                            slice_labels.append(f"{i+1}: {s.date()} → {e.date()}")

                        if not assignments or labels_ref is None:
                            st.caption("לא הצלחנו לחשב קלסטרים עבור מספיק חלונות זמן – ייתכן שאין מספיק דאטה.")
                        else:
                            A = np.vstack(assignments).T  # shape: [n_pairs, n_slices_eff]
                            # נגדיר יציבות יחסית לקלסטר בתקופה האחרונה
                            ref = A[:, -1]
                            stability = (A == ref[:, None]).mean(axis=1)

                            df_stab = pd.DataFrame(
                                {
                                    "Pair": labels_ref,
                                    "Stability": stability,
                                }
                            )
                            df_stab["Flag"] = np.where(
                                df_stab["Stability"] >= 0.7,
                                "Stable",
                                "Sensitive",
                            )

                            df_stab = df_stab.sort_values("Stability", ascending=False)

                            st.caption(
                                "יציבות מחושבת כאחוז התקופות שבהן הזוג נשאר באותו קלסטר כמו בתקופה האחרונה."
                            )
                            st.dataframe(df_stab, use_container_width=True, height=260)

                            # הצגה מהירה של top יציבים ו-sensitive
                            c1, c2 = st.columns(2)
                            with c1:
                                st.write("Top Stable Pairs")
                                st.dataframe(
                                    df_stab.head(10).reset_index(drop=True),
                                    use_container_width=True,
                                    height=220,
                                )
                            with c2:
                                st.write("Most Regime-Sensitive Pairs")
                                st.dataframe(
                                    df_stab.tail(10).reset_index(drop=True),
                                    use_container_width=True,
                                    height=220,
                                )
                except ImportError:
                    st.caption("sklearn לא מותקן – ניתוח יציבות קלסטרים אינו זמין.")
                except Exception as e:
                    st.caption(f"Cluster stability analysis failed: {e}")

        # ================== חלק 5.8 — Sector / Theme Overlay (אם meta זמין) ==================
        if df_clusters is not None and not df_clusters.empty:
            with st.expander("🏷 Sector / Theme Overlay (אם metadata זמין)", expanded=False):
                try:
                    meta_df = st.session_state.get("matrix_pairs_meta")
                    if isinstance(meta_df, pd.DataFrame) and "Pair" in meta_df.columns:
                        df_meta = meta_df.copy()
                        # ננקה קצת שמות עמודות סטנדרטיים אם קיימים
                        possible_sector_cols = [c for c in df_meta.columns if "sector" in c.lower()]
                        possible_country_cols = [c for c in df_meta.columns if "country" in c.lower()]
                        possible_asset_cols = [c for c in df_meta.columns if "asset" in c.lower()]

                        sector_col = possible_sector_cols[0] if possible_sector_cols else None
                        country_col = possible_country_cols[0] if possible_country_cols else None
                        asset_col = possible_asset_cols[0] if possible_asset_cols else None

                        df_merged = df_clusters.merge(df_meta, on="Pair", how="left")

                        group_cols = ["Cluster"]
                        display_cols = ["Pair", "Cluster"]
                        if sector_col:
                            display_cols.append(sector_col)
                            group_cols.append(sector_col)
                        if country_col:
                            display_cols.append(country_col)
                        if asset_col:
                            display_cols.append(asset_col)

                        st.caption("למטה: טבלת קלסטרים עם מידע סקטוריאלי/אזורי אם קיים.")
                        st.dataframe(
                            df_merged[display_cols].sort_values(["Cluster", "Pair"]),
                            use_container_width=True,
                            height=260,
                        )

                        if sector_col:
                            st.markdown("**פילוח סקטור לכל קלסטר**")
                            df_sector = (
                                df_merged.groupby(["Cluster", sector_col])["Pair"]
                                .count()
                                .rename("Count")
                                .reset_index()
                            )
                            st.dataframe(
                                df_sector.sort_values(["Cluster", "Count"], ascending=[True, False]),
                                use_container_width=True,
                                height=260,
                            )
                        else:
                            st.caption("לא נמצאה עמודת סקטור ב-matrix_pairs_meta – ניתן להוסיף ולשמור ב-session_state.")
                    else:
                        st.caption(
                            "כדי להפעיל Overlay, הגדר ב-session_state DataFrame בשם 'matrix_pairs_meta' "
                            "עם עמודת 'Pair' ועמודות נוספות כמו 'sector' / 'country' / 'asset_class'."
                        )
                except Exception as e:
                    st.caption(f"Sector/Theme overlay failed: {e}")
        # ================== חלק 5.85 — Universe Scores Overlay (quality / score) ==================
        if df_clusters is not None and not df_clusters.empty:
            with st.expander("🎯 Universe Scores Overlay (quality / score)", expanded=False):
                try:
                    uni_df = st.session_state.get("matrix_universe_df")
                    if not isinstance(uni_df, pd.DataFrame) or "Pair" not in uni_df.columns:
                        st.caption(
                            "כדי לראות Overlay של quality/score, שמור DataFrame ב-session_state['matrix_universe_df'] "
                            "עם עמודת 'Pair' ועמודות איכות (למשל 'quality', 'score')."
                        )
                    else:
                        df_uni = uni_df.copy()
                        # נזהה שמות עמודות סבירים ל-quality/score
                        possible_quality = [c for c in df_uni.columns if "qual" in c.lower()]
                        possible_score = [c for c in df_uni.columns if "score" in c.lower() or "rank" in c.lower()]

                        quality_col = possible_quality[0] if possible_quality else None
                        score_col = possible_score[0] if possible_score else None

                        # מיזוג לפי Pair
                        df_merged = df_clusters.merge(df_uni, on="Pair", how="left")

                        show_cols = ["Pair", "Cluster", "AvgCorr"]
                        if quality_col:
                            show_cols.append(quality_col)
                        if score_col:
                            show_cols.append(score_col)

                        st.markdown("**קלסטרים עם איכות/ציון לכל זוג**")
                        st.dataframe(
                            df_merged[show_cols].sort_values(
                                ["Cluster", quality_col or "AvgCorr"],
                                ascending=[True, False],
                            ),
                            use_container_width=True,
                            height=260,
                        )

                        # סיכום לפי קלסטר
                        agg_cols = {"AvgCorr": "mean"}
                        if quality_col:
                            agg_cols[quality_col] = "mean"
                        if score_col:
                            agg_cols[score_col] = "mean"

                        df_cluster_agg = df_merged.groupby("Cluster").agg(agg_cols).reset_index()

                        st.markdown("**סיכום לפי קלסטר – Corr / Quality / Score ממוצעים**")
                        st.dataframe(
                            df_cluster_agg.sort_values(
                                quality_col or "AvgCorr", ascending=False
                            ),
                            use_container_width=True,
                            height=220,
                        )

                        # Highlight: זוגות High-Quality / High-Score
                        c1, c2 = st.columns(2)
                        if quality_col:
                            with c1:
                                st.markdown(f"**Top High-Quality Pairs ({quality_col})**")
                                st.dataframe(
                                    df_merged.sort_values(quality_col, ascending=False)
                                    .head(20)
                                    .reset_index(drop=True),
                                    use_container_width=True,
                                    height=260,
                                )
                        if score_col:
                            with c2:
                                st.markdown(f"**Top High-Score Pairs ({score_col})**")
                                st.dataframe(
                                    df_merged.sort_values(score_col, ascending=False)
                                    .head(20)
                                    .reset_index(drop=True),
                                    use_container_width=True,
                                    height=260),
                except Exception as e:
                    st.caption(f"Universe scores overlay failed: {e}")

        # ================== חלק 5.9 — Pair-Level Regime Flags (Stable / Sensitive) ==================
        if corr_mx is not None and not corr_mx.empty and not light_mode:
            with st.expander("🎭 Pair-Level Regime Flags (Stable vs Sensitive)", expanded=False):
                try:
                    from datetime import timedelta

                    # נחשב Early / Late שוב (בדומה ל-ΔCorr), אבל הפעם נתרכז ברמת זוג
                    try:
                        delta_days = (end_date - start_date).days  # type: ignore[operator]
                        start_dt = start_date
                        end_dt = end_date
                    except Exception:
                        start_dt = pd.to_datetime(start_date)
                        end_dt = pd.to_datetime(end_date)
                        delta_days = (end_dt - start_dt).days

                    if delta_days < 4:
                        st.caption("הטווח קצר מדי לסיווג Regime per pair.")
                    else:
                        mid_date = start_dt + timedelta(days=delta_days // 2)

                        with st.spinner("מחשב קורלציות לשתי תקופות לצורך Regime Flags..."):
                            mx_early = compute_return_corr_matrix(
                                pairs_all,
                                start_dt,
                                mid_date,
                                field=str(ctrl_mx.get("field", "Close")),
                                window=int(ctrl_mx.get("ret_win", 20) or 20),
                            )
                            mx_late = compute_return_corr_matrix(
                                pairs_all,
                                mid_date,
                                end_dt,
                                field=str(ctrl_mx.get("field", "Close")),
                                window=int(ctrl_mx.get("ret_win", 20) or 20),
                            )

                        if (
                            mx_early is None
                            or mx_late is None
                            or mx_early.empty
                            or mx_late.empty
                        ):
                            st.caption("לא הצלחנו לחשב מטריצות לשתי התקופות (חוסר דאטה?).")
                        else:
                            common_idx = mx_early.index.intersection(mx_late.index)
                            mx_early = mx_early.loc[common_idx, common_idx]
                            mx_late = mx_late.loc[common_idx, common_idx]

                            if mx_early.shape != mx_late.shape or mx_early.empty:
                                st.caption("אין חיתוך מספיק בין ה-universe בשתי התקופות.")
                            else:
                                # ממוצע קורלציה לכל זוג בכל תקופה
                                rm_early = mx_early.mean(axis=1)
                                rm_late = mx_late.mean(axis=1)
                                delta = rm_late - rm_early
                                abs_delta = delta.abs()

                                df_regime = pd.DataFrame(
                                    {
                                        "Pair": common_idx,
                                        "AvgCorr_Early": rm_early.values,
                                        "AvgCorr_Late": rm_late.values,
                                        "DeltaAvgCorr": delta.values,
                                        "AbsDeltaAvgCorr": abs_delta.values,
                                    }
                                )

                                # סף: עד 0.1 שינוי ממוצע – Stable, אחרת Sensitive
                                threshold = st.slider(
                                    "סף |ΔAvg Corr| לסיווג Stable",
                                    min_value=0.02,
                                    max_value=0.30,
                                    value=0.10,
                                    step=0.01,
                                    key="mx_regime_thresh",
                                )

                                df_regime["RegimeFlag"] = np.where(
                                    df_regime["AbsDeltaAvgCorr"] <= threshold,
                                    "Stable",
                                    "Sensitive",
                                )

                                # אם יש df_clusters – נוסיף גם Cluster לזיהוי
                                if df_clusters is not None and not df_clusters.empty:
                                    df_regime = df_regime.merge(
                                        df_clusters[["Pair", "Cluster"]],
                                        on="Pair",
                                        how="left",
                                    )

                                df_regime = df_regime.sort_values(
                                    "AbsDeltaAvgCorr", ascending=False
                                )

                                st.dataframe(
                                    df_regime,
                                    use_container_width=True,
                                    height=300,
                                )

                                c1, c2 = st.columns(2)
                                with c1:
                                    st.write("Top Stable (by AbsΔ small)")
                                    st.dataframe(
                                        df_regime.sort_values(
                                            "AbsDeltaAvgCorr", ascending=True
                                        )
                                        .head(10)
                                        .reset_index(drop=True),
                                        use_container_width=True,
                                        height=220,
                                    )
                                with c2:
                                    st.write("Top Sensitive (by AbsΔ large)")
                                    st.dataframe(
                                        df_regime.head(10).reset_index(drop=True),
                                        use_container_width=True,
                                        height=220,
                                    )
                except Exception as e:
                    st.caption(f"Regime flags section failed: {e}")
        # ================== חלק 5.95 — Pair Focus Panel (Drill-Down לזוג בודד) ==================
        if corr_mx is not None and not corr_mx.empty:
            with st.expander("🔍 Pair Focus Panel – Drill-Down לזוג בודד", expanded=False):
                try:
                    pair_options = [str(p) for p in corr_mx.index]
                    if not pair_options:
                        st.caption("אין זוגות לבחירה ב-Pair Focus.")
                    else:
                        focus_pair = st.selectbox(
                            "בחר זוג למיקוד (Pair label מתוך המטריצה)",
                            pair_options,
                            key="mx_focus_pair",
                        )

                        # ---- Meta Info: Cluster / AvgCorr / Quality / Score ----
                        cluster_id = None
                        avg_corr_pair = None
                        quality_val = None
                        score_val = None

                        # Cluster + AvgCorr מתוך df_clusters אם קיים
                        if df_clusters is not None and not df_clusters.empty:
                            try:
                                row_cl = df_clusters[df_clusters["Pair"] == focus_pair]
                                if not row_cl.empty:
                                    cluster_id = int(row_cl["Cluster"].iloc[0])
                                    avg_corr_pair = float(row_cl["AvgCorr"].iloc[0])
                            except Exception:
                                pass

                        # Universe overlay (quality / score) מתוך matrix_universe_df אם קיים
                        uni_df = st.session_state.get("matrix_universe_df")
                        if isinstance(uni_df, pd.DataFrame) and "Pair" in uni_df.columns:
                            try:
                                row_u = uni_df[uni_df["Pair"] == focus_pair]
                                if not row_u.empty:
                                    # נזהה quality/score לפי שמות עמודות
                                    possible_quality = [c for c in row_u.columns if "qual" in c.lower()]
                                    possible_score = [c for c in row_u.columns if "score" in c.lower() or "rank" in c.lower()]
                                    if possible_quality:
                                        quality_val = float(row_u[possible_quality[0]].iloc[0])
                                    if possible_score:
                                        score_val = float(row_u[possible_score[0]].iloc[0])
                            except Exception:
                                pass

                        # מטריצת Tail-Dependence אם קיימת ב-session_state
                        tail_mx = st.session_state.get("mx_tail_dep_matrix")
                        has_tail = isinstance(tail_mx, pd.DataFrame) and focus_pair in getattr(tail_mx, "index", [])

                        # KPIs ראשיים
                        k1, k2, k3, k4 = st.columns(4)
                        k1.metric("Cluster", str(cluster_id) if cluster_id is not None else "N/A")
                        if avg_corr_pair is None:
                            # ננסה לחשב row-mean ישירות מהמטריצה
                            try:
                                avg_corr_pair = float(corr_mx.loc[focus_pair].dropna().mean())
                            except Exception:
                                avg_corr_pair = None
                        k2.metric(
                            "AvgCorr (row mean)",
                            f"{avg_corr_pair:.3f}" if avg_corr_pair is not None else "N/A",
                        )
                        k3.metric(
                            "Quality",
                            f"{quality_val:.3f}" if quality_val is not None else "N/A",
                        )
                        k4.metric(
                            "Score",
                            f"{score_val:.3f}" if score_val is not None else "N/A",
                        )

                        # ---- Corr row של הזוג מול כל שאר הזוגות ----
                        try:
                            corr_row = corr_mx.loc[focus_pair].dropna()
                            # נסיר את עצמו אם מופיע
                            corr_row = corr_row.drop(labels=[focus_pair], errors="ignore")
                            if not corr_row.empty:
                                top_k = st.slider(
                                    "כמה זוגות להציג ב-Top/Bottom lists?",
                                    min_value=5,
                                    max_value=min(50, len(corr_row)),
                                    value=min(10, len(corr_row)),
                                    step=1,
                                    key="mx_focus_topk",
                                )

                                st.markdown("**Top correlated pairs (לפי Corr רגיל)**")
                                corr_desc = corr_row.sort_values(ascending=False)
                                st.dataframe(
                                    corr_desc.head(top_k).to_frame("Corr"),
                                    use_container_width=True,
                                    height=260,
                                )

                                st.markdown("**Least correlated pairs (קשרים חלשים / שליליים)**")
                                corr_asc = corr_row.sort_values(ascending=True)
                                st.dataframe(
                                    corr_asc.head(top_k).to_frame("Corr"),
                                    use_container_width=True,
                                    height=260,
                                )

                                # אינדיקציה לכמה הזוג "מחובר" למערכת
                                strong_links = int((corr_row.abs() > 0.8).sum())
                                mid_links = int(((corr_row.abs() > 0.5) & (corr_row.abs() <= 0.8)).sum())
                                st.caption(
                                    f"לזוג **{focus_pair}** יש {strong_links} קשרים חזקים (|corr|>0.8) "
                                    f"ו-{mid_links} קשרים בינוניים (0.5<|corr|≤0.8) מול שאר הזוגות."
                                )
                            else:
                                st.caption("לא נמצאו ערכי קורלציה רלוונטיים עבור הזוג הנבחר.")
                        except Exception as e:
                            st.caption(f"Pair Focus: לא הצלחנו לגזור Corr row עבור {focus_pair}: {e}")

                        # ---- Tail-Dependence row אם זמינה ----
                        if has_tail:
                            try:
                                tail_row = tail_mx.loc[focus_pair].dropna()
                                tail_row = tail_row.drop(labels=[focus_pair], errors="ignore")
                                if not tail_row.empty:
                                    st.markdown("**Top tail-dependent pairs (Extreme Days)**")
                                    st.dataframe(
                                        tail_row.sort_values(ascending=False)
                                        .head(top_k)
                                        .to_frame("TailDep"),
                                        use_container_width=True,
                                        height=260,
                                    )
                                else:
                                    st.caption("Tail-Dependence מחושב, אך אין ערכים שימושיים לזוג הנבחר.")
                            except Exception as e:
                                st.caption(f"Tail-Dependence row עבור {focus_pair} נכשל: {e}")
                        else:
                            st.caption(
                                "Tail-Dependence Matrix לא זמינה או שלא כוללת את הזוג הנבחר. "
                                "כדי להפעיל אותה, הרץ את ה-expander של Tail-Dependence בחלק העליון."
                            )
                except Exception as e:
                    st.caption(f"Pair Focus Panel failed: {e}")

        # ================== חלק 5.10 — Correlation-Driven Portfolio Suggestions ==================
        if corr_mx is not None and not corr_mx.empty:
            with st.expander("🧺 Correlation-Driven Portfolio Suggestions", expanded=False):
                try:
                    row_mean = corr_mx.mean(axis=1)

                    n_low = st.slider(
                        "כמה זוגות לבחור ל-Low-Corr Basket?",
                        min_value=3,
                        max_value=min(30, len(row_mean)),
                        value=min(10, len(row_mean)),
                        step=1,
                        key="mx_low_corr_n",
                    )
                    n_high = st.slider(
                        "כמה זוגות לבחור ל-High-Corr Candidates?",
                        min_value=3,
                        max_value=min(30, len(row_mean)),
                        value=min(10, len(row_mean)),
                        step=1,
                        key="mx_high_corr_n",
                    )

                    df_rm = row_mean.to_frame("AvgCorr")
                    df_low = df_rm.sort_values("AvgCorr", ascending=True).head(n_low)
                    df_high = df_rm.sort_values("AvgCorr", ascending=False).head(n_high)

                    # אם יש df_clusters – נוסיף מידע על קלסטר
                    if df_clusters is not None and not df_clusters.empty:
                        df_low = df_low.merge(
                            df_clusters[["Pair", "Cluster"]],
                            left_index=True,
                            right_on="Pair",
                            how="left",
                        )
                        df_high = df_high.merge(
                            df_clusters[["Pair", "Cluster"]],
                            left_index=True,
                            right_on="Pair",
                            how="left",
                        )

                    c1, c2 = st.columns(2)
                    with c1:
                        st.markdown("**Low-Corr Basket (Diversification Candidates)**")
                        st.dataframe(
                            df_low.reset_index(drop=True),
                            use_container_width=True,
                            height=260,
                        )
                    with c2:
                        st.markdown("**High-Corr Pairs (Pairs Trading Candidates)**")
                        st.dataframe(
                            df_high.reset_index(drop=True),
                            use_container_width=True,
                            height=260,
                        )

                    st.caption(
                        "הסלים כאן הם הצעה ראשונית בלבד: Low-Corr לטובת פיזור, "
                        "High-Corr כקנדידטים למסחר זוגי. אפשר לשלב בהמשך גם ציוני איכות "
                        "מה-universe ופרופילי סיכון."
                    )
                except Exception as e:
                    st.caption(f"Portfolio suggestions failed: {e}")
        # ================== חלק 5.11 — Hierarchical Clustering + Dendrogram ==================
        if show_clusters and corr_mx is not None and not corr_mx.empty and not light_mode:
            with st.expander("🌳 Hierarchical Clustering & Dendrogram (אם ספריות זמינות)", expanded=False):
                try:
                    # נבנה מטריצת Distance אם עדיין לא קיימת
                    if dist_mx is None:
                        dist_mx = 1.0 - corr_mx

                    # ננסה להשתמש ב-plotly.figure_factory לדנדרוגרמה
                    try:
                        import plotly.figure_factory as ff  # type: ignore

                        fig_dendro = ff.create_dendrogram(
                            dist_mx.values,
                            orientation="left",
                            labels=list(corr_mx.index),
                            color_threshold=0.0,  # אפשר לכוונן בהמשך
                        )
                        fig_dendro.update_layout(
                            width=900,
                            height=max(400, 12 * len(corr_mx)),
                            title="Hierarchical Dendrogram (Distance=1-corr)",
                        )
                        st.plotly_chart(fig_dendro, use_container_width=True)
                    except Exception as e:
                        st.caption(
                            "לא הצלחנו ליצור דנדרוגרמה ב-Plotly. "
                            "בדוק ש-plotly.figure_factory זמין. שגיאה: "
                            f"{e}"
                        )

                    st.caption(
                        "Hierarchical Clustering מאפשר לראות את המבנה ההיררכי של הקשרים בין הזוגות, "
                        "ולחתוך את העץ ברמות שונות כדי לקבל קלסטרים טבעיים."
                    )
                except Exception as e:
                    st.caption(f"Hierarchical clustering section failed: {e}")

        # ================== חלק 5.12 — Tail-Dependence / Extreme Moves Hook ==================
        if corr_mx is not None and not corr_mx.empty and not light_mode:
            with st.expander("🔥 Tail-Dependence Matrix (Extreme Moves)", expanded=False):
                st.caption(
                    "Tail-Dependence בודק עד כמה נכסים/זוגות זזים ביחד דווקא בימים הקיצוניים "
                    "(למשל תנועות > X סטיות תקן), ולא בממוצע הכולל."
                )
                try:
                    tail_quantile = st.slider(
                        "Quantile לקצה (Tail) – לדוגמה 0.9 אומר 10% הימים הקיצוניים",
                        min_value=0.80,
                        max_value=0.99,
                        value=0.90,
                        step=0.01,
                        key="mx_tail_q",
                    )

                    tail_matrix = None
                    # Hook: אם יש פונקציה גלובלית compute_tail_dep_matrix – נשתמש בה
                    func_tail = globals().get("compute_tail_dep_matrix")
                    if callable(func_tail):
                        with st.spinner("מחשב Tail-Dependence Matrix..."):
                            # מצופה: compute_tail_dep_matrix(pairs, start, end, field, q)
                            tail_matrix = func_tail(
                                pairs_all,
                                start_date,
                                end_date,
                                field=str(ctrl_mx.get("field", "Close")),
                                q=tail_quantile,
                            )

                    if tail_matrix is not None and isinstance(tail_matrix, pd.DataFrame):
                        try:
                            import plotly.express as px  # type: ignore

                            fig_tail = px.imshow(
                                tail_matrix,
                                text_auto=False,
                                aspect="auto",
                                color_continuous_scale="Inferno",
                                title=f"Tail-Dependence Heatmap (q={tail_quantile:.2f})",
                            )
                            fig_tail.update_traces(
                                hovertemplate=(
                                    "Pair i=%{y}<br>Pair j=%{x}"
                                    "<br>Tail-dep=%{z:.3f}<extra></extra>"
                                )
                            )
                            st.plotly_chart(fig_tail, use_container_width=True)
                        except Exception:
                            st.dataframe(tail_matrix, use_container_width=True)

                        st.session_state["mx_tail_dep_matrix"] = tail_matrix.copy()

                    else:
                        st.info(
                            "כרגע לא מוגדרת פונקציה compute_tail_dep_matrix במערכת. "
                            "אפשר להוסיף אותה ב-core/matrix_helpers (להחזיר DataFrame של Tail-Dependence), "
                            "והטאב יזהה אותה אוטומטית."
                        )
                except Exception as e:
                    st.caption(f"Tail-dependence section failed: {e}")

        # ================== חלק 5.13 — Stress Testing Presets ==================
        if corr_mx is not None and not corr_mx.empty and not light_mode:
            with st.expander("⚡ Stress Testing Presets – השוואה למשברים היסטוריים", expanded=False):
                try:
                    # מילון תקופות משבר סטנדרטיות (אפשר לשנות/להרחיב)
                    stress_periods = {
                        "Global Financial Crisis (2008)": ("2007-07-01", "2009-06-30"),
                        "Euro Crisis (2011)": ("2010-06-01", "2012-01-31"),
                        "COVID Crash (2020)": ("2020-02-01", "2020-06-30"),
                        "Rates Shock 2022–2023": ("2022-01-01", "2023-12-31"),
                    }

                    stress_name = st.selectbox(
                        "בחר תקופת סטרס להשוואה",
                        list(stress_periods.keys()),
                        key="mx_stress_name",
                    )
                    s_start_str, s_end_str = stress_periods[stress_name]
                    s_start = pd.to_datetime(s_start_str)
                    s_end = pd.to_datetime(s_end_str)

                    st.caption(
                        f"תקופת סטרס נבחרת: {stress_name} ({s_start.date()} → {s_end.date()})"
                    )

                    with st.spinner("מחשב מטריצת קורלציה לתקופת הסטרס..."):
                        corr_stress = compute_return_corr_matrix(
                            pairs_all,
                            s_start,
                            s_end,
                            field=str(ctrl_mx.get("field", "Close")),
                            window=int(ctrl_mx.get("ret_win", 20) or 20),
                        )

                    if corr_stress is None or corr_stress.empty:
                        st.info(
                            "לא הצלחנו לחשב מטריצת קורלציה לתקופת הסטרס – ייתכן שאין מספיק היסטוריה "
                            "לזוגות ב-universe בטווח השנים הזה."
                        )
                    else:
                        # יישור אינדקסים
                        common_idx = corr_mx.index.intersection(corr_stress.index)
                        corr_now = corr_mx.loc[common_idx, common_idx]
                        corr_stress = corr_stress.loc[common_idx, common_idx]

                        if corr_now.empty or corr_stress.empty:
                            st.caption("אין חיתוך זוגות מספק בין התקופה הנוכחית לבין תקופת הסטרס.")
                        else:
                            # סטטיסטיקות בסיסיות
                            def _corr_stats(mx: pd.DataFrame) -> dict[str, float]:
                                m = mx.values
                                mask = ~np.eye(m.shape[0], dtype=bool)
                                vals = m[mask]
                                vals = vals[~np.isnan(vals)]
                                if vals.size == 0:
                                    return {
                                        "mean": np.nan,
                                        "std": np.nan,
                                        "high": np.nan,
                                        "neg": np.nan,
                                    }
                                return {
                                    "mean": float(vals.mean()),
                                    "std": float(vals.std()),
                                    "high": float((vals > 0.8).mean()),
                                    "neg": float((vals < -0.2).mean()),
                                }

                            stats_now = _corr_stats(corr_now)
                            stats_stress = _corr_stats(corr_stress)

                            c1, c2 = st.columns(2)
                            with c1:
                                st.markdown("**מצב נוכחי (Current Window)**")
                                st.json(
                                    {
                                        "MeanCorr": stats_now["mean"],
                                        "StdCorr": stats_now["std"],
                                        "%Corr>0.8": stats_now["high"],
                                        "%Corr<-0.2": stats_now["neg"],
                                    }
                                )
                            with c2:
                                st.markdown(f"**תקופת סטרס: {stress_name}**")
                                st.json(
                                    {
                                        "MeanCorr": stats_stress["mean"],
                                        "StdCorr": stats_stress["std"],
                                        "%Corr>0.8": stats_stress["high"],
                                        "%Corr<-0.2": stats_stress["neg"],
                                    }
                                )

                            # Δ בין המצבים
                            try:
                                delta_mx_stress = corr_now - corr_stress
                                import plotly.express as px  # type: ignore

                                fig_stress_delta = px.imshow(
                                    delta_mx_stress,
                                    text_auto=False,
                                    aspect="auto",
                                    color_continuous_scale="RdBu",
                                    title=f"ΔCorr (Current - {stress_name})",
                                )
                                st.plotly_chart(fig_stress_delta, use_container_width=True)
                            except Exception:
                                st.caption("לא הצלחנו להציג Heatmap של ΔCorr לסטרס – ראה לוגים.")
                except Exception as e:
                    st.caption(f"Stress-testing section failed: {e}")

        # ================== חלק 5.14 — Risk-Budget Overlay & Alerts ==================
        if corr_mx is not None and not corr_mx.empty:
            with st.expander("🛡 Risk-Budget Overlay & Matrix Alerts", expanded=False):
                try:
                    # ---- Risk-Budget Overlay ברמת קלסטרים (אם יש df_clusters) ----
                    risk_capital_dict = st.session_state.get("risk_capital", {}) or {}
                    total_capital = float(risk_capital_dict.get("total_capital", 0.0) or 0.0)

                    if df_clusters is not None and not df_clusters.empty:
                        # נניח בינתיים הקצאה שווה בין כל הזוגות כ-base
                        n_pairs = len(df_clusters)
                        if n_pairs > 0:
                            base_weight = 1.0 / n_pairs
                            df_rb = df_clusters.copy()
                            df_rb["BaseWeight"] = base_weight
                            if total_capital > 0:
                                df_rb["BaseExposure"] = df_rb["BaseWeight"] * total_capital
                            else:
                                df_rb["BaseExposure"] = np.nan

                            # סכימה לפי קלסטר
                            df_rb_cluster = (
                                df_rb.groupby("Cluster")[["BaseWeight", "BaseExposure"]]
                                .sum()
                                .reset_index()
                            )

                            st.markdown("**Risk Budget per Cluster (Equal-Weight Approximation)**")
                            st.dataframe(df_rb_cluster, use_container_width=True, height=220)

                            if total_capital > 0:
                                st.caption(
                                    "כרגע ההקצאה היא שווה בין כל הזוגות. בהמשך אפשר לחבר את זה בפועל "
                                    "לחשיפה אמיתית לפי פוזיציות ולייצר 'Used vs Max Risk' לכל קלסטר."
                                )
                            else:
                                st.caption(
                                    "total_capital לא מוגדר ב-session_state['risk_capital']. "
                                    "ניתן להוסיף לשם ערך (למשל מיליון ₪) כדי לראות חשיפות נומינליות."
                                )
                        else:
                            st.caption("אין קלסטרים לחישוב Risk-Budget.")
                    else:
                        st.caption(
                            "אין df_clusters זמין כרגע – Risk-Budget Overlay ברמת קלסטרים לא יחושב."
                        )

                    # ---- Alerts חכמים על בסיס מטריצת הקורלציה ----
                    st.markdown("**🔔 Matrix Alerts (HF-Style)**")
                    alerts: list[str] = []

                    # חישוב סטטיסטיקות ברמת מטריצה
                    m = corr_mx.values
                    mask = ~np.eye(m.shape[0], dtype=bool)
                    vals = m[mask]
                    vals = vals[~np.isnan(vals)]
                    if vals.size > 0:
                        mean_corr = float(vals.mean())
                        std_corr = float(vals.std())
                        high_corr_ratio = float((vals > 0.8).mean())
                        ultra_high_ratio = float((vals > 0.95).mean())
                        neg_ratio = float((vals < -0.2).mean())

                        # חוקים פשוטים לאזעקות
                        if mean_corr > 0.7 and high_corr_ratio > 0.6:
                            alerts.append(
                                "🔴 Market Highly Crowded: רוב הקורלציות גבוהות מאוד – סיכון ל-deleveraging קולקטיבי."
                            )
                        elif mean_corr > 0.5:
                            alerts.append(
                                "🟠 Market Crowded: קורלציה ממוצעת גבוהה – בדוק פיזור ורמות מינוף."
                            )

                        if neg_ratio < 0.05 and mean_corr > 0.6:
                            alerts.append(
                                "⚠️ כמות מעטה של קשרים שליליים – כמעט ואין גידור טבעי בתוך ה-universe."
                            )

                        if ultra_high_ratio > 0.2:
                            alerts.append(
                                "⚠️ אחוז משמעותי מהזוגות נמצא בקורלציה > 0.95 – מבנה שוק צפוף מאוד."
                            )

                        # שימוש ב-snapshot קודם לצורך דריפט
                        prev_corr = st.session_state.get("mx_prev_corr_for_alerts")
                        drift_score = None
                        if prev_corr is not None:
                            try:
                                prev_df = prev_corr
                                if isinstance(prev_df, pd.DataFrame) and prev_df.shape == corr_mx.shape:
                                    diff = corr_mx - prev_df
                                    dv = diff.values
                                    drift_score = float(np.linalg.norm(dv) / np.sqrt(dv.size))
                                    if drift_score > 0.2:
                                        alerts.append(
                                            f"🔴 High Structural Drift in Correlation Matrix (score={drift_score:.3f})."
                                        )
                                    elif drift_score > 0.1:
                                        alerts.append(
                                            f"🟠 Moderate Drift in Correlation Matrix (score={drift_score:.3f})."
                                        )
                            except Exception:
                                pass

                        # עדכון snapshot לאזעקות עתידיות
                        st.session_state["mx_prev_corr_for_alerts"] = corr_mx.copy()

                        # הצגת המדדים עצמם
                        a1, a2, a3, a4 = st.columns(4)
                        a1.metric("Mean corr", f"{mean_corr:.3f}")
                        a2.metric("Std(corr)", f"{std_corr:.3f}")
                        a3.metric("% corr>0.8", f"{100*high_corr_ratio:.1f}%")
                        a4.metric("% corr<-0.2", f"{100*neg_ratio:.1f}%")
                    else:
                        alerts.append("לא נמצאו ערכי קורלציה מספקים לחישוב Alerts.")

                    # שמירה ל-session_state לצורך שימוש בטאבים אחרים
                    st.session_state["matrix_alerts"] = alerts
                    if alerts:
                        for msg in alerts:
                            st.write(msg)
                    else:
                        st.caption("כרגע אין Alerts מיוחדים – מבנה המטריצה נראה תקין יחסית.")
                except Exception as e:
                    st.caption(f"Risk-Budget & Alerts section failed: {e}")

        # ================== חלק 5.15 — Export Matrix Insights to global_insights ==================
        if corr_mx is not None and not corr_mx.empty:
            try:
                import numpy as np

                # --- בסיס: סטטיסטיקות מטריצת הקורלציה ---
                m = corr_mx.values
                mask = ~np.eye(m.shape[0], dtype=bool)
                vals = m[mask]
                vals = vals[~np.isnan(vals)]

                if vals.size == 0:
                    # אין מה לסכם – לא נעדכן global_insights
                    pass
                else:
                    mean_corr = float(vals.mean())
                    std_corr = float(vals.std())
                    high_corr_ratio = float((vals > 0.8).mean())
                    neg_corr_ratio = float((vals < -0.2).mean())
                    ultra_high_ratio = float((vals > 0.95).mean())
                    n_pairs = int(corr_mx.shape[0])

                    # --- Drift & Alerts שנשמרו קודם ---
                    drift_score = st.session_state.get("mx_drift_score")
                    drift_label = st.session_state.get("mx_drift_label", "Unknown")
                    alerts = st.session_state.get("matrix_alerts", [])

                    # --- Tail-Dependence summary (אם מחושב) ---
                    tail_df = st.session_state.get("mx_tail_dep_matrix")
                    tail_mean = None
                    tail_std = None
                    if isinstance(tail_df, pd.DataFrame) and not tail_df.empty:
                        try:
                            t = tail_df.values
                            t_mask = ~np.eye(t.shape[0], dtype=bool)
                            t_vals = t[t_mask]
                            t_vals = t_vals[~np.isnan(t_vals)]
                            if t_vals.size > 0:
                                tail_mean = float(t_vals.mean())
                                tail_std = float(t_vals.std())
                        except Exception:
                            tail_mean = None
                            tail_std = None

                    # --- Cluster summary (אם df_clusters לא ריק) ---
                    n_clusters = None
                    max_cluster_size = None
                    if df_clusters is not None and not df_clusters.empty:
                        try:
                            n_clusters = int(df_clusters["Cluster"].nunique())
                            max_cluster_size = int(df_clusters["Cluster"].value_counts().max())
                        except Exception:
                            n_clusters = None
                            max_cluster_size = None

                    # --- Universe overlay (quality / score) אם קיים ---
                    uni_df = st.session_state.get("matrix_universe_df")
                    top_quality_pairs: list[str] = []
                    top_score_pairs: list[str] = []
                    if isinstance(uni_df, pd.DataFrame) and "Pair" in uni_df.columns:
                        df_uni = uni_df.copy()
                        possible_quality = [c for c in df_uni.columns if "qual" in c.lower()]
                        possible_score = [c for c in df_uni.columns if "score" in c.lower() or "rank" in c.lower()]

                        if possible_quality:
                            qcol = possible_quality[0]
                            top_quality_pairs = (
                                df_uni.dropna(subset=[qcol])
                                .sort_values(qcol, ascending=False)["Pair"]
                                .head(10)
                                .astype(str)
                                .tolist()
                            )
                        if possible_score:
                            scol = possible_score[0]
                            top_score_pairs = (
                                df_uni.dropna(subset=[scol])
                                .sort_values(scol, ascending=False)["Pair"]
                                .head(10)
                                .astype(str)
                                .tolist()
                            )

                    # --- סיווג "מצב שוק" לפי קורלציה ---
                    crowded_regime = "Neutral"
                    if mean_corr > 0.7 and high_corr_ratio > 0.5:
                        crowded_regime = "Highly Crowded"
                    elif mean_corr > 0.5:
                        crowded_regime = "Crowded"
                    elif mean_corr < 0.3 and high_corr_ratio < 0.2:
                        crowded_regime = "Fragmented"

                    # --- תיאור טקסטואלי קצר לשימוש בטאב Insights ---
                    summary_lines: list[str] = []

                    summary_lines.append(
                        f"mean corr ≈ {mean_corr:.3f}, std ≈ {std_corr:.3f}, "
                        f"{high_corr_ratio*100:.1f}% מהקשרים מעל 0.8, "
                        f"{neg_corr_ratio*100:.1f}% מתחת ל--0.2."
                    )

                    summary_lines.append(
                        f"מצב צפיפות שוק (crowded_regime): **{crowded_regime}**."
                    )

                    if drift_score is not None:
                        summary_lines.append(
                            f"drift score ≈ {drift_score:.3f} (label: {drift_label})."
                        )

                    if tail_mean is not None:
                        summary_lines.append(
                            f"Tail-Dep (off-diagonal) ממוצע ≈ {tail_mean:.3f}"
                            + (f", std ≈ {tail_std:.3f}." if tail_std is not None else ".")
                        )

                    if n_clusters is not None:
                        summary_lines.append(
                            f"מספר קלסטרים ≈ {n_clusters}, גודל קלסטר מקסימלי ≈ {max_cluster_size} זוגות."
                        )

                    if top_quality_pairs:
                        summary_lines.append(
                            "Top quality pairs (10): " + ", ".join(top_quality_pairs[:5]) + (" ..." if len(top_quality_pairs) > 5 else "")
                        )
                    if top_score_pairs:
                        summary_lines.append(
                            "Top score/rank pairs (10): " + ", ".join(top_score_pairs[:5]) + (" ..." if len(top_score_pairs) > 5 else "")
                        )

                    insight = {
                        # מטריקס core metrics
                        "mean_corr": mean_corr,
                        "std_corr": std_corr,
                        "high_corr_ratio": high_corr_ratio,
                        "neg_corr_ratio": neg_corr_ratio,
                        "ultra_high_ratio": ultra_high_ratio,
                        "n_pairs": n_pairs,
                        "crowded_regime": crowded_regime,
                        # drift
                        "drift_score": drift_score,
                        "drift_label": drift_label,
                        # tail dep
                        "tail_mean": tail_mean,
                        "tail_std": tail_std,
                        # clusters
                        "n_clusters": n_clusters,
                        "max_cluster_size": max_cluster_size,
                        # alerts & universe
                        "alerts": alerts,
                        "top_quality_pairs": top_quality_pairs,
                        "top_score_pairs": top_score_pairs,
                        # טקסט לתצוגה
                        "summary_lines": summary_lines,
                        # timestamp
                        "timestamp": str(pd.Timestamp.utcnow()),
                    }

                    gi = st.session_state.get("global_insights")
                    if not isinstance(gi, dict):
                        gi = {}
                    gi["matrix"] = insight
                    st.session_state["global_insights"] = gi

                    st.caption("🔗 Matrix Insights עודכנו ב-session_state['global_insights']['matrix'].")
            except Exception as e:
                st.caption(f"Global matrix insight export failed: {e}")

        # ================== חלק 6 — Anomaly Detection על מטריצת הקורלציות ==================
        if show_anom:
            st.markdown("#### 🚨 Anomaly Detection על מטריצת הקורלציות")

            if corr_mx is not None and not corr_mx.empty:
                method = st.selectbox(
                    "שיטת אנומליות",
                    ["Z-Score", "Mahalanobis", "IQR", "IsolationForest", "LOF", "Ensemble"],
                    key="mx_anom_method",
                )
                with st.spinner("מחשב ציוני אנומליה..."):
                    try:
                        corr_long = corr_mx.stack().rename("corr").to_frame()
                        corr_long = corr_long[
                            corr_long.index.get_level_values(0)
                            != corr_long.index.get_level_values(1)
                        ]

                        if method == "Z-Score":
                            scores = ad_rolling_zscore(corr_long["corr"], window=50)
                        elif method == "Mahalanobis":
                            scores = rolling_mahalanobis(corr_long["corr"], window=50)
                        elif method == "IQR":
                            scores = rolling_iqr_score(corr_long["corr"], window=50)
                        elif method == "IsolationForest":
                            scores = isolation_forest_score(corr_long["corr"].to_frame())
                        elif method == "LOF":
                            scores = lof_score(corr_long["corr"].to_frame())
                        else:
                            scores = ensemble_anomaly_signal(corr_long["corr"].to_frame())

                        corr_long["anomaly_score"] = scores.values
                        top_n = st.slider("כמה אנומליות להציג?", 10, 200, 50, key="mx_anom_topn")

                        top_rows = (
                            corr_long.dropna()
                            .sort_values("anomaly_score", ascending=False)
                            .head(top_n)
                        )

                        # סינון לפי זוגות מועדפים (אם נבחרו)
                        favorites = st.session_state.get("matrix_favorites", set())
                        if favorites:
                            show_only_fav = st.checkbox(
                                "הצג רק אנומליות הכוללות זוגות מועדפים",
                                value=False,
                                key="mx_anom_only_fav",
                            )
                            if show_only_fav:
                                mask_fav = (
                                    top_rows.index.get_level_values(0).isin(favorites)
                                    | top_rows.index.get_level_values(1).isin(favorites)
                                )
                                top_rows = top_rows[mask_fav]

                        st.dataframe(top_rows, use_container_width=True)
                    except Exception as e:
                        st.warning(f"Anomaly detection נכשל: {e}")
            else:
                st.info("אין מטריצת קורלציה מחושבת כרגע – לא ניתן להריץ אנומליות.")

        # ================== חלק 7 — Advanced Matrix Engine (matrix_tab.py) ==================
        if show_engine:
            st.markdown("### 🔬 Advanced Matrix Engine (matrix_tab.py)")
            with st.spinner("🔬 Running Matrix Research Engine…"):
                try:
                    _render_matrix_tab(
                        pairs=pairs_all,
                        config=config,
                        ctx=asdict(ctx_mx),
                        controls=ctrl_mx_full,
                    )
                except TypeError:
                    try:
                        _render_matrix_tab(
                            pairs=pairs_all,
                            config=config,
                            ctx=asdict(ctx_mx),
                        )
                    except Exception as e:
                        logger.exception(e)
                        _report_exception(e, "Tab Matrix")
                        st.error(f"❗ שגיאה בטאב Matrix (Advanced Engine): {e}")

        # ================== חלק 8 — Matrix Snapshots & Export ==================
        with st.expander("📦 Export — Matrix Snapshots", expanded=False):
            try:
                if corr_mx is not None and not corr_mx.empty:
                    st.download_button(
                        "💾 הורד מטריצת קורלציה (CSV)",
                        corr_mx.to_csv().encode("utf-8"),
                        file_name=f"matrix_corr_{ctx_mx.run_id}.csv",
                        mime="text/csv",
                        key=keygen("dl", "mx_corr"),
                    )
                if dist_mx is not None and not dist_mx.empty:
                    st.download_button(
                        "💾 הורד Distance Matrix (CSV)",
                        dist_mx.to_csv().encode("utf-8"),
                        file_name=f"matrix_dist_{ctx_mx.run_id}.csv",
                        mime="text/csv",
                        key=keygen("dl", "mx_dist"),
                    )
            except Exception:
                pass

