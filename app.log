                # Base + Advanced filters
                if "abs_z" in df_view.columns:
                    df_view = df_view[df_view["abs_z"].abs() >= min_abs_z]
                    df_view = df_view[df_view["abs_z"].abs() <= max_spread_zdist]

                if "quality_score" in df_view.columns:
                    df_view = df_view[df_view["quality_score"].fillna(-1.0) >= min_quality]

                if "corr" in df_view.columns:
                    df_view = df_view[df_view["corr"].fillna(-1.0) >= min_corr]

                if "half_life" in df_view.columns:
                    hl_series = pd.to_numeric(df_view["half_life"], errors="coerce")
