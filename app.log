_orig_st_dataframe = st.dataframe  # נשמור את המקור

def _dataframe_safe(data: Any, *args, **kwargs):
    """
    עטיפה ל-st.dataframe:
    1. מתרגמת use_container_width → width ('stretch' / 'content').
    2. הופכת עמודות בעייתיות ('Value', 'default') לטיפוס string כדי ש-PyArrow לא יקרוס.
    3. אם עדיין יש בעיה – הופכת את כל הטבלה ל-string.
    """
    # טיפול ב-use_container_width → width
    if "use_container_width" in kwargs:
        use_cw = kwargs.pop("use_container_width")
        # אם לא הגדירו width מפורשות – נתרגם לפי ההמלצה של Streamlit
        if "width" not in kwargs:
            kwargs["width"] = "stretch" if use_cw else "content"

    # אם זה לא DataFrame – נעביר למקור כמו שהוא
    if not isinstance(data, pd.DataFrame):
        return _orig_st_dataframe(data, *args, **kwargs)

    df2 = data.copy()

    # עמודות בעייתיות לפי הלוגים שלך
    for col in ("Value", "default"):
        if col in df2.columns:
            df2[col] = df2[col].astype("string")

    try:
        return _orig_st_dataframe(df2, *args, **kwargs)
    except Exception:
        # fallback אחרון – הכל string
        return _orig_st_dataframe(df2.astype("string"), *args, **kwargs)

# מחליפים את הפונקציה הגלובלית של Streamlit
st.dataframe = _dataframe_safe
