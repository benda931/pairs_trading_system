# חלק 7 מסתיים כאן.
# בחלק 8 נתחיל לחווט בפועל את הטאבים:
# - ניצור st.tabs([...]) לכל הטאבים (Dashboard / Scan / Pair / Backtest / Matrix / Portfolio / Insights / Opt / Config / Macro).
# - נבנה את Dashboard Home (🏠) על בסיס compute_dashboard_signals, latest_bar_timestamp, VIX וכו'.
# - נשתמש ב-controls_* ו-wrappers שהגדרנו כאן כדי שכל טאב יעבוד בצורה אחידה ומקצועית.
# ===================== Dashboard Home — Top-Level Control Center (HF-Grade) =====================

def render_dashboard_home() -> None:
    """
    טאב הבית המרכזי (🏠):

    • Market Snapshot: VIX, SPY/QQQ returns, Freshness דאטה.
    • Risk Snapshot: הון, מינוף, חשיפה/עסקה, גודל universe.
    • Top Opportunities: אותות לזוגות לפי |Z|, β, Corr, HL, quality, edge.
    • Quick Actions: מעבר מהיר לניתוח זוג / Backtest / סימון זוגות חשובים.
    • Saved Views: שמירת/טעינת/ייצוא מצב הדשבורד (טווח, פרופיל, Z, TopN, סף Alerts).
    • Daily Notes & Alerts Feed: הערות יומיות + feed ל-Alerts (בהמשך גם מ-Tabs אחרים).
    """

    st.header("🏠 לוח בקרה – מצב שוק, אותות, סיכון וסטטוס מערכת")

    pairs = get_pairs(force_refresh=False)
    if not pairs:
        st.info("אין universe טעון כרגע. ודא שהקונפיג/קבצי pair מוגדרים ו-load_pairs עובד.")
        return

    # ----- טווח זמן ופרופיל אותות -----
    d1, d2 = date_range_picker("Dashboard — טווח תאריכים", 180, "t0")

    c_top = st.container()
    with c_top:
        colA, colB, colC, colD = st.columns(4)
        with colA:
            profile = st.selectbox(
                "Signal Profile",
                ["mean_reversion", "short_term", "vol_arb", "slow_mean_reversion"],
                index=0,
                key=keygen("t0", "profile"),
                help=(
                    "פרופיל סריקה: mean_reversion (קלאסי), short_term (טווח קצר), "
                    "vol_arb (פוקוס על תנודתיות), slow_mean_reversion (איטי)."
                ),
            )
        with colB:
            z_window = int(
                _num_slider(
                    "חלון Z-Score (override)",
                    30,
                    5,
                    180,
                    1,
                    key=keygen("t0", "zwin"),
                    help="אם מופעל override, הוא גובר על ההגדרה בפרופיל.",
                )
            )
        with colC:
            top_n = int(
                _num_slider(
                    "כמה אותות להציג (Top-|Z|)",
                    15,
                    5,
                    50,
                    1,
                    key=keygen("t0", "topn"),
                )
            )
        with colD:
            z_alert = _num_slider(
                "סף התראה |Z|",
                2.5,
                1.0,
                6.0,
                0.1,
                key=keygen("t0", "z_thr"),
            )

        use_profile_defaults = st.checkbox(
            "להשתמש רק בערכי הפרופיל (להתעלם מ-override)",
            value=True,
            key=keygen("t0", "use_profile"),
        )

    # ----- Risk Snapshot -----
    st.subheader("💰 Risk Snapshot – מבט על הקרן")
    risk_cfg = st.session_state.get("risk_capital", {})
    capital_val = float(risk_cfg.get("capital", config.get("capital", 100_000.0)))
    max_expo = float(risk_cfg.get("max_exposure_per_trade", config.get("max_exposure_per_trade", 0.05)))
    max_lev = float(risk_cfg.get("max_leverage", config.get("max_leverage", 2.0)))
    uni_desc = st.session_state.get("_universe_description", {})
    uni_size = uni_desc.get("size", len(pairs))

    rs1, rs2, rs3, rs4 = st.columns(4)
    rs1.metric("Capital (USD)", f"{capital_val:,.0f}")
    rs2.metric("Max Exposure / Trade", f"{max_expo*100:.1f}%")
    rs3.metric("Max Leverage", f"{max_lev:.1f}")
    rs4.metric("Universe Size", uni_size)

    # ----- Market Snapshot (VIX, SPY/QQQ, Freshness + Z-dist) -----
    st.subheader("📡 Market Snapshot")

    ms1, ms2, ms3, ms4 = st.columns(4)

    # VIX & Regime
    vix_val = _get_vix_close()
    if vix_val is not None:
        regime_name, regime_desc = _classify_vol_regime(vix_val)
        ms1.metric("VIX", f"{vix_val:.2f}", help=regime_name)
        ms1.caption(regime_desc)
    else:
        ms1.metric("VIX", "N/A")
        ms1.caption("לא ניתן למשוך VIX כרגע.")

    # SPY / QQQ returns (20d)
    try:
        df_spy = _load_pair_data("SPY", d1, d2)
        df_qqq = _load_pair_data("QQQ", d1, d2)

        def _last_ret(df: pd.DataFrame, days: int = 20) -> Optional[float]:
            if df is None or df.empty:
                return None
            s = _pick_price_series(df)
            if len(s) < days + 1:
                return None
            return float(s.iloc[-1] / s.iloc[-days - 1] - 1.0)

        ret_spy = _last_ret(df_spy, 20)
        ret_qqq = _last_ret(df_qqq, 20)
        ms2.metric("SPY 20d", f"{ret_spy*100:.1f}%" if ret_spy is not None else "N/A")
        ms3.metric("QQQ 20d", f"{ret_qqq*100:.1f}%" if ret_qqq is not None else "N/A")
    except Exception:
        ms2.metric("SPY 20d", "N/A")
        ms3.metric("QQQ 20d", "N/A")

    # Freshness (Last Bar SPY)
    ts_last = latest_bar_timestamp("SPY")
    ms4.metric("Last Bar (SPY)", ts_last or "N/A")

    # ----- Universe & Providers Snapshot -----
    with st.expander("🧬 Universe & Providers Snapshot", expanded=False):
        st.subheader("Universe Summary")
        st.json(make_json_safe(uni_desc))

        st.subheader("Data Providers Status")
        prov_df = get_providers_status()
        if prov_df.empty:
            st.caption("אין מידע על ספקי דאטה כרגע.")
        else:
            st.dataframe(prov_df, width="stretch", height=220)

    # ----- Top Opportunities (Signals) + Z-Distribution -----
    st.subheader("🔥 Top Opportunities — לפי |Z|, איכות ו-Edge")

    with st.spinner("מחשב אותות לזוגות…"):
        if use_profile_defaults:
            df_sig = compute_universe_signals_profile(
                profile,
                pairs,
                d1,
                d2,
                top_n=top_n,
            )
            used_z_window = get_signal_profile_params(profile).get("z_window", z_window)
        else:
            df_sig = compute_dashboard_signals(
                pairs,
                d1,
                d2,
                z_window=z_window,
                top_n=top_n,
                min_points=40,
            )
            used_z_window = z_window

    if df_sig is None or df_sig.empty:
        st.info("אין אותות להצגה לטווח/פרופיל הנוכחי.")
    else:
        try:
            max_abs_z = float(df_sig["abs_z"].max())
            avg_corr = float(df_sig["corr"].mean())
            st.caption(
                f"נמצאו {len(df_sig)} אותות. |Z| מקסימלי: {max_abs_z:.2f}, "
                f"קורלציה ממוצעת: {avg_corr:.3f} (חלון Z={used_z_window})."
            )
        except Exception:
            st.caption(f"נמצאו {len(df_sig)} אותות (חלון Z={used_z_window}).")

        # זווית נוספת: התפלגות Z + Scatter Corr vs |Z|
        try:
            import plotly.express as px  # type: ignore
            with st.expander("📈 Z-Distribution & Corr vs |Z|", expanded=False):
                if "z" in df_sig.columns:
                    fig_hist = px.histogram(
                        df_sig,
                        x="z",
                        nbins=40,
                        title="Z-Score Distribution (Top signals)",
                    )
                    st.plotly_chart(fig_hist, width="stretch")
                if {"abs_z", "corr"}.issubset(df_sig.columns):
                    fig_scatter = px.scatter(
                        df_sig,
                        x="abs_z",
                        y="corr",
                        hover_data=["pair"],
                        title="Corr vs |Z| (Top signals)",
                    )
                    st.plotly_chart(fig_scatter, width="stretch")
        except Exception:
            pass

        # טבלה מעוצבת
        def _fmt_row(row: Dict[str, Any]) -> Dict[str, Any]:
            return {
                "Pair": row.get("pair"),
                "sym_x": row.get("sym_x"),
                "sym_y": row.get("sym_y"),
                "Z": round(row.get("z", np.nan), 2) if row.get("z") is not None else None,
                "|Z|": round(row.get("abs_z", np.nan), 2) if row.get("abs_z") is not None else None,
                "β": round(row.get("beta", np.nan), 3) if row.get("beta") is not None else None,
                "Corr": round(row.get("corr", np.nan), 3) if row.get("corr") is not None else None,
                "HL": None
                if row.get("half_life") is None or (isinstance(row.get("half_life"), float) and np.isnan(row.get("half_life")))
                else int(row.get("half_life")),
                "Points": int(row.get("points") or 0),
                "Quality": None
                if row.get("quality_score") is None or (
                    isinstance(row.get("quality_score"), float)
                    and np.isnan(row.get("quality_score"))
                )
                else round(float(row.get("quality_score")), 3),
                "Edge": None
                if row.get("edge") is None or (
                    isinstance(row.get("edge"), float)
                    and np.isnan(row.get("edge"))
                )
                else round(float(row.get("edge")), 3),
            }

        rows_fmt = [_fmt_row(r) for r in df_sig.to_dict("records")]
        show_df = pd.DataFrame(rows_fmt)

        st.dataframe(show_df, width="stretch", height=380)
        st.download_button(
            "💾 הורד אותות (CSV)",
            show_df.to_csv(index=False).encode("utf-8"),
            file_name=f"dashboard_signals_{st.session_state.get('run_id','')}.csv",
            mime="text/csv",
            key=keygen("dl", "dash_signals"),
        )

        # אותות מעל סף Alert
        breached = show_df[show_df["|Z|"] >= float(z_alert)]
        if not breached.empty:
            st.warning(
                f"🚨 יש {len(breached)} זוגות עם |Z| ≥ {z_alert:.2f}. "
                f"בדוק את הזוגות האלה בדחיפות."
            )

            # Slack alerts לזוגות חריגים – פעם אחת לסשן לכל זוג/ערך
            if SLACK_ERRORS_WEBHOOK:
                flag_key = keygen("alerts", "signals_sent")
                sent = st.session_state.get(flag_key, set())
                if isinstance(sent, list):
                    sent = set(sent)
                for pair_name, zval in breached[["Pair", "|Z|"]].itertuples(index=False):
                    tok = f"{pair_name}:{zval}"
                    if tok in sent:
                        continue
                    try:
                        import urllib.request
                        body = json.dumps(
                            {
                                "text": (
                                    f"🚨 Z-alert {zval:.2f} on {pair_name} | "
                                    f"profile={profile}, z_window={used_z_window}, "
                                    f"run_id={st.session_state.get('run_id','')}"
                                )
                            },
                            ensure_ascii=False,
                        ).encode("utf-8")
                        urllib.request.urlopen(
                            urllib.request.Request(
                                SLACK_ERRORS_WEBHOOK,
                                data=body,
                                headers={"Content-Type": "application/json"},
                                method="POST",
                            ),
                            timeout=5,
                        )
                        sent.add(tok)
                    except Exception:
                        pass
                st.session_state[flag_key] = list(sent)

        # Quick Actions – בחירת זוג
