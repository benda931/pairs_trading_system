def render_opt_param_ranges_editor(prefix: str = "opt_ranges") -> Dict[str, Dict[str, float]]:
    """
    עורך טווחי חיפוש (search space) לפרמטרים עיקריים.

    הפלט:
        {
          "entry_z": {"min": 1.0, "max": 3.0},
          "exit_z": {"min": 0.0, "max": 1.5},
          ...
        }

    את ה-dict הזה נעביר ל-optimization_tab דרך controls → ctx["controls"]["param_ranges"].
    """
    ranges: Dict[str, Dict[str, float]] = {}

    with st.expander("🔍 טווחי חיפוש לפרמטרים (Optimization Search Space)", expanded=False):
        st.caption("שולט בטווחים ש-Optuna יחפש בהם עבור פרמטרים נפוצים.")

        # הגדרת פרמטרים עיקריים + טווחי דיפולט
        param_defs: Dict[str, Tuple[float, float, float]] = {
            # name: (default_min, default_max, step)
            "entry_z": (1.0, 4.0, 0.1),
            "exit_z": (0.0, 2.0, 0.1),
            "take_z": (2.0, 8.0, 0.1),
            "ma_win": (5.0, 120.0, 1.0),
            "hl_min": (1.0, 60.0, 1.0),
            "slippage_bps": (0.0, 20.0, 0.5),
            "fee_bps": (0.0, 10.0, 0.5),
            "max_positions": (1.0, 50.0, 1.0),
            "rebalance_days": (1.0, 60.0, 1.0),
            "wf_folds": (1.0, 10.0, 1.0),
            "warmup_days": (0.0, 365.0, 5.0),
        }

        for name, (dmin, dmax, step) in param_defs.items():
            c1, c2 = st.columns(2)
            with c1:
                vmin = _num_input(
                    f"{name} – מינימום",
                    value=dmin,
                    min_v=None,
                    max_v=None,
                    step=step,
                    key=keygen(prefix, name, "min"),
                )
            with c2:
                vmax = _num_input(
                    f"{name} – מקסימום",
                    value=dmax,
                    min_v=None,
                    max_v=None,
                    step=step,
                    key=keygen(prefix, name, "max"),
                )
            # נוודא min<=max
            if vmax < vmin:
                vmax = vmin
            ranges[name] = {"min": float(vmin), "max": float(vmax)}

        st.caption(
            "הטווחים האלו נשמרים ב-controls['param_ranges'] וניתן להשתמש בהם ב-optimization_tab "
            "כדי להגדיר את search space של Optuna."
        )

    return ranges


