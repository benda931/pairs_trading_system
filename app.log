def get_feature_flags() -> Dict[str, Any]:
    """
    Helper קטן להחזרת feature_flags בצורה אחידה.

    • שומר תמיד dict.
    • מאפשר לטאבים אחרים (Backtest/Opt/Insights) לגשת לדגלים.
