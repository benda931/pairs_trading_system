# ===================== Smart Scan – Helpers =====================

def _adjust_scan_weights_with_opt_context(
    scan_weights: Dict[str, float],
) -> Dict[str, float]:
    """
    התאמת משקלי סריקה להקשר הטאב Opt:
    - primary_objective / secondary_objective / scenario_profile / scenario_tail_weight
      מתוך st.session_state["opt_run_cfg"] (אם קיים).
    - אם אין opt_run_cfg – מחזיר את scan_weights כמו שהם.
    """
    # עותק שלא מלכלך את המקור
    w: Dict[str, float] = {str(k): float(v) for k, v in (scan_weights or {}).items()}

    # נוודא שכל המפתחות קיימים
    for k in ("corr", "half_life", "z", "quality", "macro_fit", "vol"):
        w.setdefault(k, 0.0)

    cfg = st.session_state.get("opt_run_cfg", {}) or {}
    prim_raw = str(cfg.get("primary_objective", "") or "").upper()
    scen_raw = str(cfg.get("scenario_profile", "Neutral") or "").lower()
    tail_w = float(cfg.get("scenario_tail_weight", 0.0) or 0.0)
    tail_w = max(0.0, min(tail_w, 1.0))

    # ---- Primary objective → התאמת דגש ----
    # Return/Profit → חיזוק |Z| ו-Quality
    if any(x in prim_raw for x in ("RETURN", "PROFIT")):
        w["z"] *= 1.3
        w["quality"] *= 1.2

    # TailRisk/Drawdown → חיזוק Vol/Macro, הורדת Z
    elif any(x in prim_raw for x in ("TAIL", "DRAW")):
        w["vol"] = w.get("vol", 0.0) * 1.4 + 0.05
        w["macro_fit"] *= 1.2
        w["z"] *= 0.8

    # Sharpe/Sortino/Calmar → חיזוק Corr + Half-life
    elif any(x in prim_raw for x in ("SHARPE", "SORTINO", "CALMAR")):
        w["corr"] *= 1.3
        w["half_life"] *= 1.1

    # ---- Scenario profile + tail_weight ----
    if tail_w > 0.0:
        if scen_raw in ("risk-off", "crisis"):
            # יותר דגש על Vol / Macro, פחות על Z
            w["vol"] = w.get("vol", 0.0) * (1.0 + tail_w)
            w["macro_fit"] = w.get("macro_fit", 0.0) * (1.0 + 0.5 * tail_w)
            w["z"] *= (1.0 - 0.3 * tail_w)
        elif scen_raw == "risk-on":
            # יותר דגש על Z / Quality, פחות על Vol
            w["z"] *= (1.0 + 0.5 * tail_w)
            w["quality"] *= (1.0 + 0.3 * tail_w)
            w["vol"] *= (1.0 - 0.5 * tail_w)

    # נורמליזציה כך שסכום המשקולות החיוביות = 1 (אם יש)
    pos_sum = sum(max(v, 0.0) for v in w.values())
    if pos_sum > 0:
        w = {k: max(v, 0.0) / pos_sum for k, v in w.items()}

    return w


def _execution_intensity_label(val: Any) -> str:
    """
    מתייג execution intensity לפי signals_per_year (אם קיים):
    - < 5  → 'low'
    - < 25 → 'medium'
    - אחרת → 'high'
    """
    try:
        x = float(val)
    except Exception:
        return "unknown"

    if x < 5:
        return "low"
    if x < 25:
        return "medium"
    return "high"


def _signal_anomaly_flag(row: pd.Series) -> str:
    """
    דגל אנומליה פשוט לאות סריקה:
    - extreme_z: |Z| > 6
    - weird_half_life: HL מאוד קצר (<0.5) או מאוד ארוך (>200)
    - low_sample: נקודות מועטות מאוד
    - contradiction: Corr שלילי אבל Quality גבוה מאוד

    אם אין כלום → 'none'
    אם יש כמה → 'multi'
    """
    try:
        z = float(row.get("abs_z", np.nan))
    except Exception:
        z = np.nan
    try:
        hl = float(row.get("half_life", np.nan))
    except Exception:
        hl = np.nan
    try:
        corr = float(row.get("corr", np.nan))
    except Exception:
        corr = np.nan
    try:
        q = float(row.get("quality_score", np.nan))
    except Exception:
        q = np.nan
    try:
        pts = float(row.get("points", np.nan))
    except Exception:
        pts = np.nan

    flags: list[str] = []

    if not np.isnan(z) and abs(z) > 6.0:
        flags.append("extreme_z")
    if not np.isnan(hl) and (hl < 0.5 or hl > 200.0):
        flags.append("weird_half_life")
    if not np.isnan(pts) and pts > 0 and pts < 30:
        flags.append("low_sample")
    if not np.isnan(corr) and corr < 0 and not np.isnan(q) and q > 70:
        flags.append("contradiction")

    if not flags:
        return "none"
    if len(flags) == 1:
        return flags[0]
    return "multi"

def keygen(namespace: str, *parts: object) -> str:
    """
    מחולל מפתחות ייחודיים ל-Streamlit Widgets לפי namespace.

    Usage:
        key = keygen("theme", "mode")
        key = keygen("ff", "shap")
    """
    ns = namespace.strip(":")
    return ":".join([ns, *(str(p) for p in parts)])


def inject_css(accent: str, dark_mode: bool, high_contrast: bool = False) -> None:
    """
    מזריק CSS בסיסי לאפליקציה כדי לתת Theme אחיד:

    • Dark/Light
    • Accent color לכפתורים
    • High-contrast mode (מגדיל קונטרסט טקסט ורקע)
    """
    text = "white" if dark_mode else "#222"
    bg_primary = "#0E1117" if dark_mode else "#fafafa"
    bg_secondary = "#111827" if dark_mode else "#ffffff"
    border_color = "#ffffff" if high_contrast else "#cccccc"

    css = f"""
    <style>
        :root {{
            --accent: {accent};
            --bg-primary: {bg_primary};
            --bg-secondary: {bg_secondary};
            --text-color: {text};
            --border-color: {border_color};
        }}
        .stApp {{
            background: var(--bg-primary);
            color: var(--text-color);
        }}
        .stButton>button {{
            background: var(--accent);
            color: white;
            border: none;
            padding: 0.5rem 1rem;
            border-radius: 6px;
            transition: 0.2s;
        }}
        .stButton>button:hover {{
            filter: brightness(1.05);
        }}
        .stMetric label {{
            color: var(--text-color);
        }}
        .block-container {{
            padding-top: 1.2rem;
            padding-bottom: 3rem;
        }}
        /* Compact mode לטבלאות/כרטיסים (נשלט ב-session) */
        .compact .stDataFrame, .compact .stTable {{
            font-size: 0.85rem;
        }}
    </style>
    """
    st.markdown(css, unsafe_allow_html=True)


