    }


def _merge_config_with_defaults(raw: Dict[str, Any]) -> Dict[str, Any]:
    """
    ממזג בין קונפיג נטען לבין קונפיג דיפולטי.

    • כל מפתח שאינו קיים בקובץ – יקבל ערך דיפולטי.
    • ערכים קיימים בקובץ – מנצחים.
    """
    base = _default_config_fallback()
    base.update(raw or {})
    return base


def _validate_config(cfg: Dict[str, Any]) -> None:
    """
    ולידציה בסיסית על ה-config – כותבת אזהרות ללוג (לא מפילה את האפליקציה).

    דוגמאות:
    - capital <= 0
    - max_exposure_per_trade לא בין 0 ל-1
    - max_leverage < 1
    """
    try:
        cap = float(cfg.get("capital", 0.0))
        if cap <= 0:
            logger.warning("Config validation: capital <= 0 (value=%s)", cap)

        mexp = float(cfg.get("max_exposure_per_trade", 0.0))
        if not (0.0 < mexp <= 1.0):
            logger.warning(
                "Config validation: max_exposure_per_trade out of (0,1] (value=%s)",
                mexp,
            )

        mlev = float(cfg.get("max_leverage", 0.0))
        if mlev < 1.0:
            logger.warning(
                "Config validation: max_leverage < 1 (value=%s)", mlev
            )

        # אפשר להרחיב כאן לדגלים / שדות חובה נוספים
    except Exception as e:
        logger.warning("Config validation failed: %s", e)


# טעינת הקונפיג הגלובלי (חד-פעמי ברמת מודול)
_raw_config: Dict[str, Any] = _load_raw_config(APP_PROFILE)
config: Dict[str, Any] = _merge_config_with_defaults(_raw_config)
_validate_config(config)
config_safe: Dict[str, Any] = make_json_safe(config)


def get_config_value(key: str, default: Any = None) -> Any:
    """
    Helper נוח להחזרת ערך קונפיג עם דיפולט, גם מתוך Streamlit callbacks.

    זה מסייע במיוחד בקוד עתידי שלא רוצה לגשת ל-config הגלובלי ישירות.
    """
    try:
        return config.get(key, default)
    except Exception:
        return default


