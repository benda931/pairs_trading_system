# ===================== Market Data Router (IBKR + Yahoo + Future Sources) =====================

def _ensure_market_data_router(force_rebuild: bool = False) -> None:
    """
    יוצר או מחליף Market Data Router לסשן ושומר ב-st.session_state["md_router"].

    • מנסה להתחבר ל-IBKR דרך get_ib_instance().
    • בונה Router דיפולטי (IBKR + Yahoo) דרך build_default_router().
    • מכבד סדר עדיפויות מה-config (market_data_prefer).
    • לא מפיל את ה-UI במקרה של כישלון – במקרה כזה נשארים עם ספקים זמינים בלבד.
    """
    if "md_router" in st.session_state and not force_rebuild:
        return

    # חיבור ל-IBKR (אופציונלי)
    try:
        ib = get_ib_instance()
    except Exception as exc:
        ib = None
        st.warning(f"❗ חיבור ל-IBKR נכשל: {exc}")

    prefer = config.get("market_data_prefer", ["ibkr", "yahoo"])
    yahoo_auto_adjust = bool(config.get("md_yahoo_auto_adjust", False))

    try:
        router = build_default_router(
            ib=ib,
            use_yahoo=True,
            yahoo_auto_adjust=yahoo_auto_adjust,
            prefer=prefer,
            allow_fallbacks=True,
            strict=False,
        )
        st.session_state["md_router"] = router
    except Exception as e:
        # במקרה קיצון שבו גם build_default_router נכשל – נרשום לוג ונשאיר None
        logger.warning("Failed to build Market Data Router: %s", e)
        st.session_state["md_router"] = None


@st.cache_data(ttl=300, show_spinner=False)
def get_providers_status() -> pd.DataFrame:
    """
    מחזיר DataFrame עם סטטוס ספקי הדאטה לפי describe_available_providers().

    משמש:
    - טאב Dashboard Home (📡 Providers Status)
    - System Health Panel
    """
    try:
        df = describe_available_providers()
        return df if isinstance(df, pd.DataFrame) else pd.DataFrame()
    except Exception as e:
        logger.warning("describe_available_providers failed: %s", e)
        return pd.DataFrame()


def _init_data_in_session() -> None:
