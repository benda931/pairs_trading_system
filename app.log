# ===================== Determinism & Seed / run_id =====================

def set_global_seed(seed: int) -> int:
    """
    קובע seed גלובלי (random + numpy) ושומר אותו ב-session_state.

    Notes
    -----
    - מיועד לשימוש מה-sidebar.
    - seed משמש גם ליצירת run_id (דרך ensure_run_id).
    """
    try:
        import random
        random.seed(int(seed))
    except Exception:
        pass
    try:
        np.random.seed(int(seed))
    except Exception:
        pass
    st.session_state["global_seed"] = int(seed)
    return int(seed)


def _generate_run_id(seed: int) -> str:
    ts = datetime.now().strftime("%Y%m%d-%H%M%S")
    return f"run-{seed}-{ts}"


def ensure_run_id(seed: int) -> str:
    """
    מוודא שקיים run_id יחיד לסשן הנוכחי.

    • אם אין run_id ב-session_state ⇒ יוצר חדש.
    • אם יש ⇒ מחזיר אותו.

    run_id ישמש:
    - לסימן ייחודי לדוחות Backtest/Opt/Scan.
    - לשמות קבצים ב-Snapshots/Export.
    """
    rid = st.session_state.get("run_id")
    if not rid:
        rid = _generate_run_id(int(seed))
        st.session_state["run_id"] = rid
    return str(rid)


# ===================== AppContext =====================

@dataclass
class AppContext:
    """
    Unified context shared across all tabs.

    זהו מקור האמת (Single Source of Truth) לכל הריצות:
    - תאריכים (start/end)
    - הון, חשיפות, מינוף
    - רשימת זוגות (pairs universe)
    - config מלא
    - controls (פרמטרים ספציפיים לכל טאב)
    - seed & run_id
    - section (scan/backtest/optimize/portfolio/...)
    - profile (APP_PROFILE)
    """
    start_date: date
    end_date: date
    capital: float
    max_exposure_per_trade: float
    max_leverage: float
    pairs: List[Any]
    config: Dict[str, Any]
    controls: Dict[str, Any]
    seed: int
    run_id: str
    # Optional metadata
    section: str = "dashboard"
    profile: str = APP_PROFILE
    md_router: Optional[MarketDataRouter] = None

def build_ctx(
    start_date: date,
    end_date: date,
    controls: Dict[str, Any],
    *,
    section: str = "dashboard",
) -> AppContext:
    """
    בונה אובייקט AppContext אחד לכל ריצה/טאב.

    • מוסיף feature_flags ל-controls.
    • משלב פרמטרי risk מה-session עם fallback ל-config.
    • משתמש ב-seed הגלובלי (global_seed) וב-run_id מה-session.
    • שומר את ctx גם ב-session_state["ctx"] לצורך Export Center / Macro.

    Parameters
    ----------
    start_date, end_date : date
        טווח הריצה.
    controls : dict
        פרמטרים ייחודיים לטאב (למשל: entry_z, max_positions, n_trials).
    section : str
        שם לוגי של החלק ("scan", "backtest", "optimize", "portfolio"...).

    Returns
    -------
    AppContext
    """
    flags = get_feature_flags()
    seed_val = int(st.session_state.get("global_seed", config.get("seed", _DEF_SEED)))
    controls_full = {**controls, "seed": seed_val, **flags}

    # פרמטרי סיכון/הון – אפשר לעקוף דרך controls; אחרת config.json
    risk_cfg = st.session_state.get("risk_capital", {})
    cap = float(controls.get("capital", risk_cfg.get("capital", config.get("capital", 100_000.0))))
    mexp = float(
        controls.get(
            "max_exposure_per_trade",
            risk_cfg.get("max_exposure_per_trade", config.get("max_exposure_per_trade", 0.05)),
        )
    )
    mlev = float(
        controls.get(
            "max_leverage",
            risk_cfg.get("max_leverage", config.get("max_leverage", 2.0)),
        )
    )

    ctx = AppContext(
        start_date=start_date,
        end_date=end_date,
        capital=cap,
        max_exposure_per_trade=mexp,
        max_leverage=mlev,
        pairs=get_pairs(force_refresh=False),
        config=config,
        controls=controls_full,
        seed=seed_val,
        run_id=str(st.session_state.get("run_id", "")),
        section=section,
        profile=APP_PROFILE,
        md_router=st.session_state.get("md_router"), 
    )

    st.session_state["ctx"] = asdict(ctx)
    return ctx


def ctx_to_markdown(ctx: AppContext, kpis: Optional[Dict[str, Any]] = None) -> str:
    """
    בונה דוח Markdown קומפקטי מ-AppContext + KPIs אופציונליים.

    שימושי ל:
    - הורדת דוחות מהירים בטאבים (Backtest / Overview / Optimization / Portfolio).
    - ייצוא לדוחות ועדת סיכונים / ניהול קרן.
    """
    lines: List[str] = [
        f"# {ctx.section.title()} Report",
        f"**Run ID:** {ctx.seed}-{ctx.run_id}",
        f"**Timestamp:** {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}",
        "",
        "## Context",
        f"- Dates: {ctx.start_date} → {ctx.end_date}",
        f"- Capital: {ctx.capital:,.0f}",
        f"- Max Exposure/Trade: {ctx.max_exposure_per_trade}",
        f"- Max Leverage: {ctx.max_leverage}",
        f"- Pairs Count: {len(ctx.pairs)}",
        f"- Profile: {ctx.profile}",
        "",
    ]
    if kpis:
        lines += [
            "## KPIs",
            json.dumps(make_json_safe(kpis), ensure_ascii=False, indent=2),
            "",
        ]
    return "\n".join(lines)


# ===================== Snapshots & Audit Helpers =====================

def save_run_snapshot(
    section: str,
    ctx: AppContext,
    extra: Optional[Dict[str, Any]] = None,
) -> Path:
    """
    שומר Snapshot JSON לריצה (config, controls, seed, git_rev וכו').

    • נקרא לפני ריצות כבדות (Backtest / Optimization / Macro / Scan).
    • מאפשר שחזור מלא של פרמטרים / ממצאים גם חודשים קדימה.
    • כותב לקובץ תחת logs/snapshots.

    Returns
    -------
    Path
        הנתיב לקובץ ה-snapshot שנשמר (או PROJECT_ROOT במקרה כשל).
    """
    try:
        snap_dir = PROJECT_ROOT / "logs" / "snapshots"
        snap_dir.mkdir(parents=True, exist_ok=True)
        ts = datetime.now().strftime("%Y%m%d-%H%M%S")
        git_rev = os.getenv("GIT_REV", "")

        payload: Dict[str, Any] = {
            "section": section,
            "timestamp": ts,
            "git_rev": git_rev,
            "seed": ctx.seed,
            "run_id": ctx.run_id,
            "config": make_json_safe(ctx.config),
            "controls": make_json_safe(ctx.controls),
            "feature_flags": get_feature_flags(),
        }
        if extra:
            payload.update(extra)

        p = snap_dir / f"{section}-{ts}.json"
        p.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding="utf-8")
        return p
    except Exception as e:
        logger.warning("Snapshot save failed: %s", e)
        return PROJECT_ROOT


# ===================== Optional W&B Telemetry =====================

def wandb_setup(project: str = "omri-pairs") -> Optional[Any]:
    """
    Initialize Weights & Biases אם הפיצ'ר דולק (FF_TELEMETRY_WANDB).

    • Import lazy – לא הופך את wandb לתלות קשה.
    • עובד במצב "online" אם יש WANDB_API_KEY, אחרת "offline".
    • מקבל seed, run_id ו-feature_flags לקונפיג.
    """
    try:
        import wandb  # type: ignore
        mode = "online" if os.getenv("WANDB_API_KEY") else "offline"
        wandb.init(
            project=project,
            mode=mode,
            reinit=True,
            allow_val_change=True,
            config={
                "seed": st.session_state.get("global_seed"),
                "run_id": st.session_state.get("run_id"),
                "feature_flags": get_feature_flags(),
                "app_profile": APP_PROFILE,
            },
        )
        return wandb
    except Exception as e:
        logger.warning("wandb_setup failed: %s", e)
        return None


def wandb_log_kpis(kpis: Dict[str, Any]) -> None:
    """
    רישום KPIs ל-wandb (אם ריצה פעילה) – best-effort בלבד.
    """
    try:
        import wandb  # type: ignore
        if wandb.run is not None:
            wandb.log(kpis)
    except Exception:
        pass


# ===================== Sidebar: Theme, Data Source, Pairs, Risk, Feature Flags =====================

def _init_theme_and_sidebar() -> None:
    """
    אתחול Theme & Sidebar גלובלי:

    • Theme (Light/Dark, Accent, High-contrast, Compact layout).
    • Auto-refresh (אם יש streamlit_autorefresh).
    • Data Source (Auto/IBKR/Yahoo) + העדפה ל-Router.
    • Universe Info & Global Pair Selector.
    • Risk & Capital.
    • Determinism (Global Seed + run_id).
    • Feature Flags (SHAP, Clustering, Meta-Opt, GPU, Telemetry וכו').

    זהו הלב הוויזואלי של השליטה הגלובלית – כל הטאבים מסתמכים על state שנקבע כאן.
    """
    # ---- Theme ----
    st.sidebar.header("🎨 Theme")
    mode = st.sidebar.radio(
        "Mode",
        ["Light", "Dark"],
        horizontal=True,
        key=keygen("theme", "mode"),
    )
    dark_mode = (mode == "Dark")
    accent_choice = st.sidebar.selectbox(
        "Accent Color",
        list(ACCENT_PALETTES.keys()),
        index=0,
        key=keygen("theme", "accent"),
    )
    high_contrast = st.sidebar.checkbox(
        "High-contrast charts & UI",
        value=False,
        key=keygen("theme", "hi_contrast"),
    )
    compact_layout = st.sidebar.checkbox(
        "Compact layout (tables/cards)",
        value=False,
        key=keygen("theme", "compact"),
    )

    # מזריקים CSS ומעדכנים Plotly
    accent_color = ACCENT_PALETTES[accent_choice]
    inject_css(accent_color, dark_mode, high_contrast=high_contrast)
    _apply_plotly_theme_from_ui()

    # נשמור Theme ב-session לשימוש בטאבים
    st.session_state["ui_dark_mode"] = bool(dark_mode)
    st.session_state["ui_accent_color"] = accent_color
    st.session_state["ui_high_contrast"] = bool(high_contrast)
    st.session_state["ui_compact"] = bool(compact_layout)

    # עטיפה ל-class "compact" על ה-App – אפשר להשתמש בזה ב-HTML/JS חיצוני אם תרצה
    if compact_layout:
        st.markdown("<script>document.body.classList.add('compact');</script>", unsafe_allow_html=True)
    else:
        st.markdown("<script>document.body.classList.remove('compact');</script>", unsafe_allow_html=True)

    # ---- Auto-Refresh ----
    try:
        if st.sidebar.checkbox(
            "🔄 Auto-refresh",
            value=False,
            key=keygen("refresh", "auto"),
        ) and st_autorefresh:
            st_autorefresh(interval=60_000, key=keygen("refresh", "timer"))
    except Exception:
        pass

    # ---- Universe Info ----
    st.sidebar.subheader("🗄️ Data & Universe")
    try:
        uni = st.session_state.get("universe", [])
        desc = st.session_state.get("_universe_description", {})
        st.sidebar.caption(f"Universe symbols loaded: {len(uni)}")
        if desc:
            with st.sidebar.expander("Universe Details", expanded=False):
                st.json(make_json_safe(desc))
    except Exception:
        st.sidebar.caption("Universe info unavailable.")

    # ---- Data Source Selection ----
    st.sidebar.subheader("📡 Data Source")
    source_choice = st.sidebar.selectbox(
        "מקור דאטה מועדף",
        ["Auto", "IBKR", "Yahoo"],
        index=0,
        key=keygen("data", "source"),
        help="בחר ספק דאטה או השאר על Auto כדי להשתמש בסדר עדיפויות + fallback",
    )
    if source_choice == "Auto":
        preferred_source = None
    elif source_choice == "IBKR":
        preferred_source = "ibkr"
    elif source_choice == "Yahoo":
        preferred_source = "yahoo"
    else:
        preferred_source = None

    st.session_state["data_source_preferred"] = preferred_source

    # ---- Global Pair Selector ----
    try:
        pairs = get_pairs(force_refresh=False)
        if pairs:
            sel_idx = 0
            current_selected = st.session_state.get("selected_pair")
            labels = [make_pair_label(p) for p in pairs]
            if isinstance(current_selected, str):
                current_label = make_pair_label(current_selected)
                if current_label in labels:
                    sel_idx = max(0, labels.index(current_label))

            selected_label = st.sidebar.selectbox(
                "🎯 זוג נבחר (גלובלי)",
                options=labels,
                index=sel_idx,
                key=keygen("global", "selpair"),
            )
            # נשמור label, וגם ננסה לשמור את האובייקט המקורי (אם נמצא)
            st.session_state["selected_pair"] = selected_label
        else:
            st.sidebar.caption("אין זוגות זמינים לבחירה.")
    except Exception:
        st.sidebar.caption("בחירת זוג גלובלית לא זמינה.")

    # ---- Determinism / Global Seed ----
    st.sidebar.subheader("🎯 Determinism")
    seed_initial = int(config.get("seed", _DEF_SEED))
    seed_val = int(
        st.sidebar.number_input(
            "Global Seed",
            min_value=0,
            value=int(st.session_state.get("global_seed", seed_initial)),
            step=1,
            key=keygen("seed", "global"),
            help="שולט על כל מקרי ה-RNG (Backtest/Opt/Scan) לצורך שחזור ניסויים.",
        )
    )
    set_global_seed(seed_val)
    run_id = ensure_run_id(seed_val)
    st.sidebar.caption(f"Run ID: `{run_id}`")

    # ---- Risk & Capital ----
    st.sidebar.subheader("💰 Risk & Capital")
    capital_val = float(
        st.sidebar.number_input(
            "Capital (USD)",
            min_value=1_000.0,
            value=float(st.session_state.get("risk_capital", {}).get("capital", config.get("capital", 100_000.0))),
            step=1_000.0,
            key=keygen("risk", "capital"),
        )
    )
    max_expo = float(
        st.sidebar.slider(
            "Max Exposure / Trade",
            0.0,
            0.50,
            float(st.session_state.get("risk_capital", {}).get("max_exposure_per_trade", config.get("max_exposure_per_trade", 0.05))),
            0.01,
            key=keygen("risk", "max_expo"),
        )
    )
    max_lev = float(
        st.sidebar.slider(
            "Max Leverage",
            1.0,
            10.0,
            float(st.session_state.get("risk_capital", {}).get("max_leverage", config.get("max_leverage", 2.0))),
            0.1,
            key=keygen("risk", "max_lev"),
        )
    )

    st.session_state["risk_capital"] = {
        "capital": capital_val,
        "max_exposure_per_trade": max_expo,
        "max_leverage": max_lev,
    }

    # ---- Quick Risk Profiles (Presets) ----
    with st.sidebar.expander("📌 Risk Profiles (Presets)", expanded=False):
        try:
            col_a, col_b, col_c = st.columns(3)
            if col_a.button("Conservative", key=keygen("risk", "prof_cons")):
                st.session_state["risk_capital"] = {
                    "capital": capital_val,
                    "max_exposure_per_trade": 0.02,
                    "max_leverage": 1.5,
                }
                st.success("Applied Conservative profile (2% / 1.5x)")
            if col_b.button("Balanced", key=keygen("risk", "prof_bal")):
                st.session_state["risk_capital"] = {
                    "capital": capital_val,
                    "max_exposure_per_trade": 0.05,
                    "max_leverage": 2.0,
                }
                st.success("Applied Balanced profile (5% / 2x)")
            if col_c.button("Aggressive", key=keygen("risk", "prof_agg")):
                st.session_state["risk_capital"] = {
                    "capital": capital_val,
                    "max_exposure_per_trade": 0.10,
                    "max_leverage": 3.0,
                }
                st.success("Applied Aggressive profile (10% / 3x)")
        except Exception:
            st.sidebar.caption("Risk profiles unavailable.")

    # ---- Feature Flags (Global) ----
    st.sidebar.subheader("🧪 Feature Flags")
    FF_SHAP_ENABLE = st.sidebar.toggle(
        "Enable SHAP Explainability",
        value=bool(config.get("FF_SHAP_ENABLE", True)),
        key=keygen("ff", "shap"),
    )
    FF_CLUSTERING_ENABLE = st.sidebar.toggle(
        "Enable Clustering",
        value=bool(config.get("FF_CLUSTERING_ENABLE", True)),
        key=keygen("ff", "clust"),
    )
    FF_META_OPT = st.sidebar.toggle(
        "Enable Meta-Optimization",
        value=bool(config.get("FF_META_OPT", False)),
        key=keygen("ff", "meta"),
    )
    FF_TELEMETRY_WANDB = st.sidebar.toggle(
        "Enable W&B Telemetry",
        value=bool(config.get("FF_TELEMETRY_WANDB", False)),
        key=keygen("ff", "wandb"),
    )
    FF_VOL_REGIME_HMM = st.sidebar.toggle(
        "Enable Vol-Regime HMM",
        value=bool(config.get("FF_VOL_REGIME_HMM", False)),
        key=keygen("ff", "hmm"),
    )
    FF_DOWNLOAD_REPORTS = st.sidebar.toggle(
        "Enable Report Downloads",
        value=bool(config.get("FF_DOWNLOAD_REPORTS", True)),
        key=keygen("ff", "dl"),
    )
    FF_GPU_ACCEL = st.sidebar.toggle(
        "GPU Accel (CuPy/JAX)",
        value=bool(config.get("FF_GPU_ACCEL", False)),
        key=keygen("ff", "gpu"),
    )

    st.session_state["feature_flags"] = {
        "FF_SHAP_ENABLE": FF_SHAP_ENABLE,
