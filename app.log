# מיקום דיפולטי לקובץ ההיסטוריה של backtests (כמו בקובץ הישן)
hist_path = PROJECT_ROOT / "logs" / "backtest_history.csv"


@st.cache_data(ttl=120, show_spinner=False)
def _load_backtest_history() -> pd.DataFrame:
    """
    טוען את קובץ backtest_history.csv אם קיים.

    מצופה לכלול לפחות:
    - PnL (per-trade או per-run)
    - Sharpe
    - Drawdown

    אבל יעבוד גם אם יש עמודות נוספות:
    - 'Date' / 'Timestamp'
    - 'Strategy'
    - 'Pair' / 'pair'
    """
    if not hist_path.exists():
        return pd.DataFrame()
    try:
        df = pd.read_csv(hist_path)
        return df
    except Exception as e:
        logger.warning("Failed to read backtest_history.csv: %s", e)
        return pd.DataFrame()


def _compute_equity_and_drawdown(hist: pd.DataFrame) -> Tuple[pd.DataFrame, Optional[pd.Series], Optional[pd.Series]]:
    """
    מחשב Equity curve ו-Drawdown curve על בסיס היסטוריית PnL.

    לוגיקה:
    - אם יש עמודת 'Equity' → נשתמש בה.
    - אחרת:
        * אם יש 'Date' / 'Timestamp' → נסדר לפי תאריך ונחשב cumulative PnL.
        * אם אין → ניקח סדרת PnL לפי סדר השורות ונחשב cumulative.

    Returns
    -------
    df_eq : DataFrame עם index כ-Date/Index ועמודת 'Equity'.
    dd : Series של drawdown (Equity - cummax(Equity)).
    dd_pct : Series של drawdown באחוזים.
    """
    if hist is None or hist.empty:
        return pd.DataFrame(), None, None

    df = hist.copy()
    idx = None

    # בוחרים index זמין
    for col in ("Date", "date", "Timestamp", "timestamp"):
        if col in df.columns:
            try:
                idx = pd.to_datetime(df[col], errors="coerce")
                break
            except Exception:
                idx = None

    if idx is not None is not False:
        df.index = idx
        df = df.sort_index()

    if "Equity" in df.columns:
        eq = pd.to_numeric(df["Equity"], errors="coerce").dropna()
    else:
        if "PnL" in df.columns:
            pnls = pd.to_numeric(df["PnL"], errors="coerce").dropna()
            eq = pnls.cumsum()
            if idx is not None and len(eq) == len(df.index):
                eq.index = df.index
        else:
            return pd.DataFrame(), None, None

    df_eq = pd.DataFrame({"Equity": eq})
    dd = eq - eq.cummax()
    dd_pct = dd / eq.cummax().replace(0, np.nan)
    return df_eq, dd, dd_pct


def _compute_kpis_from_history(hist: pd.DataFrame) -> Dict[str, Any]:
    """
    מחשב סט KPIs מורחב מתוך טבלת backtest_history:

    בסיסיים:
    - total_pnl
    - avg_sharpe
    - max_dd
    - trades
    - win_rate

    מתקדמים:
    - mean_pnl, std_pnl
    - sortino
    - profit_factor
    - pnl_positive_sum, pnl_negative_sum
    - avg_trade_pnl
    - fraction_profitable_trades
    - sh_by_strategy (אם יש עמודת Strategy)
    - pnl_by_pair (אם יש עמודת Pair/pair)
    """
    k: Dict[str, Any] = {
        "total_pnl": None,
        "avg_sharpe": None,
        "max_dd": None,
        "trades": 0,
        "win_rate": None,
        "mean_pnl": None,
        "std_pnl": None,
        "sortino": None,
        "profit_factor": None,
        "pnl_positive_sum": None,
        "pnl_negative_sum": None,
        "avg_trade_pnl": None,
        "fraction_profitable_trades": None,
        "sh_by_strategy": None,
        "pnl_by_pair": None,
    }
    if hist is None or hist.empty:
        return k

    try:
        if "PnL" in hist.columns:
            pnls = pd.to_numeric(hist["PnL"], errors="coerce").dropna()
        else:
            pnls = pd.Series(dtype=float)

        if not pnls.empty:
            k["total_pnl"] = float(pnls.sum())
            k["mean_pnl"] = float(pnls.mean())
            k["std_pnl"] = float(pnls.std(ddof=0))
            k["trades"] = int(len(pnls))
            k["avg_trade_pnl"] = float(pnls.mean())

            wins = pnls[pnls > 0]
            losses = pnls[pnls < 0]
            k["pnl_positive_sum"] = float(wins.sum()) if not wins.empty else 0.0
            k["pnl_negative_sum"] = float(losses.sum()) if not losses.empty else 0.0
            if len(pnls) > 0:
                k["win_rate"] = float((pnls > 0).sum() / len(pnls) * 100.0)
                k["fraction_profitable_trades"] = float((pnls > 0).sum() / len(pnls))

            # Sortino
            downside = pnls[pnls < 0]
            ds_std = float(downside.std(ddof=0)) if len(downside) > 0 else 0.0
            if ds_std > 0:
                sortino = (pnls.mean() / ds_std) * np.sqrt(len(pnls))
            else:
                sortino = 0.0
            k["sortino"] = float(sortino)

            # Profit Factor
            gains = float(wins.sum()) if not wins.empty else 0.0
            losses_abs = float(-losses.sum()) if not losses.empty else 0.0
            pf = gains / losses_abs if losses_abs > 0 else np.nan
            k["profit_factor"] = float(pf) if not np.isnan(pf) else None

        # Sharpe / DD אם קיימים
        if "Sharpe" in hist.columns:
            k["avg_sharpe"] = float(pd.to_numeric(hist["Sharpe"], errors="coerce").dropna().mean())
        if "Drawdown" in hist.columns:
            k["max_dd"] = float(pd.to_numeric(hist["Drawdown"], errors="coerce").dropna().max())

        # Breakdown לפי Strategy (אם יש)
        strategy_col = None
        for col in ("Strategy", "strategy", "STRATEGY"):
            if col in hist.columns:
                strategy_col = col
                break
        if strategy_col and "Sharpe" in hist.columns:
            try:
                sh_by_strategy = (
                    hist.groupby(strategy_col)["Sharpe"]
                    .mean()
                    .sort_values(ascending=False)
                    .to_dict()
                )
                k["sh_by_strategy"] = sh_by_strategy
            except Exception:
                k["sh_by_strategy"] = None

        # Breakdown לפי Pair (אם יש)
        pair_col = None
        for col in ("Pair", "pair", "PAIR"):
            if col in hist.columns:
                pair_col = col
                break
        if pair_col and "PnL" in hist.columns:
            try:
                pnl_by_pair = (
                    hist.groupby(pair_col)["PnL"]
                    .sum()
                    .sort_values(ascending=False)
                    .head(10)
                    .to_dict()
                )
                k["pnl_by_pair"] = pnl_by_pair
            except Exception:
                k["pnl_by_pair"] = None

    except Exception as e:
        logger.warning("Failed to compute KPIs from history: %s", e)

    return k


def render_backtest_history_explorer(hist: pd.DataFrame) -> None:
    """
    פאנל "Backtest History Explorer":

    • מציג preview של ההיסטוריה (head/tail).
    • מאפשר לבחור Subset (לפי Strategy/Pair אם קיימים).
    • מאפשר להוריד CSV מסונן.
    """
    with st.expander("📚 Backtest History Explorer", expanded=False):
        if hist is None or hist.empty:
            st.caption("אין כרגע היסטוריית Backtest זמינה.")
            return

        # בחירת Strategy (אם קיים)
        df = hist.copy()
        strategy_col = None
        for col in ("Strategy", "strategy", "STRATEGY"):
            if col in df.columns:
                strategy_col = col
                break
        pair_col = None
        for col in ("Pair", "pair", "PAIR"):
            if col in df.columns:
                pair_col = col
                break

        col1, col2 = st.columns(2)
        if strategy_col:
            strategies = ["(All)"] + sorted(df[strategy_col].dropna().unique().tolist())
            with col1:
                sel_strat = st.selectbox(
                    "Strategy filter",
                    strategies,
                    index=0,
                    key=keygen("hist", "strat"),
                )
            if sel_strat != "(All)":
                df = df[df[strategy_col] == sel_strat]

        if pair_col:
            pairs = ["(All)"] + sorted(df[pair_col].dropna().unique().tolist())[:200]
            with col2:
                sel_pair = st.selectbox(
                    "Pair filter",
                    pairs,
                    index=0,
                    key=keygen("hist", "pair"),
                )
            if sel_pair != "(All)":
                df = df[df[pair_col] == sel_pair]

        st.caption(f"Filtered rows: {len(df)}")
        st.dataframe(df.head(200), width="stretch")

        # הורדת CSV מסונן
        st.download_button(
            "💾 Download filtered history (CSV)",
            df.to_csv(index=False).encode("utf-8"),
            file_name="backtest_history_filtered.csv",
            mime="text/csv",
            key=keygen("dl", "hist_filtered"),
        )


def render_global_header_and_kpis() -> None:
    """
    מצייר את הכותרת הראשית + KPIs גלובליים מתוך backtest_history.csv
    + Equity curve ו-Drawdown summary.

    • כותרת, Timestamp, Run ID.
    • 7 KPIs ראשיים.
    • Equity curve (Plotly אם זמין, אחרת line_chart).
    • פאנל KPIs מורחב + Explorer.
    • Telemetry ל-wandb.
    """
    # Header
    st.markdown(
        f"<h1 style='margin-bottom:0'>📈 Pairs Trading Dashboard</h1>"
        f"<small>Last update: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')} — "
        f"Run ID: {st.session_state.get('run_id','')}</small>",
        unsafe_allow_html=True,
    )

    hist = _load_backtest_history()
    kpis = _compute_kpis_from_history(hist)

    # KPIs שורה עליונה
    kpi1, kpi2, kpi3, kpi4, kpi5, kpi6, kpi7 = st.columns(7)
    if hist is None or hist.empty:
        for col, lbl in zip(
            (kpi1, kpi2, kpi3, kpi4, kpi5, kpi6, kpi7),
            ("Total PnL", "Avg Sharpe", "Max DD", "Trades", "Win Rate", "Sortino", "Profit Factor"),
        ):
            col.metric(lbl, "N/A")
    else:
        total_pnl = kpis.get("total_pnl")
        avg_sharpe = kpis.get("avg_sharpe")
        max_dd = kpis.get("max_dd")

        kpi1.metric("Total PnL", f"{total_pnl:,.0f}" if total_pnl is not None else "N/A")
        kpi2.metric("Avg Sharpe", f"{avg_sharpe:.2f}" if avg_sharpe is not None else "N/A")
        kpi3.metric("Max DD", f"{max_dd:.2f}" if max_dd is not None else "N/A")

        trades = int(kpis.get("trades") or 0)
        win_rate = kpis.get("win_rate")
        kpi4.metric("Trades", trades if trades else "N/A")
        kpi5.metric("Win Rate", f"{win_rate:.1f}%" if win_rate is not None else "N/A")

        sortino = kpis.get("sortino")
        pf = kpis.get("profit_factor")
        kpi6.metric("Sortino", f"{sortino:.2f}" if sortino is not None else "N/A")
        kpi7.metric("Profit Factor", f"{pf:.2f}" if pf is not None else "N/A")

    # Equity & Drawdown
    df_eq, dd, dd_pct = _compute_equity_and_drawdown(hist)
    if df_eq is not None and not df_eq.empty:
        with st.expander("📈 Equity & Drawdown Overview", expanded=False):
            col_l, col_r = st.columns([2, 1])
            try:
                if "plotly" in sys.modules:
                    import plotly.express as px  # type: ignore

                    fig_eq = px.line(
                        df_eq.reset_index(),
                        x=df_eq.index.name or "index",
                        y="Equity",
                        title="Equity Curve",
                    )
                    col_l.plotly_chart(fig_eq, width="stretch")
                else:
                    col_l.line_chart(df_eq["Equity"])
            except Exception:
                col_l.line_chart(df_eq["Equity"])

            if dd is not None and dd_pct is not None:
                try:
                    dd_stats = {
                        "max_dd_abs": float(dd.min()),
                        "max_dd_pct": float(dd_pct.min() * 100.0),
                    }
                except Exception:
                    dd_stats = {"max_dd_abs": None, "max_dd_pct": None}

                col_r.markdown("**Drawdown Stats**")
                col_r.metric(
                    "Max DD (Abs)",
                    f"{dd_stats['max_dd_abs']:,.0f}" if dd_stats["max_dd_abs"] is not None else "N/A",
                )
                col_r.metric(
                    "Max DD (%)",
                    f"{dd_stats['max_dd_pct']:.1f}%" if dd_stats["max_dd_pct"] is not None else "N/A",
                )

    # עוד KPIs (מורחב) + Explorer
    with st.expander("📊 More KPIs & Breakdown", expanded=False):
        try:
            if hist is None or hist.empty:
                st.caption("אין נתונים מתקדמים לחישוב כעת.")
            else:
                # מנקים NaN ל-None לטובת JSON
                k_clean = {
                    k: (None if (isinstance(v, float) and np.isnan(v)) else v)
                    for k, v in kpis.items()
                }
                st.subheader("KPIs (raw)")
                st.json(make_json_safe(k_clean))

                # Breakdown לפי Strategy (אם קיים)
                if k_clean.get("sh_by_strategy"):
                    st.subheader("Sharpe by Strategy")
                    st.json(make_json_safe(k_clean["sh_by_strategy"]))

                # Breakdown לפי Pair (אם קיים)
                if k_clean.get("pnl_by_pair"):
                    st.subheader("Top PnL by Pair")
                    st.json(make_json_safe(k_clean["pnl_by_pair"]))
        except Exception:
            st.caption("אין נתונים מתקדמים לחישוב כעת.")

    # Explorer (Head/Filters/Download)
    render_backtest_history_explorer(hist)

    # Telemetry ל-wandb אם דולק
    try:
        if get_feature_flags().get("FF_TELEMETRY_WANDB") and hist is not None and not hist.empty:
            wandb_log_kpis(
                {
                    "kpi/total_pnl": float(kpis.get("total_pnl") or 0.0),
                    "kpi/avg_sharpe": float(kpis.get("avg_sharpe") or 0.0),
                    "kpi/max_dd": float(kpis.get("max_dd") or 0.0),
                    "kpi/trades": float(kpis.get("trades") or 0),
                    "kpi/win_rate": float(kpis.get("win_rate") or 0.0),
                    "kpi/sortino": float(kpis.get("sortino") or 0.0),
                    "kpi/profit_factor": float(kpis.get("profit_factor") or 0.0),
                }
            )
    except Exception:
        pass


# ===================== VIX Widget, Regime & Risk Alerts =====================

@st.cache_data(ttl=300, show_spinner=False)
def _get_vix_close() -> Optional[float]:
    """
    מחזיר מחיר סגירה אחרון של VIX (בעזרת yfinance).

    • TTL=5 דקות – לא צריך למשוך כל שנייה.
    • אם יש בעיה – מחזיר None בלי להפיל את ה-UI.
    """
    try:
        df = yf.Ticker("^VIX").history(period="1d")
        return float(df["Close"].iloc[-1])
    except Exception as e:
        logger.warning("Failed to fetch VIX: %s", e)
        return None


def _classify_vol_regime(vix_val: float) -> Tuple[str, str]:
    """
    מגדיר משטר תנודתיות לפי VIX:

    • < 15   → "Low Vol"
    • 15–25  → "Normal Vol"
    • 25–35  → "High Vol"
    • ≥ 35   → "Crisis Vol"

    מחזיר tuple (regime_name, description).
    """
    if vix_val < 15:
        return "Low Vol", "שוק שקט יחסית – אסטרטגיות Mean-Reversion קלאסיות בדרך כלל מרוויחות."
    if vix_val < 25:
        return "Normal Vol", "תנודתיות נורמלית – רוב האסטרטגיות מתנהגות 'כמצופה'."
    if vix_val < 35:
        return "High Vol", "תנודתיות גבוהה – להקטין מינוף ולשקול הקטנת חשיפה בזוגות 'שבריריים'."
    return "Crisis Vol", "משטר משברי – לפשט פורטפוליו, להפחית חשיפה, לשקול Kill-Switch חלקי/מלא."


def render_vix_and_alerts() -> None:
    """
    מצייר ווידג'ט של VIX Sidebar + Alerts לפי סף:

    • מציג metric של VIX + Regime Label.
    • Slider לבחירת סף התראה.
    • אם VIX ≥ threshold:
        - מציג Warning ב-sidebar.
        - שולח הודעת Slack (אם ה-hook מוגדר) פעם אחת לסשן.
    """
    vix_val = _get_vix_close()

    st.sidebar.subheader("📊 Volatility & Risk Regime")
    if vix_val is not None:
        regime_name, regime_desc = _classify_vol_regime(vix_val)
        st.sidebar.metric("VIX", f"{vix_val:.2f}", help=regime_name)
        st.sidebar.caption(regime_desc)
    else:
        st.sidebar.warning("VIX unavailable")
        regime_name = ""
        regime_desc = ""

    st.sidebar.subheader("🔔 Alerts")
    vix_threshold = st.sidebar.slider(
        "VIX alert threshold",
        10.0,
        60.0,
        float(config.get("vix_threshold", 25.0)),
        0.5,
        key=keygen("alerts", "vix_thr"),
    )

    if vix_val is not None and vix_val >= vix_threshold:
        st.sidebar.warning(f"⚠️ VIX {vix_val:.2f} ≥ {vix_threshold:.2f} — consider reducing risk")
        flag_key = keygen("alerts", "vix_sent")
        if SLACK_ERRORS_WEBHOOK and not st.session_state.get(flag_key):
            try:
                import urllib.request
                body = json.dumps(
                    {
                        "text": (
                            f"⚠️ VIX {vix_val:.2f} ≥ {vix_threshold:.2f} — risk alert "
                            f"(regime={regime_name}, run_id={st.session_state.get('run_id','')})"
                        )
                    },
                    ensure_ascii=False,
                ).encode("utf-8")
                req = urllib.request.Request(
                    SLACK_ERRORS_WEBHOOK,
                    data=body,
                    headers={"Content-Type": "application/json"},
                    method="POST",
                )
                urllib.request.urlopen(req, timeout=5)
                st.session_state[flag_key] = True
            except Exception as e:
                logger.warning("Failed to send VIX Slack alert: %s", e)


# ===================== System Health — Pro =====================

def render_system_health_panel() -> None:
    """
    מציג פאנל System Health עשיר:

    • גרסאות של Python, numpy, pandas, streamlit, plotly, optuna.
    • מידע על CPU/RAM/Disk (אם psutil זמין).
    • סטטוס ספקי הדאטה (IBKR/Yahoo וכו').
    • גודל universe והאם GPU accel דולק.
    • רשימת אזהרות אם משהו "לא בריא".
    """
    with st.expander("🛠 System Health — Pro", expanded=False):
        sysinfo: Dict[str, Any] = {}
        warnings_list: List[str] = []
        try:
            import platform
            sysinfo.update(
                {
                    "python": sys.version.split()[0],
                    "platform": platform.platform(),
                    "numpy": np.__version__,
                    "pandas": pd.__version__,
                    "streamlit": st.__version__,
                }
            )
            # בדיקת גרסת Python
            py_ver = sys.version_info[:3]
            if py_ver < _MIN_PYTHON:
                warnings_list.append(
                    f"Python version {py_ver} < recommended {_MIN_PYTHON[0]}.{_MIN_PYTHON[1]}"
                )
        except Exception:
            pass

        # plotly/optuna versions (optional)
        try:
            import plotly  # type: ignore
            sysinfo["plotly"] = getattr(plotly, "__version__", "n/a")
        except Exception:
            sysinfo["plotly"] = "missing"
            warnings_list.append("plotly is missing – חלק מהגרפים המתקדמים עשויים לא לעבוד.")

        try:
            import optuna  # type: ignore
            sysinfo["optuna"] = getattr(optuna, "__version__", "n/a")
        except Exception:
            sysinfo["optuna"] = "missing"

        # psutil – CPU/RAM/Disk
        try:
            import psutil  # type: ignore
            vm = psutil.virtual_memory()
            disk = psutil.disk_usage(str(PROJECT_ROOT))
            cpu_pct = psutil.cpu_percent(interval=0.1)
            ram_used_ratio = vm.used / vm.total if vm.total > 0 else 0.0
            disk_used_ratio = disk.used / disk.total if disk.total > 0 else 0.0

            sysinfo.update(
                {
                    "cpu_percent": cpu_pct,
                    "ram_used_mb": int(vm.used / (1024 * 1024)),
                    "ram_total_mb": int(vm.total / (1024 * 1024)),
                    "disk_used_gb": round(disk.used / (1024 ** 3), 2),
                    "disk_total_gb": round(disk.total / (1024 ** 3), 2),
                }
            )

            if ram_used_ratio > 0.9:
                warnings_list.append("RAM usage > 90% – כדאי לסגור אפליקציות אחרות או להגדיל זיכרון.")
            if disk_used_ratio > 0.9:
                warnings_list.append("Disk usage > 90% – יש לנקות לוגים/קבצים כדי למנוע תקלות.")
        except Exception:
            pass

        # providers status summary
        try:
            prov_df = get_providers_status()
            sysinfo["providers"] = (
                {
                    "rows": int(len(prov_df)),
                    "columns": list(map(str, prov_df.columns)),
                }
                if not prov_df.empty
                else "no providers info"
            )
        except Exception:
            sysinfo["providers"] = "unavailable"

        # universe size + GPU flag + feature flags
        try:
            uni_desc = st.session_state.get("_universe_description", {})
            sysinfo["universe_size"] = uni_desc.get("size", None)
            sysinfo["gpu_accel"] = get_feature_flags().get("FF_GPU_ACCEL", False)
            sysinfo["ff"] = get_feature_flags()
        except Exception:
            pass

        st.subheader("System Snapshot")
        st.json(make_json_safe(sysinfo))

        if warnings_list:
            st.subheader("Warnings")
            for w in warnings_list:
                st.markdown(f"- ⚠️ {w}")
        else:
            st.caption("No critical health warnings detected.")


