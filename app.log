@st.cache_data(ttl=3600, show_spinner=False)
def _cached_load_pairs() -> List[Any]:
    """
    טעינת universe של זוגות (pairs) עם cache.

    משתמש ב-common.data_loader.load_pairs מתיקיית common.
    מחזיר [] במקרה של כשל או אם אין זוגות.

    ה-objects יכולים להיות:
    - str ("XLY-XLC")
    - dict עם שדות sym_x/sym_y/score/metadata
    - כל מבנה אחר שהמערכת שלך משתמשת בו.
    """
    try:
        out = _load_pairs()
        return list(out) if out is not None else []
    except Exception as e:
        logger.warning("load_pairs failed: %s", e)
        return []


def get_pairs(force_refresh: bool = False) -> List[Any]:
    """
    מחזיר את universe של הזוגות, עם אפשרות לרענון cache.

    Parameters
    ----------
    force_refresh : bool
        אם True – ינקה cache ויטעין מחדש מ-load_pairs.

    Returns
    -------
    List[Any]
        רשימת זוגות (str/dict/...) לפי מימוש load_pairs.
    """
    if force_refresh:
        try:
            _cached_load_pairs.clear()  # type: ignore[attr-defined]
        except Exception:
            pass
    return _cached_load_pairs()


def describe_pairs_universe(pairs: List[Any]) -> Dict[str, Any]:
    """
    נותן תקציר סטטיסטי על ה-universe – למטרות UI ו-Debug.

    מחזיר dict עם:
    - size: כמות הזוגות
    - type_breakdown: כמה str / dict / other
    - sample: כמה ערכים ראשונים (כדי לראות צורה כללית)
    """
    info: Dict[str, Any] = {"size": 0, "type_breakdown": {}, "sample": []}
    if not pairs:
        return info

    info["size"] = len(pairs)
    tb: Dict[str, int] = {}
    for p in pairs[: min(100, len(pairs))]:
        tname = type(p).__name__
        tb[tname] = tb.get(tname, 0) + 1
    info["type_breakdown"] = tb
    # sample קטן – נשמור max 5, נשתמש ב-json-safe
    info["sample"] = [make_json_safe(p) for p in pairs[:5]]
    return info


