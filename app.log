# ---------- Alerts Registry (Global Feed) ----------

def register_alert(
    kind: str,
    severity: str,
    message: str,
    *,
    source: str = "dashboard",
    meta: Optional[Dict[str, Any]] = None,
) -> None:
    """
    רושם Alert גלובלי ב-session_state["_alerts"].

    Parameters
    ----------
    kind : str
        סוג ההתראה (לדוגמה: "risk", "data", "macro", "engine", "execution").
    severity : str
        "info" / "warning" / "critical".
    message : str
        הודעה קריאה.
    source : str
        מקור הלוגי של ההתראה (Tab/Module).
    meta : dict, optional
        Metadata נוסף – למשל { "pair": "XLY-XLC", "z": 3.1 }.

    Notes
    -----
    • לא מפיל את המערכת אם יש בעיה.
    • Alerts נשמרים כ-list של dictים (JSON-safe-friendly).
    • ניתן לצרוך אותם ב:
      - Dashboard Home (Daily Notes & Alerts Feed)
      - Risk Engine Panel
      - System Timeline (דרך record_event)
    """
    try:
        alerts = st.session_state.get("_alerts", [])
        if not isinstance(alerts, list):
            alerts = []
        alert = {
            "ts": datetime.now().isoformat(timespec="seconds"),
            "kind": kind,
            "severity": severity,
            "message": message,
            "source": source,
            "meta": make_json_safe(meta or {}),
        }
        alerts.append(alert)
        st.session_state["_alerts"] = alerts
    except Exception:
        # לא נופלים בגלל בעיית Alerts
        pass


# ---------- System Timeline (Events Log) ----------

def record_event(
    category: str,
    message: str,
    *,
    meta: Optional[Dict[str, Any]] = None,
) -> None:
    """
    רושם Event ל-Timeline גלובלי ב-session_state["_timeline"].

    Examples
    --------
        record_event("backtest", "Backtest run completed", {"run_id": ctx.run_id})
        record_event("risk", "Kill-Switch logical trigger", {"reason": "...", "limits": {...}})

    Categories אפשריים:
        "backtest", "optimize", "scan", "macro", "risk", "config", "system", "portfolio"
    """
    try:
        tl = st.session_state.get("_timeline", [])
        if not isinstance(tl, list):
            tl = []
        ev = {
            "ts": datetime.now().isoformat(timespec="seconds"),
            "category": category,
            "message": message,
            "meta": make_json_safe(meta or {}),
        }
        tl.append(ev)
        st.session_state["_timeline"] = tl
    except Exception:
        pass


def render_timeline_panel() -> None:
    """
    מציג Timeline של אירועים ברמת מערכת:

    • רשימת events לפי סדר כרונולוגי יורד.
    • מסנן לפי קטגוריה (אופציונלי).
    • אפשרות להוריד CSV/JSON.
    """
    with st.expander("📜 System Timeline – יומן אירועים", expanded=False):
        try:
            tl = st.session_state.get("_timeline", [])
            if not tl or not isinstance(tl, list):
                st.caption("אין עדיין אירועים ביומן.")
                return

            df_tl = pd.DataFrame(tl)
            df_tl = df_tl.sort_values("ts", ascending=False)

            # מסנן קטגוריה
            categories = ["(All)"] + sorted(df_tl["category"].dropna().unique().tolist())
            col_f1, col_f2 = st.columns([1, 2])
            with col_f1:
                sel_cat = st.selectbox(
                    "Category filter",
                    categories,
                    index=0,
                    key=keygen("timeline", "cat"),
                )
            df_view = df_tl.copy()
            if sel_cat != "(All)":
                df_view = df_view[df_view["category"] == sel_cat]

            st.caption(f"סה\"כ אירועים: {len(df_tl)}, מסוננים: {len(df_view)}")
            st.dataframe(df_view.head(200), width="stretch", height=260)

            col_dl1, col_dl2 = st.columns(2)
            with col_dl1:
                st.download_button(
                    "💾 Download timeline.csv",
                    df_tl.to_csv(index=False).encode("utf-8"),
                    file_name="timeline_events.csv",
                    mime="text/csv",
                    key=keygen("dl", "timeline_csv"),
                )
            with col_dl2:
                st.download_button(
                    "💾 Download timeline.json",
                    json.dumps(make_json_safe(tl), ensure_ascii=False, indent=2).encode("utf-8"),
                    file_name="timeline_events.json",
                    mime="application/json",
                    key=keygen("dl", "timeline_json"),
                )
        except Exception as e:
            st.caption(f"Timeline unavailable: {e}")


# ---------- Risk Limits & State ----------

@dataclass
class RiskLimits:
    """
    מגבלות סיכון ברמת קרן.

    ערכים טיפוסיים (אפשר לשנות ב-config.json):
    - max_daily_loss_pct: 3–5%
    - max_intraday_loss_pct: 5–7% (לוגי בלבד כרגע – אין intraday אמיתי)
    - max_gross_leverage: 3–5x
    - max_drawdown_pct: 15–25%
    - vix_kill_threshold: 35–40
    - anomaly_trigger_min_frac: מינימום שיעור ימים "אנומליים" בחלון קצר
      שמפעיל כלל Kill-Switch נוסף.
    """
    max_daily_loss_pct: float = 0.03
    max_intraday_loss_pct: float = 0.05
    max_gross_leverage: float = 3.0
    max_drawdown_pct: float = 0.20
    vix_kill_threshold: float = 35.0
    anomaly_trigger_min_frac: float = 0.20  # 20% ימים "דגל אדום" בחלון קצר


@dataclass
class RiskState:
    """
    מצב סיכון נוכחי (State) – הערכה על בסיס נתונים היסטוריים זמינים.

    • equity_today, equity_yday – Equity של הקרן (מתוך backtest_history / live).
    • daily_pnl_abs, daily_pnl_pct – שינוי יומי באקוויטי.
    • max_dd_pct – Drawdown מקסימלי (באחוזים מהשיא).
    • gross_leverage – מינוף כולל (פורמלי; כרגע פרוקסי מתוך config).
    • vix – מדד תנודתיות שוק.

    הרחבות:
    --------
    • anomaly_score – מדד "כמה חריגה" התנהגות התשואות האחרונה (0–1, למשל אחוז ימים עם דגל).
    • anomaly_flag – האם היום האחרון מסומן כחריג לפי ensemble של גלאים.
    """
    equity_today: Optional[float]
    equity_yday: Optional[float]
    daily_pnl_abs: Optional[float]
    daily_pnl_pct: Optional[float]
    max_dd_pct: Optional[float]
    gross_leverage: Optional[float]
    vix: Optional[float]
    anomaly_score: Optional[float] = None
    anomaly_flag: Optional[bool] = None


def get_risk_limits_from_config() -> RiskLimits:
    """
    בונה RiskLimits מתוך config.json (אם קיים שם משהו) או דיפולטים.

    config.json יכול לכלול, לדוגמה:
    - "risk_max_daily_loss_pct": 0.03
    - "risk_max_intraday_loss_pct": 0.05
    - "risk_max_gross_leverage": 3.0
    - "risk_max_drawdown_pct": 0.2
    - "risk_vix_kill_threshold": 35.0
    - "risk_anomaly_trigger_min_frac": 0.20
    """
    return RiskLimits(
        max_daily_loss_pct=float(config.get("risk_max_daily_loss_pct", 0.03)),
        max_intraday_loss_pct=float(config.get("risk_max_intraday_loss_pct", 0.05)),
        max_gross_leverage=float(config.get("risk_max_gross_leverage", 3.0)),
        max_drawdown_pct=float(config.get("risk_max_drawdown_pct", 0.20)),
        vix_kill_threshold=float(config.get("risk_vix_kill_threshold", 35.0)),
        anomaly_trigger_min_frac=float(config.get("risk_anomaly_trigger_min_frac", 0.20)),
    )

def _estimate_risk_state_from_history(hist: pd.DataFrame) -> RiskState:
    """
    מעריך RiskState מתוך backtest_history (בקירוב):

    • equity / daily PnL / max_dd – כמו קודם.
    • anomaly_score / anomaly_flag – מתבסס על התשואות היומיות של ה-Equity
      דרך core.anomaly_detection (ensemble_anomaly_signal).
    """
    equity_today = equity_yday = daily_pnl_abs = daily_pnl_pct = max_dd_pct = None
    gross_lev = float(config.get("max_leverage", 2.0))
    anomaly_score: Optional[float] = None
    anomaly_flag: Optional[bool] = None

    if hist is not None and not hist.empty:
        df_eq, dd, dd_pct = _compute_equity_and_drawdown(hist)
        if df_eq is not None and not df_eq.empty:
            eq_vals = df_eq["Equity"].dropna()
            if len(eq_vals) >= 2:
                equity_today = float(eq_vals.iloc[-1])
                equity_yday = float(eq_vals.iloc[-2])
                daily_pnl_abs = equity_today - equity_yday
                if equity_yday != 0:
                    daily_pnl_pct = (equity_today / equity_yday - 1.0)

            # max DD
            if dd_pct is not None and not dd_pct.dropna().empty:
                max_dd_pct = float(dd_pct.min())  # dd_pct שלילי (ירידה מהשיא)

            # ---- Anomaly detection על תשואות ה-Equity ----
            try:
                if anom is not None and eq_vals.size >= 60:
                    daily_ret = eq_vals.pct_change().dropna()
                    if not daily_ret.empty:
                        sig = anom.ensemble_anomaly_signal(daily_ret)  # bool Series
                        sig = sig.reindex(daily_ret.index)
                        if sig.notna().any():
                            # דגל ליום האחרון
                            anomaly_flag = bool(sig.iloc[-1])
                            # anomaly_score = אחוז ימים "דגל" ב-60 האחרונים
                            recent = sig.tail(60)
                            anomaly_score = float(recent.mean()) if len(recent) > 0 else None
            except Exception:
                # לא מפילים Risk Engine בגלל בעיית anomaly
                anomaly_flag = None
                anomaly_score = None

    vix_val = _get_vix_close()
    return RiskState(
        equity_today=equity_today,
        equity_yday=equity_yday,
        daily_pnl_abs=daily_pnl_abs,
        daily_pnl_pct=daily_pnl_pct,
        max_dd_pct=max_dd_pct,
        gross_leverage=gross_lev,
        vix=vix_val,
        anomaly_score=anomaly_score,
        anomaly_flag=anomaly_flag,
    )



# ---------- Kill-Switch Decision Logic ----------

@dataclass
class KillSwitchDecision:
    enabled: bool
    reason: str
    triggered_rules: List[str]
    recommended_actions: List[str]
    state: RiskState
    limits: RiskLimits


def evaluate_kill_switch(
    state: RiskState,
    limits: RiskLimits,
) -> KillSwitchDecision:
    """
    מעריך אם יש להפעיל Kill-Switch (תאורטי) על בסיס מצב סיכון ומגבלות:

    חוקים לדוגמה:
    - Daily loss מעבר לסף.
    - Drawdown היסטורי מעבר לסף.
    - VIX מעל סף משברי.
    - מינוף כולל גבוה מדי.
    - *חדש*: תדירות חריגה של אנומליות בתשואות הקרן.
    """
    triggered: List[str] = []
    recommended: List[str] = []

    # daily loss rule
    if state.daily_pnl_pct is not None and state.daily_pnl_pct <= -limits.max_daily_loss_pct:
        triggered.append(
            f"Daily loss {state.daily_pnl_pct*100:.2f}% ≤ -{limits.max_daily_loss_pct*100:.2f}%"
        )
        recommended.append("עצור פתיחת פוזיציות חדשות להיום; שקול סגירה חלקית של פוזיציות מפסידות.")

    # drawdown rule
    if state.max_dd_pct is not None and state.max_dd_pct <= -limits.max_drawdown_pct:
        triggered.append(
            f"Max DD {state.max_dd_pct*100:.2f}% ≤ -{limits.max_drawdown_pct*100:.2f}%"
        )
        recommended.append("שקול הורדת מינוף גלובלית; בדוק אסטרטגיות עם drawdown קיצוני.")

    # VIX rule
    if state.vix is not None and state.vix >= limits.vix_kill_threshold:
        triggered.append(
            f"VIX {state.vix:.2f} ≥ {limits.vix_kill_threshold:.2f}"
        )
        recommended.append("תעדף הקטנת פוזיציות בזוגות 'שבריריים' וחשיפות ממונפות.")

    # anomaly-based rule (HF-grade)
    if (
        state.anomaly_flag is True
        and state.anomaly_score is not None
        and state.anomaly_score >= limits.anomaly_trigger_min_frac
    ):
        triggered.append(
            f"Portfolio anomaly frequency {state.anomaly_score*100:.1f}% ≥ "
            f"{limits.anomaly_trigger_min_frac*100:.1f}% (last ~60 days)"
        )
        recommended.append(
            "תדירות החריגות בתשואות הקרן גבוהה – מומלץ להקטין מינוף, "
            "להקפיא פתיחת פוזיציות חדשות ולבדוק אנומליות בטאבים Matrix/Insights."
        )

    # leverage rule
    if state.gross_leverage is not None and state.gross_leverage > limits.max_gross_leverage:
        triggered.append(
            f"Gross leverage {state.gross_leverage:.2f}x > {limits.max_gross_leverage:.2f}x"
        )
        recommended.append("הורד מינוף מיידית (Reduce gross) עד מתחת לסף המגבלה.")

    enabled = len(triggered) > 0
    if not enabled:
        reason = "No kill-switch rules triggered."
        recommended = ["המשך פעילות כרגיל; מעקב אחר VIX, PnL יומי ואנומליות בפורטפוליו."]
    else:
        reason = " ; ".join(triggered)

    return KillSwitchDecision(
        enabled=enabled,
        reason=reason,
        triggered_rules=triggered,
        recommended_actions=recommended,
        state=state,
        limits=limits,
    )


# ---------- Scenario Engine (Simple What-If) ----------

@dataclass
class RiskScenario:
    """
    תרחיש פשוט ל-What-If:

    • name: שם התרחיש ("SPY -10%", "Vol spike", ...).
    • spy_shock_pct: שינוי היפותטי ב-SPY (למשל -0.10).
    • vix_target: ערך VIX היפותטי (למשל 40).
    """
    name: str
    spy_shock_pct: float
    vix_target: Optional[float] = None


SCENARIOS: List[RiskScenario] = [
    RiskScenario("Mild Correction (SPY -5%)", spy_shock_pct=-0.05, vix_target=25.0),
    RiskScenario("Shock (SPY -10%)", spy_shock_pct=-0.10, vix_target=35.0),
    RiskScenario("Crisis (SPY -20%)", spy_shock_pct=-0.20, vix_target=45.0),
]


def _simulate_equity_scenario(
    hist: pd.DataFrame,
    scenario: RiskScenario,
) -> Optional[Dict[str, Any]]:
    """
    סימולציה נאיבית: מה קורה ל-equity אם SPY היה חוטף את ה-shock הנתון?

    גישה פשוטה:
    - מניחים ש-PnL יומי פרופורציונלי בקירוב לתשואת SPY.
    - "מגדילים" חלק מהפסד על בסיס shock/ret_spy_20d.
    זה רק אינדיקציה, לא מודל סיכונים מלא.
    """
    if hist is None or hist.empty:
        return None

    df_eq, dd, dd_pct = _compute_equity_and_drawdown(hist)
    if df_eq is None or df_eq.empty:
        return None

    eq_vals = df_eq["Equity"].dropna()
    if len(eq_vals) < 5:
        return None

    equity_today = float(eq_vals.iloc[-1])

    # נניח שהסיכון היחסי דומה ל-Vol של SPY ב-20 ימים האחרונים
    try:
        df_spy = _load_pair_data("SPY", TODAY - timedelta(days=60), TODAY)
        if df_spy is not None and not df_spy.empty:
            s_spy = _pick_price_series(df_spy)
            rets_spy = s_spy.pct_change(1).dropna()
            vol_spy = float(rets_spy.std(ddof=0))
        else:
            vol_spy = 0.02  # fallback
    except Exception:
        vol_spy = 0.02

    shock = scenario.spy_shock_pct
    approx_pnl_change = equity_today * shock * (1.0 / max(vol_spy, 0.01)) * 0.25
    equity_after = equity_today + approx_pnl_change
    dd_effect = approx_pnl_change / max(equity_today, 1.0)

    return {
        "equity_today": equity_today,
        "equity_after": equity_after,
        "approx_pnl_change": approx_pnl_change,
        "approx_pnl_change_pct": approx_pnl_change / max(equity_today, 1.0),
        "approx_dd_effect_pct": dd_effect,
    }


def render_risk_engine_panel() -> None:
    """
    מציג פאנל Risk Engine:

    • מציג מגבלות סיכון (RiskLimits) שנקבעו.
    • מחשב מצב סיכון נוכחי מתוך backtest_history + VIX.
    • מראה האם Kill-Switch "לוגי" היה אמור להיות מופעל.
    • מציע Recommended Actions מילוליים.
    • מציג סימולציות תרחיש (What-If) על equity (מאוד נאיבי, אבל אינדיקטיבי).
    • רושם Alerts ו-Events מתאימים ל-Alerts Feed ול-Timeline.
    """
    with st.expander("🚨 Risk Engine & Kill-Switch (Logical)", expanded=False):
        try:
            limits = get_risk_limits_from_config()
            hist = _load_backtest_history()
            state = _estimate_risk_state_from_history(hist)
            decision = evaluate_kill_switch(state, limits)

            col_l, col_r = st.columns([2, 1])

            # Limits display
            col_l.subheader("Configured Risk Limits")
            col_l.json(
                {
                    "max_daily_loss_pct": limits.max_daily_loss_pct,
                    "max_intraday_loss_pct": limits.max_intraday_loss_pct,
                    "max_gross_leverage": limits.max_gross_leverage,
                    "max_drawdown_pct": limits.max_drawdown_pct,
                    "vix_kill_threshold": limits.vix_kill_threshold,
                    "anomaly_trigger_min_frac": limits.anomaly_trigger_min_frac,
                }
            )

            # State display
            col_l.subheader("Current Risk State (approx)")
            col_l.json(
                {
                    "equity_today": state.equity_today,
                    "equity_yday": state.equity_yday,
                    "daily_pnl_abs": state.daily_pnl_abs,
                    "daily_pnl_pct": state.daily_pnl_pct,
                    "max_dd_pct": state.max_dd_pct,
                    "gross_leverage": state.gross_leverage,
                    "vix": state.vix,
                    "anomaly_score": state.anomaly_score,
                    "anomaly_flag": state.anomaly_flag,
                }
            )

            # Decision
            col_r.subheader("Kill-Switch Decision")
            if decision.enabled:
                col_r.error("Kill-Switch TRIGGERED (logical)")
                col_r.write(decision.reason)

                if decision.recommended_actions:
                    col_r.markdown("**Recommended actions:**")
                    for act in decision.recommended_actions:
                        col_r.markdown(f"- {act}")

                # רישום Alert + Event
                register_alert(
                    kind="risk",
                    severity="critical",
                    message=f"Kill-Switch triggered: {decision.reason}",
                    source="risk_engine",
                    meta={
                        "limits": {
                            "max_daily_loss_pct": limits.max_daily_loss_pct,
                            "max_drawdown_pct": limits.max_drawdown_pct,
                            "vix_kill_threshold": limits.vix_kill_threshold,
                        },
                        "state": {
                            "daily_pnl_pct": state.daily_pnl_pct,
                            "max_dd_pct": state.max_dd_pct,
                            "vix": state.vix,
                            "gross_leverage": state.gross_leverage,
                        },
                    },
                )
                record_event(
                    category="risk",
                    message="Kill-Switch logical trigger",
                    meta={"reason": decision.reason},
                )
            else:
                col_r.success("Kill-Switch NOT triggered")
                col_r.caption(decision.reason)

            # Scenario What-If
            st.subheader("🧪 Scenario What-If (Simple)")
            if hist is None or hist.empty:
                st.caption("אין היסטוריית backtest – לא ניתן להעריך תרחישים.")
            else:
                scenario_names = [sc.name for sc in SCENARIOS]
                sel_sc_name = st.selectbox(
                    "בחר תרחיש",
                    scenario_names,
                    index=0,
                    key=keygen("risk", "scenario"),
                )
                scenario = next(sc for sc in SCENARIOS if sc.name == sel_sc_name)
                sim = _simulate_equity_scenario(hist, scenario)
                if sim is None:
                    st.caption("לא ניתן להעריך תרחיש – מעט מדי נתונים או Equity לא מוגדר.")
                else:
                    col_s1, col_s2 = st.columns(2)
                    col_s1.write(
                        {
                            "equity_today": sim["equity_today"],
                            "equity_after": sim["equity_after"],
                            "approx_pnl_change": sim["approx_pnl_change"],
                            "approx_pnl_change_pct": sim["approx_pnl_change_pct"],
                        }
                    )
                    col_s2.metric(
                        "Equity change (approx)",
                        f"{sim['approx_pnl_change']:,.0f}",
                        f"{sim['approx_pnl_change_pct']*100:.1f}%",
                    )

        except Exception as e:
            st.caption(f"Risk engine unavailable: {e}")


# ===================== Part 11 — Strategy Playbook & Pair Intelligence (HF-Grade) =====================

from dataclasses import dataclass


# ---------- Strategy Profiles from Backtest History ----------

@dataclass
class StrategyProfile:
    """
    פרופיל אסטרטגיה ברמת קרן:

    • name: שם האסטרטגיה (למשל "Pairs_MR_v1").
    • trades: כמות טריידים.
    • total_pnl: רווח/הפסד מצטבר.
    • sharpe: ממוצע Sharpe.
    • max_dd: Drawdown מקסימלי (אם קיים).
    • win_rate: אחוז טריידים רווחיים.
    • avg_holding_days: ממוצע ימי החזקה (אם יש עמודה מתאימה).
    """
    name: str
    trades: int
    total_pnl: float
    sharpe: Optional[float]
    max_dd: Optional[float]
    win_rate: Optional[float]
    avg_holding_days: Optional[float]


def _build_strategy_profiles(hist: pd.DataFrame) -> List[StrategyProfile]:
    """
    בונה רשימת StrategyProfile מתוך backtest_history:

    מחפש עמודה:
    - 'Strategy' / 'strategy' / 'STRATEGY'

    שדות:
    - PnL
    - Sharpe (אם קיים)
    - Drawdown (אם קיים)
    - HoldingDays (אם קיימת עמודה כזו)
    """
    profiles: List[StrategyProfile] = []
    if hist is None or hist.empty:
        return profiles

    # למצוא עמודת Strategy
    strategy_col = None
    for col in ("Strategy", "strategy", "STRATEGY"):
        if col in hist.columns:
            strategy_col = col
            break
    if not strategy_col:
        return profiles

    df = hist.copy()
    df[strategy_col] = df[strategy_col].astype(str)

    pnl_col = "PnL" if "PnL" in df.columns else None
    sharpe_col = "Sharpe" if "Sharpe" in df.columns else None
    dd_col = "Drawdown" if "Drawdown" in df.columns else None
    hold_col = None
    for col in ("HoldingDays", "holding_days", "holding", "HoldDays"):
        if col in df.columns:
            hold_col = col
            break

    if pnl_col:
        df[pnl_col] = pd.to_numeric(df[pnl_col], errors="coerce")
    if sharpe_col:
        df[sharpe_col] = pd.to_numeric(df[sharpe_col], errors="coerce")
    if dd_col:
        df[dd_col] = pd.to_numeric(df[dd_col], errors="coerce")
    if hold_col:
        df[hold_col] = pd.to_numeric(df[hold_col], errors="coerce")

    grouped = df.groupby(strategy_col)
    for strat_name, g in grouped:
        pnls = pd.to_numeric(g.get(pnl_col, pd.Series(dtype=float)), errors="coerce").dropna() if pnl_col else pd.Series(dtype=float)
        sharpe_vals = pd.to_numeric(g.get(sharpe_col, pd.Series(dtype=float)), errors="coerce").dropna() if sharpe_col else pd.Series(dtype=float)
        dd_vals = pd.to_numeric(g.get(dd_col, pd.Series(dtype=float)), errors="coerce").dropna() if dd_col else pd.Series(dtype=float)

        trades = int(len(g))
        total_pnl = float(pnls.sum()) if not pnls.empty else 0.0
        sharpe = float(sharpe_vals.mean()) if not sharpe_vals.empty else None
        max_dd = float(dd_vals.max()) if not dd_vals.empty else None

        # win rate
        win_rate = None
        if pnl_col and not pnls.empty:
            win_rate = float((pnls > 0).sum() / len(pnls) * 100.0)

        # holding days
        avg_hold = None
        if hold_col:
            hold_vals = pd.to_numeric(g[hold_col], errors="coerce").dropna()
            if not hold_vals.empty:
                avg_hold = float(hold_vals.mean())

        profiles.append(
            StrategyProfile(
                name=str(strat_name),
                trades=trades,
                total_pnl=total_pnl,
                sharpe=sharpe,
                max_dd=max_dd,
                win_rate=win_rate,
                avg_holding_days=avg_hold,
            )
        )

    return profiles


def render_strategy_playbook_panel() -> None:
    """
    Strategy Playbook Panel:

    • בונה profiles לכל אסטרטגיה מהיסטוריית Backtest.
    • מסדר לפי פקטור שנבחר (Total PnL / Sharpe / Win Rate / Trades).
    • מציג טבלה מסודרת.
    • מציג “כרטיסי אסטרטגיה” (Top 3) עם Bullet Points וניתוח מילולי.

    זה המקום שבו מנהל הקרן רואה:
    - אילו אסטרטגיות הן Workhorses (מרוויחות יציבות).
    - אילו אסטרטגיות מסוכנות (Sharpe נמוך, DD גבוה).
    """
    with st.expander("📘 Strategy Playbook – פרופילי אסטרטגיות", expanded=False):
        hist = _load_backtest_history()
        if hist is None or hist.empty:
            st.caption("אין היסטוריית Backtest – לא ניתן לבנות Strategy Playbook כרגע.")
            return

        profiles = _build_strategy_profiles(hist)
        if not profiles:
            st.caption("לא נמצאה עמודת Strategy ב-backtest_history – אין פרופילי אסטרטגיה.")
            return

        df_profiles = pd.DataFrame(
            [
                {
                    "Strategy": p.name,
                    "Trades": p.trades,
                    "Total PnL": p.total_pnl,
                    "Sharpe": p.sharpe,
                    "Max DD": p.max_dd,
                    "Win Rate (%)": p.win_rate,
                    "Avg Holding (days)": p.avg_holding_days,
                }
                for p in profiles
            ]
        )

        sort_by = st.selectbox(
            "מיין לפי",
            ["Total PnL", "Sharpe", "Win Rate (%)", "Trades"],
            index=0,
            key=keygen("playbook", "sort"),
        )
        ascending = sort_by in ("Trades",)  # לרוב רוצים PnL/Sharpe/WinRate לפי יורד
        df_sorted = df_profiles.sort_values(sort_by, ascending=ascending)
        st.dataframe(df_sorted, width="stretch", height=260)

        # כרטיסי אסטרטגיה – Top 3
        st.subheader("🃏 Strategy Cards (Top 3)")
        top3 = df_sorted.head(3).to_dict("records")
        for i, row in enumerate(top3, start=1):
            st.markdown(f"#### {i}. {row['Strategy']}")
            bullets = []

            trades = row.get("Trades", 0)
            sharpe = row.get("Sharpe")
            wr = row.get("Win Rate (%)")
            max_dd = row.get("Max DD")
            pnl = row.get("Total PnL")
            avg_hold = row.get("Avg Holding (days)")

            bullets.append(f"- טריידים: {trades}")
            if pnl is not None:
                bullets.append(f"- PnL מצטבר: {pnl:,.0f}")
            if sharpe is not None:
                bullets.append(f"- Sharpe ממוצע: {sharpe:.2f}")
            if max_dd is not None:
                bullets.append(f"- Max Drawdown (היסטורי): {max_dd:.2f}")
            if wr is not None:
                bullets.append(f"- Win Rate: {wr:.1f}%")
            if avg_hold is not None:
                bullets.append(f"- ממוצע ימי החזקה: {avg_hold:.1f}")

            st.markdown("\n".join(bullets))

            # ניתוח rule-based פשוט
            qualitative: List[str] = []
            if sharpe is not None:
                if sharpe > 1.5:
                    qualitative.append("האסטרטגיה מציגה יחס תשואה/סיכון חזק, ומתאימה להיות ליבת הקרן.")
                elif sharpe > 1.0:
                    qualitative.append("אסטרטגיה יציבה יחסית, מתאימה להמשיך בהיקף נוכחי או מוגדל בזהירות.")
                elif sharpe < 0.5:
                    qualitative.append("האסטרטגיה מסוכנת ביחס לתשואה – כדאי לבחון שינויים או לצמצם exposure.")
            if max_dd is not None and max_dd < -0.2:
                qualitative.append("Drawdown היסטורי עמוק, מומלץ להגביל מינוף או לקבוע מגבלות exposure מחמירות.")
            if wr is not None and wr < 45:
                qualitative.append("Win Rate נמוך – יש לוודא שהרווח לא מגיע מכמה טריידים בודדים גדולים מדי.")
            if trades < 30:
                qualitative.append("מספר טריידים נמוך יחסית – נדרש יותר דאטה לפני קבלת החלטה חד-משמעית.")

            if qualitative:
                st.markdown("**Interpretation:**")
                for q in qualitative:
                    st.markdown(f"- {q}")


# ---------- Pair Intelligence Panel (Top / Fragile / Overtraded) ----------

def _build_pair_stats_from_history(hist: pd.DataFrame) -> pd.DataFrame:
    """
    בונה טבלת סטטיסטיקות לזוגות מתוך backtest_history:

    מחפש עמודה:
    - 'Pair' / 'pair' / 'PAIR'

    שדות:
    - Trades – מספר רשומות
    - TotalPnL – סכום PnL
    - AvgPnL – ממוצע PnL
    - AvgSharpe – ממוצע Sharpe (אם קיים)
    """
    if hist is None or hist.empty:
        return pd.DataFrame()

    pair_col = None
    for col in ("Pair", "pair", "PAIR"):
        if col in hist.columns:
            pair_col = col
            break
    if not pair_col:
        return pd.DataFrame()

    df = hist.copy()
    df[pair_col] = df[pair_col].astype(str)
    if "PnL" in df.columns:
        df["PnL"] = pd.to_numeric(df["PnL"], errors="coerce")
    if "Sharpe" in df.columns:
        df["Sharpe"] = pd.to_numeric(df["Sharpe"], errors="coerce")

    agg = df.groupby(pair_col).agg(
        Trades=("PnL", "count"),
        TotalPnL=("PnL", "sum"),
        AvgPnL=("PnL", "mean"),
    )
    if "Sharpe" in df.columns:
        agg["AvgSharpe"] = df.groupby(pair_col)["Sharpe"].mean()
    else:
        agg["AvgSharpe"] = np.nan

    agg = agg.sort_values("TotalPnL", ascending=False)
    agg.index.name = "Pair"
    return agg.reset_index()


def render_pair_intelligence_panel() -> None:
    """
    Panel שנותן “מודיעין זוגות” ברמת קרן:

    • Top Winners – זוגות עם PnL מצטבר גבוה.
    • Top Losers – זוגות שמפסידים הכי הרבה.
    • Fragile Pairs – זוגות עם Sharpe נמוך/שלילי + הרבה טריידים (Overtraded & Risky).
    • אפשרות לסמן זוגים בעייתיים / מועדפים, ולשמור flags ב-session_state["pair_flags"].
    """
    with st.expander("🧠 Pair Intelligence – זיהוי כוכבים ובעייתיים", expanded=False):
        hist = _load_backtest_history()
        if hist is None or hist.empty:
            st.caption("אין היסטוריית Backtest – לא ניתן לבנות Pair Intelligence כרגע.")
            return

        stats = _build_pair_stats_from_history(hist)
        if stats.empty:
            st.caption("לא נמצאה עמודת Pair ב-backtest_history – אין Pair stats.")
            return

        # Top Winners / Losers
        st.subheader("Top Winners & Losers")
        col_w, col_l = st.columns(2)
        with col_w:
            st.markdown("**Top Winners (PnL מצטבר)**")
            st.dataframe(
                stats.sort_values("TotalPnL", ascending=False).head(10),
                width="stretch",
            )
        with col_l:
            st.markdown("**Top Losers (PnL מצטבר)**")
            st.dataframe(
                stats.sort_values("TotalPnL", ascending=True).head(10),
                width="stretch",
            )

        # Fragile Pairs – הרבה טריידים, Sharpe נמוך או שלילי
        st.subheader("Fragile Pairs (Overtraded / Low Sharpe)")
        frag = stats.copy()
        median_trades = frag["Trades"].median() if not frag["Trades"].empty else 0
        frag = frag[
            (frag["Trades"] >= median_trades) &
            (frag["AvgSharpe"].fillna(0) < 0.5)
        ]
        if frag.empty:
            st.caption("לא זוהו זוגות 'שבריריים' לפי המדדים שנבחרו.")
        else:
            st.dataframe(
                frag.sort_values(["AvgSharpe", "Trades"], ascending=[True, False]).head(15),
                width="stretch",
            )

        # Flagging pairs
        st.subheader("🏷️ Mark pairs as 'avoid' / 'favorite'")
        pair_flags = st.session_state.get("pair_flags", {})
        pair_flags = dict(pair_flags) if isinstance(pair_flags, dict) else {}
        pair_flags.setdefault("avoid", [])
        pair_flags.setdefault("favorite", [])

        avoid_current = pair_flags["avoid"]
        favorite_current = pair_flags["favorite"]

        all_pairs = stats["Pair"].tolist()
        col_a, col_b = st.columns(2)
        with col_a:
            sel_avoid = st.multiselect(
                "סמן זוגות להימנעות (avoid)",
                options=all_pairs,
                default=avoid_current,
                key=keygen("pi", "avoid"),
            )
        with col_b:
            sel_fav = st.multiselect(
                "סמן זוגות מועדפים (favorite)",
                options=all_pairs,
                default=favorite_current,
                key=keygen("pi", "fav"),
            )

        pair_flags["avoid"] = sel_avoid
        pair_flags["favorite"] = sel_fav
        st.session_state["pair_flags"] = pair_flags

        st.caption(
            f"מספר זוגות avoid: {len(sel_avoid)} | "
            f"מספר זוגות favorite: {len(sel_fav)}"
        )


# ---------- Narrative Explainer Panel (Rule-Based) ----------

def render_narrative_explainer_panel() -> None:
    """
    Narrative Explainer – סיכום טקסטואלי אוטומטי (rule-based) על מצב הקרן:

    • משתמש ב-KPIs מהיסטוריית Backtest.
    • משתמש ב-RiskState (equity, daily PnL, DD, VIX).
    • משלב אינדיקציה על אסטרטגיות חזקות/חלשות ועל זוגות בעייתיים.

    זה מתאים למנהל קרן שרוצה “Executive Summary” ב-2–3 פסקאות.
    """
    with st.expander("🧾 Narrative Explainer – סיכום מצב הקרן", expanded=False):
        hist = _load_backtest_history()
        kpis = _compute_kpis_from_history(hist) if " _compute_kpis_from_history" in globals() or "_compute_kpis_from_history" in globals() else {}
        limits = get_risk_limits_from_config()
        state = _estimate_risk_state_from_history(hist)
        decision = evaluate_kill_switch(state, limits)

        lines: List[str] = []

        # פסקה 1 – ביצועים כלליים
        if hist is None or hist.empty:
            lines.append("נכון לעכשיו אין היסטוריית Backtest זמינה, ולכן לא ניתן לספק סיכום ביצועים אמין.")
        else:
            total_pnl = kpis.get("total_pnl")
            avg_sharpe = kpis.get("avg_sharpe")
            max_dd = kpis.get("max_dd")
            trades = kpis.get("trades")

            part_perf = "מבחינת ביצועים היסטוריים, "
            if total_pnl is not None:
                part_perf += f"סך הרווח/הפסד המצטבר עומד על כ־{total_pnl:,.0f} דולר"
            else:
                part_perf += "לא ניתן להעריך את ה-PnL המצטבר"

            if avg_sharpe is not None:
                part_perf += f", עם Sharpe ממוצע של כ-{avg_sharpe:.2f}"
            if max_dd is not None:
                part_perf += f" ו-Drawdown מקסימלי (היסטורי) של כ-{max_dd:.2f}."
            else:
                part_perf += "."

            if trades:
                part_perf += f" כמות הטריידים הכוללת בתקופה הנמדדת היא כ-{trades} טריידים."

            lines.append(part_perf)

        # פסקה 2 – מצב סיכון נוכחי
        part_risk = "מנקודת מבט סיכונית, "
        if state.daily_pnl_pct is not None:
            part_risk += f"התוצאה היומית האחרונה מוערכת בכ-{state.daily_pnl_pct*100:.2f}% "
        else:
            part_risk += "לא קיימת הערכה מדויקת ל-PnL היומי האחרון "

        if state.max_dd_pct is not None:
            part_risk += f"וה-Drawdown ההיסטורי הנוכחי עומד סביב {state.max_dd_pct*100:.2f}% "
        part_risk += "בהשוואה למגבלות שהוגדרו ב-Risk Engine. "

        if state.vix is not None:
            if state.vix < limits.vix_kill_threshold:
                part_risk += f"מדד ה-VIX הנוכחי ({state.vix:.2f}) נמוך מסף ה-Kill-Switch ({limits.vix_kill_threshold:.2f}), "
                part_risk += "ולכן מבחינת תנודתיות שוק אין אינדיקציה מיידית לעצירת פעילות."
            else:
                part_risk += f"מדד ה-VIX הנוכחי ({state.vix:.2f}) גבוה מסף ה-Kill-Switch ({limits.vix_kill_threshold:.2f}), "
                part_risk += "מה שמעיד על משטר תנודתיות קיצוני ומצדיק זהירות מיוחדת."
        else:
            part_risk += "לא קיימת כרגע אינדיקציה ל-VIX, ולכן נדרש שיקול דעת ידני יותר."

        lines.append(part_risk)

        # פסקה 3 – Kill-Switch & המלצות
        if decision.enabled:
            lines.append(
                "בהתבסס על החוקים שהוגדרו ב-Kill-Switch, המערכת מסמנת מצב *מסוכן* שבו לפחות כלל אחד הופעל. "
                f"הסיבה המרכזית: {decision.reason}."
            )
            if decision.recommended_actions:
                recommendation_text = "ההמלצות המעשיות כוללות בין היתר: " + "; ".join(decision.recommended_actions)
                lines.append(recommendation_text)
        else:
            lines.append(
                "בשקלול כלל מדדי הסיכון ומגבלות ה-Kill-Switch, לא זוהו כרגע טריגרים המצריכים עצירה מלאה של הפעילות. "
                "עם זאת, מומלץ להמשיך ולנטר את PnL היומי, ה-Drawdown וה-VIX ברציפות."
            )

        # פסקה 4 – אסטרטגיות וזוגות
        hist_for_profiles = _load_backtest_history()
        profiles = _build_strategy_profiles(hist_for_profiles) if hist_for_profiles is not None else []
        pair_stats = _build_pair_stats_from_history(hist_for_profiles) if hist_for_profiles is not None else pd.DataFrame()

        # אסטרטגיות מובילות/בעייתיות
        if profiles:
            best_strat = max(profiles, key=lambda p: p.sharpe or 0.0)
            worst_strat = min(profiles, key=lambda p: p.sharpe or 0.0)
            txt_strat = (
                f"במבט על רמת האסטרטגיות, נראה שהאסטרטגיה '{best_strat.name}' מציגה את פרופיל הסיכון-תשואה "
                f"החזק ביותר (Sharpe משוער ~{(best_strat.sharpe or 0):.2f}), "
                f"בעוד '{worst_strat.name}' נראית חלשה יחסית ודורשת בדיקה נוספת."
            )
            lines.append(txt_strat)


        # זוגות Fragile
        if not pair_stats.empty:
            median_trades = pair_stats["Trades"].median()
            frag = pair_stats[
                (pair_stats["Trades"] >= median_trades) &
                (pair_stats["AvgSharpe"].fillna(0) < 0.5)
            ]
            if not frag.empty:
                frag_pairs = frag.sort_values(["AvgSharpe", "Trades"], ascending=[True, False])["Pair"].head(5).tolist()
                lines.append(
                    "כמו כן, זוהו מספר זוגות 'שבריריים' (Overtraded/Low Sharpe) שראוי לעקוב אחריהם מקרוב: "
                    + ", ".join(map(str, frag_pairs)) + "."
                )

        # הצגת הטקסט
        st.markdown("\n\n".join(lines))


