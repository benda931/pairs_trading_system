# ===================== JSON Helpers & Safe Serialization =====================

def make_json_safe(obj: Any) -> Any:
    """
    Deep-convert אובייקטים לפורמט בטוח ל-JSON.

    משמש ל:
    - Snapshots (logs/snapshots/*.json)
    - Export Center (דוחות, קונפיגים, ctx)
    - Telemetry / דוחות פרופיילינג
    - שמירת "Saved Views" / Notes / Alerts ב-session או בדיסק

    תומך ב:
    - dict / list / tuple / set (רקורסיבי)
    - Path
    - pandas.Timestamp
    - datetime.date / datetime.datetime
    - numpy.integer / numpy.floating
    """
    from pathlib import Path as _Path
    import numpy as _np
    import pandas as _pd
    from datetime import date as _date, datetime as _dt

    if isinstance(obj, dict):
        return {k: make_json_safe(v) for k, v in obj.items()}
    if isinstance(obj, (list, tuple, set)):
        return [make_json_safe(v) for v in obj]
    if isinstance(obj, (_Path, _pd.Timestamp, _date, _dt)):
        return str(obj)
    if isinstance(obj, (_np.integer, _np.floating)):
        return obj.item()
    return obj


# ===================== Config Profiles & Loading =====================

APP_PROFILE: str = os.getenv("APP_PROFILE", "default").strip() or "default"


@st.cache_data(ttl=600, show_spinner=False)
def _load_raw_config(profile: str = "default") -> Dict[str, Any]:
    """
    טוען את config.json דרך config_manager (אם קיים) עם תמיכה בפרופילים.

    • מנסה קודם להעביר profile ל-load_config אם הוא תומך בזה.
    • אם לא – קורא load_config("config.json") בלי פרופיל.
    • במקרה כשל – מחזיר dict ריק.
    """
    try:
        try:
            cfg = _load_config("config.json", profile=profile)  # type: ignore[call-arg]
        except TypeError:
            cfg = _load_config("config.json")
        if not isinstance(cfg, dict):
            logger.warning("Config loader returned non-dict, using empty config.")
            return {}
        return cfg
    except Exception as e:
        logger.warning("Failed to load config.json (profile=%s): %s", profile, e)
        return {}


