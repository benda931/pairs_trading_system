@contextmanager
def _profile_section(section_name: str = "section"):
    """
    פרופיילר קליל לסקשנים – שומר גם ל-log וגם ל-session_state לניתוח בתוך הדשבורד.

    שימוש:
        with _profile_section("backtest"):
            run_backtest(...)

    הנתונים יצטברו ב-_profile_data ב-session_state ויוצגו בדוח פרופיילינג (חלק 15).
    """
    t0 = perf_counter()
    try:
        yield
    finally:
        dt = perf_counter() - t0
        try:
            logger.info("⏱️ %s took %.3fs", section_name, dt)
        except Exception:
            # לוגים לעולם לא מפילים את המערכת
            pass

        # שמירה ל-session לצורך דוחות פרופיילינג
        try:
            prof = st.session_state.get("_profile_data", [])
            if not isinstance(prof, list):
                prof = []
            prof.append(
                {
                    "section": section_name,
                    "dt_sec": float(dt),
                    "ts": datetime.now().isoformat(timespec="seconds"),
                }
            )
            st.session_state["_profile_data"] = prof
        except Exception:
            # session_state גם לא אמור להפיל
            pass


