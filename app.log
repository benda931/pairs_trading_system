# ===================== Profiling Report (HF-Grade) =====================

def render_profile_report() -> None:
    """
    מציג דוח פרופיילינג מתקדם על כל הסקשנים שרצו:

    הנתונים מגיעים מ-_profile_section, ששומר:
        {"section": section_name, "dt_sec": dt, "ts": timestamp}

    הדוח כולל:
    - טבלה גולמית ממויינת לפי dt_sec.
    - Aggregation לפי section: min/mean/median/max/count.
    - זיהוי "סקשנים בעייתיים" (אטיים באופן עקבי).
    - כפתורי הורדה ל-CSV/JSON.
    """
    with st.expander("⏱️ Profiling Report (Experimental, HF-Grade)", expanded=False):
        try:
            prof = st.session_state.get("_profile_data", [])
            if not prof or not isinstance(prof, list):
                st.caption("אין כרגע נתוני פרופיילינג. השתמש ב-_profile_section סביב קטעי קוד כבדים.")
                return

            df_prof = pd.DataFrame(prof)
            if df_prof.empty:
                st.caption("אין כרגע נתוני פרופיילינג.")
                return

            # מוודאים עמודות בסיסיות
            if "dt_sec" not in df_prof.columns:
                st.caption("נתוני הפרופיילינג לא כוללים dt_sec – לא ניתן לבנות דוח.")
                st.json(make_json_safe(prof))
                return

            # ---- טבלה גולמית (sorted) ----
            st.subheader("Raw Profiling Events")
            st.dataframe(
                df_prof.sort_values("dt_sec", ascending=False).reset_index(drop=True),
                width="stretch",
                height=260,
            )

            # ---- Aggregation לפי section ----
            st.subheader("Aggregated by Section")
            try:
                agg = (
                    df_prof.groupby("section")["dt_sec"]
                    .agg(["count", "mean", "median", "min", "max"])
                    .sort_values("mean", ascending=False)
                )
                # נעגל תצוגה
                agg_display = agg.copy()
                for col in ("mean", "median", "min", "max"):
                    agg_display[col] = agg_display[col].round(4)
                st.dataframe(agg_display, width="stretch", height=260)
            except Exception as e:
                st.caption(f"לא ניתן לחשב Aggregation: {e}")

            # ---- זיהוי סקשנים בעייתיים ----
            try:
                if not df_prof.empty:
                    # threshold פשוט: סקשן עם זמן ממוצע מעל חצי שנייה
                    slow_sections = []
                    if "section" in df_prof.columns:
                        agg2 = df_prof.groupby("section")["dt_sec"].mean().sort_values(ascending=False)
                        slow_sections = [
                            (sec, val) for sec, val in agg2.items() if val >= 0.5
                        ]
                    if slow_sections:
                        st.subheader("🚨 Slow Sections (avg dt_sec ≥ 0.5s)")
                        for sec, val in slow_sections:
                            st.markdown(f"- `{sec}` – ממוצע {val:.3f} שניות")
                    else:
                        st.caption("אין סקשנים שנראים איטיים במיוחד לפי סף 0.5 שניות.")
            except Exception:
                pass

            # ---- הורדות ----
            col_dl1, col_dl2 = st.columns(2)
            with col_dl1:
                st.download_button(
                    "💾 Download profiling.csv",
                    df_prof.to_csv(index=False).encode("utf-8"),
                    file_name="profiling_report.csv",
                    mime="text/csv",
                    key=keygen("dl", "prof_csv"),
                )
            with col_dl2:
                st.download_button(
                    "💾 Download profiling.json",
                    json.dumps(make_json_safe(prof), ensure_ascii=False, indent=2).encode("utf-8"),
                    file_name="profiling_report.json",
                    mime="application/json",
                    key=keygen("dl", "prof_json"),
                )
        except Exception as e:
            st.caption(f"Profiling report unavailable: {e}")


# ===================== Export Center — Reports & Artifacts =====================

def render_dashboard_export_center(ctx_dict: Optional[Dict[str, Any]] = None) -> None:
    """
    Export Center מרכזי: snapshots, audit log, config, context + ZIP bundle.

    זה 'מרכז הארטיפקטים' של המערכת – הכל במקום אחד לצורך שיחזור
    ובקרה ברמה של קרן גידור:

    כולל:
    - הורדת ctx (Context JSON) מהריצה האחרונה.
    - רשימת Snapshots זמינים + בחירת Snapshot לצפייה/הורדה.
    - Audit Log (dashboard_audit.log).
    - Config export (config_safe).
    - Markdown Report מה-ctx.
    - ZIP bundle של כל הארטיפקטים (context+config+log+snapshot).
    """
    with st.expander("📦 Export Center — Reports & Artifacts", expanded=False):
        # 1) Context JSON (AppContext האחרון)
        try:
            if not ctx_dict and isinstance(st.session_state.get("ctx"), dict):
                ctx_dict = st.session_state.get("ctx")
        except Exception:
            ctx_dict = None

        if ctx_dict:
            st.subheader("Context (Current Run)")
            st.json(make_json_safe(ctx_dict))

            st.download_button(
                "🧾 Download Context (JSON)",
                json.dumps(make_json_safe(ctx_dict), ensure_ascii=False, indent=2).encode("utf-8"),
                file_name=f"context_{ctx_dict.get('run_id','')}.json",
                mime="application/json",
                key=keygen("dl", "ctx_json"),
            )
        else:
            st.caption("אין הקשר ריצה שמור כרגע (ctx).")

        # 2) Snapshots directory
        latest_snapshot = None
        all_snapshots: List[Path] = []
        try:
            snap_dir = PROJECT_ROOT / "logs" / "snapshots"
            if snap_dir.exists():
                all_snapshots = sorted(snap_dir.glob("*.json"), reverse=True)
        except Exception:
            pass

        if all_snapshots:
            st.subheader("Snapshots (last runs)")
            snap_labels = [f"{p.name}" for p in all_snapshots]
            sel_snap = st.selectbox(
                "בחר Snapshot לצפייה/הורדה",
                options=snap_labels,
                index=0,
                key=keygen("snap", "pick"),
            )
            try:
                snap_path = all_snapshots[snap_labels.index(sel_snap)]
                latest_snapshot = snap_path
                st.caption(f"נבחר snapshot: `{snap_path.name}`")
                # Preview של הקובץ
                try:
                    snap_content = json.loads(snap_path.read_text(encoding="utf-8", errors="replace"))
                    st.json(make_json_safe(snap_content))
                except Exception:
                    st.text(snap_path.read_text(encoding="utf-8", errors="replace"))

                st.download_button(
                    "💾 Download Selected Snapshot",
                    snap_path.read_bytes(),
                    file_name=snap_path.name,
                    key=keygen("dl", "snap_selected"),
                )
            except Exception:
                st.caption("לא ניתן לטעון snapshot נבחר.")
        else:
            st.caption("אין snapshots זמינים עדיין. הם נוצרים לפני ריצות Backtest/Opt/Scan.")

        # 3) Audit log
        audit_bytes: Optional[bytes] = None
        if log_path.exists():
            try:
                audit_bytes = log_path.read_bytes()
                st.subheader("Audit Log")
                st.download_button(
                    "🗒️ Download Audit Log",
                    audit_bytes,
                    file_name="dashboard_audit.log",
                    mime="text/plain",
                    key=keygen("dl", "audit_log"),
                )
            except Exception:
                st.caption("Audit log לא זמין לקריאה. בדוק הרשאות/דיסק.")

        # 4) Config export (config_safe)
        config_bytes: Optional[bytes] = None
        try:
            config_bytes = json.dumps(config_safe, ensure_ascii=False, indent=2).encode("utf-8")
            st.subheader("Config Export")
            st.download_button(
                "⚙️ Download Config (JSON)",
                config_bytes,
                file_name="config_export.json",
                key=keygen("dl", "cfg_export"),
            )
        except Exception:
            st.caption("לא ניתן לייצא את ה-config כרגע.")

        # 5) Markdown report מה-ctx (Context Report)
        try:
            if ctx_dict:
                ctx_obj = AppContext(
                    start_date=ctx_dict["start_date"],
                    end_date=ctx_dict["end_date"],
                    capital=ctx_dict["capital"],
                    max_exposure_per_trade=ctx_dict["max_exposure_per_trade"],
                    max_leverage=ctx_dict["max_leverage"],
                    pairs=ctx_dict["pairs"],
                    config=ctx_dict["config"],
                    controls=ctx_dict["controls"],
                    seed=ctx_dict["seed"],
                    run_id=ctx_dict["run_id"],
                    section=ctx_dict.get("section", "dashboard"),
                    profile=ctx_dict.get("profile", APP_PROFILE),
                )
                md_report = ctx_to_markdown(ctx_obj)
                st.download_button(
                    "📝 Download Context Report (MD)",
                    md_report.encode("utf-8"),
                    file_name=f"context_report_{ctx_obj.run_id}.md",
                    mime="text/markdown",
                    key=keygen("dl", "ctx_md"),
                )
        except Exception:
            st.caption("לא ניתן לבנות דוח Markdown מלא מה-ctx הנוכחי.")

        # 6) ZIP bundle of artifacts (context + config + audit + latest snapshot)
        try:
            import io
            import zipfile

            if st.button("📦 Build ZIP bundle (context+config+logs+snapshot)", key=keygen("dl", "zip_btn")):
                buf = io.BytesIO()
                with zipfile.ZipFile(buf, mode="w", compression=zipfile.ZIP_DEFLATED) as zf:
                    # context.json
                    if ctx_dict:
                        zf.writestr(
                            "context.json",
                            json.dumps(make_json_safe(ctx_dict), ensure_ascii=False, indent=2),
                        )
                    # config_export.json
                    if config_bytes:
                        zf.writestr("config_export.json", config_bytes)
                    # audit.log
                    if audit_bytes:
                        zf.writestr("dashboard_audit.log", audit_bytes)
                    # latest snapshot
                    if latest_snapshot and latest_snapshot.exists():
                        zf.writestr(
                            latest_snapshot.name,
                            latest_snapshot.read_text(encoding="utf-8"),
                        )
                st.download_button(
                    "⬇️ Download ZIP bundle",
                    data=buf.getvalue(),
                    file_name="dashboard_artifacts.zip",
                    mime="application/zip",
                    key=keygen("dl", "zip_bundle"),
                )
        except Exception:
            st.caption("לא ניתן לבנות ZIP bundle כרגע (בדוק ספריות io/zipfile).")

        # 7) System info snapshot קטן (גרסאות בסיסיות)
        try:
            sysinfo = {
                "python": sys.version.split()[0],
                "streamlit": st.__version__,
                "numpy": np.__version__,
                "pandas": pd.__version__,
            }
            st.subheader("System Info (Quick)")
            st.json(sysinfo)
        except Exception:
            pass


