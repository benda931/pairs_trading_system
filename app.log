# ---------- AI-Style Helper (Rule-Based Advisor) ----------

def render_ai_style_helper_panel() -> None:
    """
    AI-Style Helper (Rule-Based) – 'יועץ' פנימי שנותן המלצות לפי מצב הדאטה/סיכון/סיגנלים.

    • משתמש ב:
        - VIX, Risk Engine state.
        - קיום Top Opportunities (Z גבוה).
        - Feature Flags (מה דלוק/כבוי).
    • מחזיר Bullet Points בעברית – מה כדאי לעשות *עכשיו*.
    """
    with st.expander("🤖 Assistant – מה כדאי לעשות עכשיו?", expanded=False):
        hist = _load_backtest_history()
        kpis = _compute_kpis_from_history(hist) if hist is not None and not hist.empty else {}
        limits = get_risk_limits_from_config()
        state = _estimate_risk_state_from_history(hist) if hist is not None else RiskState(None, None, None, None, None, None, None)
        decision = evaluate_kill_switch(state, limits)
        flags = get_feature_flags()

        tips: List[str] = []

        # 1) מצב סיכון
        if decision.enabled:
            tips.append("הסיכון כרגע גבוה – לפי חוקי ה-Kill-Switch. רצוי להקטין מינוף ולהימנע מפתיחת פוזיציות חדשות.")
        else:
            tips.append("ה-Kill-Switch לא מסומן כרגע – אפשר להמשיך לפעול, אך תמיד במודעות לסיכון.")

        if state.vix is not None:
            if state.vix >= limits.vix_kill_threshold:
                tips.append(f"מדד ה-VIX ({state.vix:.1f}) גבוה מאוד – מומלץ לעבוד במצב Risk-Off ולצמצם אסטרטגיות אגרסיביות.")
            elif state.vix >= 25:
                tips.append(f"מדד ה-VIX ({state.vix:.1f}) גבוה – מומלץ לתת דגש לאסטרטגיות איטיות/יציבות יותר.")
            else:
                tips.append(f"מדד ה-VIX ({state.vix:.1f}) סביר – אפשר לתת יותר משקל לאסטרטגיות Mean-Reversion ו-Short-Term.")

        # חריגות – אם anomaly_score גבוה
        if state.anomaly_score is not None and state.anomaly_score >= limits.anomaly_trigger_min_frac:
            tips.append(
                f"תדירות האנומליות בתשואות הקרן גבוהה יחסית "
                f"({state.anomaly_score*100:.1f}% מהימים האחרונים סומנו חריגים) – "
                "מומלץ לבדוק את פאנל האנומליות במטריצות (Matrix Research) "
                "ולצמצם אגרסיביות בתרחיש הנוכחי."
            )

        # 2) ביצועים היסטוריים
        total_pnl = kpis.get("total_pnl")
        avg_sharpe = kpis.get("avg_sharpe")
        if total_pnl is not None and avg_sharpe is not None:
            if avg_sharpe > 1.5:
                tips.append("שילוב האסטרטגיות הנוכחי מציג Sharpe גבוה – מומלץ לשמר את הליבה ולהתמקד בשיפור סיכון בקצוות (tail risk).")
            elif avg_sharpe < 0.8:
                tips.append("Sharpe ממוצע נמוך – כדאי לזהות אסטרטגיות חלשות ב-Strategy Playbook ולצמצם exposure שם.")

        # 3) Feature Flags
        if not flags.get("FF_SHAP_ENABLE", False):
            tips.append("שקול להדליק FF_SHAP_ENABLE כדי לקבל תובנות עמוקות יותר בטאב Insights.")
        if not flags.get("FF_CLUSTERING_ENABLE", False):
            tips.append("שקול להדליק FF_CLUSTERING_ENABLE כדי לנצל את Matrix Research במלוא הכוח.")
        if flags.get("FF_GPU_ACCEL", False):
            tips.append("GPU Accelerated mode פעיל – אפשר להרשות לעצמך הרצות כבדות יותר ב-Optimization/Matrix.")

        # 4) פעולות מומלצות לפי מצב כללי
        tips.append("בדוק את Pair Intelligence כדי לזהות זוגות שבריריים/Overtraded לפני הגדלת exposure.")
        tips.append("השתמש ב-Workflow Templates כדי לזרז עבודה – במיוחד Mean-Reversion Scan + Backtest.")

        st.markdown("### המלצות Rule-Based")
        for t in tips:
            st.markdown(f"- {t}")


