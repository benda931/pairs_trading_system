# Optimization Tab (optimization_tab.py / root.optimization_tab.py)
def _render_optimization_tab_wrapper(
    start_date: date,
    end_date: date,
    controls: Dict[str, Any],
    *,
    section: str = "optimize",
) -> None:
    """
    עטיפה סביב optimization_tab.render_optimization_tab:

    • מייבא את הפונקציה רק ברגע השימוש (Lazy import) כדי להימנע מ-circular imports.
    • מנקה פרמטרים legacy (seed, n_trials) מה-kwargs כדי לא לשבור תאימות.
    • בונה AppContext + Snapshot + פרופייל.
    """
    try:
        try:
            from root.optimization_tab import render_optimization_tab as _rt  # type: ignore
        except Exception:
            from optimization_tab import render_optimization_tab as _rt  # type: ignore
    except Exception:
        st.info("🔧 Optimization tab unavailable (module missing).")
        return

    ctx = build_ctx(start_date, end_date, controls, section=section)
    seed = ctx.seed

    if get_feature_flags().get("FF_DOWNLOAD_REPORTS", True):
        save_run_snapshot("optimize", ctx)

    safe_kwargs = dict(controls)
    safe_kwargs.pop("seed", None)
    safe_kwargs.pop("n_trials", None)

    with _profile_section("optimize"):
        try:
            _rt(seed=seed, ctx=asdict(ctx), **safe_kwargs)
        except TypeError:
            # חתימה ישנה שלא מכירה ctx/seed
            _rt(**safe_kwargs)


