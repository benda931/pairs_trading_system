    _AnalysisContext = None  # type: ignore
    _create_sanity_profile = None  # type: ignore


def _render_analysis_tab_wrapper(
    start_date: date,
    end_date: date,
    *,
    section: str = "scan",
    controls: Optional[Dict[str, Any]] = None,
) -> None:
    """
    עטיפה אחידה לטאב Analysis / Smart Scan.

    מטרה:
    - להתאים בין הקריאות מה-dashboard לבין ה-API של analysis.render_analysis_tab.
    - לבנות AnalysisContext בסיסי (ctx_base) + profile דיפולטי.
    - להעביר price_loader שמסתמך על _load_pair_data.
    - לשלב AppContext + Snapshots + פרופיילר.

    במקרה שהמודול analysis אינו זמין – מציג הודעה ולא מפיל את האפליקציה.
    """
    if _analysis_render_tab is None:
        st.info("🔧 Analysis tab unavailable (module missing).")
        return

    controls = controls or {}
    # בונים ctx לריצה הזו (סריקה)
    ctx = build_ctx(start_date, end_date, controls, section=section)

    # profile דיפולטי נשמר ב-session כדי לא לאבד הגדרות
    profile = st.session_state.get("analysis_profile_default")
    if profile is None and _create_sanity_profile is not None:
        profile = _create_sanity_profile()
        st.session_state["analysis_profile_default"] = profile

    def _analysis_price_loader(sym: str, period: Optional[str], bar_size: str) -> pd.Series:
        """
        טעינת מחירים לטאב Analysis.

        כרגע:
        - מתעלם מ-period, עובד לפי start_date/end_date שניתנו ל-dashboard.
        - bar_size נשמר לחתימות עתידיות; כרגע תומכים בעיקר ב-1d.
        """
        df = _load_pair_data(sym, start_date, end_date)
        if isinstance(df, pd.DataFrame):
            s = _pick_price_series(df)
            return s
        return pd.Series(dtype=float)

    # AnalysisContext בסיסי (ניתן להרחבה עתידית – vol_regime, macro_bias וכו')
    ctx_base = None
    if _AnalysisContext is not None:
        ctx_base = _AnalysisContext(
            sym_x="",
            sym_y="",
            start_date=start_date,
            end_date=end_date,
        )

    # Snapshot לפני ריצה כבדה
    if get_feature_flags().get("FF_DOWNLOAD_REPORTS", True):
        save_run_snapshot("scan", ctx)

    with _profile_section("analysis_smart_scan"):
        _analysis_render_tab(
            profile=profile,
            price_loader=_analysis_price_loader,
            ctx_base=ctx_base,
        )


