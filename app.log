# ===================== Symbol & Pair Normalization Helpers =====================

def _extract_symbols_from_pair_dashboard(pair_obj: Any) -> Tuple[str, str]:
    """
    מנרמל אובייקט זוג לצמד (sym_x, sym_y) כמחרוזות.

    תומך ב:
    - dict עם "symbols": {"symbols": ["XLY", "XLC"]}
    - dict עם sym_x / sym_y
    - dict עם symbol_a / symbol_b
    - list/tuple באורך 2
    - string בפורמטים: "XLY/XLC", "XLY,XLC", "XLY-XLC", "XLY|XLC", "XLY:XLC"
    - string בודד → fallback: משתמש באותו סימבול פעמיים (לא אידיאלי, אבל לא מפיל).
    """
    # dict {"symbols": ["XLY", "XLC"]}
    if isinstance(pair_obj, dict):
        if "symbols" in pair_obj and isinstance(pair_obj["symbols"], (list, tuple)):
            syms = pair_obj["symbols"]
            if len(syms) == 2:
                return str(syms[0]), str(syms[1])
        if {"sym_x", "sym_y"}.issubset(pair_obj):
            return str(pair_obj["sym_x"]), str(pair_obj["sym_y"])
        if {"symbol_a", "symbol_b"}.issubset(pair_obj):
            return str(pair_obj["symbol_a"]), str(pair_obj["symbol_b"])

    # list / tuple
    if isinstance(pair_obj, (list, tuple)) and len(pair_obj) == 2:
        return str(pair_obj[0]), str(pair_obj[1])

    # string formats: "XLY/XLC", "XLY,XLC", "XLY-XLC", "XLY|XLC", "XLY:XLC"
    if isinstance(pair_obj, str):
        s = pair_obj.strip()
        for sep in ("/", ",", "-", "|", ":"):
            if sep in s:
                a, b = s.split(sep, 1)
                return a.strip(), b.strip()
        # fallback: single symbol used twice (לא אידיאלי, אבל עדיף מקריסה)
        return s, s

    # אם לא הצלחנו – נזרוק ValueError (עדיף ללכוד נקודתית בקוד הקורא)
    raise ValueError(f"Cannot extract symbols from pair object: {pair_obj!r}")


def _normalize_symbol_input(obj: Any) -> List[str]:
    """
    מנרמל כל אובייקט סימבול/זוג לרשימה של tickers נקיים (strings).

    תומך ב:
    - "XLY"
    - "XLY-XLC" (label; יחזור ["XLY-XLC"])
    - {"symbols": ["XLY","XLC"]} / {"SYMBOLS": [...]} / {"sym_x":...,"sym_y":...}
    - "{'SYMBOLS': ['XLY', 'XLC']}" (stringified dict)
    - lists/tuples/sets של האובייקטים הנ"ל.

    הערה:
    - אם זה dict כללי – נעבור על כל ה-values ונחפש סימבולים בתוכם.
    """
    # dict-like
    if isinstance(obj, dict):
        # צורות סטנדרטיות
        if "symbols" in obj:
            return _normalize_symbol_input(obj["symbols"])
        if "SYMBOLS" in obj:
            return _normalize_symbol_input(obj["SYMBOLS"])
        if {"sym_x", "sym_y"}.issubset(obj):
            return [str(obj["sym_x"]).strip(), str(obj["sym_y"]).strip()]
        if {"symbol_a", "symbol_b"}.issubset(obj):
            return [str(obj["symbol_a"]).strip(), str(obj["symbol_b"]).strip()]
        # fallback: נסרוק את כל הערכים
        out: List[str] = []
        for v in obj.values():
            out.extend(_normalize_symbol_input(v))
        return out

    # list / tuple / set
    if isinstance(obj, (list, tuple, set)):
        out: List[str] = []
        for item in obj:
            out.extend(_normalize_symbol_input(item))
        # הסרה של כפילויות, שומר על סדר ראשון
        seen: set[str] = set()
        uniq: List[str] = []
        for s in out:
            if s not in seen:
                seen.add(s)
                uniq.append(s)
        return uniq

    # string — עשוי להיות raw ticker או stringified dict/list
    if isinstance(obj, str):
        s = obj.strip()
        if (s.startswith("{") and s.endswith("}")) or (s.startswith("[") and s.endswith("]")):
            try:
                parsed = ast.literal_eval(s)
                return _normalize_symbol_input(parsed)
            except Exception:
                return [s]
        return [s]

    # fallback — cast to string
    return [str(obj).strip()]


def make_pair_label(p: Any) -> str:
    """
    מנרמל כל אובייקט pair ל-label קריא (מחרוזת).

    תומך ב:
    - str ("XLY-XLP")
    - dict עם key "pair"
    - dict עם sym_x/sym_y או symbol_a/symbol_b
    - tuple/list של (sym_x, sym_y)

    חשוב:
    - משתמש במינוס '-' כברירת מחדל (תואם לקוד הישן).
    """
    if isinstance(p, dict):
        if "pair" in p:
            return str(p["pair"])
        if {"sym_x", "sym_y"}.issubset(p):
            return f"{p['sym_x']}-{p['sym_y']}"
        if {"symbol_a", "symbol_b"}.issubset(p):
            return f"{p['symbol_a']}-{p['symbol_b']}"
        return str(p)
    if isinstance(p, (list, tuple)) and len(p) == 2:
        return f"{p[0]}-{p[1]}"
    return str(p)


def split_pair_label(label: str) -> Tuple[Optional[str], Optional[str]]:
    """
    מנסה לפצל label לשני סימבולים לפי מפרידים נפוצים.

    מפרידים נתמכים:
    - '|', '/', '\\', ':', '-'

    מחזיר:
    - (sym_x, sym_y) או (None, None) במקרה כישלון.
    """
    seps = ("|", "/", "\\", ":", "-")
    for sep in seps:
        if sep in label:
            left, right = label.split(sep, 1)
            left, right = left.strip(), right.strip()
            if left and right:
                return left, right
    return None, None


# ===================== Price Field Helpers =====================

_PREFERRED_PRICE_FIELDS = ("Close", "Adj Close", "close", "adj_close", "price", "LAST_PRICE")


def _pick_price_series(df: pd.DataFrame, preferred: Tuple[str, ...] = _PREFERRED_PRICE_FIELDS) -> pd.Series:
    """
    בוחר עמודת מחיר הגיונית מתוך DataFrame.

    לוגיקה:
    - מחפש לפי סדר השמות המועדפים (Close, Adj Close, close, ...).
    - אם לא מצא – לוקח את העמודה הראשונה.
    - מחזיר Series מטופלת ל-numeric ו-dropna.
    """
    if df is None or df.empty:
        return pd.Series(dtype=float)

    for col in preferred:
        if col in df.columns:
            s = df[col]
            return pd.to_numeric(s, errors="coerce").dropna()

    # fallback: העמודה הראשונה
    s = df[df.columns[0]]
    return pd.to_numeric(s, errors="coerce").dropna()


# ===================== Safe Correlation Helper =====================

def _safe_corr_dashboard(a: pd.Series, b: pd.Series) -> float:
    """
    קורלציה בטוחה על Series נומריים בלבד.

    • ממירה ל-numpy float64.
    • אם פחות מ-2 נקודות לכל סדרה – מחזירה NaN.
    • עטופה ב-try/except כדי למנוע קריסות.
    """
    try:
        a_arr = np.asarray(a.values, dtype="float64")
        b_arr = np.asarray(b.values, dtype="float64")

        if a_arr.size < 2 or b_arr.size < 2:
            return float("nan")

        return float(np.corrcoef(a_arr, b_arr)[0, 1])
    except Exception:
        return float("nan")


# ===================== Core Price Loading: Router + Fallback =====================

@st.cache_data(ttl=600, show_spinner=False)
def _load_single_symbol_via_router(
    sym: str,
    start_date: date,
    end_date: date,
    *,
    bar_size: str = "1d",
) -> pd.DataFrame:
    """
    ניסיון טעינת דאטה לסימבול בודד דרך MarketDataRouter.

    • משתמש ב-st.session_state["md_router"].
    • מכבד מקור מועדף מ-st.session_state["data_source_preferred"] אם קיים.
    • מחזיר DataFrame עם index לפי datetime, ממוין, או DataFrame ריק אם נכשל.
    """
    router_local = st.session_state.get("md_router")
    if router_local is None:
        return pd.DataFrame()

    preferred_source = st.session_state.get("data_source_preferred")

    try:
        start_dt = datetime.combine(start_date, datetime.min.time())
        end_dt = datetime.combine(end_date, datetime.max.time())
        res = router_local.get_history(  # type: ignore[attr-defined]
            symbols=[sym],
            start=start_dt,
            end=end_dt,
            period=None,
            bar_size=bar_size,
            preferred_source=preferred_source,
            require_non_empty=False,
        )
        df = getattr(res, "df", None)
        if df is None or df.empty:
            return pd.DataFrame()

        df = df.copy()
        if "symbol" in df.columns:
            df = df[df["symbol"] == sym]
        if "datetime" in df.columns:
            df = df.set_index("datetime")
        df = df.sort_index()
        return df
    except Exception as e:
        logger.warning("Router-based load for %s failed: %s", sym, e)
        return pd.DataFrame()

def _render_system_status() -> None:
    """
    פס סטטוס עליון – מצב API מול IBKR, ספקי דאטה, וקפיטל מהקונפיג.
    לא מפיל את האפליקציה גם אם משהו לא זמין.
    """
    st.markdown("### 🩺 מצב מערכת")

    col1, col2, col3 = st.columns(3)

    # -------- 1) סטטוס IBKR --------
    ib_status = st.session_state.get("ibkr_status", "unknown")
    if ib_status == "ok":
        ib_label = "✅ מחובר"
    elif ib_status == "readonly":
        ib_label = "⚠️ Read-Only"
    elif ib_status == "error":
        ib_label = "❌ שגיאה"
    else:
        ib_label = "❓ לא ידוע"

    col1.metric("IBKR API", ib_label)

    # -------- 2) ספקי דאטה (Router) --------
    providers_txt = "N/A"
    if build_default_router is not None:
        try:
            router = build_default_router()
            providers = getattr(router, "providers", None)
            if providers:
                providers_txt = ", ".join(providers)
        except Exception:
            providers_txt = "Error"

    col2.metric("ספקי דאטה", providers_txt)

    # -------- 3) קפיטל מהקונטקסט / קונפיג --------
    ctx = st.session_state.get("ctx") or {}
    capital = (
        ctx.get("capital")
        or ctx.get("risk_capital")
        or ctx.get("max_capital")
        or 0
    )
    try:
        capital_str = f"{float(capital):,.0f}" if capital else "N/A"
    except Exception:
        capital_str = "N/A"

    col3.metric("Capital בקונפיג", capital_str)

@st.cache_data(ttl=900, show_spinner=False)
def _load_pair_data(symbol: Any, start_date: date, end_date: date) -> pd.DataFrame:
    """
    Load price data for a symbol or pair label.

    זהו *נקודת הכניסה המרכזית* לטעינת דאטה לכל הטאבים.

    Parameters
    ----------
    symbol : Any
        יכול להיות:
        - סימבול בודד ("XLY")
        - label של צמד ("XLY-XLC")
        - dict כמו {"SYMBOLS": ["XLY","XLC"]} או {"sym_x":...,"sym_y":...}
        - stringified dict "{'SYMBOLS': ['XLY','XLC']}" (מ-session/JSON)
    start_date, end_date : date
        טווח התאריכים הרצוי.

    לוגיקה:
    1. מנרמל את הקלט ל-symbols_norm דרך _normalize_symbol_input.
    2. מסתכל על הסימבול הראשון כמייצג (sym).
    3. אם sym *לא* נראה כמו label של pair:
        - מנסה לטעון דרך MarketDataRouter.
        - אם אין דאטה/Router נכשל → fallback ל-load_price_data(sym) מה-DB/CSV.
    4. אם sym נראה כמו label של pair (מכיל מפריד):
        - ישר משתמש ב-load_price_data(sym) (היסטוריה שמורה לצמד).
    5. חותך לפי start/end על index.

    Return
    ------
    DataFrame
        DataFrame עם index לפי תאריך ועמודות מחיר, או DataFrame ריק אם אין דאטה.
    """
    # שלב 0: נירמול קלט לסדרה של טיקרים נקיים
    symbols_norm = _normalize_symbol_input(symbol)
    if not symbols_norm:
        return pd.DataFrame()
    sym = symbols_norm[0]

    # זיהוי label של צמד (לא נכס בודד)
    seps = ("|", "/", "\\", ":", "-")
    is_pair_label = any(sep in sym for sep in seps)

    # ניסיון 1: Router (לסימבול בודד בלבד)
    if not is_pair_label:
        df_router = _load_single_symbol_via_router(sym, start_date, end_date, bar_size="1d")
        if df_router is not None and not df_router.empty:
            return df_router

    # ניסיון 2: fallback – load_price_data ההיסטורי (לצמדים, או אם Router נכשל)
    try:
        df = load_price_data(sym)
    except Exception as e:
        logger.warning("load_price_data(%s) failed: %s", sym, e)
        return pd.DataFrame()

    if df is None or df.empty:
        return pd.DataFrame()

    try:
        df = df.copy()
        idx = pd.to_datetime(df.index)
        mask = (idx >= pd.Timestamp(start_date)) & (idx <= pd.Timestamp(end_date))
        return df.loc[mask]
    except Exception:
        # אם slicing נכשל – נחזיר כמו שהוא
        return df


# ===================== Pair Legs Loader & Alignment =====================

def load_pair_legs(
    pair_obj: Any,
    start_date: date,
    end_date: date,
) -> Tuple[pd.Series, pd.Series, str]:
    """
    טוען את שני ה-legs של זוג ומחזיר סדרות מחירים מיושרות + label.

    Parameters
    ----------
    pair_obj : Any
        אובייקט שמתאר זוג – תומך בכל הצורות של _extract_symbols_from_pair_dashboard.
    start_date, end_date : date
        טווח התאריכים הרצוי.

    Returns
    -------
    (s1, s2, label)
        s1, s2 – סדרות מחירים מיושרות (numeric, dropna, aligned inner join).
        label – מחרוזת קריאה לזוג (make_pair_label).
    """
    label = make_pair_label(pair_obj)
    sym_x, sym_y = _extract_symbols_from_pair_dashboard(pair_obj)

    df_x = _load_pair_data(sym_x, start_date, end_date)
    df_y = _load_pair_data(sym_y, start_date, end_date)

    if df_x is None or df_x.empty or df_y is None or df_y.empty:
        return pd.Series(dtype=float), pd.Series(dtype=float), label

    s1 = _pick_price_series(df_x)
    s2 = _pick_price_series(df_y)

    s1, s2 = s1.align(s2, join="inner")
    return s1, s2, label


def compute_pair_corr(
    pair_obj: Any,
    start_date: date,
    end_date: date,
) -> float:
    """
    מחשב קורלציה בטוחה לזוג מסוים לטווח נתון.

    תומך בכל הצורות של pair_obj ומסתמך על load_pair_legs + _safe_corr_dashboard.
    """
    s1, s2, _ = load_pair_legs(pair_obj, start_date, end_date)
    if s1.empty or s2.empty:
        return float("nan")
    return _safe_corr_dashboard(s1, s2)


# ===================== Latest Bar & Freshness Helpers =====================

@st.cache_data(ttl=300, show_spinner=False)
def latest_bar_timestamp(symbol: str = "SPY", days_lookback: int = 10) -> Optional[str]:
    """
    מחזיר את חותמת הזמן של הבר האחרון עבור סימבול נתון.

    • מנסה לטעון את הדאטה דרך _load_pair_data.
    • days_lookback – כמה ימים אחורה לחפש (למקרה שאין מסחר כל יום, חגים וכו').
    • מחזיר מחרוזת "YYYY-MM-DD HH:MM:SS" או None אם אין דאטה.

    משמש בעיקר:
    - Dashboard Home → טריות דאטה (Freshness).
    - System Health Panels.
    """
    try:
        df = _load_pair_data(symbol, TODAY - timedelta(days=days_lookback), TODAY)
        if df is None or df.empty:
            return None
        idx = pd.to_datetime(df.index)
        ts = pd.to_datetime(idx.dropna()).max()
        if pd.isna(ts):
            return None
        return ts.strftime("%Y-%m-%d %H:%M:%S")
    except Exception:
        return None


# חלק 3 מסתיים כאן.
# בחלק 4 נבנה:
# - חישובי אותות גנריים לזוגות (Z, β דינמי, ספרד, Half-Life) כולל DataFrame של אותות
#   שישמש מאוחר יותר:
#   • Dashboard Home (Top Opportunities)
#   • Smart Scan / Analysis
#   • Matrix Research
# - Helperים ל-returns (למשל pct_change windows) לצורך קורלציות/מטריצות

# ===================== Generic Signal Helpers (Spread, Z, β, HL) =====================

def _calc_zscore_series(x: pd.Series, window: int) -> pd.Series:
    """
    מחשב Z-Score לסדרה נומרית:

        Z_t = (x_t - mean_window) / std_window

    • window: אורך חלון החישוב.
    • מחזיר Series עם NaN בתחילת החישוב (כמו rolling סטנדרטי).
    """
    x = pd.to_numeric(x, errors="coerce")
    mu = x.rolling(window).mean()
    sd = x.rolling(window).std(ddof=0)
    return (x - mu) / sd


def _last_non_nan(s: pd.Series, default: float = float("nan")) -> float:
    """
    מחזיר את הערך האחרון הלא-NaN בסדרה, או default אם אין כזה.
    """
    try:
        return float(s.dropna().iloc[-1])
    except Exception:
        return default


def _rolling_beta(
    s1: pd.Series,
    s2: pd.Series,
    window: int,
) -> pd.Series:
    """
    מחשב β מתגלגל בין שתי סדרות:

        β_t ≈ Cov(s1,s2)_window / Var(s2)_window

    • rolling window עם ddof=0.
    • ffill כדי להימנע מהתנהגות מוזרה בתחילת הסדרה.
    """
    s1 = pd.to_numeric(s1, errors="coerce")
    s2 = pd.to_numeric(s2, errors="coerce")
    cov = s1.rolling(window).cov(s2)
    var = s2.rolling(window).var(ddof=0)
    beta = cov / var
    return beta.ffill()


def _compute_spread_and_beta(
    s1: pd.Series,
    s2: pd.Series,
    beta_window: int,
) -> Tuple[pd.Series, pd.Series, float]:
    """
    מחשב β מתגלגל וספרד על בסיס β האחרון:

        spread_t = s1_t - β_last * s2_t

    Parameters
    ----------
    s1, s2 : Series
        סדרות המחירים של שני ה-legs (מיושרות).
    beta_window : int
        חלון לחישוב β מתגלגל.

    Returns
    -------
    (beta_series, spread_series, beta_last)
    """
    beta_series = _rolling_beta(s1, s2, beta_window)
    beta_last = _last_non_nan(beta_series, default=1.0)
    spread = s1 - beta_last * s2
    return beta_series, spread, beta_last


# ===================== Single-Pair Signal Computation (HF-Grade) =====================

def compute_pair_signal(
    pair_obj: Any,
    start_date: date,
    end_date: date,
    *,
    z_window: int = 30,
    multi_z_windows: Optional[List[int]] = None,
    beta_window: Optional[int] = None,
    min_points: int = 40,
) -> Optional[Dict[str, Any]]:
    """
    מחשב אות (signal) עבור זוג בודד לטווח נתון – ברמת קרן גידור.

    Features
    --------
    - pair, sym_x, sym_y
    - β דינמי אחרון (Rolling OLS proxy)
    - spread_t = s1_t - β_last * s2_t
    - Z-Score אחרון של הספרד (חלון z_window)
    - Multi-Z: Z אחרון עבור חלונות נוספים (למשל [10, 60, 120])
    - corr בין ה-legs (לפי _safe_corr_dashboard)
    - half_life של הספרד (דרך calculate_half_life)
    - points: כמות נקודות בפועל
    - quality_score (אם evaluate_pair_quality זמין)
    - edge (אם _evaluate_edge זמין)
    - z_window, beta_window, start/end

    אם אין מספיק דאטה או שיש בעיה חריגה – מחזיר None.
    """
    try:
        label = make_pair_label(pair_obj)
        sym_x, sym_y = _extract_symbols_from_pair_dashboard(pair_obj)

        # טעינת סדרות המחירים לשני ה-legs
        s1, s2, _ = load_pair_legs(pair_obj, start_date, end_date)
        if s1.empty or s2.empty:
            return None

        # לוודא שיש מספיק נקודות
        if len(s1) < max(min_points, z_window + 5):
            return None

        # β window – אם לא מוגדר, נשתמש ב-max(10, z_window)
        bw = int(beta_window) if beta_window is not None else max(10, min(120, z_window))

        beta_series, spread, beta_last = _compute_spread_and_beta(s1, s2, bw)

        # Z לספרד (חלון ראשי)
        z_main = _calc_zscore_series(spread, z_window)
        z_last = _last_non_nan(z_main)

        # Multi-Z windows (למשל עבור טווחי זמן שונים)
        z_extra: Dict[str, float] = {}
        if multi_z_windows:
            for w in multi_z_windows:
                try:
                    w_int = int(w)
                    if w_int <= 0:
                        continue
                    z_tmp = _calc_zscore_series(spread, w_int)
                    z_extra[f"z_w{w_int}"] = _last_non_nan(z_tmp)
                except Exception:
                    continue

        # קורלציה כללית
        corr_val = _safe_corr_dashboard(s1, s2)

        # Half-Life (דרך ה-util שלך; אם מחזיר None – ניקח NaN)
        hl_raw = calculate_half_life(spread) if callable(calculate_half_life) else None
        hl = float(hl_raw) if hl_raw is not None else float("nan")

        # quality_score דרך evaluate_pair_quality (אם זמין)
        quality_score: Optional[float] = None
        try:
            quality_score = float(evaluate_pair_quality(s1, s2))  # type: ignore[arg-type]
        except Exception:
            quality_score = None

        # edge estimation דרך _evaluate_edge (אם זמין)
        edge_val: Optional[float] = None
        try:
            # לא יודעים את החתימה המדויקת – best-effort + עטוף ב-try/except
            edge_info = _evaluate_edge(
                sym_x=sym_x,
                sym_y=sym_y,
                start_date=start_date,
                end_date=end_date,
                spread=spread,
                z_series=z_main,
            )
            if isinstance(edge_info, dict) and "edge" in edge_info:
                edge_val = float(edge_info["edge"]) if edge_info["edge"] is not None else None
        except Exception:
            edge_val = None

        sig: Dict[str, Any] = {
            "pair": label,
            "sym_x": sym_x,
            "sym_y": sym_y,
            "beta": float(beta_last),
            "z": float(z_last),
            "abs_z": float(abs(z_last)),
            "corr": float(corr_val),
            "half_life": hl,
            "points": int(len(spread)),
            "z_window": int(z_window),
            "beta_window": int(bw),
            "start": str(start_date),
            "end": str(end_date),
            "quality_score": quality_score,
            "edge": edge_val,
            "status": "ok",
        }
        # מוסיפים Multi-Z אם יש
        sig.update({k: float(v) for k, v in z_extra.items()})
        return sig

    except Exception as e:
        logger.warning("compute_pair_signal failed for %r: %s", pair_obj, e)
        return None


def compute_pair_signal_with_reason(
    pair_obj: Any,
    start_date: date,
    end_date: date,
    *,
    z_window: int = 30,
    multi_z_windows: Optional[List[int]] = None,
    beta_window: Optional[int] = None,
    min_points: int = 40,
) -> Dict[str, Any]:
    """
    כמו compute_pair_signal, אבל **אף פעם לא מחזיר None** – תמיד מחזיר dict.

    השדות:
    - status: "ok" / "skipped" / "error"
    - reason: טקסט קצר במקרה של skip/error
    - כל השדות האחרים של compute_pair_signal במקרה "ok" (z, beta, ...)

    זה שימושי למנועי Diagnostics כדי לראות *למה* זוגות הושמטו.
    """
    base: Dict[str, Any] = {
        "pair": make_pair_label(pair_obj),
        "sym_x": None,
        "sym_y": None,
        "status": "skipped",
        "reason": "",
    }

    try:
        label = base["pair"]
        sym_x, sym_y = _extract_symbols_from_pair_dashboard(pair_obj)
        base["sym_x"], base["sym_y"] = sym_x, sym_y

        s1, s2, _ = load_pair_legs(pair_obj, start_date, end_date)
        if s1.empty or s2.empty:
            base["reason"] = "no_data"
            return base

        if len(s1) < max(min_points, z_window + 5):
            base["reason"] = "insufficient_points"
            base["points"] = int(len(s1))
            return base

        # אם הגענו לכאן – נשתמש ב-compute_pair_signal הרגיל
        sig = compute_pair_signal(
            pair_obj,
            start_date,
            end_date,
            z_window=z_window,
            multi_z_windows=multi_z_windows,
            beta_window=beta_window,
            min_points=min_points,
        )
        if sig is None:
            base["reason"] = "compute_failed"
            base["status"] = "error"
            return base

        sig["status"] = "ok"
        sig["reason"] = ""
        return sig
    except Exception as e:
        base["status"] = "error"
        base["reason"] = f"exception: {e}"
        return base


# ===================== Bulk Signal Engine for Universe =====================

@st.cache_data(ttl=180, show_spinner=False)
def compute_universe_signals(
    pairs: List[Any],
    start_date: date,
    end_date: date,
    *,
    z_window: int = 30,
    multi_z_windows: Optional[List[int]] = None,
    beta_window: Optional[int] = None,
    top_n: Optional[int] = None,
    min_points: int = 40,
    max_workers: int = 8,
) -> pd.DataFrame:
    """
    מנוע אותות לזוגות ברמת universe שלם (HF-grade).

    • מריץ compute_pair_signal לכל זוג (בצורה מקבילית).
    • מחזיר DataFrame מסודר עם כל האותות שהצליחו ("status=ok").
    • אם top_n מוגדר – מחזיר רק את ה-Top לפי |Z|.
    • כולל quality_score/edge אם זמינים.

    Parameters
    ----------
    pairs : list
        רשימת זוגות (str/dict/...) כמו שמוחזר מ-get_pairs.
    start_date, end_date : date
        טווח התאריכים לניתוח.
    z_window : int
        חלון Z לספרד (עיקרי).
    multi_z_windows : list[int], optional
        חלונות נוספים ל-Multi-Z (למשל [10, 60, 120]).
    beta_window : int, optional
        חלון β; אם None – נגזר מ-z_window.
    top_n : int, optional
        אם לא None – חיתוך ל-Top |Z|.
    min_points : int
        מינימום נקודות כדי לחשב אות אמין.
    max_workers : int
        כמות threads ל-ThreadPoolExecutor.

    Returns
    -------
    DataFrame
        רק הזוגות להם status="ok". לזוגות שהושמטו יש מנוע Diagnostics נפרד.
    """
    if not pairs:
        return pd.DataFrame()

    from concurrent.futures import ThreadPoolExecutor, as_completed

    results: List[Dict[str, Any]] = []

    with ThreadPoolExecutor(max_workers=max_workers) as ex:
        futures = {
            ex.submit(
                compute_pair_signal,
                p,
                start_date,
                end_date,
                z_window=z_window,
                multi_z_windows=multi_z_windows,
                beta_window=beta_window,
                min_points=min_points,
            ): p
            for p in pairs
        }
        for fut in as_completed(futures):
            out = fut.result()
            if out and out.get("status", "ok") == "ok":
                results.append(out)

    if not results:
        return pd.DataFrame()

    df = pd.DataFrame(results)

    # סדרת מיון בסיסית לפי |Z|, quality_score ו-Points
    sort_cols: List[str] = []
    ascending: List[bool] = []
    if "abs_z" in df.columns:
        sort_cols.append("abs_z")
        ascending.append(False)
    if "quality_score" in df.columns:
        sort_cols.append("quality_score")
        ascending.append(False)
    if "points" in df.columns:
        sort_cols.append("points")
        ascending.append(False)

    if sort_cols:
        df = df.sort_values(sort_cols, ascending=ascending)

    if top_n is not None:
        df = df.head(int(top_n))

    df = df.reset_index(drop=True)
    return df


@st.cache_data(ttl=180, show_spinner=False)
def compute_universe_signals_with_diagnostics(
    pairs: List[Any],
    start_date: date,
    end_date: date,
    *,
    z_window: int = 30,
    multi_z_windows: Optional[List[int]] = None,
    beta_window: Optional[int] = None,
    min_points: int = 40,
    max_workers: int = 8,
) -> Tuple[pd.DataFrame, pd.DataFrame]:
    """
    כמו compute_universe_signals, אבל מחזיר גם DataFrame של Diagnostics:

    Returns
    -------
    (signals_df, diagnostics_df)
        signals_df    – כל השורות עם status="ok".
        diagnostics_df – כל הזוגות (כולל כישלונות/חסרים) עם status ו-reason.
    """
    if not pairs:
        return pd.DataFrame(), pd.DataFrame()

    from concurrent.futures import ThreadPoolExecutor, as_completed

    ok_results: List[Dict[str, Any]] = []
    diag_results: List[Dict[str, Any]] = []

    with ThreadPoolExecutor(max_workers=max_workers) as ex:
        futures = {
            ex.submit(
                compute_pair_signal_with_reason,
                p,
                start_date,
                end_date,
                z_window=z_window,
                multi_z_windows=multi_z_windows,
                beta_window=beta_window,
                min_points=min_points,
            ): p
            for p in pairs
        }
        for fut in as_completed(futures):
            out = fut.result()
            if not isinstance(out, dict):
                continue
            diag_results.append(out)
            if out.get("status") == "ok":
                ok_results.append(out)

    df_ok = pd.DataFrame(ok_results) if ok_results else pd.DataFrame()
    df_diag = pd.DataFrame(diag_results) if diag_results else pd.DataFrame()

    # מיון בסיסי ל-ok
    if not df_ok.empty and "abs_z" in df_ok.columns:
        df_ok = df_ok.sort_values(["abs_z", "points"], ascending=[False, False]).reset_index(drop=True)

    return df_ok, df_diag


# ===================== Profiles for Signals (Mean-Reversion / Short-Term / Vol-Arb) =====================

SIGNAL_PROFILES: Dict[str, Dict[str, Any]] = {
    "mean_reversion": {
        "z_window": 30,
        "multi_z_windows": [10, 60],
        "min_points": 60,
    },
    "short_term": {
        "z_window": 10,
        "multi_z_windows": [5, 20],
        "min_points": 30,
    },
    "vol_arb": {
        "z_window": 20,
        "multi_z_windows": [10, 40],
        "min_points": 40,
    },
    "slow_mean_reversion": {
        "z_window": 60,
        "multi_z_windows": [30, 120],
        "min_points": 120,
    },
}


def get_signal_profile_params(profile: str) -> Dict[str, Any]:
    """
    מחזיר פרמטרי ברירת מחדל לפרופיל אותות נתון.

    פרופילים מוכרים:
    - "mean_reversion"
    - "short_term"
    - "vol_arb"
    - "slow_mean_reversion"

    אם הפרופיל לא מוכר – חוזר לפרופיל "mean_reversion".
    """
    profile = (profile or "mean_reversion").strip().lower()
    if profile not in SIGNAL_PROFILES:
        profile = "mean_reversion"
    return dict(SIGNAL_PROFILES[profile])


@st.cache_data(ttl=180, show_spinner=False)
def compute_universe_signals_profile(
    profile: str,
    pairs: List[Any],
    start_date: date,
    end_date: date,
    *,
    top_n: Optional[int] = None,
    max_workers: int = 8,
) -> pd.DataFrame:
    """
    עטיפה נוחה להרצת אותות לפי פרופיל:

    Example:
        df_sig = compute_universe_signals_profile(
            "mean_reversion", pairs, start, end, top_n=20
        )
    """
    params = get_signal_profile_params(profile)
    return compute_universe_signals(
        pairs=pairs,
        start_date=start_date,
        end_date=end_date,
        z_window=int(params.get("z_window", 30)),
        multi_z_windows=params.get("multi_z_windows"),
        beta_window=None,
        top_n=top_n,
        min_points=int(params.get("min_points", 40)),
        max_workers=max_workers,
    )


# ===================== Dashboard-Specific Wrapper (Top Opportunities) =====================

@st.cache_data(ttl=120, show_spinner=False)
def compute_dashboard_signals(
    pairs: List[Any],
    start_date: date,
    end_date: date,
    *,
    z_window: int = 30,
    top_n: int = 15,
    min_points: int = 40,
) -> pd.DataFrame:
    """
    עטיפה ייעודית ל-Dashboard Home:

    • מריץ compute_universe_signals על ה-universe.
    • מחזיר כבר את ה-Top |Z| לפי דרישות הדשבורד.
    • מאפשר שינוי זמין של חלון Z וגודל Top-N.

    משמש:
    - טאב 🏠 Dashboard Home (סקשן "Top Opportunities").
    """
    pairs_list = list(pairs or [])
    if not pairs_list:
        return pd.DataFrame()

    df_sig = compute_universe_signals(
        pairs=pairs_list,
        start_date=start_date,
        end_date=end_date,
        z_window=z_window,
        multi_z_windows=[z_window, 10, 60],  # ברירת מחדל Multi-Z לדשבורד
        beta_window=None,
        top_n=top_n,
        min_points=min_points,
        max_workers=8,
    )
    return df_sig


# ===================== Returns & Matrix Helpers (for Matrix Research) =====================

@st.cache_data(ttl=600, show_spinner=False)
def compute_universe_returns(
    pairs: List[Any],
    start_date: date,
    end_date: date,
    *,
    field: str = "Close",
    window: int = 1,
) -> pd.DataFrame:
    """
    מחשב Returns (pct_change) לכל universe עבור נכסים/זוגות.

    • לטאבי Matrix/Overview/Research, לאו דווקא רק לזוגות – מקבל את רשימת pairs,
      אבל בפועל משתמש ב-labelים שלהם כמפתחות columns.
    • מחזיר DataFrame שבו כל עמודה היא סדרת price של pair/symbol,
      והערכים הם pct_change(window).

    Notes
    -----
    - window=1 → תשואה יומית.
    - window=20 → תשואה על פני כחודש מסחר.
    """
    if not pairs:
        return pd.DataFrame()

    all_series: Dict[str, pd.Series] = {}
    for p in pairs:
        label = make_pair_label(p)
        df = _load_pair_data(p, start_date, end_date)
        if df is None or df.empty:
            continue
        # נסה קודם field, אחרת השתמש ב-_pick_price_series
        if field in df.columns:
            s = pd.to_numeric(df[field], errors="coerce").dropna()
        else:
            s = _pick_price_series(df)
        if s.empty:
            continue
        all_series[label] = s

    if not all_series:
        return pd.DataFrame()

    prices = pd.DataFrame(all_series).dropna(how="all")
    if prices.empty:
        return pd.DataFrame()

    returns = prices.pct_change(window)
    return returns


@st.cache_data(ttl=600, show_spinner=False)
def compute_return_corr_matrix(
    pairs: List[Any],
    start_date: date,
    end_date: date,
    *,
    field: str = "Close",
    window: int = 20,
) -> pd.DataFrame:
    """
    מחשב מטריצת קורלציה על בסיס returns של universe (לצורך Matrix Research / Overview).

    • קורא compute_universe_returns.
    • מחזיר DataFrame – מטריצת קורלציה של ה-returns.
    """
    rets = compute_universe_returns(
        pairs=pairs,
        start_date=start_date,
        end_date=end_date,
        field=field,
        window=window,
    )
    if rets is None or rets.empty:
        return pd.DataFrame()
    return rets.corr()


