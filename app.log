SLACK_ERRORS_WEBHOOK = os.getenv("SLACK_ERRORS_WEBHOOK", "")


def _report_exception(e: Exception, section: str = "") -> None:
    """
    שולחת חריגות ל-Sentry + Slack (אם מוגדרים), בלי להפיל את הדשבורד.

    Parameters
    ----------
    e : Exception
        החריגה שנתפסה.
    section : str, optional
        שם הלוגי של החלק שבו קרתה השגיאה (למשל "Tab Backtest").

    התנהגות:
    - Sentry: capture_exception (best-effort).
    - Slack: הודעת טקסט עם snippet של traceback (עד 3.5k תווים).
    """
    # Sentry (אופציונלי)
    try:
        sentry_sdk.capture_exception(e)
    except Exception:
        pass

    # Slack (אופציונלי)
    if not SLACK_ERRORS_WEBHOOK:
        return

    try:
        import traceback
        import urllib.request

        tb = "\n".join(traceback.format_exception(type(e), e, e.__traceback__))
        snippet = tb[:3500]
        text = f"""❗ *{section or 'Unhandled'}*
```{type(e).__name__}: {e}```
```{snippet}```"""
        body = json.dumps({"text": text}, ensure_ascii=False).encode("utf-8")
        req = urllib.request.Request(
            SLACK_ERRORS_WEBHOOK,
            data=body,
            headers={"Content-Type": "application/json"},
            method="POST",
        )
        urllib.request.urlopen(req, timeout=5)
    except Exception:
        # לא מפילים את המערכת אם Slack נכשל
        pass


