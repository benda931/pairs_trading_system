def _check_environment() -> None:
    """
    מבצע בדיקות סביבה קלות (גרסת Python/Streamlit, תקיית logs) ורושם ל-log.

    לא נועד להפיל את האפליקציה – רק לתת אינדיקציה בדוח/לוג אם משהו חשוד.
    """
    try:
        py_ver = sys.version_info[:3]
        if py_ver < _MIN_PYTHON:
            logger.warning(
                "Python version is %s but recommended >= %s.%s",
                py_ver,
                _MIN_PYTHON[0],
                _MIN_PYTHON[1],
            )
    except Exception:
        pass

    try:
        # Streamlit version check (best-effort)
        st_ver = getattr(st, "__version__", "unknown")
        logger.info("Streamlit version: %s", st_ver)
    except Exception:
        pass

    try:
        logger.info("Project root: %s", PROJECT_ROOT)
        logger.info("Logs path: %s", log_path)
    except Exception:
        pass


