            "אילו פרמטרים/Features משפיעים, והאם יש רמזים ל-Overfitting."
        )

    # צד ימין – Overview מהיר על ביצועים כדי לתת הקשר ל-Insights
    with col_right:
        st.markdown("**Performance Snapshot – הקשר לתובנות**")
        hist = _load_backtest_history()
        k = None
        if hist is None or hist.empty:
            st.caption("אין backtest_history.csv – קשה לייצר תובנות ללא ביצועים היסטוריים.")
        else:
            k = _compute_kpis_from_history(hist)
            k1, k2, k3, k4 = st.columns(4)
            total_pnl = k.get("total_pnl")
            avg_sharpe = k.get("avg_sharpe")
            max_dd = k.get("max_dd")
            trades = k.get("trades")

            k1.metric("Total PnL (hist)", f"{total_pnl:,.0f}" if total_pnl is not None else "N/A")
            k2.metric("Avg Sharpe (hist)", f"{avg_sharpe:.2f}" if avg_sharpe is not None else "N/A")
            k3.metric("Max DD (hist)", f"{max_dd:.2f}" if max_dd is not None else "N/A")
            k4.metric("Trades (hist)", trades if trades else "N/A")

            # High-Level Drivers – אסטרטגיות וזוגות
            with st.expander("High-Level Drivers (Strategies / Pairs)", expanded=False):
                try:
                    # Strategy-level summary
                    strat_col = None
                    for c in ("Strategy", "strategy", "STRATEGY"):
                        if c in hist.columns:
                            strat_col = c
                            break

                    if strat_col and "PnL" in hist.columns:
                        df_strat = hist.copy()
                        df_strat["PnL"] = pd.to_numeric(df_strat["PnL"], errors="coerce")
                        # PnL + Sharpe per strategy אם קיים
                        agg_strat = df_strat.groupby(strat_col).agg(
                            TotalPnL=("PnL", "sum"),
                        )
                        if "Sharpe" in df_strat.columns:
                            df_strat["Sharpe"] = pd.to_numeric(df_strat["Sharpe"], errors="coerce")
                            agg_strat["AvgSharpe"] = df_strat.groupby(strat_col)["Sharpe"].mean()
                        agg_strat = agg_strat.sort_values("TotalPnL", ascending=False)
                        st.markdown("**PnL / Sharpe לפי אסטרטגיה**")
                        st.dataframe(agg_strat, width="stretch", height=240)

                        # לציון אסטרטגיות קיצוניות
                        try:
                            best = agg_strat.sort_values("TotalPnL", ascending=False).head(1)
                            worst = agg_strat.sort_values("TotalPnL", ascending=True).head(1)
                            st.caption(
                                f"אסטרטגיה מובילה (PnL): {best.index[0]} • "
                                f"חלשה (PnL): {worst.index[0]}"
                            )
                        except Exception:
                            pass
                    else:
                        st.caption("אין שדה Strategy ב-history – לא ניתן לסכם לפי אסטרטגיה.")

                    # Pair-level summary קצר
                    pair_col = None
                    for c in ("Pair", "pair", "PAIR"):
                        if c in hist.columns:
                            pair_col = c
                            break
                    if pair_col and "PnL" in hist.columns:
                        df_pair = hist.copy()
                        df_pair["PnL"] = pd.to_numeric(df_pair["PnL"], errors="coerce")
                        pair_pnl = (
                            df_pair.groupby(pair_col)["PnL"]
                            .sum()
                            .sort_values(ascending=False)
                        )
                        c_pp1, c_pp2 = st.columns(2)
                        with c_pp1:
                            st.markdown("**Top 10 PnL Pairs**")
                            st.dataframe(
                                pair_pnl.head(10).to_frame("TotalPnL"),
                                width="stretch",
                                height=200,
                            )
                        with c_pp2:
                            st.markdown("**Bottom 10 PnL Pairs**")
                            st.dataframe(
                                pair_pnl.tail(10).to_frame("TotalPnL"),
                                width="stretch",
                                height=200,
                            )
                except Exception as e:
                    st.caption(f"High-level driver summary unavailable: {e}")

    # ================== חלק 2 — Insights Engine (insights.py) ==================
    st.markdown("### 🔬 Insights Engine (insights.py) — SHAP / Feature Importance / ML Analysis")

    with st.spinner("💡 Generating insights…"):
        try:
            _render_insights_tab(
                start_date=ctrl_ins.get("start_date"),
                end_date=ctrl_ins.get("end_date"),
                shap_top=int(ctrl_ins["shap_top"]),
                importance_threshold=float(ctrl_ins["importance_threshold"]),
                ctx=st.session_state.get("ctx", {}),
            )
        except Exception as e:
            logger.exception(e)
            _report_exception(e, "Tab Insights")
            st.error(f"❗ שגיאה בטאב Insights: {e}")

    # ================== חלק 3 — Overfitting & Stability Checks ==================
    st.subheader("🧪 Overfitting & Stability Checks (Rule-Based)")

    with st.expander("Overfitting & Stability Heuristics", expanded=False):
        hist = _load_backtest_history()
        if hist is None or hist.empty:
            st.caption("אין היסטוריית Backtest – קשה לגזור בדיקות יציבות.")
        else:
            notes: List[str] = []

            # 1) שמירה על יחס PnL / Drawdown / Sharpe
            try:
                if k is None:
                    k = _compute_kpis_from_history(hist)
                total_pnl = float(k.get("total_pnl") or 0.0)
                avg_sharpe = float(k.get("avg_sharpe") or 0.0) if k.get("avg_sharpe") is not None else 0.0
                max_dd = float(k.get("max_dd") or 0.0) if k.get("max_dd") is not None else 0.0

                if avg_sharpe < 0.7 and total_pnl > 0:
                    notes.append("Sharpe נמוך ביחס ל-PnL חיובי – כדאי לבדוק אם חלק גדול מהרווח מגיע מתקופה קצרה/קטע ספציפי.")
                if max_dd < -15:
                    notes.append("Drawdown היסטורי עמוק (< -15%) – כדאי לבדוק תקופות/מקטעים שבהם המודל התרסק.")
            except Exception:
                pass

            # 2) פיצול הגיוני בין in-sample / out-of-sample (אם יש 'Fold'/'Set')
            try:
                fold_col = None
                for c in ("Fold", "fold", "Set", "set"):
                    if c in hist.columns:
                        fold_col = c
                        break
                if fold_col and "PnL" in hist.columns:
                    df_folds = hist.copy()
                    df_folds["PnL"] = pd.to_numeric(df_folds["PnL"], errors="coerce")
                    fold_stats = df_folds.groupby(fold_col)["PnL"].agg(["count", "mean", "sum"])
                    st.markdown("**ביצועים לפי Fold/Set**")
                    st.dataframe(fold_stats, width="stretch", height=220)
                    if fold_stats.shape[0] >= 2:
                        best_fold = fold_stats["mean"].idxmax()
                        worst_fold = fold_stats["mean"].idxmin()
                        notes.append(
                            f"ביצועים משתנים בין folds – Fold טוב במיוחד: {best_fold} | חלש: {worst_fold}. "
                            "פערים גדולים יכולים להיות רמז ל-Overfitting."
                        )
                else:
                    st.caption("לא נמצא Fold/Set בנתונים – אין חלוקה טבעית ל-in/out sample.")
            except Exception:
                st.caption("fold-based stability checks unavailable (אבל Insights עדיין תקפים).")

            # 3) הערות rule-based נשענות על Risk Engine
            try:
                hist_bt = _load_backtest_history()
                limits = get_risk_limits_from_config()
                state = _estimate_risk_state_from_history(hist_bt) if hist_bt is not None else RiskState(None, None, None, None, None, None, None)
                decision = evaluate_kill_switch(state, limits)
                if decision.enabled:
                    notes.append("Risk Engine מסמן טריגר ל-Kill-Switch – חשוב להתייחס לרמת סיכון גם בהייטונינג של פרמטרים.")
            except Exception:
                pass

            if notes:
                st.markdown("**הערות יציבות/Overfitting (rule-based):**")
                for n in notes:
                    st.markdown(f"- {n}")
            else:
                st.caption("לא זוהו אינדיקציות חזקות ל-Overfitting לפי ההיוריסטיקות הפשוטות.")

    # ================== חלק 3.1 — HF-Grade PnL Distribution & Tail Risk ==================
    st.subheader("📈 PnL Distribution & Tail Risk (HF-grade)")

    with st.expander("PnL Distribution, Hit Ratio & Tail Events", expanded=False):
        hist = _load_backtest_history()
        if hist is None or hist.empty or "PnL" not in hist.columns:
            st.caption("אין נתוני PnL זמינים ב-history – לא ניתן לחשב התפלגות.")
        else:
            import numpy as np

            df_p = hist.copy()
            df_p["PnL"] = pd.to_numeric(df_p["PnL"], errors="coerce")
            pnl = df_p["PnL"].dropna().values
            if pnl.size == 0:
                st.caption("עמודת PnL ריקה – לא ניתן לחשב התפלגות.")
            else:
                mean_p = float(np.mean(pnl))
                std_p = float(np.std(pnl, ddof=1)) if pnl.size > 1 else 0.0
                hit_ratio = float((pnl > 0).mean())
                loss_ratio = float((pnl < 0).mean())
                if std_p > 0:
                    skew = float(((pnl - mean_p) ** 3).mean() / std_p**3)
                    kurt = float(((pnl - mean_p) ** 4).mean() / std_p**4)
                else:
                    skew = np.nan
                    kurt = np.nan

                c1, c2, c3, c4, c5 = st.columns(5)
                c1.metric("Mean PnL", f"{mean_p:,.2f}")
                c2.metric("Std PnL", f"{std_p:,.2f}")
                c3.metric("Hit ratio", f"{hit_ratio*100:.1f}%")
                c4.metric("Skewness", f"{skew:.2f}" if np.isfinite(skew) else "N/A")
                c5.metric("Kurtosis", f"{kurt:.2f}" if np.isfinite(kurt) else "N/A")

                # Worst 10 events
                st.markdown("**10 התוצאות הכי גרועות (Tail Events):**")
                df_p_sorted = df_p.sort_values("PnL").head(10)
                st.dataframe(df_p_sorted, use_container_width=True, height=220)

    # ================== חלק 3.2 — Regime-Based Performance Attribution ==================
    st.subheader("📊 Regime-Based Performance Attribution")

    with st.expander("Performance by Regime (אם קיים Regime ב-history)", expanded=False):
        hist = _load_backtest_history()
        if hist is None or hist.empty or "PnL" not in hist.columns:
            st.caption("אין נתוני PnL / Regime זמינים.")
        else:
            regime_col = None
            for c in ("Regime", "regime", "VolRegime", "vol_regime", "MatrixRegime", "matrix_regime"):
                if c in hist.columns:
                    regime_col = c
                    break
            if not regime_col:
                st.caption("לא נמצאה עמודת Regime ב-history – לא ניתן לנתח ביצועים לפי משטרים.")
            else:
                df_r = hist.copy()
                df_r["PnL"] = pd.to_numeric(df_r["PnL"], errors="coerce")
                agg_regime = df_r.groupby(regime_col)["PnL"].agg(
                    Count="count",
                    MeanPnL="mean",
                    TotalPnL="sum",
                )
                st.dataframe(agg_regime.sort_values("TotalPnL", ascending=False), use_container_width=True, height=260)

    # ================== חלק 3.3 — Strategy x Fold Stability Heatmap ==================
    st.subheader("🧬 Strategy × Fold Stability (Heatmap)")

    with st.expander("Strategy × Fold PnL / Stability", expanded=False):
        hist = _load_backtest_history()
        if hist is None or hist.empty or "PnL" not in hist.columns:
            st.caption("אין history עם Strategy/Fold – לא ניתן לבנות Heatmap.")
        else:
            strat_col = None
            fold_col = None
            for c in ("Strategy", "strategy", "STRATEGY"):
                if c in hist.columns:
                    strat_col = c
                    break
            for c in ("Fold", "fold", "Set", "set"):
                if c in hist.columns:
                    fold_col = c
                    break
            if not strat_col or not fold_col:
                st.caption("לא נמצאו גם Strategy וגם Fold ב-history – לא ניתן לבנות Heatmap.")
            else:
                df_sf = hist.copy()
                df_sf["PnL"] = pd.to_numeric(df_sf["PnL"], errors="coerce")
                pivot = df_sf.pivot_table(
                    index=strat_col,
                    columns=fold_col,
                    values="PnL",
                    aggfunc="mean",
                )
                st.dataframe(pivot, use_container_width=True, height=260)
                try:
                    import plotly.express as px  # type: ignore

                    fig_sf = px.imshow(
                        pivot,
                        text_auto=False,
                        aspect="auto",
                        title="Strategy × Fold Mean PnL",
                    )
                    st.plotly_chart(fig_sf, use_container_width=True)
                except Exception:
                    st.caption("Plotly heatmap לא זמין – מציג רק טבלה.")

    # ================== חלק 3.4 — Insights ↔ Risk Engine Action Panel ==================
    st.subheader("🧭 Insights ↔ Risk Engine – Action Panel")

    with st.expander("Suggested Actions לפי Matrix Regime + Risk Engine", expanded=False):
        actions: List[str] = []

        # Matrix regime side (אם קיים)
        crowded = None
        drift_label = None
        if mx_ins:
            crowded = mx_ins.get("crowded_regime")
            drift_label = mx_ins.get("drift_label")

        # Risk engine state/decision
        risk_decision = None
        try:
            hist_bt = _load_backtest_history()
            limits = get_risk_limits_from_config()
            state = _estimate_risk_state_from_history(hist_bt) if hist_bt is not None else RiskState(None, None, None, None, None, None, None)
            risk_decision = evaluate_kill_switch(state, limits)
        except Exception:
            pass

        # Rule-of-thumb suggestions
        if crowded == "Highly Crowded":
            actions.append("להוריד מינוף נטו ולהקטין חשיפה לזוגות עם קורלציה גבוהה במיוחד (cluster size גדול).")
            actions.append("לשקול הוספת pairs עם קורלציה נמוכה/שלילית כדי להגדיל פיזור.")
        elif crowded == "Crowded":
            actions.append("לבדוק תלות חזקה בין אסטרטגיות/זוגות – האם הרבה אסטרטגיות נשענות על אותו מבנה שוק.")
        elif crowded == "Fragmented":
            actions.append("שוק מפוזר – אפשר לשקול להרחיב universe ולהגדיל מספר הזוגות הפעילים (אם הסיכון מאפשר).")

        if drift_label == "Drifting":
            actions.append("המטריצה חווה drift חזק – לוודא שהמודלים מתעדכנים, "
                           "ש-weighting לא נשען על היסטוריה ישנה מדי, ולשקול התאמת פרמטרים.")
        elif drift_label == "Transition":
            actions.append("המטריצה במצב מעבר – כדאי להיות זהיר עם הגדלת מינוף/סיכון עד שהמבנה יתייצב.")

        if risk_decision and getattr(risk_decision, "enabled", False):
            actions.append("Risk Engine מסמן Kill-Switch פעיל – להתייחס ברצינות להורדת חשיפה / עצירת אסטרטגיות חלשות.")

        if not actions:
            st.caption("לא זוהו כרגע המלצות חדות – Matrix Regime ו-Risk Engine לא מצביעים על בעיה חריגה.")
        else:
            for a in actions:
                st.markdown(f"- {a}")

    # ================== חלק 4 — Export & Notes for Insights ==================
    st.subheader("📦 Export & Notes for Insights Run")

    with st.expander("Insights Run Snapshot & Export", expanded=False):
        try:
            # Snapshot של הקונפיג + Matrix Regime summary קצר
            matrix_snapshot = None
            if mx_ins:
                matrix_snapshot = {
                    "mean_corr": mx_ins.get("mean_corr"),
                    "crowded_regime": mx_ins.get("crowded_regime"),
                    "drift_score": mx_ins.get("drift_score"),
                    "drift_label": mx_ins.get("drift_label"),
                }

            cfg = {
                "experiment_name": experiment_name,
                "shap_top": int(ctrl_ins["shap_top"]),
                "importance_threshold": float(ctrl_ins["importance_threshold"]),
                "ctx_section": ctx_section,
                "ctx_dates": ctx_dates,
                "FF_SHAP_ENABLE": get_feature_flags().get("FF_SHAP_ENABLE", True),
                "matrix_snapshot": matrix_snapshot,
            }
            st.download_button(
                "🧾 Insights Params (JSON)",
                json.dumps(make_json_safe(cfg), ensure_ascii=False, indent=2).encode("utf-8"),
                file_name=f"insights_params_{st.session_state.get('run_id','')}.json",
                mime="application/json",
                key=keygen("dl", "ins_params"),
            )

            # Export מלא של global_insights (כולל matrix ועוד בעתיד)
            if isinstance(gi, dict) and gi:
                st.download_button(
                    "🌐 Global Insights Snapshot (full JSON)",
                    json.dumps(make_json_safe(gi), ensure_ascii=False, indent=2).encode("utf-8"),
                    file_name=f"global_insights_{st.session_state.get('run_id','')}.json",
                    mime="application/json",
                    key=keygen("dl", "global_insights"),
                )
        except Exception:
            pass

        # שדה הערות ספציפי ל-Insights
        notes_key = keygen("ins_notes", f"{TODAY}")
        if notes_key not in st.session_state:
            st.session_state[notes_key] = ""

        insights_note = st.text_area(
            "הערות/מסקנות ל-Insights Run הנוכחי",
            key=notes_key,
            height=120,
            help="כאן אתה יכול לכתוב Bullet Points על מה למדת, אילו פרמטרים משנים, ומה לשנות לקראת הריצה הבאה.",
        )
        # הערך נשמר אוטומטית ב-session_state[notes_key]


# ---- Tab 8: Optimization ----
with app_tabs[8]:
    st.markdown("### ⚙️ אופטימיזציה – Optuna & Meta-Optimization (Experiment Lab ברמת קרן)")

    pairs_all = get_pairs(False)

    # ================== חלק 1 — Controls, Presets & Experiment Context ==================
    col_left, col_right = st.columns([1, 2])

    # ------- עזר פנימי: עורך טווחי חיפוש (search space) לפרמטרים -------
    def _build_opt_param_ranges():
        """
        עורך טווחי חיפוש ל-Optuna עבור פרמטרים מרכזיים.

        הפלט:
            param_ranges[name] = {"min": float, "max": float}
        """
        ranges = {}

        with st.expander("🔍 טווחי חיפוש (Search Space) לפרמטרים", expanded=False):
            st.caption(
                "הטווחים האלו עוברים ל-optimization_tab דרך controls['param_ranges'], "
                "ויכולים לשמש לבניית search space של Optuna."
            )

            # חלוקת הפרמטרים לקבוצות לוגיות – נוח לעבודה
            st.markdown("**Entry / Exit / Targets**")
            c1, c2, c3 = st.columns(3)
            with c1:
                entry_z_min = st.number_input(
                    "entry_z – מינ'",
                    value=1.0,
                    step=0.1,
                    key=keygen("t8_ranges", "entry_z_min"),
                )
                exit_z_min = st.number_input(
                    "exit_z – מינ'",
                    value=0.0,
                    step=0.1,
                    key=keygen("t8_ranges", "exit_z_min"),
                )
            with c2:
                entry_z_max = st.number_input(
                    "entry_z – מקס'",
                    value=4.0,
                    step=0.1,
                    key=keygen("t8_ranges", "entry_z_max"),
                )
                exit_z_max = st.number_input(
                    "exit_z – מקס'",
                    value=2.0,
                    step=0.1,
                    key=keygen("t8_ranges", "exit_z_max"),
                )
            with c3:
                take_z_min = st.number_input(
                    "take_z – מינ'",
                    value=2.0,
                    step=0.1,
                    key=keygen("t8_ranges", "take_z_min"),
                )
                take_z_max = st.number_input(
                    "take_z – מקס'",
                    value=8.0,
                    step=0.1,
                    key=keygen("t8_ranges", "take_z_max"),
                )

            ranges["entry_z"] = {"min": float(entry_z_min), "max": float(max(entry_z_min, entry_z_max))}
            ranges["exit_z"] = {"min": float(exit_z_min), "max": float(max(exit_z_min, exit_z_max))}
            ranges["take_z"] = {"min": float(take_z_min), "max": float(max(take_z_min, take_z_max))}

            st.markdown("---")
            st.markdown("**Mean-Reversion / Stat-Arb Parameters**")
            c4, c5, c6 = st.columns(3)
            with c4:
                z_win_min = st.number_input(
                    "z_window – מינ' (ימים)",
                    value=10.0,
                    step=1.0,
                    key=keygen("t8_ranges", "zwin_min"),
                )
                hl_min_min = st.number_input(
                    "hl_min – מינ' (ימים)",
                    value=1.0,
                    step=1.0,
                    key=keygen("t8_ranges", "hlmin_min"),
                )
            with c5:
                z_win_max = st.number_input(
                    "z_window – מקס' (ימים)",
                    value=90.0,
                    step=1.0,
                    key=keygen("t8_ranges", "zwin_max"),
                )
                hl_min_max = st.number_input(
                    "hl_min – מקס' (ימים)",
                    value=60.0,
                    step=1.0,
                    key=keygen("t8_ranges", "hlmin_max"),
                )
            with c6:
                coint_p_min = st.number_input(
                    "p-value min (cointegration)",
                    value=0.001,
                    step=0.001,
                    key=keygen("t8_ranges", "cointp_min"),
                )
                coint_p_max = st.number_input(
                    "p-value max (cointegration)",
                    value=0.10,
                    step=0.001,
                    key=keygen("t8_ranges", "cointp_max"),
                )

            ranges["z_window"] = {"min": float(z_win_min), "max": float(max(z_win_min, z_win_max))}
            ranges["hl_min"] = {"min": float(hl_min_min), "max": float(max(hl_min_min, hl_min_max))}
            ranges["coint_p"] = {"min": float(coint_p_min), "max": float(max(coint_p_min, coint_p_max))}

            st.markdown("---")
            st.markdown("**Risk & Execution (Slippage / Fees / Positions)**")
            c7, c8, c9 = st.columns(3)
            with c7:
                slippage_min = st.number_input(
                    "slippage_bps – מינ'",
                    value=0.0,
                    step=0.5,
                    key=keygen("t8_ranges", "slip_min"),
                )
                fee_min = st.number_input(
                    "fee_bps – מינ'",
                    value=0.0,
                    step=0.5,
                    key=keygen("t8_ranges", "fee_min"),
                )
            with c8:
                slippage_max = st.number_input(
                    "slippage_bps – מקס'",
                    value=10.0,
                    step=0.5,
                    key=keygen("t8_ranges", "slip_max"),
                )
                fee_max = st.number_input(
                    "fee_bps – מקס'",
                    value=5.0,
                    step=0.5,
                    key=keygen("t8_ranges", "fee_max"),
                )
            with c9:
                max_pos_min = st.number_input(
                    "max_positions – מינ'",
                    value=1.0,
                    step=1.0,
                    key=keygen("t8_ranges", "maxpos_min"),
                )
                max_pos_max = st.number_input(
                    "max_positions – מקס'",
                    value=30.0,
                    step=1.0,
                    key=keygen("t8_ranges", "maxpos_max"),
                )

            ranges["slippage_bps"] = {"min": float(slippage_min), "max": float(max(slippage_min, slippage_max))}
            ranges["fee_bps"] = {"min": float(fee_min), "max": float(max(fee_min, fee_max))}
            ranges["max_positions"] = {"min": float(max_pos_min), "max": float(max(max_pos_min, max_pos_max))}

            st.markdown("---")
            st.markdown("**Walk-Forward & Rebalancing**")
            c10, c11, c12 = st.columns(3)
            with c10:
                reb_min = st.number_input(
                    "rebalance_days – מינ'",
                    value=1.0,
                    step=1.0,
                    key=keygen("t8_ranges", "reb_min"),
                )
                wf_min = st.number_input(
                    "wf_folds – מינ'",
                    value=1.0,
                    step=1.0,
                    key=keygen("t8_ranges", "wf_min"),
                )
            with c11:
                reb_max = st.number_input(
                    "rebalance_days – מקס'",
                    value=30.0,
                    step=1.0,
                    key=keygen("t8_ranges", "reb_max"),
                )
                wf_max = st.number_input(
                    "wf_folds – מקס'",
                    value=8.0,
                    step=1.0,
                    key=keygen("t8_ranges", "wf_max"),
                )
            with c12:
                warmup_min = st.number_input(
                    "warmup_days – מינ'",
                    value=30.0,
                    step=5.0,
                    key=keygen("t8_ranges", "wu_min"),
                )
                warmup_max = st.number_input(
                    "warmup_days – מקס'",
                    value=240.0,
                    step=5.0,
                    key=keygen("t8_ranges", "wu_max"),
                )

            ranges["rebalance_days"] = {"min": float(reb_min), "max": float(max(reb_min, reb_max))}
            ranges["wf_folds"] = {"min": float(wf_min), "max": float(max(wf_min, wf_max))}
            ranges["warmup_days"] = {"min": float(warmup_min), "max": float(max(warmup_min, warmup_max))}

        return ranges

    # ------- עזר פנימי: לוג Timeline לריצות אופטימיזציה -------
    def _log_opt_run_to_timeline(ctx_obj, ctrl: dict) -> None:
        try:
            tl = st.session_state.get("opt_runs_timeline", [])
            if not isinstance(tl, list):
                tl = []
            tl.append(
                {
                    "ts": datetime.now().isoformat(timespec="seconds"),
                    "run_id": ctx_obj.run_id,
                    "section": ctx_obj.section,
                    "start": str(ctx_obj.start_date),
                    "end": str(ctx_obj.end_date),
                    "n_trials": int(ctrl.get("n_trials", 0) or 0),
                    "timeout_min": int(ctrl.get("timeout_min", 0) or 0),
                    "direction": ctrl.get("direction", "maximize"),
                    "opt_mode": ctrl.get("opt_mode", "Universe / Top Pairs"),
                    "experiment_name": ctrl.get("experiment_name", ""),
                }
            )
            st.session_state["opt_runs_timeline"] = tl
        except Exception:
            pass

    with col_left:
        # טווח תאריכים שבו נשתמש לדאטה (למשל בחישובי objective)
        start_date, end_date = date_range_picker("אופטימיזציה — טווח תאריכים", 365, "t8")

        # ------------------ Presets — הגדרות מוכנות ------------------
        st.markdown("**Optimization Presets**")
        pcol1, pcol2, pcol3, pcol4, pcol5 = st.columns(5)

        with pcol1:
            if st.button("Quick Scan", key=keygen("opt", "preset_quick")):
                st.session_state[keygen("t8", "trials")] = 50
                st.session_state[keygen("t8", "to")] = 5
                st.session_state[keygen("t8", "dir")] = "maximize"
                st.success("Preset 'Quick Scan' הוחל (50 ניסויים / 5 דקות).")

        with pcol2:
            if st.button("Deep Search", key=keygen("opt", "preset_deep")):
                st.session_state[keygen("t8", "trials")] = 300
                st.session_state[keygen("t8", "to")] = 60
                st.session_state[keygen("t8", "dir")] = "maximize"
                st.success("Preset 'Deep Search' הוחל (300 ניסויים / 60 דקות).")

        with pcol3:
            if st.button("Risk-Off Tune", key=keygen("opt", "preset_riskoff")):
                st.session_state[keygen("t8", "trials")] = 100
                st.session_state[keygen("t8", "to")] = 20
                st.session_state[keygen("t8", "dir")] = "maximize"
                st.success("Preset 'Risk-Off Tune' הוחל (100 ניסויים / 20 דקות).")

        with pcol4:
            if st.button("Robust WF", key=keygen("opt", "preset_robust")):
                st.session_state[keygen("t8", "trials")] = 150
                st.session_state[keygen("t8", "to")] = 30
                st.session_state[keygen("t8", "dir")] = "maximize"
                st.session_state[keygen("t8_ranges", "wf_min")] = 3.0
                st.session_state[keygen("t8_ranges", "wf_max")] = 8.0
                st.success("Preset 'Robust WF' הוחל (דגש על Walk-Forward יציב).")

        with pcol5:
            if st.button("Tail-Risk Focus", key=keygen("opt", "preset_tail")):
                st.session_state[keygen("t8", "trials")] = 120
                st.session_state[keygen("t8", "to")] = 25
                st.session_state[keygen("t8", "dir")] = "maximize"
                st.success("Preset 'Tail-Risk Focus' הוחל (פוקוס על DD / Tail).")

        # ------------------ Core контролים לאופטימיזציה ------------------
        st.markdown("**Core Optimization Controls**")
        core_cols = st.columns(3)
        with core_cols[0]:
            n_trials = int(
                st.number_input(
                    "מס' ניסויים (Optuna)",
                    min_value=10,
                    max_value=5000,
                    value=int(st.session_state.get(keygen("t8", "trials"), 50)),
                    step=10,
                    key=keygen("t8", "trials_input"),
                )
            )
        with core_cols[1]:
            timeout_min = int(
                st.number_input(
                    "Timeout (דקות)",
                    min_value=1,
                    max_value=720,
                    value=int(st.session_state.get(keygen("t8", "to"), 10)),
                    step=1,
                    key=keygen("t8", "timeout_input"),
                )
            )
        with core_cols[2]:
            direction = st.selectbox(
                "כיוון אופטימיזציה",
                ["maximize", "minimize"],
                index=0,
                key=keygen("t8", "direction_input"),
            )

        # נשמור גם ב-session_state כדי שיהיה תאום בין Presets / controls
        st.session_state[keygen("t8", "trials")] = n_trials
        st.session_state[keygen("t8", "to")] = timeout_min
        st.session_state[keygen("t8", "dir")] = direction

        # טווחי חיפוש לפרמטרים (search space)
        param_ranges = _build_opt_param_ranges()

        # הגדרות מנוע מתקדמות – Multi-objective, Robustness וכו'
        st.markdown("**Advanced Engine Controls**")
        with st.expander("🧠 Multi-Objective / Robustness / Engine", expanded=False):
            a1, a2, a3 = st.columns(3)
            with a1:
                primary_objective = st.selectbox(
                    "Objective ראשי",
                    ["Sharpe", "Sortino", "Calmar", "Return", "TailRisk"],
                    index=0,
                    key=keygen("t8", "obj_primary"),
                )
            with a2:
                secondary_objective = st.selectbox(
                    "Objective משני (אופציונלי)",
                    ["(None)", "MaxDD", "Volatility", "Trades", "RobustScore"],
                    index=0,
                    key=keygen("t8", "obj_secondary"),
                )
            with a3:
                secondary_weight = st.number_input(
                    "Weight למשני (0–1)",
                    min_value=0.0,
                    max_value=1.0,
                    value=0.25,
                    step=0.05,
                    key=keygen("t8", "obj_secondary_w"),
                )

            r1, r2, r3 = st.columns(3)
            with r1:
                wf_use = st.checkbox(
                    "להשתמש ב-Walk-Forward בתוך Optuna",
                    value=True,
                    key=keygen("t8", "wf_use"),
                )
            with r2:
                robust_min_folds = st.number_input(
                    "מינ' folds לעמידות",
                    min_value=1,
                    max_value=12,
                    value=3,
                    step=1,
                    key=keygen("t8", "robust_min_folds"),
                )
            with r3:
                robust_min_sharpe = st.number_input(
                    "Sharpe מינימום ב-WF",
                    min_value=-1.0,
                    max_value=3.0,
                    value=0.5,
                    step=0.1,
                    key=keygen("t8", "robust_min_sharpe"),
                )

            e1, e2, e3 = st.columns(3)
            with e1:
                sampler_type = st.selectbox(
                    "Sampler (Optuna)",
                    ["auto", "TPE", "Random", "Grid"],
                    index=0,
                    key=keygen("t8", "sampler"),
                )
            with e2:
                pruner_type = st.selectbox(
                    "Pruner",
                    ["none", "median", "successive_halving"],
                    index=1,
                    key=keygen("t8", "pruner"),
                )
            with e3:
                max_concurrent = st.number_input(
                    "Max concurrent trials (hint)",
                    min_value=1,
                    max_value=32,
                    value=4,
                    step=1,
                    key=keygen("t8", "max_concurrent"),
                )

        # כעת נבנה את ה-controls (כולל הכל) להעברה למנוע האופטימיזציה
        ctrl_opt_full = {
            "n_trials": n_trials,
            "timeout_min": timeout_min,
            "direction": direction,
            "param_ranges": param_ranges,
            "primary_objective": primary_objective,
            "secondary_objective": secondary_objective if secondary_objective != "(None)" else None,
            "secondary_objective_weight": float(secondary_weight),
            "wf_use": bool(wf_use),
            "robust_min_folds": int(robust_min_folds),
            "robust_min_sharpe": float(robust_min_sharpe),
            "sampler_type": sampler_type,
            "pruner_type": pruner_type,
            "max_concurrent_trials": int(max_concurrent),
            **st.session_state.get("risk_capital", {}),
        }

        # שם ניסוי – חשוב לתיעוד ול-timeline
        opt_experiment_name = st.text_input(
            "שם ניסוי אופטימיזציה (Experiment Name)",
            value=st.session_state.get("opt_experiment_name", ""),
            key=keygen("opt", "exp_name"),
            help="למשל: 'MR_30d_opt_v1', 'Sharpe_meta_fold3', 'VolTarget_experiment'.",
        )
        st.session_state["opt_experiment_name"] = opt_experiment_name
        if opt_experiment_name:
            ctrl_opt_full["experiment_name"] = opt_experiment_name

        # מצב אופטימיזציה – על כל ה-universe או על זוג אחד
        st.markdown("**Optimization Mode**")
        opt_mode = st.radio(
            "Target",
            ["Universe / Top Pairs", "זוג נבחר בלבד"],
            index=0,
            key=keygen("opt", "mode"),
            help="האם האופטימיזציה מכוונת לכל ה-universe או לזוג ספציפי מתוך selected_pair.",
        )
        ctrl_opt_full["opt_mode"] = opt_mode

        target_pair = None
        if opt_mode == "זוג נבחר בלבד":
            sp = st.session_state.get("selected_pair")
            if sp:
                target_pair = sp
            st.caption(f"Target Pair: `{target_pair or 'לא נבחר'}`")

        # בונים AppContext מלא
        ctx_opt = build_ctx(start_date, end_date, ctrl_opt_full, section="optimize")

        # Snapshot לפני ריצה (אם הפיצ'ר דולק)
        if get_feature_flags().get("FF_DOWNLOAD_REPORTS", True):
            save_run_snapshot("optimize", ctx_opt)

        st.markdown("**Optimization Context**")
        st.json(
            {
                "experiment_name": opt_experiment_name or "(לא הוגדר)",
                "dates": f"{ctx_opt.start_date} → {ctx_opt.end_date}",
                "capital": ctx_opt.capital,
                "max_exposure_per_trade": ctx_opt.max_exposure_per_trade,
                "max_leverage": ctx_opt.max_leverage,
                "n_trials": n_trials,
                "timeout_min": timeout_min,
                "direction": direction,
                "opt_mode": opt_mode,
                "target_pair": target_pair,
                "primary_objective": primary_objective,
                "secondary_objective": secondary_objective,
            }
        )

        # מתג למטה: האם לאפשר Meta-Optimization (אם הדגל דולק ב-Feature Flags)
        ff = get_feature_flags()
        if ff.get("FF_META_OPT", False):
            meta_enabled = st.checkbox(
                "הפעל Meta-Optimization (לדוגמה: אופטימיזציה של טווחי פרמטרים עצמם)",
                value=True,
                key=keygen("opt", "meta_en"),
            )
            ctrl_opt_full["meta_optimization_enabled"] = bool(meta_enabled)
        else:
            st.caption("Meta-Optimization כבוי (FF_META_OPT=False).")

    # צד ימין – ביצועים היסטוריים / הקשר למה לשפר
    with col_right:
        st.markdown("**Performance Snapshot – מה אנחנו מנסים לשפר?**")
        hist = _load_backtest_history()
        if hist is None or hist.empty:
            st.caption("אין backtest_history.csv – לקונטקסט היסטורי יש פחות משמעות כרגע.")
        else:
            k = _compute_kpis_from_history(hist)
            k1, k2, k3, k4 = st.columns(4)
            total_pnl = k.get("total_pnl")
            avg_sharpe = k.get("avg_sharpe")
            max_dd = k.get("max_dd")
            trades = k.get("trades")

            k1.metric("Total PnL (hist)", f"{total_pnl:,.0f}" if total_pnl is not None else "N/A")
            k2.metric("Avg Sharpe (hist)", f"{avg_sharpe:.2f}" if avg_sharpe is not None else "N/A")
            k3.metric("Max DD (hist)", f"{max_dd:.2f}" if max_dd is not None else "N/A")
            k4.metric("Trades (hist)", trades if trades else "N/A")

            with st.expander("High-Level Context (Strategies / Pairs)", expanded=False):
                try:
                    strat_col = None
                    for c in ("Strategy", "strategy", "STRATEGY"):
                        if c in hist.columns:
                            strat_col = c
                            break

                    if strat_col and "PnL" in hist.columns:
                        df_strat = hist.copy()
                        df_strat["PnL"] = pd.to_numeric(df_strat["PnL"], errors="coerce")
                        strat_stats = (
                            df_strat.groupby(strat_col)["PnL"]
                            .mean()
                            .sort_values(ascending=False)
                        )
                        st.markdown("**PnL ממוצע לפי Strategy**")
                        st.dataframe(
                            strat_stats.to_frame("MeanPnL"),
                            width="stretch",
                            height=220,
                        )
                    else:
                        st.caption("אין שדה Strategy ב-history – אין breakdown ברמת אסטרטגיה.")
                except Exception:
                    st.caption("Strategy breakdown unavailable (לא חובה לאופטימיזציה).")

    # ================== חלק 2 — Optimization Engine (optimization_tab.py) ==================
    st.markdown("### 🔬 Optimization Engine (optimization_tab.py) — Optuna / Meta-Opt / Grid Search")

    # לוג Timeline לריצה הנוכחית (לפני שאנו מריצים בפועל)
    try:
        _log_opt_run_to_timeline(ctx_opt, ctrl_opt_full)
    except Exception:
        pass

    # כאן אין כפתור Run – הכל מתרחש על כל rerun של הטאב; אפשר להוסיף כפתור בעתיד
    with st.spinner("⚙️ Running optimization…"):
        try:
            _render_optimization_tab_wrapper(
                start_date,
                end_date,
                controls=ctrl_opt_full,
                section="optimize",
            )
        except Exception as e:
            logger.exception(e)
            _report_exception(e, "Tab Optimize")
            st.error(f"❗ שגיאה בטאב אופטימיזציה: {e}")

    # ================== חלק 3 — Optimization Session Debug (opt_*) ==================
    st.subheader("🧭 Optimization Session Debug (opt_* keys)")

    with st.expander("opt_* Session State Keys", expanded=False):
        try:
            opt_keys = {
                k: v
                for k, v in st.session_state.items()
                if isinstance(k, str) and k.startswith("opt_")
            }
            if not opt_keys:
                st.caption("אין כרגע מפתחות session_state שמתחילים ב-'opt_' – ייתכן שה-optimization_tab לא שומר state בפורמט זה.")
            else:
                st.json(make_json_safe(opt_keys))
        except Exception as e:
            st.caption(f"Optimization session debug unavailable: {e}")

    # ================== חלק 4 — Diagnostics & Rule-Based Observations ==================
    st.subheader("🧪 Diagnostics & Observations (Rule-Based) – איכות הניסויים עד כה")

    with st.expander("תובנות כלליות על ריצות אופטימיזציה (מההיסטוריה)", expanded=False):
        hist = _load_backtest_history()
        if hist is None or hist.empty:
            st.caption("אין היסטוריית Backtest – אין מה להסיק על ריצות אופטימיזציה.")
        else:
            notes = []

            try:
                trades = int(len(hist))
                if trades < 50:
                    notes.append("נראה שהיו מעט טריידים / תוצאות – מומלץ להריץ עוד ניסויים לפני הסקת מסקנות.")
                elif trades > 1500:
                    notes.append("יש מספר גדול מאוד של טריידים – כדאי לוודא שזמן הריצה ודיסק נשארים בשליטה.")
            except Exception:
                pass

            try:
                fold_col = None
                for c in ("Fold", "fold", "Set", "set"):
                    if c in hist.columns:
                        fold_col = c
                        break
                if fold_col and "PnL" in hist.columns:
                    df_folds = hist.copy()
                    df_folds["PnL"] = pd.to_numeric(df_folds["PnL"], errors="coerce")
                    fold_stats = df_folds.groupby(fold_col)["PnL"].agg(["count", "mean", "sum"])
                    st.markdown("**ביצועים לפי Fold/Set (Walk-Forward Stability)**")
                    st.dataframe(fold_stats, width="stretch", height=220)
                    if fold_stats.shape[0] >= 2:
                        best_fold = fold_stats["mean"].idxmax()
                        worst_fold = fold_stats["mean"].idxmin()
                        notes.append(
                            f"Fold/Set הטוב ביותר: {best_fold} (mean PnL={fold_stats.loc[best_fold,'mean']:.2f}), "
                            f"החלש ביותר: {worst_fold}."
                        )
                else:
                    st.caption("לא נמצא Fold/Set בנתונים – אין חלוקה טבעית לבדיקת יציבות אופטימיזציה.")
            except Exception:
                st.caption("Fold-based diagnostics unavailable.")

            if notes:
                st.markdown("**Observations:**")
                for n in notes:
                    st.markdown(f"- {n}")
            else:
                st.caption("לא זוהו Observations מיוחדים ברמת מאקרו מה-history.")

    # ================== חלק 5 — Export & Snapshot for Optimization Runs ==================
    st.subheader("📦 Export — Optimization Params & Context")

    with st.expander("Export Optimization Setup", expanded=False):
        try:
            opt_cfg = {
                "experiment_name": st.session_state.get("opt_experiment_name", ""),
                "n_trials": int(ctrl_opt_full.get("n_trials", 50) or 50),
                "timeout_min": int(ctrl_opt_full.get("timeout_min", 10) or 10),
                "direction": ctrl_opt_full.get("direction", "maximize"),
                "primary_objective": ctrl_opt_full.get("primary_objective"),
                "secondary_objective": ctrl_opt_full.get("secondary_objective"),
                "secondary_objective_weight": ctrl_opt_full.get("secondary_objective_weight"),
                "ctx_section": ctx_opt.section,
                "ctx_dates": f"{ctx_opt.start_date} → {ctx_opt.end_date}",
                "capital": ctx_opt.capital,
                "max_exposure_per_trade": ctx_opt.max_exposure_per_trade,
                "max_leverage": ctx_opt.max_leverage,
                "param_ranges": ctrl_opt_full.get("param_ranges", {}),
            }
            st.download_button(
                "🧾 Optimization Params (JSON)",
                json.dumps(make_json_safe(opt_cfg), ensure_ascii=False, indent=2).encode("utf-8"),
                file_name=f"optimization_params_{ctx_opt.run_id}.json",
                mime="application/json",
                key=keygen("dl", "opt_params"),
            )

            md_opt = ctx_to_markdown(ctx_opt)
            st.download_button(
