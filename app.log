    raw = st.session_state.get("feature_flags", {})
    return dict(raw) if isinstance(raw, dict) else {}

def _build_backtest_manifest(ctx_bt, ctrl_bt_full: dict, last_row: Optional[pd.Series] = None) -> dict:
    """
    Manifest קומפקטי לריצת Backtest אחת – נשמר ב-session_state
    וניתן להורדה / חיבור ל-ML / Governance.
    """
    try:
        ctx_dict = asdict(ctx_bt)
    except Exception:
        ctx_dict = getattr(ctx_bt, "__dict__", {}) or {}

    manifest: Dict[str, Any] = {
        "timestamp_utc": datetime.utcnow().isoformat() + "Z",
        "section": "backtest",
        "run_id": ctx_dict.get("run_id"),
        "ctx": make_json_safe(ctx_dict),
        "controls": make_json_safe(ctrl_bt_full),
    }

    if last_row is not None:
        try:
            manifest["last_history_row"] = make_json_safe(last_row.to_dict())
        except Exception:
            pass

    return manifest

def st_df_safe(df: pd.DataFrame, **kwargs) -> None:
    """
    עטיפה ל-st.dataframe שהופכת עמודות בעייתיות (Value, default)
    לעמודות string כדי ש-PyArrow לא יקרוס.
    אם גם זה נכשל – נופלים לפול סטרינג על כל הטבלה.
    """
    df2 = df.copy()

    # עמודות שאנחנו יודעים שהן בעייתיות לפי הלוגים
    for col in ("Value", "default"):
        if col in df2.columns:
            df2[col] = df2[col].astype("string")

    try:
        st.dataframe(df2, **kwargs)
    except Exception:
        # אם עדיין יש בעיה – הכל נהיה string וזהו
        st.dataframe(df2.astype("string"), **kwargs)
def _compute_last_run_summary_from_history(hist: pd.DataFrame) -> Dict[str, Any]:
    """
    מנסה לבנות סיכום קצר לריצה האחרונה מתוך backtest_history (אם קיים).
    """
    summary: Dict[str, Any] = {
        "pair": None,
        "sharpe": None,
        "pnl": None,
        "max_dd": None,
        "trades": None,
        "run_id": None,
        "finished_at": None,
    }
    if hist is None or hist.empty:
        return summary

    df = hist.copy()
    # נניח שיש עמודות כמו RunID / PnL / Sharpe / MaxDD / Trades / Pair
    time_col = None
    for cand in ("FinishedAt", "finished_at", "end_time", "timestamp"):
        if cand in df.columns:
            time_col = cand
            break

    if time_col:
        df = df.sort_values(time_col)
        last = df.iloc[-1]
    else:
        last = df.iloc[-1]

    def g(col: str):
        return last[col] if col in df.columns else None

    summary["pair"] = g("Pair") or g("pair") or g("symbol_pair")
    summary["pnl"] = g("PnL") or g("pnl") or g("total_pnl")
    summary["sharpe"] = g("Sharpe") or g("sharpe")
    summary["max_dd"] = g("MaxDD") or g("max_dd")
    summary["trades"] = g("Trades") or g("trades") or g("n_trades")
    summary["run_id"] = g("RunID") or g("run_id")
    summary["finished_at"] = g(time_col) if time_col else None

    return summary

# ---- Tab 3: Backtest ----
def render_backtest_tab_v2() -> None:
    """
    Backtest Tab v2 — HF-grade

    • Presets (Smoke / Deep WF / Tail-risk / Fast debug)
    • Walk-forward / standard modes
    • Risk profile (conservative / balanced / aggressive)
    • Single pair + batch (Universe / Favorites)
    • A/B parameter comparison (שני סטים מתוך opt_df)
    • Tight integration with:
        - Optimization (opt_df / opt_params)
        - Risk Engine (Kill-Switch snapshot)
        - Insights / ML (bt_ml_bridge, bt_last_manifest)
        - Export Center (params / ctx / manifest)
    """
    st.markdown("### 📈 Backtest – סימולציות היסטוריות ברמת קרן")

    # ================== חלק 1 — Controls & Context ==================
    col_left, col_right = st.columns([1, 2])

    # -------- צד שמאל: קונטרולים, קונטקסט, מצב מתקדם --------
    with col_left:
        # טווח תאריכים לבק־טסט
        start_date, end_date = date_range_picker("Backtest — טווח תאריכים", 365, "t3")

        # ---------- Presets לפני ה־controls (משפיעים על ה-sliders) ----------
        st.markdown("**Backtest Presets (Quality / Depth / Risk)**")
        p1, p2, p3, p4 = st.columns(4)

        # Presets עובדים דרך session_state על המפתחות של controls_backtest (keygen("t3", ...))
        if p1.button("Smoke / Sanity", key=keygen("bt", "preset_smoke")):
            st.session_state[keygen("t3", "slip")] = 3.0
            st.session_state[keygen("t3", "fee")] = 1.0
            st.session_state[keygen("t3", "maxpos")] = 3
            st.session_state[keygen("t3", "reb")] = 10
            st.session_state[keygen("t3", "wf")] = 1
            st.session_state[keygen("t3", "wu")] = 30
            st.session_state[keygen("t3", "obj")] = "Sharpe"
            st.session_state[keygen("t3", "risk")] = "None"
            st.success("Preset 'Smoke / Sanity' הוחל (ריצה קלה ומהירה לבדיקה).")

        if p2.button("Deep WF", key=keygen("bt", "preset_deepwf")):
            st.session_state[keygen("t3", "slip")] = 2.0
            st.session_state[keygen("t3", "fee")] = 1.0
            st.session_state[keygen("t3", "maxpos")] = 8
            st.session_state[keygen("t3", "reb")] = 5
            st.session_state[keygen("t3", "wf")] = 5
            st.session_state[keygen("t3", "wu")] = 120
            st.session_state[keygen("t3", "obj")] = "Sharpe"
            st.session_state[keygen("t3", "risk")] = "Risk Parity"
            st.success("Preset 'Deep WF' הוחל (Walk-Forward עמוק ויציב).")

        if p3.button("Tail-Risk Focus", key=keygen("bt", "preset_tail")):
            st.session_state[keygen("t3", "slip")] = 3.0
            st.session_state[keygen("t3", "fee")] = 2.0
            st.session_state[keygen("t3", "maxpos")] = 4
            st.session_state[keygen("t3", "reb")] = 7
            st.session_state[keygen("t3", "wf")] = 3
            st.session_state[keygen("t3", "wu")] = 90
            st.session_state[keygen("t3", "obj")] = "Calmar"
            st.session_state[keygen("t3", "risk")] = "Vol Target"
            st.success("Preset 'Tail-Risk Focus' הוחל (דגש על DD / זנב).")

        if p4.button("Fast Debug", key=keygen("bt", "preset_debug")):
            st.session_state[keygen("t3", "slip")] = 1.0
            st.session_state[keygen("t3", "fee")] = 0.0
            st.session_state[keygen("t3", "maxpos")] = 2
            st.session_state[keygen("t3", "reb")] = 3
            st.session_state[keygen("t3", "wf")] = 1
            st.session_state[keygen("t3", "wu")] = 20
            st.session_state[keygen("t3", "obj")] = "Return"
            st.session_state[keygen("t3", "risk")] = "None"
            st.success("Preset 'Fast Debug' הוחל (ריצה קצרה לדיבוג/תיקונים).")

        st.markdown("---")

        # כעת בונים את ה-controls הרגילים (כבר כוללים slippage/fees/wf וכו')
        ctrl_bt = controls_backtest("t3")
        ctrl_bt_full = {
            **ctrl_bt,
            **st.session_state.get("risk_capital", {}),
        }

        # פיצ'רים מתקדמים לטאב Backtest (לא שוברים את המנוע, רק מעשירים את הקונטקסט)
        with st.expander("⚙️ Backtest Advanced Options", expanded=False):
            # 1) מצב Walk-Forward / רגיל (נשמר בקונטקסט, אפשר לחבר למנוע בהמשך)
            wf_mode = st.selectbox(
                "Backtest Mode",
                ["standard", "walk-forward"],
                index=0,
                help="standard = ריצה רגילה; walk-forward = חלונות מתגלגלים (למימוש הדרגתי במנוע).",
                key="t3_wf_mode",
            )

            # 2) פרופיל סיכון לבק־טסט (שמרני / רגיל / אגרסיבי) – נשמר בקונטקסט
            risk_profile = st.selectbox(
                "Risk Profile",
                ["conservative", "balanced", "aggressive"],
                index=1,
                help="הגדרה לוגית בלבד כרגע – אפשר למפות אותה לסייזינג / סטופים במנוע בק-טסט.",
                key="t3_risk_profile",
            )

            # 2.5) תיוג ריצה (label) – נכנס ל-ctx / manifest
            run_label = st.text_input(
                "Run label / Scenario tag (אופציונלי)",
                value=st.session_state.get("bt_run_label", ""),
                key="t3_run_label",
                help="לדוגמה: 'MR_30d_v3', 'WF_tail_risk', 'Stress_test_2025Q1'.",
            )
            st.session_state["bt_run_label"] = run_label

            # 3) חיבור לאופטימיזציה: שימוש בפרמטרים הטובים האחרונים
            use_opt_params = st.checkbox(
                "💡 Use last optimisation params (אם זמינים)",
                value=True,
                help="אם opt_df קיים, נשתמש בשורה הטובה ביותר כפרמטרים התחלתיים לבק-טסט.",
                key="t3_use_opt_params",
            )

            # 4) Batch Backtest – ריצה על כמה זוגות
            pairs_all = get_pairs(False)
            batch_pairs: List[str] = []
            if pairs_all:
                # לייבל קריא כמו בטאב Pair
                def _lbl(p: Any) -> str:
                    try:
                        if isinstance(p, dict):
                            if "pair" in p:
                                return str(p["pair"])
                            if "symbols" in p and isinstance(p["symbols"], (list, tuple)) and len(p["symbols"]) == 2:
                                return f"{p['symbols'][0]}-{p['symbols'][1]}"
                            if "sym_x" in p and "sym_y" in p:
                                return f"{p['sym_x']}-{p['sym_y']}"
                        if isinstance(p, (list, tuple)) and len(p) == 2:
                            return f"{p[0]}-{p[1]}"
                        return str(p)
                    except Exception:
                        return str(p)

                labels_all = [_lbl(p) for p in pairs_all]

                # מקור רשימת הזוגות לבאצ': Universe / Favorites / Important
                pair_flags = st.session_state.get("pair_flags", {}) or {}
                favorites_raw = []
                if isinstance(pair_flags, dict):
                    for key in ("favorite", "important"):
                        val = pair_flags.get(key)
                        if isinstance(val, list):
                            favorites_raw.extend(val)
                favorites = sorted(set(map(str, favorites_raw)))

                batch_source = st.radio(
                    "מקור זוגות לבאצ׳",
                    ["Universe", "Favorites (Pair Intelligence)"] if favorites else ["Universe"],
                    index=0,
                    key="t3_batch_source",
                    help="אם קיימים favorite/important pairs מפאנל Pair Intelligence – אפשר להריץ עליהם באצʼ.",
                )

                enable_batch = st.checkbox(
                    "🧪 Batch Backtest (מספר זוגות ברצף)",
                    value=False,
                    key="t3_enable_batch",
                )
                if enable_batch:
                    if batch_source.startswith("Favorites") and favorites:
                        default_labels = [
                            p for p in labels_all if p in favorites
                        ][: min(5, len(favorites))] or labels_all[: min(5, len(labels_all))]
                        options = [p for p in labels_all if p in favorites] or labels_all
                    else:
                        default_labels = labels_all[: min(5, len(labels_all))]
                        options = labels_all

                    batch_pairs = st.multiselect(
                        "בחר זוגות לבאצ׳ (Backtest sequential)",
                        options=options,
                        default=default_labels,
                        help="הרצה ברצף של ה-Backtest על מספר זוגות. ברירת המחדל – 5 זוגות ראשונים.",
                        key="t3_batch_pairs",
                    )
            else:
                enable_batch = False

            # 5) דגל Auto-save ל־history / DuckDB (כרגע לוגי בלבד, למנוע בעתיד)
            auto_persist = st.checkbox(
                "Persist backtest runs to history/DB (אם זמין במנוע)",
                value=True,
                key="t3_auto_persist",
            )

            # 6) Seed: אוטומטי מול קבוע (לרנדומיזציה בק־טסט)
            auto_seed = st.checkbox(
                "Use auto-seed per run",
                value=False,
                help="אם פעיל – נבחר seed שונה לכל הרצה (במקום seed קבוע מה-ctx).",
                key="t3_auto_seed",
            )

        # בניית ctx עם התוספות הלוגיות
        ctx_bt = build_ctx(start_date, end_date, ctrl_bt_full, section="backtest")
        ctx_bt_dict = asdict(ctx_bt)
        ctx_bt_dict["backtest_mode"] = wf_mode
        ctx_bt_dict["risk_profile"] = risk_profile
        ctx_bt_dict["auto_persist"] = auto_persist
        ctx_bt_dict["enable_batch"] = enable_batch
        ctx_bt_dict["batch_pairs"] = batch_pairs
        ctx_bt_dict["run_label"] = run_label

        # Snapshot לפני הרצה (אם הפיצ'ר דולק)
        if get_feature_flags().get("FF_DOWNLOAD_REPORTS", True):
            save_run_snapshot("backtest", ctx_bt)

        # הצגת פרטי הקשר (Context) בקצרה
        st.markdown("**Context Summary**")
        st.json(
            {
                "dates": f"{ctx_bt.start_date} → {ctx_bt.end_date}",
                "capital": ctx_bt.capital,
                "max_exposure_per_trade": ctx_bt.max_exposure_per_trade,
                "max_leverage": ctx_bt.max_leverage,
                "seed": ctx_bt.seed,
                "run_id": ctx_bt.run_id,
                "mode": wf_mode,
                "risk_profile": risk_profile,
                "run_label": run_label or "(none)",
            }
        )

        # מיני-פאנל Risk Engine (Kill-Switch) על בסיס ההיסטוריה
        try:
            hist_for_risk = _load_backtest_history()
            if hist_for_risk is not None and not hist_for_risk.empty:
                limits = get_risk_limits_from_config()
                state = _estimate_risk_state_from_history(hist_for_risk)
                decision = evaluate_kill_switch(state, limits)

                r1, r2, r3 = st.columns(3)
                r1.metric(
                    "Daily PnL (%)",
                    f"{(state.daily_pnl_pct or 0)*100:.2f}%"
                    if state.daily_pnl_pct is not None
                    else "N/A",
                )
                r2.metric(
                    "Max DD (%)",
                    f"{(state.max_dd_pct or 0)*100:.2f}%"
                    if state.max_dd_pct is not None
                    else "N/A",
                )
                r3.metric("Kill-Switch", "ON" if decision.enabled else "OFF")
                if decision.enabled:
                    st.warning(f"Kill-Switch logical trigger: {decision.reason}")
        except Exception:
            # לא מפילים את הטאב אם Risk Engine לא זמין
            pass

        # בחירת זוג מועדף ל-Backtest (אם הוא מוגדר)
        sp = st.session_state.get("selected_pair")
        if sp:
            st.caption(f"Selected pair for focus: `{sp}` (ניתן להתחשב בו בשלב ההרצה).")
        else:
            st.caption("לא נבחר עדיין זוג ספציפי ל-Backtest (selected_pair).")

    # -------- צד ימין: היסטוריה גלובלית + KPI גלובלי --------
    with col_right:
        hist = _load_backtest_history()
        st.markdown("**Backtest History Snapshot (גלובלי)**")
        if hist is None or hist.empty:
            st.caption("אין עדיין היסטוריית Backtest (backtest_history.csv).")
        else:
            # פילטרים לוגיים (Pair + טווח תאריכים) על history – UX
            with st.expander("🔎 פילטרים על היסטוריית Backtest", expanded=False):
                pair_col_hist = None
                for c in ("Pair", "pair", "PAIR"):
                    if c in hist.columns:
                        pair_col_hist = c
                        break

                df_hist_view = hist.copy()

                if pair_col_hist:
                    pairs_hist = (
                        df_hist_view[pair_col_hist]
                            .dropna()
                            .astype(str)
                            .unique()
                            .tolist()
                    )
                    pairs_hist = sorted(pairs_hist)
                    sel_pairs_hist = st.multiselect(
                        "סינון לפי זוגות",
                        options=pairs_hist,
                        default=pairs_hist[: min(10, len(pairs_hist))],
                        key="t3_hist_pairs",
                    )
                    if sel_pairs_hist:
                        df_hist_view = df_hist_view[
                            df_hist_view[pair_col_hist].isin(sel_pairs_hist)
                        ]

                # סינון לפי Sharpe / תאריך אם קיימות עמודות
                if "Sharpe" in df_hist_view.columns:
                    min_sh = st.slider(
                        "Sharpe מינימלי להיסטוריה",
                        min_value=float(df_hist_view["Sharpe"].min()),
                        max_value=float(df_hist_view["Sharpe"].max()),
                        value=float(df_hist_view["Sharpe"].min()),
                        step=0.1,
                        key="t3_hist_sharpe_min",
                    )
                    df_hist_view = df_hist_view[
                        df_hist_view["Sharpe"] >= min_sh
                    ]

                st.dataframe(df_hist_view.tail(200), width="stretch", height=220)

                # הורדת היסטוריה מסוננת (נוח לניתוח מהיר)
                st.download_button(
                    "💾 Download filtered history (CSV)",
                    df_hist_view.to_csv(index=False).encode("utf-8"),
                    file_name="backtest_history_filtered_tab3.csv",
                    mime="text/csv",
                    key="t3_hist_filtered_dl",
                )

            # KPI-ים גלובליים
            kps = _compute_kpis_from_history(hist)
            k1, k2, k3, k4 = st.columns(4)
            total_pnl = kps.get("total_pnl")
            avg_sharpe = kps.get("avg_sharpe")
            max_dd = kps.get("max_dd")
            trades = kps.get("trades")

            k1.metric(
                "Total PnL (hist)",
                f"{total_pnl:,.0f}" if total_pnl is not None else "N/A",
            )
            k2.metric(
                "Avg Sharpe (hist)",
                f"{avg_sharpe:.2f}" if avg_sharpe is not None else "N/A",
            )
            k3.metric(
                "Max DD (hist)",
                f"{max_dd:.2f}" if max_dd is not None else "N/A",
            )
            k4.metric("Trades (hist)", trades if trades else "N/A")

            # Top pairs מההיסטוריה
            with st.expander("Top Backtest Pairs (hist)", expanded=False):
                try:
                    pair_col = None
                    for c in ("Pair", "pair", "PAIR"):
                        if c in hist.columns:
                            pair_col = c
                            break
                    if pair_col and "PnL" in hist.columns:
                        df_top_pairs = (
                            hist.groupby(pair_col)["PnL"]
                                .sum()
                                .sort_values(ascending=False)
                                .head(10)
                        )
                        st.dataframe(
                            df_top_pairs.to_frame("TotalPnL"),
                            width="stretch",
                            height=220,
                        )

                        # לחיצה על זוג מעדכנת selected_pair – UX מקשר לטאבים אחרים
                        sel_from_hist = st.selectbox(
                            "בחר זוג מההיסטוריה לעדכון selected_pair",
                            options=df_top_pairs.index.tolist(),
                            key="t3_hist_pair_select",
                        )
                        if st.button(
                            "🔁 עדכן selected_pair מההיסטוריה",
                            key="t3_hist_set_pair",
                        ):
                            st.session_state["selected_pair"] = sel_from_hist
                            st.success(
                                f"selected_pair עודכן ל-{sel_from_hist}. עבור לטאב Pair / Backtest."
                            )
                    else:
                        st.caption("אין עמודת Pair/PnL מתאימה ב-history.")
                except Exception as e:
                    st.caption(f"Top pairs summary unavailable: {e}")

    # ================== חלק 2 — Run Backtest (core engine) ==================
    st.markdown("### 🏃 Run Backtest Engine")

    run_col1, run_col2 = st.columns([3, 1])

    with run_col1:
        # כפתורי הרצה ברורים – יחיד + באצ'
        run_single = st.button("▶ Run backtest (single pair)", key="t3_run_single")
        run_batch = (
            st.button("🧪 Run batch backtest (multi-pair)", key="t3_run_batch")
            if enable_batch
            else False
        )

        # ================== A/B PARAMETER COMPARISON (חדש) ==================
        st.markdown("#### 🔬 A/B parameter comparison (from optimisation table)")
        enable_ab = st.checkbox(
            "Enable A/B comparison (בחר שתי שורות מ-opt_df)",
            value=False,
            key="t3_ab_enable",
        )
        run_ab = False
        ab_selection: Dict[str, Any] = {}

        if enable_ab:
            opt_df_ab = st.session_state.get("opt_df")
            if isinstance(opt_df_ab, pd.DataFrame) and not opt_df_ab.empty:
                df_sorted = (
                    opt_df_ab.sort_values("Score", ascending=False)
                    if "Score" in opt_df_ab.columns
                    else opt_df_ab.copy()
                ).reset_index(drop=True)

                indices = list(range(len(df_sorted)))

                def _fmt_ab_row(i: int) -> str:
                    row = df_sorted.iloc[i]
                    score = row.get("Score", None)
                    sharpe = row.get("Sharpe", None)
                    parts = [f"#{i}"]
                    if score is not None and isinstance(score, (int, float)):
                        parts.append(f"Score={float(score):.3f}")
                    if sharpe is not None and isinstance(sharpe, (int, float)):
                        parts.append(f"Sharpe={float(sharpe):.2f}")
                    return " | ".join(parts)

                col_ab1, col_ab2 = st.columns(2)
                with col_ab1:
                    idx_a = st.selectbox(
                        "Row A (opt_df)",
                        options=indices,
                        index=0,
                        format_func=_fmt_ab_row,
                        key="t3_ab_idx_a",
                    )
                    label_a = st.text_input(
                        "Label A",
                        value="Config A",
                        key="t3_ab_label_a",
                    )
                with col_ab2:
                    idx_b = st.selectbox(
                        "Row B (opt_df)",
                        options=indices,
                        index=min(1, len(indices) - 1),
                        format_func=_fmt_ab_row,
                        key="t3_ab_idx_b",
                    )
                    label_b = st.text_input(
                        "Label B",
                        value="Config B",
                        key="t3_ab_label_b",
                    )

                run_ab = st.button(
                    "▶ Run A/B backtest compare",
                    key="t3_run_ab",
                    help="מריץ שתי ריצות backtest אחת אחרי השנייה עם פרמטרים שונים.",
                )

                ab_selection = {
                    "df_sorted": df_sorted,
                    "idx_a": idx_a,
                    "idx_b": idx_b,
                    "label_a": label_a,
                    "label_b": label_b,
                }
            else:
                st.caption("אין opt_df בטאב האופטימיזציה – אין מה להשוות כרגע.")

        # ולידציה בסיסית לפני ריצה
        def _validate_backtest_inputs() -> bool:
            if start_date >= end_date:
                st.error("תאריך התחלה חייב להיות קטן מתאריך סיום.")
                return False
            if (
                getattr(ctx_bt, "capital", 0) is not None
                and getattr(ctx_bt, "capital", 0) <= 0
            ):
                st.error("Capital חייב להיות גדול מ-0 לצורך בק-טסט.")
                return False
            return True

        # פונקציית עזר להרצת בק-טסט אחד (עם עטיפת שגיאות)
        def _run_single_backtest_for_params(
            opt_params_local: Dict[str, Any],
            label: str,
        ) -> None:
            st.markdown(f"#### Backtest: {label}")
            with st.spinner(f"🏃 Running backtest for {label}…"):
                try:
                    seed = ctx_bt.seed
                    if auto_seed:
                        seed = int(datetime.utcnow().timestamp()) % 10_000_000

                    try:
                        _render_backtest_tab(
                            opt_params_local,
                            start_date,
                            end_date,
                            **ctrl_bt,
                            seed=seed,
                            ctx=ctx_bt_dict,
                        )
                    except TypeError:
                        try:
                            _render_backtest_tab(
                                opt_params_local,
                                start_date,
                                end_date,
                                **ctrl_bt,
                            )
                        except TypeError:
                            _render_backtest_tab(
                                st.session_state.get("opt_params"),
                                start_date,
                                end_date,
                            )
                except Exception as e:
                    logger.exception(e)
                    _report_exception(e, "Tab Backtest")
                    st.error(f"❗ שגיאה בבק-טסט עבור {label}: {e}")

        # ============ ריצת Single / Batch רגילה ============
        if (run_single or run_batch) and _validate_backtest_inputs():
            # opt_params בסיסי מה-session
            base_opt_params = dict(st.session_state.get("opt_params") or {})

            # אם יש אופטימיזציה אחרונה ואפשר להשתמש בה
            if use_opt_params:
                opt_df = st.session_state.get("opt_df")
                if isinstance(opt_df, pd.DataFrame) and not opt_df.empty:
                    try:
                        # לוקחים את השורה עם Score מקסימלי (אם קיימת)
                        if "Score" in opt_df.columns:
                            best_row = opt_df.sort_values(
                                "Score", ascending=False
                            ).iloc[0]
                        else:
                            best_row = opt_df.iloc[0]
                        # נשמור אותה כפרמטרים גולמיים (רק עמודות לא-מטריקות)
                        metric_like = {"Score", "Sharpe", "Profit", "Drawdown"}
                        best_params = {
                            k: float(v)
                            for k, v in best_row.items()
                            if k not in metric_like and isinstance(v, (int, float))
                        }
                        base_opt_params.update(best_params)
                        st.caption(
                            "⚙️ פרמטרים מחוזקים מאופטימיזציה אחרונה שולבו ב-opt_params."
                        )
                    except Exception:
                        pass

            # ריצה על זוג בודד
            if run_single:
                opt_params = dict(base_opt_params)
                sp = st.session_state.get("selected_pair")
                if sp:
                    # נפצל sym_x/sym_y מתוך label ונשתול אותם ב-opt_params (אם לא קיימים)
                    for _sep in ("|", "/", "\\", ":", "-"):
                        if _sep in sp:
                            sx, sy = sp.split(_sep, 1)
                            opt_params.setdefault("sym_x", sx.strip())
                            opt_params.setdefault("sym_y", sy.strip())
                            break
                _run_single_backtest_for_params(opt_params, sp or "default-pair")

            # ריצה באצ' על מספר זוגות
            if run_batch and enable_batch and batch_pairs:
                for label in batch_pairs:
                    opt_params = dict(base_opt_params)
                    for _sep in ("|", "/", "\\", ":", "-"):
                        if _sep in label:
                            sx, sy = label.split(_sep, 1)
                            opt_params["sym_x"] = sx.strip()
                            opt_params["sym_y"] = sy.strip()
                            break
                    _run_single_backtest_for_params(opt_params, label)

            # אחרי כל הריצות – סיכום אחרון + Manifest ל-session
            hist_after = _load_backtest_history()
            if hist_after is not None and not hist_after.empty:
                last_summary = _compute_last_run_summary_from_history(hist_after)
                st.session_state["bt_last_summary"] = last_summary

                # הצגת Quick Metrics מהריצה האחרונה
                st.markdown("### 📊 Last Run Summary (global history)")

                c1, c2, c3, c4 = st.columns(4)
                c1.metric("Pair", last_summary.get("pair") or "N/A")
                c2.metric(
                    "Sharpe",
                    f"{last_summary.get('sharpe', float('nan')):.2f}"
                    if last_summary.get("sharpe") is not None
                    else "N/A",
                )
                c3.metric(
                    "PnL",
                    f"{last_summary.get('pnl', 0):,.0f}"
                    if last_summary.get("pnl") is not None
                    else "N/A",
                )
                c4.metric(
                    "Max DD",
                    f"{last_summary.get('max_dd', 0):.2f}"
                    if last_summary.get("max_dd") is not None
                    else "N/A",
                )

                # Manifest + גשר ל-ML / Tabs אחרים
                last_row = hist_after.iloc[-1]
                bt_manifest = _build_backtest_manifest(
                    ctx_bt, ctrl_bt_full, last_row=last_row
                )
                # מוסיפים את התיוג לריצה גם במניפסט
                bt_manifest.setdefault("tags", {})
                bt_manifest["tags"]["run_label"] = run_label or ""
                bt_manifest["tags"]["risk_profile"] = risk_profile
                bt_manifest["tags"]["mode"] = wf_mode

                st.session_state["bt_last_manifest"] = bt_manifest

                # גשר ל-ML / insights: סיכום קצר ברמת המערכת
                st.session_state["bt_ml_bridge"] = {
                    "run_id": bt_manifest.get("run_id"),
                    "pair": last_summary.get("pair"),
                    "sharpe": last_summary.get("sharpe"),
                    "pnl": last_summary.get("pnl"),
                    "max_dd": last_summary.get("max_dd"),
                    "trades": last_summary.get("trades"),
                    "run_label": run_label or "",
                    "risk_profile": risk_profile,
                    "mode": wf_mode,
                }

                with st.expander("📄 Backtest Manifest (JSON)", expanded=False):
                    st.json(bt_manifest)

        # ============ ריצת A/B Compare ============
        if run_ab and _validate_backtest_inputs():
            opt_df_ab = ab_selection.get("df_sorted")
            idx_a = ab_selection.get("idx_a")
            idx_b = ab_selection.get("idx_b")
            label_a = ab_selection.get("label_a") or "Config A"
            label_b = ab_selection.get("label_b") or "Config B"

            if isinstance(opt_df_ab, pd.DataFrame) and opt_df_ab.shape[0] > 0:
                try:
                    metric_like = {"Score", "Sharpe", "Profit", "Drawdown"}

                    row_a = opt_df_ab.iloc[int(idx_a)]
                    row_b = opt_df_ab.iloc[int(idx_b)]

                    def _row_to_params(row: pd.Series) -> Dict[str, float]:
                        out: Dict[str, float] = {}
                        for k, v in row.items():
                            if k in metric_like:
                                continue
                            if isinstance(v, (int, float)):
                                out[k] = float(v)
                        return out

                    params_a = _row_to_params(row_a)
                    params_b = _row_to_params(row_b)

                    # נוסיף גם sym_x/sym_y אם נבחר pair
                    sp = st.session_state.get("selected_pair")
                    if sp:
                        for _sep in ("|", "/", "\\", ":", "-"):
                            if _sep in sp:
                                sx, sy = sp.split(_sep, 1)
                                params_a.setdefault("sym_x", sx.strip())
                                params_a.setdefault("sym_y", sy.strip())
                                params_b.setdefault("sym_x", sx.strip())
                                params_b.setdefault("sym_y", sy.strip())
                                break

                    # מריצים A ואז B
                    _run_single_backtest_for_params(
                        params_a,
                        f"{sp or 'pair'} | {label_a}",
                    )
                    _run_single_backtest_for_params(
                        params_b,
                        f"{sp or 'pair'} | {label_b}",
                    )

                    # --- A/B Results Summary (last two runs from history) ---
                    hist_ab = _load_backtest_history()
                    if hist_ab is not None and len(hist_ab) >= 2:
                        df_ab = hist_ab.copy()

                        # ננסה למיין לפי עמודת זמן אם קיימת
                        time_col = None
                        for cand in ("FinishedAt", "finished_at", "end_time", "timestamp"):
                            if cand in df_ab.columns:
                                time_col = cand
                                break
                        if time_col:
                            df_ab = df_ab.sort_values(time_col)

                        # מניחים ששתי הריצות האחרונות הן B (האחרונה) ואז A (לפניה)
                        row_b_last = df_ab.iloc[-1]
                        row_a_prev = df_ab.iloc[-2]

                        def _get_val(row: pd.Series, *names: str):
                            """עזר קטן להוציא ערך מהשורה לפי כמה שמות אפשריים."""
                            for n in names:
                                if n in row.index:
                                    return row[n]
                            return None

                        metrics_rows = []
                        for metric_name, col_candidates in [
                            ("PnL", ("PnL", "pnl", "total_pnl")),
                            ("Sharpe", ("Sharpe", "sharpe")),
                            ("Max DD", ("MaxDD", "max_dd", "Drawdown", "drawdown")),
                            ("Trades", ("Trades", "trades", "n_trades")),
                        ]:
                            va = _get_val(row_a_prev, *col_candidates)
                            vb = _get_val(row_b_last, *col_candidates)

                            try:
                                va_f = float(va) if va is not None else None
                            except Exception:
                                va_f = None
                            try:
                                vb_f = float(vb) if vb is not None else None
                            except Exception:
                                vb_f = None

                            delta = None
                            if va_f is not None and vb_f is not None:
                                delta = vb_f - va_f

                            metrics_rows.append(
                                {
                                    "metric": metric_name,
                                    f"{label_a}": va_f,
                                    f"{label_b}": vb_f,
                                    "Δ (B - A)": delta,
                                }
                            )

                        st.markdown("#### 🧮 A/B Backtest Comparison (last two runs)")
                        st.dataframe(
                            pd.DataFrame(metrics_rows),
                            width="stretch",
                            height=200,
                        )
                    else:
                        st.caption("A/B summary: אין מספיק שורות ב-history כדי להשוות שתי ריצות.")
                except Exception as e:
                    st.error(f"A/B compare failed: {e}")

    with run_col2:
        st.markdown("**Run Options**")
        st.caption(
            "Backtest רץ בלחיצה על הכפתורים משמאל. אפשר להריץ יחיד, באצ' של מספר זוגות, או A/B Compare."
        )
        st.caption(f"Run ID: `{ctx_bt.run_id}`")
        st.caption(
            "ניתן להשתמש בפאנל ה-Advanced משמאל להגדרת מצב Walk-Forward / פרופיל סיכון / Batch / Run label."
        )

    # ================== חלק 3 — Export Backtest Params & Manifest ==================
    with st.expander("📦 Export — Backtest", expanded=False):
        try:
            # פרמטרים לוגיים מלאים (כולל risk_capital)
            st.download_button(
                "🧾 Backtest Params (JSON)",
                json.dumps(
                    ctrl_bt_full, ensure_ascii=False, indent=2
                ).encode("utf-8"),
                file_name=f"backtest_params_{ctx_bt.run_id}.json",
                mime="application/json",
                key=keygen("dl", "bt_params"),
            )
            # דוח Markdown על הקונטקסט
            md_bt = ctx_to_markdown(ctx_bt)
            st.download_button(
                "📝 Backtest Context (MD)",
                md_bt.encode("utf-8"),
                file_name=f"backtest_ctx_{ctx_bt.run_id}.md",
                mime="text/markdown",
                key=keygen("dl", "bt_ctx_md"),
            )
            # Manifest אחרון אם קיים
            bt_manifest = st.session_state.get("bt_last_manifest")
            if isinstance(bt_manifest, dict) and bt_manifest:
                st.download_button(
                    "📄 Backtest Manifest (JSON)",
                    json.dumps(
                        make_json_safe(bt_manifest), ensure_ascii=False, indent=2
                    ).encode("utf-8"),
                    file_name=f"backtest_manifest_{bt_manifest.get('run_id','')}.json",
                    mime="application/json",
                    key=keygen("dl", "bt_manifest"),
                )
        except Exception:
            pass

