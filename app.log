# ===================== Part 12 — Scenario Deck & Workflow Templates (HF-Grade) =====================

# הערה: כאן אנחנו משתמשים ב:
# - SCENARIOS, RiskScenario, _simulate_equity_scenario, _load_backtest_history
# - record_event, register_alert, make_json_safe, keygen, st, pd, np, config


# ---------- Scenario Deck Panel (ממשק מרכזי לתרחישים) ----------

def render_scenario_deck_panel() -> None:
    """
    Scenario Deck — פאנל תרחישים קלסי ברמת קרן:

    • מציג רשימת תרחישים מוגדרים מראש (Crash, Shock, Vol Spike וכו').
    • עבור תרחיש נבחר:
        - מריץ סימולציה נאיבית על Equity (באמצעות _simulate_equity_scenario).
        - מציג השפעת התרחיש על הקרן (Equity change, DD משוער).
        - מציע Actions לוגיים (למשל: הקטנת מינוף, הקפאת אסטרטגיות מסוימות).
    • רושם Event ל-Timeline ומאפשר לייצא את תוצאות התרחיש כ-JSON.
    """
    with st.expander("🌋 Scenario Deck – תרחישים מאקרו על הקרן", expanded=False):
        hist = _load_backtest_history()
        if hist is None or hist.empty:
            st.caption("אין היסטוריית Backtest – לא ניתן להריץ תרחישים כרגע.")
            return

        # אפשר להרחיב את SCENARIOS הקיימת עם עוד תרחישים:
        extra_scenarios: List[RiskScenario] = [
            RiskScenario("Gradual Grind-Down (SPY -3%)", spy_shock_pct=-0.03, vix_target=20.0),
            RiskScenario("Rally (SPY +5%)", spy_shock_pct=0.05, vix_target=15.0),
        ]
        scenario_list = SCENARIOS + extra_scenarios

        names = [sc.name for sc in scenario_list]
        sel_name = st.selectbox(
            "בחר תרחיש",
            names,
            index=0,
            key=keygen("scenario", "name"),
        )
        scenario = next(sc for sc in scenario_list if sc.name == sel_name)

        sim = _simulate_equity_scenario(hist, scenario)
        if sim is None:
            st.caption("לא ניתן להעריך תרחיש – מעט מדי נתונים או Equity לא מוגדר.")
            return

        col_l, col_r = st.columns(2)
        with col_l:
            st.subheader("Simulation Result (approx.)")
            st.json(
                make_json_safe(
                    {
                        "equity_today": sim["equity_today"],
                        "equity_after": sim["equity_after"],
                        "approx_pnl_change": sim["approx_pnl_change"],
                        "approx_pnl_change_pct": sim["approx_pnl_change_pct"],
                        "approx_dd_effect_pct": sim["approx_dd_effect_pct"],
                    }
                )
            )

        with col_r:
            st.subheader("Key Metrics")
            st.metric(
                "Equity change (approx)",
                f"{sim['approx_pnl_change']:,.0f}",
                f"{sim['approx_pnl_change_pct']*100:.1f}%",
            )
            st.metric(
                "DD impact (approx)",
                f"{sim['approx_dd_effect_pct']*100:.1f}%",
            )

            # המלצות טקסטואליות פשוטות לפי סוג התרחיש
            hints: List[str] = []
            if scenario.spy_shock_pct < 0:
                hints.append("להקטין מינוף גלובלי, במיוחד בזוגות עם קורלציה חזקה ל-SPY/QQQ.")
                hints.append("לשקול גידור חלקי עם נכסים דפנסיביים או מזומן.")
            if scenario.spy_shock_pct <= -0.1:
                hints.append("להעביר חלק מהאקספוזר לאסטרטגיות פחות תלויות במומנטום שוק רחב.")
                hints.append("להוריד exposure בזוגות שנמצאו כ-'Fragile Pairs' בפאנל Pair Intelligence.")
            if scenario.spy_shock_pct > 0:
                hints.append("לשקול הגדלת exposure באסטרטגיות עם ביצועים טובים בשווקי Rally.")
            if scenario.vix_target and scenario.vix_target >= 35:
                hints.append("שוק בתנודתיות גבוהה – לוודא שה-Kill-Switch מוגדר נכון.")

            if hints:
                st.markdown("**Recommended playbook for this scenario:**")
                for h in hints:
                    st.markdown(f"- {h}")

        # רישום לאירועים / Alerts עם כפתור
        col_e1, col_e2 = st.columns(2)
        with col_e1:
            if st.button("📌 רשום Event ל-Timeline", key=keygen("scenario", "record")):
                record_event(
                    category="macro",
                    message=f"Scenario simulated: {scenario.name}",
                    meta={
                        "spy_shock_pct": scenario.spy_shock_pct,
                        "vix_target": scenario.vix_target,
                        "simulation": sim,
                    },
                )
                st.success("נרשם Event ל-Timeline.")
        with col_e2:
            if st.button("📨 רשום Alert ל-Alerts Feed", key=keygen("scenario", "alert")):
                register_alert(
                    kind="macro",
                    severity="warning",
                    message=f"Scenario '{scenario.name}' simulated (Equity change≈{sim['approx_pnl_change_pct']*100:.1f}%)",
                    source="scenario_deck",
                    meta={
                        "spy_shock_pct": scenario.spy_shock_pct,
                        "vix_target": scenario.vix_target,
                        "simulation": sim,
                    },
                )
                st.success("נרשם Alert ל-Alerts Feed.")

        # הורדת JSON של התרחיש
        st.download_button(
            "💾 Download Scenario Result (JSON)",
            json.dumps(
                make_json_safe(
                    {
                        "scenario": {
                            "name": scenario.name,
                            "spy_shock_pct": scenario.spy_shock_pct,
                            "vix_target": scenario.vix_target,
                        },
                        "simulation": sim,
                    }
                ),
                ensure_ascii=False,
                indent=2,
            ).encode("utf-8"),
            file_name=f"scenario_{scenario.name.replace(' ', '_')}.json",
            key=keygen("scenario", "dl"),
        )


