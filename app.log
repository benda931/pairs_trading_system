                        beta_window=None,
                        top_n=int(universe_n),
                        min_points=int(min_points_eff),
                        max_workers=8,
                    )
            except Exception as e:
                logger.exception(e)
                _report_exception(e, "Tab Scan — quick_signals")
                df_sig_quick = pd.DataFrame()
                st.error(f"❗ שגיאה בחישוב אותות מהירים: {e}")

            if df_sig_quick is None or df_sig_quick.empty:
                st.info("אין אותות תואמים בקריטריונים הנוכחיים (או שהחישוב נכשל).")
            else:
                df_view = df_sig_quick.copy()

                # fair_value_zdist
                if "abs_z" in df_view.columns:
                    df_view["fair_value_zdist"] = pd.to_numeric(df_view["abs_z"], errors="coerce").abs()
                else:
                    df_view["fair_value_zdist"] = np.nan

                # נרמול לסקור
                w_sum = sum(v for v in eff_scan_weights.values() if v > 0)
                if w_sum <= 0:
                    w_sum = 1.0

                if "corr" in df_view.columns:
                    corr_raw = pd.to_numeric(df_view["corr"], errors="coerce")
                    df_view["_norm_corr"] = ((corr_raw + 1.0) / 2.0).clip(0.0, 1.0)
                else:
                    df_view["_norm_corr"] = np.nan

                if "half_life" in df_view.columns:
                    hl_raw = pd.to_numeric(df_view["half_life"], errors="coerce")
                    hl_cap = max(hl_max, 1.0)
                    df_view["_norm_hl"] = (1.0 - (hl_raw.clip(lower=0, upper=hl_cap) / hl_cap)).clip(0.0, 1.0)
                else:
                    df_view["_norm_hl"] = np.nan

                if "abs_z" in df_view.columns:
                    z_cap = max(max_spread_zdist, min_abs_z if min_abs_z > 0 else 2.0)
                    z_raw = pd.to_numeric(df_view["abs_z"], errors="coerce").abs()
                    df_view["_norm_z"] = (z_raw.clip(0.0, z_cap) / z_cap).clip(0.0, 1.0)
                else:
                    df_view["_norm_z"] = np.nan

                if "quality_score" in df_view.columns:
                    q_raw = pd.to_numeric(df_view["quality_score"], errors="coerce")
                    df_view["_norm_quality"] = (q_raw / 100.0).clip(0.0, 1.0)
                else:
                    df_view["_norm_quality"] = np.nan

                if "macro_fit_score" in df_view.columns:
                    m_raw = pd.to_numeric(df_view["macro_fit_score"], errors="coerce")
                    df_view["_norm_macro_fit"] = (m_raw / 100.0).clip(0.0, 1.0)
                else:
                    df_view["_norm_macro_fit"] = np.nan

                if "volatility" in df_view.columns:
                    v_raw = pd.to_numeric(df_view["volatility"], errors="coerce")
                    v_cap = v_raw.quantile(0.9) if not v_raw.dropna().empty else 1.0
                    v_cap = max(v_cap, 1e-6)
                    df_view["_norm_vol"] = (1.0 - (v_raw.clip(0.0, v_cap) / v_cap)).clip(0.0, 1.0)
                else:
                    df_view["_norm_vol"] = np.nan

                # Composite scan_score
                df_view["scan_score"] = (
                    eff_scan_weights["corr"] * df_view["_norm_corr"].fillna(0.0)
                    + eff_scan_weights["half_life"] * df_view["_norm_hl"].fillna(0.0)
                    + eff_scan_weights["z"] * df_view["_norm_z"].fillna(0.0)
                    + eff_scan_weights["quality"] * df_view["_norm_quality"].fillna(0.0)
                    + eff_scan_weights["macro_fit"] * df_view["_norm_macro_fit"].fillna(0.0)
                    + eff_scan_weights["vol"] * df_view["_norm_vol"].fillna(0.0)
                ) / w_sum

                # סגמנטציה אם קיימים שדות
                with st.expander("🎯 Segment Filters (sector / region / currency)", expanded=False):
                    seg_cols = {}
                    for cname in ("sector", "industry", "region", "country", "currency"):
