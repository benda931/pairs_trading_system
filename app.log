def _apply_scan_template_to_session(scan_cfg: Dict[str, Any]) -> None:
    """
    מיישם הגדרות Scan לתוך session_state בהתאם למפתחות controls_scan ("t1").

    זה בעצם "מכין" את טאב סריקה עם ערכי ברירת מחדל לפי Workflow Template.
    """
    try:
        profile = scan_cfg.get("profile")
        zwin = scan_cfg.get("z_window")
        universe_n = scan_cfg.get("universe_n")
        min_corr = scan_cfg.get("min_corr")

        if profile:
            st.session_state[keygen("t0", "profile")] = profile
        if zwin is not None:
            st.session_state[keygen("t0", "zwin")] = int(zwin)
            st.session_state[keygen("t1", "zwin")] = int(zwin)
        if universe_n is not None:
            st.session_state[keygen("t1", "universe")] = int(universe_n)
        if min_corr is not None:
            st.session_state[keygen("t1", "mincorr")] = float(min_corr)
    except Exception:
        pass


def _apply_backtest_template_to_session(bt_cfg: Dict[str, Any]) -> None:
    """
    מיישם הגדרות Backtest לתוך session_state בהתאם למפתחות controls_backtest ("t3").
    """
    try:
        st.session_state[keygen("t3", "slip")] = float(bt_cfg.get("slippage_bps", 2.0))
        st.session_state[keygen("t3", "fee")] = float(bt_cfg.get("fee_bps", 1.0))
        st.session_state[keygen("t3", "maxpos")] = int(bt_cfg.get("max_positions", 5))
        st.session_state[keygen("t3", "reb")] = int(bt_cfg.get("rebalance_days", 5))
        st.session_state[keygen("t3", "wf")] = int(bt_cfg.get("wf_folds", 3))
        st.session_state[keygen("t3", "wu")] = int(bt_cfg.get("warmup_days", 60))
        st.session_state[keygen("t3", "obj")] = bt_cfg.get("objective", "Sharpe")
        st.session_state[keygen("t3", "risk")] = bt_cfg.get("risk_model", "None")
    except Exception:
        pass


def _apply_macro_template_to_session(macro_cfg: Dict[str, Any]) -> None:
    """
    מיישם הגדרות Macro לתוך session_state בהתאם למפתחות controls_macro ("t10").
    """
    try:
        if "macro_profile" in macro_cfg:
            st.session_state[keygen("t10", "macro_prof")] = macro_cfg["macro_profile"]
    except Exception:
        pass


def render_workflow_templates_panel() -> None:
    """
    Workflow Templates Panel:

    • מאפשר לבחור "זרימה" של עבודה (Workflow) – למשל:
      - Mean-Reversion Scan + Backtest
      - Aggressive Short-Term Alpha
      - Defensive Regime (Risk-Off)

    • בעת הפעלה:
      - מעדכן את ה-session_state בפרמטרים המתאימים ל-Scan/Backtest/Macro.
      - רושם Event ל-Timeline.
      - יכול (בעתיד) גם להפעיל אוטומטית Tabs, אבל כרגע מטרתנו להכין את הפרמטרים.

    זה מאפשר לך:
    - בלחיצה אחת, להכין את המערכת לריצה לפי "Playbook" מוגדר.
    """
    with st.expander("🧩 Workflow Templates – זרימות עבודה מוכנות", expanded=False):
        names = list(WORKFLOW_TEMPLATES.keys())
        if not names:
            st.caption("אין Workflow Templates מוגדרים כרגע.")
            return

        sel_name = st.selectbox(
            "בחר Workflow",
            names,
            index=0,
            key=keygen("wf", "name"),
        )
        tmpl = WORKFLOW_TEMPLATES[sel_name]
        st.caption(tmpl.get("description", ""))

        col_apply, col_info = st.columns([1, 2])
        with col_apply:
            if st.button("החל Workflow על הפרמטרים", key=keygen("wf", "apply")):
                scan_cfg = tmpl.get("scan", {})
                bt_cfg = tmpl.get("backtest", {})
                macro_cfg = tmpl.get("macro", {})

                _apply_scan_template_to_session(scan_cfg)
                _apply_backtest_template_to_session(bt_cfg)
                if macro_cfg:
                    _apply_macro_template_to_session(macro_cfg)

                record_event(
                    category="system",
                    message=f"Workflow '{sel_name}' applied",
                    meta={
                        "scan": scan_cfg,
                        "backtest": bt_cfg,
                        "macro": macro_cfg,
                    },
                )
                register_alert(
                    kind="system",
                    severity="info",
                    message=f"Workflow '{sel_name}' applied to session parameters.",
                    source="workflow_templates",
                    meta={
                        "scan": scan_cfg,
                        "backtest": bt_cfg,
                        "macro": macro_cfg,
                    },
                )
                st.success("Workflow הוחל על הפרמטרים. עבור לטאב סריקה/Backtest כדי לראות את ההשפעה.")
        with col_info:
            st.subheader("פרטי Workflow (JSON)")
            st.json(make_json_safe(tmpl))

# ===================== Part 13 — Data Quality & Diagnostics Center (HF-Grade++) =====================

# הערה: משתמש בפונקציות קיימות:
# - _load_pair_data, _pick_price_series, make_pair_label, _normalize_symbol_input, _safe_corr_dashboard
# - get_pairs, get_providers_status, router, st, pd, np, datetime, date, TODAY, keygen
# - _default_config_fallback, _raw_config, config, log_path


# ---------- Data Quality Metrics for a Single Symbol ----------

def _compute_symbol_data_quality(
    sym: str,
    start_date: date,
    end_date: date,
) -> Dict[str, Any]:
    """
    מחשב מדדי איכות דאטה עבור סימבול בודד:

    מטריקות:
    - rows: מספר שורות.
    - start/end: טווח תאריכים בפועל (בנתונים).
    - days_span: אורך טווח התאריכים בפועל (ימים).
    - unique_days: מספר הימים הייחודיים ב-index (אחרי normalize).
    - missing_days_est: הערכה גסה של ימים חסרים לעומת span.
    - coverage_ratio: יחס כיסוי (unique_days / span).
    - nan_fraction: אחוז הערכים שהם NaN בעמודת מחיר.
    - zero_volume_fraction: אם יש Volume – אחוז ימים עם Volume=0.
    - mean_return / vol_return: ממוצע תשואה יומית וסטיית תקן (אינדיקטור איכות לשימוש).
    - max_gap_days: פער מקסימלי בין שני תאריכים עוקבים.
    """
    out: Dict[str, Any] = {
        "symbol": sym,
        "rows": 0,
        "start": None,
        "end": None,
        "days_span": None,
        "unique_days": None,
        "missing_days_est": None,
        "coverage_ratio": None,
        "nan_fraction": None,
        "zero_volume_fraction": None,
        "mean_return": None,
        "vol_return": None,
        "max_gap_days": None,
    }
    try:
        df = _load_pair_data(sym, start_date, end_date)
        if df is None or df.empty:
            return out

        out["rows"] = int(len(df))
        idx = pd.to_datetime(df.index)
        if idx.empty:
            return out

        start_actual = idx.min().date()
        end_actual = idx.max().date()
        out["start"] = str(start_actual)
        out["end"] = str(end_actual)

        # Span + coverage
        span = (end_actual - start_actual).days + 1
        out["days_span"] = span
        unique_days = len(idx.normalize().unique())
        out["unique_days"] = unique_days
        out["missing_days_est"] = max(span - unique_days, 0)
        out["coverage_ratio"] = float(unique_days / span) if span > 0 else None

        # Max gap between consecutive trading days
        days_sorted = sorted(idx.normalize().unique())
        if len(days_sorted) > 1:
            gaps = [
                (days_sorted[i] - days_sorted[i - 1]).days
                for i in range(1, len(days_sorted))
            ]
            out["max_gap_days"] = int(max(gaps))
        else:
            out["max_gap_days"] = None

        # Price series metrics
        price = _pick_price_series(df)
        if not price.empty:
            nan_frac = float(price.isna().sum() / len(price))
            out["nan_fraction"] = nan_frac

            # Returns
            rets = price.pct_change(1).dropna()
            if not rets.empty:
                out["mean_return"] = float(rets.mean())
                out["vol_return"] = float(rets.std(ddof=0))

        # Volume if exists
        vol_frac = None
        for col in ("Volume", "volume", "VOL"):
            if col in df.columns:
                v = pd.to_numeric(df[col], errors="coerce")
                if len(v) > 0:
                    vol_frac = float((v.fillna(0) == 0).sum() / len(v))
                break
        out["zero_volume_fraction"] = vol_frac

        return out
    except Exception:
        return out


# ---------- Pair-Level Data Quality (לשני ה-legs) ----------

def _compute_pair_data_quality(
    pair_obj: Any,
    start_date: date,
    end_date: date,
) -> Dict[str, Any]:
    """
    מחשב מדדי איכות דאטה עבור זוג:

    • sym_x_quality / sym_y_quality – קריאה ל-_compute_symbol_data_quality לכל leg.
    • corr_approx_price – קורלציה בטוחה בין סדרות המחירים.
    • corr_approx_rets – קורלציה בין תשואות יומיות (אם אפשר).
    • overlap_ratio – יחס מספר הימים המשותפים (intersection) מתוך איחוד הימים.
    """
    label = make_pair_label(pair_obj)
    try:
        sym_x, sym_y = _extract_symbols_from_pair_dashboard(pair_obj)
    except Exception:
        return {
            "pair": label,
            "sym_x": None,
            "sym_y": None,
            "sym_x_quality": None,
            "sym_y_quality": None,
            "corr_approx_price": None,
            "corr_approx_rets": None,
            "overlap_ratio": None,
        }

    qx = _compute_symbol_data_quality(sym_x, start_date, end_date)
    qy = _compute_symbol_data_quality(sym_y, start_date, end_date)

    corr_price = None
    corr_rets = None
    overlap_ratio = None

    try:
        df_x = _load_pair_data(sym_x, start_date, end_date)
        df_y = _load_pair_data(sym_y, start_date, end_date)
        if df_x is not None and not df_x.empty and df_y is not None and not df_y.empty:
            s1 = _pick_price_series(df_x)
            s2 = _pick_price_series(df_y)
            s1, s2 = s1.align(s2, join="inner")

            if len(s1) > 3:
                corr_price = _safe_corr_dashboard(s1, s2)
                # Returns correlation
                rets1 = s1.pct_change(1).dropna()
                rets2 = s2.pct_change(1).dropna()
                rets1, rets2 = rets1.align(rets2, join="inner")
                if len(rets1) > 3:
                    corr_rets = _safe_corr_dashboard(rets1, rets2)

            # overlap ratio
            days_x = set(pd.to_datetime(df_x.index).normalize().unique())
            days_y = set(pd.to_datetime(df_y.index).normalize().unique())
            inter = len(days_x & days_y)
            union = len(days_x | days_y)
            overlap_ratio = float(inter / union) if union > 0 else None
    except Exception:
        pass

    return {
        "pair": label,
        "sym_x": sym_x,
        "sym_y": sym_y,
        "sym_x_quality": qx,
        "sym_y_quality": qy,
        "corr_approx_price": corr_price,
        "corr_approx_rets": corr_rets,
        "overlap_ratio": overlap_ratio,
    }


# ---------- Data Quality Panel (Universe-Level) ----------

def render_data_quality_panel() -> None:
    """
    Data Quality Center:

    • בוחן איכות דאטה ל-top N זוגות (או לכל universe).
    • מציג:
        - שורות/ימים מכוסים.
        - Missing days estimate + coverage ratio.
        - מבנה פערים (max_gap_days).
        - NaN fraction, zero_volume_fraction.
        - corr_approx על prices + על returns.
        - overlap_ratio בין שני ה-legs.

    • מזהה זוגות "בעייתיים":
        - coverage_ratio נמוך (לדוגמה < 0.8)
        - nan_fraction > 1%
        - missing_days_est > threshold
        - overlap_ratio נמוך (קושי לבנות spread עקבי)

    • מאפשר בחירת סימבול/זוג לבדיקה פרטנית וניתוח ידני.

    זה כלי dev+risk יחד: לראות בעיות דאטה לפני שמסתמכים על תוצאות Backtest/Signals.
    """
    with st.expander("🔍 Data Quality & Diagnostics Center", expanded=False):
        pairs = get_pairs(False)
        if not pairs:
            st.caption("אין זוגות בזיכרון – לא ניתן להריץ Data Quality.")
            return

        col0, col1, col2 = st.columns([1, 1, 2])
        with col0:
            max_pairs = st.number_input(
                "כמה זוגות לדגום?",
                min_value=5,
                max_value=200,
                value=30,
                step=5,
                key=keygen("dq", "max_pairs"),
            )
        with col1:
            days_back = st.number_input(
                "כמה ימים אחורה לבדוק?",
                min_value=30,
                max_value=365 * 3,
                value=365,
                step=30,
                key=keygen("dq", "days_back"),
            )
        with col2:
            st.caption(
                "Data quality נבדק על טווח דגימה מצומצם (למשל שנה אחורה) כדי לא לשרוף משאבים על כל ההיסטוריה."
            )

        end_date = TODAY
        start_date = TODAY - timedelta(days=int(days_back))

        pairs_sample = pairs[: int(max_pairs)]
        dq_records: List[Dict[str, Any]] = []
        with st.spinner("מריץ בדיקות איכות דאטה לזוגות..."):
            for p in pairs_sample:
                dq_records.append(_compute_pair_data_quality(p, start_date, end_date))

        if not dq_records:
            st.caption("לא התקבלו תוצאות Data Quality.")
            return

        # Flatten לצורך תצוגה
        rows = []
        for rec in dq_records:
            sxq = rec.get("sym_x_quality") or {}
            syq = rec.get("sym_y_quality") or {}
            rows.append(
                {
                    "Pair": rec.get("pair"),
                    "sym_x": rec.get("sym_x"),
                    "sym_y": rec.get("sym_y"),
                    "rows_x": sxq.get("rows"),
                    "rows_y": syq.get("rows"),
                    "cov_ratio_x": sxq.get("coverage_ratio"),
                    "cov_ratio_y": syq.get("coverage_ratio"),
                    "missing_days_x": sxq.get("missing_days_est"),
                    "missing_days_y": syq.get("missing_days_est"),
                    "nan_frac_x": sxq.get("nan_fraction"),
                    "nan_frac_y": syq.get("nan_fraction"),
                    "zero_vol_frac_x": sxq.get("zero_volume_fraction"),
                    "zero_vol_frac_y": syq.get("zero_volume_fraction"),
                    "corr_price": rec.get("corr_approx_price"),
                    "corr_rets": rec.get("corr_approx_rets"),
                    "overlap_ratio": rec.get("overlap_ratio"),
                }
            )
        df_dq = pd.DataFrame(rows)

        # תקציר – scoring פשוט
        def _quality_score(row: pd.Series) -> float:
            score = 1.0
            # יחס כיסוי
            for cr in ("cov_ratio_x", "cov_ratio_y"):
                val = row.get(cr)
                if val is None or np.isnan(val):
                    continue
                if val < 0.7:
                    score -= 0.4
                elif val < 0.9:
                    score -= 0.2
            # NaNs
            for nf in ("nan_frac_x", "nan_frac_y"):
                val = row.get(nf)
                if val is None or np.isnan(val):
                    continue
                if val > 0.05:
                    score -= 0.4
                elif val > 0.01:
                    score -= 0.2
            # overlap
            ov = row.get("overlap_ratio")
            if ov is not None and not np.isnan(ov):
                if ov < 0.7:
                    score -= 0.3
                elif ov < 0.9:
                    score -= 0.1
            return float(max(score, -1.0))

        df_dq["quality_score"] = df_dq.apply(_quality_score, axis=1)

        bad_pairs = df_dq[df_dq["quality_score"] < 0.4]
        st.caption(
            f"בדקנו {len(df_dq)} זוגות. "
            f"{len(bad_pairs)} מהם מדורגים באיכות נמוכה (quality_score < 0.4)."
        )

        # הצגת הטבלה (עם sorting)
        sort_by = st.selectbox(
            "מיין לפי",
            ["quality_score", "cov_ratio_x", "cov_ratio_y", "nan_frac_x", "nan_frac_y"],
            index=0,
            key=keygen("dq", "sort"),
        )
        ascending = sort_by not in ("quality_score",)
        df_view = df_dq.sort_values(sort_by, ascending=ascending)
        st.dataframe(df_view, width="stretch", height=320)

        # plot (אם plotly זמין)
        try:
            import plotly.express as px  # type: ignore
            with st.expander("📈 Data Quality Visualization", expanded=False):
                fig_q = px.histogram(
                    df_dq,
                    x="quality_score",
                    nbins=30,
                    title="Distribution of Pair Data Quality Scores",
                )
                st.plotly_chart(fig_q, width="stretch")
        except Exception:
            pass

        st.download_button(
            "💾 Download Data Quality (CSV)",
            df_dq.to_csv(index=False).encode("utf-8"),
            file_name="data_quality_pairs.csv",
            mime="text/csv",
            key=keygen("dq", "dl"),
        )

        # בחירת זוג/סימבול לפאנל פרטני
        st.subheader("בדיקת סימבול/זוג בודד")
        col_s1, col_s2 = st.columns(2)
        with col_s1:
            sel_pair_label = st.selectbox(
                "בחר זוג לדיאגנוסטיקה",
                options=df_dq["Pair"].tolist(),
                index=0,
                key=keygen("dq", "pair_sel"),
            )
        with col_s2:
            raw_syms = _normalize_symbol_input(sel_pair_label)
            sel_sym = st.selectbox(
                "בחר סימבול בודד",
                options=raw_syms,
                index=0,
                key=keygen("dq", "sym_sel"),
            )

        q_sym = _compute_symbol_data_quality(sel_sym, start_date, end_date)
        st.markdown(f"**Data Quality for `{sel_sym}` ({start_date} → {end_date})**")
        st.json(make_json_safe(q_sym))


# ===================== Developer Tools — Config, Router, Logs, Cache =====================

def render_developer_tools_panel() -> None:
    """
    Developer Tools – כלים למפתח/קוונט:

    • הצגת config.json הנוכחי + diff מול defaults + raw.
    • בדיקות sanity לקונפיג (ערכים חריגים).
    • סטטוס Router: האם קיים, מקור מועדף, בדיקת SPY מהירה.
    • Quick log viewer (הצצה בהודעות האחרונות של log).
    • כפתורי נוחות:
        - Reset caches (cache_data) לפונקציות מרכזיות.
        - Reset חלקי של session_state (prefix-based).
    """
    with st.expander("🧑‍💻 Developer Tools – Config & Router & Logs & Cache", expanded=False):
        # Config & Diff
        st.subheader("Config (current vs defaults vs raw)")
        try:
            default_cfg = _default_config_fallback()
            raw_cfg = _raw_config
            merged = config  # כבר merged

            df_cfg = pd.DataFrame(
                [
                    {
                        "key": k,
                        "default": default_cfg.get(k),
                        "raw": raw_cfg.get(k),
                        "effective": merged.get(k),
                    }
                    for k in sorted(set(default_cfg.keys()) | set(raw_cfg.keys()) | set(merged.keys()))
                ]
            )
            st.dataframe(df_cfg, width="stretch", height=260)
        except Exception as e:
            st.caption(f"Config diff unavailable: {e}")

        # Sanity checks על config
        st.subheader("Config Sanity Checks")
        sanity_msgs: List[str] = []
        try:
            cap = float(config.get("capital", 0))
            if cap <= 0:
                sanity_msgs.append("⚠️ capital <= 0 – ערך לא הגיוני להון.")
            mexp = float(config.get("max_exposure_per_trade", 0))
            if not (0 < mexp <= 1):
                sanity_msgs.append("⚠️ max_exposure_per_trade צריך להיות בין (0, 1].")
            mlev = float(config.get("max_leverage", 0))
            if mlev < 1:
                sanity_msgs.append("⚠️ max_leverage < 1 – לא יאפשר מינוף תקין.")
        except Exception:
            sanity_msgs.append("⚠️ שגיאה בבדיקת sanity לתצורת הסיכון.")

        # Risk Engine limits sanity
        try:
            rl = get_risk_limits_from_config()
            if rl.max_daily_loss_pct <= 0 or rl.max_daily_loss_pct > 0.2:
                sanity_msgs.append("⚠️ risk_max_daily_loss_pct מחוץ לטווח סביר (0–20%).")
            if rl.max_drawdown_pct <= 0 or rl.max_drawdown_pct > 0.8:
                sanity_msgs.append("⚠️ risk_max_drawdown_pct מחוץ לטווח סביר (0–80%).")
        except Exception:
            sanity_msgs.append("⚠️ שגיאה בבדיקת sanity ל-RiskLimits.")

        if sanity_msgs:
            for msg in sanity_msgs:
                st.markdown(msg)
        else:
            st.caption("✅ לא זוהו בעיות קונפיג קריטיות.")

        # Router status + Quick SPY check
        st.subheader("Market Data Router")
        try:
            r = st.session_state.get("md_router")
            pref = st.session_state.get("data_source_preferred")
            info = {
                "router_type": str(type(r)),
                "data_source_preferred": pref,
                "router_exists": r is not None,
            }
            st.json(info)

            if r is not None:
                # Quick SPY check
                if st.button("🔄 Quick SPY sanity fetch (last 10 days)", key=keygen("dev", "spycheck")):
                    try:
                        df_spy = _load_pair_data("SPY", TODAY - timedelta(days=10), TODAY)
                        if df_spy is None or df_spy.empty:
                            st.warning("SPY data fetch returned empty DataFrame.")
                        else:
                            st.success(f"SPY data loaded with {len(df_spy)} rows.")
                            st.dataframe(df_spy.tail(5), width="stretch")
                    except Exception as e:
                        st.error(f"SPY sanity fetch failed: {e}")
        except Exception as e:
            st.caption(f"Router info unavailable: {e}")

        # Quick log preview
        st.subheader("Dashboard Log Preview")
        try:
            if log_path.exists():
                text = log_path.read_text(encoding="utf-8", errors="replace")
                tail = text[-2000:]
                st.text(tail)
            else:
                st.caption("No dashboard_audit.log found.")
        except Exception as e:
            st.caption(f"Log preview unavailable: {e}")

        # Cache controls & session cleanup
        st.subheader("Cache & Session Tools")
        col_c1, col_c2 = st.columns(2)

        with col_c1:
            if st.button("🧹 Clear all cache_data", key=keygen("dev", "clear_cache_all")):
                try:
                    st.cache_data.clear()
                    st.success("All cache_data cleared.")
                except Exception as e:
                    st.error(f"Failed to clear cache_data: {e}")

        with col_c2:
            prefix_to_clear = st.text_input(
                "מחק session_state לפי prefix (למשל 'opt_', 't3')",
                value="",
                key=keygen("dev", "sess_prefix"),
            ).strip()
            if st.button("🗑️ Clear session keys by prefix", key=keygen("dev", "clear_sess")) and prefix_to_clear:
                try:
                    to_del = [k for k in list(st.session_state.keys()) if k.startswith(prefix_to_clear)]
                    for k in to_del:
                        del st.session_state[k]
                    st.success(f"נמחקו {len(to_del)} מפתחות session_state שמתחילים ב-'{prefix_to_clear}'.")
                except Exception as e:
                    st.error(f"Failed to clear session keys: {e}")


